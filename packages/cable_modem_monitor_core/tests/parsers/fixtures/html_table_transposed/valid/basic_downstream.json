{
  "_description": "Basic transposed table — rows are metrics, columns are channels",
  "_html": "<html><body><table border=1><tr><th>Downstream</th><th colspan=3>Bonding Channel Value</th></tr><tr><td>Channel ID</td><td>10</td><td>9</td><td>11</td></tr><tr><td>Frequency</td><td>519000000 Hz</td><td>513000000 Hz</td><td>525000000 Hz</td></tr><tr><td>Signal to Noise Ratio</td><td>39 dB</td><td>38 dB</td><td>37 dB</td></tr><tr><td>Power Level</td><td>5 dBmV</td><td>4 dBmV</td><td>3 dBmV</td></tr></table></body></html>",
  "_resource": "/status.html",
