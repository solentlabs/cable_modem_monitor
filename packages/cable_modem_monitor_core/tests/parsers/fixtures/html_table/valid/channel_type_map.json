{
  "_description": "Mixed channel types with map-based channel_type detection from modulation field",
  "_html": "<html><body><table><tr><th colspan='4'>Signal Data</th></tr><tr><th>ID</th><th>Modulation</th><th>Frequency</th><th>Power</th></tr><tr><td>1</td><td>QAM256</td><td>507000000 Hz</td><td>3.2 dBmV</td></tr><tr><td>33</td><td>OFDM</td><td>722000000 Hz</td><td>1.5 dBmV</td></tr></table></body></html>",
