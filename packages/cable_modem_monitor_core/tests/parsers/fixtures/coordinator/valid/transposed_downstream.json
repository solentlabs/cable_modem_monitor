{
  "_description": "Coordinator routes transposed section to HTMLTableTransposedParser",
  "_html": {
    "/status.html": "<html><body><table><tr><th>Downstream</th><th colspan=2>Value</th></tr><tr><td>Channel ID</td><td>1</td><td>2</td></tr><tr><td>Frequency</td><td>519000000 Hz</td><td>513000000 Hz</td></tr><tr><td>Power Level</td><td>5 dBmV</td><td>4 dBmV</td></tr></table></body></html>"
  },
  "_parser_config": {
    "downstream": {
      "format": "table_transposed",
      "resource": "/status.html",
      "selector": {"type": "header_text", "match": "Downstream"},
      "rows": [
        {"label": "Channel ID", "field": "channel_id", "type": "integer"},
        {"label": "Frequency", "field": "frequency", "type": "frequency", "unit": "Hz"},
        {"label": "Power Level", "field": "power", "type": "float", "unit": "dBmV"}
      ],
      "channel_type": {"fixed": "qam"}
    }
  },
  "_expected": {
    "downstream": [
      {"channel_id": 1, "frequency": 519000000, "power": 5.0, "channel_type": "qam"},
      {"channel_id": 2, "frequency": 513000000, "power": 4.0, "channel_type": "qam"}
    ],
    "upstream": []
  }
}
