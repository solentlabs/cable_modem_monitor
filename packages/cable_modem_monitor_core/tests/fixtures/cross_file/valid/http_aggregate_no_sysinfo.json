{
  "_modem": {
    "manufacturer": "Solent Labs", "model": "T400", "transport": "http",
    "default_host": "192.168.100.1",
    "auth": {"strategy": "none"},
    "hardware": {"docsis_version": "3.0"},
    "status": "verified",
    "attribution": {"contributors": [{"github": "tester", "contribution": "Test"}]},
    "isps": ["Various"]
  },
  "_parser": {
    "downstream": {
      "format": "table",
      "resource": "/status.html",
      "tables": [{
        "selector": {"type": "header_text", "match": "Downstream"},
        "columns": [
          {"index": 0, "field": "channel_id", "type": "integer"},
          {"index": 1, "field": "corrected", "type": "integer"}
        ],
        "channel_type": {"fixed": "qam"}
      }]
    },
    "aggregate": {
      "total_corrected": {"sum": "corrected", "channels": "downstream"}
    }
  }
}
