            "compression": 0,
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\"\n        \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html>\n<head>\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"css/global.css\">\n<!--[if IE 6]>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/ie6styles.css\"/>\n<![endif]-->\n<!--[if IE 7]>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/ie7styles.css\"/>\n<![endif]-->\n<link type=\"text/css\" href=\"css/ui-lightness/jquery-ui-1.8.21.custom.css\" rel=\"stylesheet\">\n<style type=\"text/css\" media=\"all\">\n.ui-progressbar-value { background-image: url(i/pbar-ani.gif); }\n.description {\n\tmargin-bottom:10px !important;\n}\n</style>\n<script type='text/javascript'>\n\tvar user_id=\"1\";\n</script>\n<script type=\"text/javascript\" src=\"scripts/jquery-1.7.2.min.js\"></script>\n<script type=\"text/javascript\" src=\"scripts/jquery-ui-1.8.21.custom.min.js\"></script>\n<script type=\"text/javascript\">\n\tvar timestamp = new Date().getTime();\n\tdocument.write('<script type=\"text/javascript\" src=\"lang/language_en.js?v='+timestamp+'\"><\\/script>');\n\tdocument.write('<script type=\"text/javascript\" src=\"scripts/construct.js?v='+timestamp+'\"><\\/script>');\n</script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"func.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"utility.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"linuxs.js\"></script>\n<script language=\"JavaScript\" src=\"validate.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\">\n$(document).ready(function() \n{\n\tpageInit(\"Advanced\",\"adv_Product\");\n\tdataToVisible(document.forms[0]);\t\n        initProduct_param();\n\n});\n</script>\n<title>DM1000</title>\n<script language=\"javascript\" type=\"text/javascript\">\n<!--    \n\nvar in_refresh = false;\n\nfunction logoutF()\n{\n\tdocument.tF0.logout.value=1;\n\tdocument.tF0.submit();\n\treturn true;\n} \n\nfunction doConfirm()\n{\n    if(confirm(str_pd10)){\n        alert(str_pd11);\n        return true;\n        }\n    return false;\n}\n\nfunction rebootsettings()\n{\n    if(doConfirm()==true){\n        var cf = document.forms[0];\n        dataToHidden(document.forms[0]);\n        cf.todo.value=\"reboot\";\n        cf.submit();\n        }\n    else\n        return false;\n}\n\nfunction defaultsettings()\n{\n    if(doConfirm()==true){\n        var cf = document.forms[0];\n        dataToHidden(document.forms[0]);\n        cf.todo.value=\"defaultsettings\";\n        cf.submit();\n        }\n    else\n        return false;\n}\n\nfunction buildProduct_param(data)\n{  \n    /*Interface, Provisioned, State, Speed (Mbps), MAC address, IP Address, Subnet Mask*/ \n    var head ='<tr height=\"25\"><th width=\"15%\" height=\"30\" align=\"left\">'+str_status21+'</th>'\n              +'<th>'+str_status22+'</th>'\n              +'<th>'+str_status23+'</th>'\n              +'<th>'+str_status24+'</th>'\n              +'<th>'+str_status25+'</th>'\n              +'<th>'+str_pd4+'</th>'\n              +'<th>'+str_pd5+'</th></tr>';   \n    \n    var txtInterface=\"\";\n    var txtProductType=\"\";\n    var txtComponentLoggingLevels=\"\";\n\n    var count=0;\n    \n    var nodes = data.nodes;\n    $.each(nodes, function(key, val) {\n        /*Interface*/\n        var name = val.name;\n        var provisioned = val.provisioned;\n        var state = val.state;\n        var speed = val.speed;\n        var mac = val.mac;\n        var ip = val.ip;\n        var subnet = val.subnet;\n  \n        if(name!=undefined){\n            txtInterface +='<tr height=\"25\"><td width=\"15%\" height=\"30\" align=\"left\">'+name+'</td>'\n                  +'<td>'+provisioned+'</td>'\n                  +'<td>'+state+'</td>'\n                  +'<td>'+speed+'</td>'\n                  +'<td>'+mac+'</td>'\n                  +'<td>'+ip+'</td>'\n                  +'<td>'+subnet+'</td></tr>';\n        }\n\n        /*ProductType*/\n        var param = val.param;\n        var ProductType = val.ProductType;\n        \n        if(key >=3 && val.param!=undefined)\n        {\n                txtProductType+= '<tr height=\"30\"><th width=\"10%\" height=\"30\" align=\"left\">' + param + '</th>'\n                                            + '<td width=\"10%\" height=\"30\" align=\"left\">' + ProductType + '</td></tr>';\n        }\n\n        /*ComponentLoggingLevels*/\n        var component = val.component;\n        var list = val.list;\n        \n        if(component!= undefined)\n        {\n            count=key;\n            txtComponentLoggingLevels = '<tr height=\"10\"><td width=\"9%\" height=\"10\" align=\"left\"><b>' + component + '</b></td></tr>';\n        }\n        if(list!= undefined)\n        {\n            if(key%3==(count+1)%3)\n                txtComponentLoggingLevels += '<tr height=\"10\"><td width=\"9%\" height=\"10\" align=\"left\">' + list + '</td>';\n            else if(key%3==(count+2)%3)\n                txtComponentLoggingLevels += '<td width=\"10%\" height=\"10\" align=\"left\">' + list + '</td>';\n            else if(key%3==(count+3)%3)\n                txtComponentLoggingLevels += '<td width=\"10%\" height=\"10\" align=\"left\">' + list + '</td></tr>';\n        }\n              \n    });\n    $(\"#interface_param\").html(head+txtInterface);\n    $(\"#Product_Type\").html(txtProductType);\n    $(\"#Component_Logging_Levels\").html(txtComponentLoggingLevels);\n}\n\nfunction Product_param_Refresh()\n{\n         var strUrl =\"setup.cgi?todo=Pd_info\";\n\n         if (!in_refresh)\n        {\n        $.ajax(\n        {\n            type: \"GET\",\n            async: true,\n            url: strUrl,\n            dataType: \"json\",\n            success: function (response, status, request)\n            {\n               buildProduct_param(response);\n            },\n            complete: function()\n            {\n                in_refresh = false;\n            }\n        });\n    }\n}\n\nfunction initProduct_param()\n{\n    var txt = '<tr> <th colspan=\"3\">' + Loading + '</th></tr>';\n\n    $(\"#interface_param\").html(txt);\n    $(\"#Product_Type\").html(txt);\n    $(\"#Component_Logging_Levels\").html(txt);\n    Product_param_Refresh();\n}\n//-->\n</script>\n</head>\n<body>\n<div id=\"wrapper\">\n  <div id=\"header\"> <img src=\"i/entry-level.png\" id=\"logo\"> </div>\n  <div id=\"content\">\n    <div id=\"tabs\"> </div>\n    <div id=\"first\">\n      <div id=\"placeholder\">\n        <table>\n          <tbody>\n            <tr>\n              <td class=\"CNAV\"><div id=\"navigation_bar\"></div></td>\n              <td class=\"CCFG\"><!-- mainpage START -->\n                <form name=\"tF0\" method=\"post\" action=\"setup.cgi\">\n                  <div id=\"mainpage\">\n                    <div id=\"page_title\">\n                      <div class=\"description\">\n                        <h3>\n                          <script>dw(smnu_Product);</script>\n                        </h3>\n                      </div>\n                        <table class=\"common_table\">\n\t\t\t<tr height=\"25\">                            \n\t\t\t\t<td width=\"60%\" height=\"30\" align=\"left\"><b><script>dw(smnu_CM_Status);</script>:</b></td>\n\t\t\t\t<td width=\"40%\" height=\"30\" align=\"left\" ><input name=\"cm_st\" id=\"cm_st\" style=\"text-align:left;\" size=\"25\" class=\"read_only\" disabled=\"disabled\" value=\"OPERATIONAL\n\" type=\"text\"></td>\n\t\t\t</tr>\n            </table>\n\t\t     <div id=\"reservedlist\">\n\t\t\t<h4><script>dw(str_pd1);</script></h4>\n\n                        <table class=\"common_table\" id=\"interface_param\"></table>\n\t\t\t\t\t\t\n\t\t\t<h4><script>dw(str_pd2);</script></h4>\n                          <table class=\"common_table\" id=\"Product_Type\"></table>\n\n                        <h4><script>dw(str_pd3);</script></h4>\n                          <table class=\"common_table\" id=\"Component_Logging_Levels\"></table>\n                          \n\t\t\t<h4><script>dw(str_pd6);</script></h4>\n\t\t\t\t<div class=\"description\">\n\t\t\t\t\t<div><script>dw(str_pd7);</script></div>\n\t\t\t\t</div>\n                <table><tr><td><input class=\"submitBtn\" type=\"button\" id=\"reboot\" name=\"reboot\" value=\"Reboot\" onClick=\"rebootsettings();\"></td></tr></table>\n\n                        <h4><script>dw(str_pd8);</script></h4>\n\t\t\t\t<div class=\"description\">\n\t\t\t\t\t<div><script>dw(str_pd9);</script></div>\n\t\t\t\t</div>\n                <table><tr><td><input class=\"submitBtn\" type=\"button\" id=\"reset\" name=\"reset\" value=\"Reset\" onClick=\"defaultsettings();\"></td></tr></table>\n                          \n                      </div>\n                      <!--DD <br>\n                      <br>\n                      <br>\n                      <br> -->\n                    </div>\n                  </div>\n                  <input type=\"hidden\" name=\"todo\" value=\"refresh\">\n                  <input type=\"hidden\" name=\"this_file\" value=\"adv_Product.html\">\n                  <input type=\"hidden\" name=\"next_file\" value=\"adv_Product.html\">\n                </form>\n                <!-- mainpage END -->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </div>\n    <!--DD <img src=\"i/content_bottom.jpg\" complete=\"complete\" height=\"6\" width=\"973\"> -->\n    <div id=\"footer\"></div>\n    <div id=\"walk-dialog\" style=\"display: none;\" title=\"\"></div>\n    <div id=\"action-dialog\" style=\"display: none;\" title=\"\"></div>\n    <div id=\"error-dialog\" style=\"display: none;\" title=\"\"></div>\n    <div id=\"wait-dialog\" style=\"display: none;\" title=\"\"></div>\n  </div>\n</div>\n</body>\n</html>\n\n"
