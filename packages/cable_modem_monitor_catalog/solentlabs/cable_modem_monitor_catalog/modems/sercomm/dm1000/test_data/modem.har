            "mimeType": "text/html",
            "compression": 0,
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\"\n        \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html>\n<head>\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<!-- release 140505-->\n<!-- (c) Copyright 2014-2015, ARRIS Group, Inc., All rights reserved. -->\n<link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"css/global.css\">\n<!--[if IE 6]>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/ie6styles.css\"/>\n<![endif]-->\n<!--[if IE 7]>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/ie7styles.css\"/>\n<![endif]-->\n<link type=\"text/css\" href=\"css/ui-lightness/jquery-ui-1.8.21.custom.css\" rel=\"stylesheet\">\n<style type=\"text/css\" media=\"all\">\n.ui-progressbar-value { background-image: url(i/pbar-ani.gif); }\n.login_box {\nborder-top:1px solid #DFDFDF !important;\nborder-top-left-radius: 10px;\nborder-top-right-radius: 10px;\nwidth:50%;\nmargin:0 auto;\nclear:both;\nbackground: url(i/fullWidth_bg.jpg) no-repeat top !important;\npadding-bottom:5px !important;\n}\nh3 {\n    line-height: 27px !important;\n\tcolor:#FFFFFF !important;\n\ttext-align:center;\n\tmargin-bottom:5px;\n}\n.common_table tr:nth-child(2n+1) {\n    background: transparent !important;\n}\n.common_table tr {\n    border-bottom: 0px solid #d8d8d8 !important;\n}\n#nav {\n\tdisplay:none;\n}\n.hint{\n\ttext-align:center;\n\tcolor:#0089d8;\n\tfont-size:13px;\n}\n.common_table tr td:last-child {\n    text-align: left !important;\n}\ninput[type=\"submit\"].submitBtn {\n    float: none !important;\n}\n</style>\n<script type='text/javascript'>\n\tvar user_id=\"0\";\n</script>\n<script type=\"text/javascript\" src=\"scripts/jquery-1.7.2.min.js\"></script>\n<script type=\"text/javascript\" src=\"scripts/jquery-ui-1.8.21.custom.min.js\"></script>\n<script type=\"text/javascript\">\n\tvar timestamp = new Date().getTime();\n\tdocument.write('<script type=\"text/javascript\" src=\"lang/language_en.js?v='+timestamp+'\"><\\/script>');\n\tdocument.write('<script type=\"text/javascript\" src=\"scripts/construct.js?v='+timestamp+'\"><\\/script>');\n</script>\n<script language=\"JavaScript\" src=\"validate.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"func.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"utility.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\" src=\"linuxs.js\"></script>\n<script language=\"Javascript\" src=\"base64.js\"></script>\n<script language=\"javascript\" type=\"text/javascript\">\n$(document).ready(function() \n{\n\tisParentWin();\n\tpageInit(\"Login\",\"login\");\n\tdataToVisible(document.forms[0]);\t\n\n});\n\n</script>\n<title>DM1000</title>\n<script language=\"javascript\" type=\"text/javascript\">\n<!--    \n\nfunction logoutF()\n{\n\tdocument.tF.logout.value=1;\n\tdocument.tF.submit();\n\treturn true;\n}\n\nfunction doSubmit()\n{\n    document.tF.action.value = \"submit\";\n    \n    /* encode username and password with Base64 algorithm */\n    if(document.tF.pws.value != \"\")\n    {\n        document.tF.passwd.value =base64encode(document.tF.pws.value);\n    }\n    \n    checkfw();\n}\nfunction isParentWin()\n{\n    if(!window.opener)\n    {\n        document.tF.is_parent_window.value = '1' ;\n    }\n    else\n    {\n        document.tF.is_parent_window.value = '0';\n    }\n}\nfunction checkfw()\n{\n\t\tif(\"\"==\"enable\" && (base64encode(document.tF.pws.value) == document.tF.cur_passwd.value)){\n\t\t\tnewwin=window.open('chk_wait.html',\"Firmware\",\"toolbar=no,location=no,directories=no,status=no,menubar=no,scrollbars=yes,width=395,height=200,resizable=0\");\n\t\t\tnewwin.focus();\n\t\t}\n    document.tF.pws.value =base64encode(document.tF.pws.value); \n}\n\n//-->\n</script>\n</head>\n<body>\n<div id=\"wrapper\">\n  <div id=\"header\"> <img src=\"i/entry-level.png\" id=\"logo\"> </div>\n  <div id=\"content\">\n    <div id=\"tabs\" style=\"display:none;\"> </div>\n    <div id=\"first\" class=\"login_box\">\n      <div id=\"placeholder\">\n        <table>\n          <tbody>\n            <tr>\n              <!-- <td width=\"200px\"><div id=\"navigation_bar\"> </div></td> -->\n              <td style=\"padding-top:8px;\"><!-- mainpage START -->\n                <form name=\"tF\" action=\"setup.cgi\" method=\"post\"   onsubmit=\"doSubmit()\">\n                  <div id=\"mainpage\">\n                    <div>\n                      <div class=\"description\">\n                        <h3>\n                          <script>dw(show3);</script>\n                        </h3>\n                        <div class=\"hint\">\n                          <script>dw(LoginText);</script>\n                        </div>\n                      </div>\n                      <div id=\"login\">\n                        <!--\n\t\t\t\t\t\t<h4>\n                          <script>dw(show3);</script>\n                        </h4>\n\t\t\t\t\t\t-->\n                        <table class=\"common_table\">\n                          <tbody>\n                            <tr>\n                              <td width=\"28%\"></td>\n                              <td width=\"20%\"><script>dw(UserName);</script></td>\n                              <td><input type=\"text\" maxLength=\"25\" size=\"12\" name=\"login_user\" value=\"technician\"></td>\n                            </tr>\n                            <tr>\n                              <td width=\"28%\"></td>\n                              <td width=\"20%\"><script>dw(Password);</script></td>\n                              <td><INPUT type=\"password\"  maxLength=\"70\" size=\"12\" name=\"pws\" value=\"\" autocomplete=\"off\"></td>\n                            </tr>\n                          </tbody>\n                        </table>\n                      </div>\n                      <center>\n\t\t\t\t\t  <div id=\"ApplyButton\