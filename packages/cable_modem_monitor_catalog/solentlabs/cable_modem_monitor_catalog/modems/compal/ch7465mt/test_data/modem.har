            {
              "name": "X-Frame-Options",
              "value": "SAMEORIGIN"
            }
          ],
          "content": {
            "size": 22216,
            "mimeType": "application/javascript",
            "compression": 0,
            "text": "/*\r\nCopyright (c) 2014 CBN Derek Chen\r\n\r\nModified from jRange https://github.com/nitinhayaran/jRange/\r\njRange is authored and maintained by @nitinhayaran\r\nReleased under the MIT License\r\n\r\n */\r\n\r\n//Ranges Global Values by Derek\r\nvar IMID;\r\nvar cbn_slider = [];\r\nvar myRangeIndex;\t\r\nvar parentalctl_disable = false;//if parentalctl_disable is true,the click event and drag event can't be trigger //Chris\r\nvar onRemove = false;\r\nvar drogID;\r\nvar SliderInputValue = {\"low\":new Array,\"high\":new Array};\r\nvar combinelist = {\"low\":new Array,\"high\":new Array};\r\n(function($, window, document, undefined) {\r\n\r\n\tvar jRange = function(){\r\n\t\treturn this.init.apply(this, arguments);\r\n\t};\r\n\tjRange.prototype = {\r\n\t\tdefaults : {\r\n\t\t\tonstatechange : function(){},\r\n\t\t\tisRange : false,\r\n\t\t\tshowLabels : true,\r\n\t\t\tstep  : 1,\r\n\t\t\tformat: '%s',\r\n\t\t\ttheme : 'theme-green',\r\n\t\t\twidth : 300,\r\n\t\t\trangesLimit: 1\r\n\t\t},\r\n\t\ttemplate : \r\n\t\t'<div class=\"slider-container\">\\\r\n\t\t\t<div class=\"slider-bar\">\\\r\n                <div class=\"slider-on\" style=\"z-index:1500\"></div>\\\r\n                <div class=\"slider-handle low\"></div>\\\r\n                <div class=\"slider-handle high\"></div>\\\r\n                <div class=\"slider-off\"></div>\\\r\n\t\t\t</div>\\\r\n\t\t\t<div class=\"scale\"></div>\\\r\n\t\t</div>',\r\n\t\tinit : function(node, options){\r\n\t\t\tthis.options       = $.extend({}, this.defaults, options);\r\n\t\t\tthis.inputNode     = $(node);\r\n\t\t\tthis.options.value = this.inputNode.val() || (this.options.isRange ? this.options.from+','+this.options.from : this.options.from);\r\n\t\t\tthis.domNode       = $(this.template);\r\n\t\t\tthis.domNode.addClass(this.options.theme);\r\n\t\t\tthis.inputNode.after(this.domNode);\r\n\t\t\tthis.domNode.on('change', this.onChange);\r\n\t\t\tthis.pointers     = $('.slider-handle', this.domNode);\r\n\t\t\tthis.lowPointer   = this.pointers.first();\r\n\t\t\tthis.highPointer  = this.pointers.last();\r\n\t\t\t//this.labels       = $('.slider-label', this.domNode);\r\n\t\t\tthis.lowLabel     = $('.low', this.domNode);\r\n\t\t\tthis.highLabel    = $('.high', this.domNode);\r\n\t\t\tthis.lowLabel.val = this.options.from;\r\n\t\t\tthis.highLabel.val= this.options.to;\r\n\t\t\tthis.scale        = $('.scale', this.domNode);\r\n\t\t\tthis.onbar          = $('.slider-on', this.domNode);\r\n\t\t\tthis.backgroundBar = $('.slider-off', this.domNode);\r\n\t\t\tthis.interval     = this.options.to - this.options.from;\r\n\t\t\tthis.rangesLimit  = this.options.rangesLimit;\r\n\t\t\tthis.rangeIndex = -1;\r\n\t\t\tthis.deadBlock = [0,0];\r\n\t\t\t\r\n\t\t\tthis.render();\r\n\t\t},\r\n\t\trender: function(){\r\n\t\t\t// Check if inputNode is visible, and have some width, so that we can set slider width accordingly.\r\n\t\t\tif( this.inputNode.width() === 0 && !this.options.width ){\r\n\t\t\t\tconsole.log('jRange : no width found, returning');\r\n\t\t\t\treturn;\r\n\t\t\t}else{\r\n\t\t\t\tthis.domNode.width( this.options.width || this.inputNode.width() );\r\n\t\t\t\tthis.inputNode.hide();\r\n\t\t\t}\r\n\r\n\t\t\tif(this.isSingle()){\r\n\t\t\t\tthis.lowPointer.hide();\r\n\t\t\t\tthis.lowLabel.hide();\r\n\t\t\t}\r\n\t\t\t/*if(!this.options.showLabels){\r\n\t\t\t\tthis.labels.hide();\r\n\t\t\t}*/\r\n\t\t\t\r\n\t\t\t/*Derek_S*/\r\n\t\t\tcbn_slider.push(this);\r\n\t\t\t//sort ranges\r\n\t\t\tcbn_slider = mergeSort(cbn_slider);\r\n\t\t\t//get my sorted range index\r\n\t\t\tthis.rangeIndex = cbn_slider.indexOf(this);\r\n\t\t\t/*Derek_E*/\r\n\t\t\t\r\n\t\t\tthis.attachEvents();\r\n\t\t\t//this.renderScale();\r\n\t\t\tthis.setValue(this.options.value);\r\n\t\t\t/*Chris_S*/\r\n\t\t\tif(this.options.to - this.lowLabel.val < 2 * this.highPointer.width())\r\n\t\t\t\t$(\".time-slider\").find(\"[value='\"+this.lowLabel.val+\",\"+this.lowLabel.val+\"']\").next().find(\".low\").css(\"z-index\",\"1000\");\r\n\t\t\telse\r\n\t\t\t\t$(\".time-slider\").find(\"[value='\"+this.lowLabel.val+\",\"+this.lowLabel.val+\"']\").next().find(\".high\").css(\"z-index\",\"1000\");\r\n\t\t\t/*Chris_E*/\r\n\t\t},\r\n\t\tattachEvents: function(){//bind events\r\n\t\t\tthis.onbar.click($.proxy(this.onbarClicked, this));//reduce the length of this range\r\n\t\t\tthis.backgroundBar.click($.proxy(this.backgroundBarClicked, this));//add new range\r\n\t\t\tthis.onHoverSlider();\r\n\t\t\tthis.onHoverOnbar();/*Chris*/\r\n\t\t\tthis.pointers.mousedown($.proxy(this.onDragStart, this));\r\n\t\t\tthis.pointers.bind('dragstart', function(event) { event.preventDefault(); });\r\n\t\t},\r\n\t\tonHoverOnbar: function(){/*Chris bind to show remove button*/\r\n\t\t\tthis.onbar.bind('mouseleave',$.proxy(this.onbarOnMouseleave, this));\r\n\t\t\tthis.onbar.bind('mousemove',$.proxy(this.onbarOnMousemove, this));\r\n\t\t},\r\n\t\tonbarOnMouseleave: function(e){\r\n\t\t\tvar handle_remove = $(\".slider-handle-remove\");\r\n\t\t\thandle_remove.hide();\r\n\t\t},\r\n\t\tonbarOnMousemove: function(e){\r\n\t\t\tvar handle_remove = $(\".slider-handle-remove\");\r\n\t\t\tif(cbn_slider.length<this.rangesLimit){\r\n\t\t\tvar thisPosition = (this.lowPointer.position().left + this.highPointer.position().left)/2;\r\n\t\t\thandle_remove.css(\"left\",thisPosition);\r\n\t\t\thandle_remove.show();\r\n\t\t\t}\r\n\t\t},\r\n\t\t/*onbar events_S*/\r\n\t\tonbarClicked: function(e){\r\n\t\t\tif(parentalctl_disable)\r\n\t\t\t\treturn;\r\n\t\t\t// make nearest pointer smoothly move to click point\r\n\t\t\t// var x = e.pageX - this.backgroundBar.offset().left;\r\n\t\t\t// if(this.isSingle())\r\n\t\t\t\t// this.setPosition(this.pointers.last(), x, true, true);\r\n\t\t\t// else{\r\n\t\t\t\t// var pointer = Math.abs(parseInt(this.pointers.first().css('left'), 10) - x + this.pointers.first().width() / 2) < Math.abs(parseInt(this.pointers.last().css('left'), 10) - x + this.pointers.first().width() / 2) ?\r\n\t\t\t\t\t// this.pointers.first() : this.pointers.last();\r\n\t\t\t\t// this.setPosition(pointer, x, true, true);\r\n\t\t\t// }\r\n\t\t\tvar handle_remove = $(\".slider-handle-remove\");\r\n\t\t\t\thandle_remove.hide();\r\n\t\t\tvar x = e.pageX - this.backgroundBar.offset().left;\r\n\t\t\tif(this.isSingle())\r\n\t\t\t\tthis.setPosition(this.pointers.last(), x, true, true);\r\n\t\t\telse{\r\n\t\t\t\tvar leftPos,\r\n\t\t\t\tlowPos = this.lowPointer.position().left,\r\n\t\t\t\thighPos = this.highPointer.position().left,\r\n\t\t\t\tcircleWidth = this.highPointer.width() / 2;\r\n\r\n\t\t\t\t\r\n\t\t\t\tif(cbn_slider.length>1){\r\n\t\t\t\t\tthis.setPtrPosition(this.pointers.first(), x, true, circleWidth,lowPos,highPos);\r\n\t\t\t\t\tthis.setPtrPosition(this.pointers.last(), x, true, circleWidth,lowPos,highPos);\r\n\t\t\t\t\tthis.showPointerValue(this.pointers.first(), x, true);\r\n\t\t\t\t\tthis.showPointerValue(this.pointers.last(), x, true);\r\n\t\t\t\t\tthis.onbar['animate']({\r\n\t\t\t\t\t\t'width' : 0,\r\n\t\t\t\t\t\t'left'\t: x\r\n\t\t\t\t\t});\r\n\t\t\t\t}else{\r\n\t\t\t\t\tthis.setPtrPosition(this.pointers.first(), this.options.from, true, circleWidth,lowPos,highPos);\r\n\t\t\t\t\tthis.setPtrPosition(this.pointers.last(), this.options.from, true, circleWidth,lowPos,highPos);\r\n\t\t\t\t\tthis.showPointerValue(this.pointers.first(), this.options.from, true);\r\n\t\t\t\t\tthis.showPointerValue(this.pointers.last(), this.options.from, true);\r\n\t\t\t\t\tthis.onbar['animate']({\r\n\t\t\t\t\t\t'width' : 0,\r\n\t\t\t\t\t\t'left'\t: this.options.from\r\n\t\t\t\t\t});\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\tvar dom = $(this.domNode);\r\n\t\t\t\tIMID = $(dom).attr('id');\r\n\t\t\t\tmyRangeIndex = cbn_slider.indexOf(this);\r\n\t\t\t\t\r\n\t\t\t\tif(cbn_slider.length>1){\r\n\t\t\t\t\tthis.onbar.unbind('mousemove');\r\n\t\t\t\t\tcbn_slider.splice(myRangeIndex, 1);\r\n\t\t\t\t\t//sort ranges\r\n\t\t\t\t\tcbn_slider = mergeSort(cbn_slider);\r\n\t\t\t\t\t//get my sorted range index\r\n\t\t\t\t\t/*\r\n\t\t\t\t\tsetTimeout(function(){\r\n\t\t\t\t\t\t$( \"#\"+IMID ).remove();\r\n\t\t\t\t\t},400);\r\n\t\t\t\t\t*/\r\n\t\t\t\t\t$( \"#\"+IMID ).prev().remove();//remove <input> tag\r\n\t\t\t\t\t$( \"#\"+IMID ).remove();\r\n\r\n\t\t\t\t}else{\t\t\t\t\t\r\n\t\t\t\t\tthis.highPointer.addClass('focused');\r\n\t\t\t\t\tthis.highLabel.addClass('focused');\r\n\t\t\t\t\t$(\".slider-handle\").css(\"z-index\",\"150\"); \r\n\t\t\t\t\tthis.highPointer.css(\"z-index\",\"1000\");\r\n\t\t\t\t\t}\r\n\t\t\t}\r\n\t\t},\r\n\t\t/*onbar events_E*/\r\n\t\t/*background bar events_S*/\r\n\t\tbackgroundBarClicked: function(e){//the clicked event of background bar\r\n\t\t\tif(parentalctl_disable)\r\n\t\t\t\treturn;\r\n\t\t\tif(cbn_slider.length<=this.rangesLimit){//Derek\r\n\t\t\t\t\r\n\t\t\t\tvar slider = {};\r\n\t\t\t\tslider.Low = new Array();\r\n\t\t\t\tslider.High = new Array();\r\n\t\t\t\t$( \".slider-bar\" ).each(function(index) { /* store each Low and High to slider*/\r\n\t\t\t\t\tslider.Low[index] = $(this).find(\".low\");\r\n\t\t\t\t\tslider.High[index] = $(this).find(\".high\");\r\n\t\t\t\t});\r\n\t\t\t\t\r\n\t\t\t\t/*Chris_S - 20150128 - modify the add range to 2 hour*/\r\n\t\t\t\tvar x = e.pageX - this.backgroundBar.offset().left;\r\n\t\t\t\tvar value = this.positionToValue(x);\r\n\t\t\t\tvar rate = function(){};\r\n\t\t\t\trate.l = this.positionToValue(x);\r\n\t\t\t\trate.h = parseInt(this.positionToValue(x))+(60*2);\r\n\t\t\t\tif(value > parseInt(this.interval - (this.options.step * 2)))\r\n\t\t\t\t{\r\n\t\t\t\t\trate.h = rate.l;\r\n\t\t\t\t\trate.l = parseInt(this.positionToValue(x))-(60*2);\r\n\t\t\t\t}\t\r\n\t\t\t\t\t\r\n\t\t\t\tvar width = this.domNode.width();\r\n\t\t\t\tx = x / width * this.interval;\r\n\t\t\t\tvar entry = $('<input type=\"hidden\" class=\"cbn-slider\" value=\"'+rate.l+','+rate.h+'\" />');\r\n\t\t\t\tvar parent = this.inputNode.parents().eq(0);\r\n\t\t\t\t$(entry).appendTo(parent);\r\n\t\t\t\trecodeSliderHistory(\"RemoveInvalid\");\r\n\t\t\t\tjRangetrigger(this.rangesLimit,cbn_slider.length);\r\n\t\t\t\trecodeSliderHistory(\"combine\");\r\n\t\t\t\t/*Chris_E - 20150128 - modify the add range to 2 hour*/\r\n\t\t\t\t\r\n\t\t\t\t$(\".slider-bar\").each(function(index) { /*Chris - remove the prev if low = high*/\r\n\t\t\t\t\tif($(slider.Low[index]).text()==$(slider.High[index]).text())\r\n\t\t\t\t\t\t$(slider.Low[index]).prev().trigger(\"click\");\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t},\r\n\t\tbackgroundbarOnMouseleave: function(e){\r\n\t\t\t$(\".slider-handle-add\").hide();\r\n\t\t},\r\n\t\tbackgroundbarOnMousemove: function(e){\r\n\t\t\tvar handle_add = $(\".slider-handle-add\");\r\n\t\t\tif(cbn_slider.length<this.rangesLimit){\r\n\t\t\thandle_add.show();\r\n\t\t\tvar position = e.clientX -  $(\".slider-off\").offset().left;\r\n\t\t\thandle_add.css(\"left\",position-handle_add.width() / 2);//Derek fix in zooming bug\r\n\t\t\t}\r\n\t\t},\r\n\t\t/*background bar events_E*/\r\n\t\t/*handles events_S*/\r\n\t\tonDragStart: function(e){\r\n\t\t\tif(parentalctl_disable)\r\n\t\t\t\treturn;\r\n\t\t\t//this.offHoverSlider();\r\n\t\t\tif(e.which !== 1){return;}\r\n\t\t\te.stopPropagation(); e.preventDefault();\r\n\t\t\tvar pointer = $(e.target);\r\n\t\t\tpointer.addClass('focused');\r\n\t\t\tthis[(pointer.hasClass('low')?'low':'high') + 'Label'].addClass('focused');\r\n\t\t\t/*Chris_S : always top the last slider-handle*/\r\n\t\t\t$(\".slider-handle\").css(\"z-index\",\"150\"); \r\n\t\t\tpointer.css(\"z-index\",\"1000\");\r\n\t\t\tdrogID = $(pointer).parent().parent().attr(\"id\"); //record the id which is onDrag now. For dragging the slider\r\n\t\t\t/*Chris_E*/\r\n\t\t\t\r\n\t\t\t/*Derek_S*/\r\n\t\t\t//sort ranges\r\n\t\t\tcbn_slider = mergeSort(cbn_slider);\r\n\t\t\t//get my sorted range index\r\n\t\t\tthis.rangeIndex = cbn_slider.indexOf(this);\r\n\t\t\t//set deadblock and get deadBlock\r\n\t\t\tthis.deadBlock = getDeadBlock(cbn_slider,this.rangeIndex,pointer.hasClass('high'),this.options.from,this.options.to);\r\n\t\t\t/*Derek_E*/\r\n\t\t\t$(document).on('mousemove.slider', $.proxy(this.onDrag, this, pointer));\r\n\t\t\t$(document).on('mouseup.slider', $.proxy(this.onDragEnd, this));\r\n\t\t\tthis.onbar.unbind('mousemove',$.proxy(this.onbarOnMousemove, this));//Chris - don't show remove when onDragStart\r\n\t\t},\r\n\t\tonDrag: function(pointer, e){\r\n\t\t\te.stopPropagation(); e.preventDefault();\r\n\t\t\tvar handle_add = $(\".slider-handle-add\");\r\n\t\t\thandle_add.hide();\r\n\t\t\t/*Derek_S*/\r\n\t\t\t//if p is in the deadBlock then do nothing\r\n\t\t\tvar position = e.clientX - this.domNode.offset().left;\r\n\t\t\tvar p = this.positionToValue(position);\r\n\t\t\tvar checked = checkTouched(p,this.deadBlock);\r\n\t\t\tif(checked){\r\n\t\t\t\t//do nothing\r\n\t\t\t}else{\r\n\t\t\t/*Chris_S*/\r\n\t\t\t\tif(position < this.options.from){\r\n\t\t\t\t\tposition = this.options.from;\r\n\t\t\t\t}else if(position > this.options.to){\r\n\t\t\t\t\tposition = this.options.to;\r\n\t\t\t\t}\r\n\t\t\t\tthis.onChange(e,this, pointer, position);\r\n\t\t\t\t//this.domNode.trigger('change', [this, pointer, position]);\r\n\t\t\t/*Chris_E*/\r\n\t\t\t}\r\n\t\t\t/*Derek_E*/\r\n\t\t\t\r\n\t\t\t/*Chris_S - remove all the invalid rules when drags the slider*/\r\n\t\t\tvar slider = {};\r\n\t\t\tslider.Low = new Array();\r\n\t\t\tslider.High = new Array();\r\n\t\t\tslider.parentID = new Array();\r\n\t\t\t$( \".slider-bar\" ).each(function(index) { /* store each Low and High to slider*/\r\n\t\t\t\tslider.Low[index] = $(this).find(\".low\");\r\n\t\t\t\tslider.High[index] = $(this).find(\".high\");\r\n\t\t\t\tslider.parentID[index] = $(this).find(\".low\").parent().parent().attr(\"id\");\r\n\t\t\t\tif(drogID != slider.parentID[index])\r\n\t\t\t\t{\r\n\t\t\t\t\tif($(slider.Low[index]).text()==$(slider.High[index]).text())\r\n\t\t\t\t\t\t$(slider.Low[index]).prev().trigger(\"click\");\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\t/*Chris_E*/\r\n\t\t},\r\n\t\tonDragEnd: function(){\r\n\t\t\tthis.pointers.removeClass('focused');\r\n\t\t\t//this.labels.removeClass('focused');\r\n\t\t\t$(document).off('.slider');\r\n\t\t\t//$(document).off('.slider');\r\n\t\t\t//this.onHoverSlider();\r\n\t\t\tthis.onbar.bind('mousemove',$.proxy(this.onbarOnMousemove, this));//Chris - show remove when onDragEnd\r\n\t\t\trecodeSliderHistory(\"combine\");//Chris - 20150129\r\n\t\t},\r\n\t\tonChange: function(e, self, pointer, position){\r\n\t\t\tvar min, max;\r\n\t\t\tif(self.isSingle()){\r\n\t\t\t\tmin = 0;\r\n\t\t\t\tmax = self.domNode.width();\r\n\t\t\t}else{\r\n\t\t\t\tmin = pointer.hasClass('high')? self.lowPointer.position().left + self.lowPointer.width() / 2 : 0;\r\n\t\t\t\tmax = pointer.hasClass('low') ? self.highPointer.position().left + self.highPointer.width() / 2 : self.domNode.width();\r\n\t\t\t}\r\n\t\t\tvar value = Math.min(Math.max(position, min), max);\r\n\t\t\t/*Chris_S - 20150128 - change the drog range to 1 hour*/\r\n\t\t\tvar errorValue = this.highPointer.width() / 5;\r\n\t\t\tvar range = parseInt(this.options.width) / 24;\r\n\t\t\tvalue = (Math.floor((value+errorValue)/range))*range;\r\n\t\t\t/*Chris_E - 20150128 - change the drog range to 1 hour*/\r\n\t\t\tself.setPosition(pointer, value, true);\r\n\t\t},\r\n\t\tsetPosition: function(pointer, position, isPx, animate){\r\n\t\t\tvar leftPos,\r\n\t\t\t\tlowPos = this.lowPointer.position().left,\r\n\t\t\t\thighPos = this.highPointer.position().left,\r\n\t\t\t\tcircleWidth = this.highPointer.width() / 2;\r\n\t\t\tif(!isPx){\r\n\t\t\t\tposition = this.prcToPx(position);\r\n\t\t\t}\r\n\t\t\tvar pos = this.setPtrPosition(pointer, position, animate, circleWidth,lowPos,highPos);\r\n\t\t\tthis.setOnbarPosition(leftPos, animate, circleWidth,pos[0],pos[1]);\r\n\t\t\tthis.showPointerValue(pointer, position, animate);\r\n\r\n\t\t},\r\n\t\tsetPtrPosition: function(pointer, position, animate, circleWidth,lowPos,highPos){\r\n\t\t\t\r\n\t\t\tif(pointer[0] === this.highPointer[0]){\r\n\t\t\t\thighPos = position  - circleWidth;\r\n\t\t\t}else{\r\n\t\t\t\tlowPos = posi