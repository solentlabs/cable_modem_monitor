            "text": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>Mercury EMTA style guide</title>\n<meta http-equiv=\"content-type\" content=\"text/html;charset=ISO-8859-1\">\n<META HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-cache\">\n<style type=\"text/css\">\n.green, .svg-inject.green path, .svg-inject.green circle , .diag-svg-inject.green path, .diag-svg-inject.green circle,.PARCON-svg-inject.green path, .PARCON-svg-inject.green circle\n{ \n\tcolor:#11aa44;\n\tfill:#11aa44!important;\n}\n.red, .svg-inject.red path, .svg-inject.red circle , .diag-svg-inject.red path, .diag-svg-inject.red circle ,.PARCON-svg-inject.red path, .PARCON-svg-inject.red circle\n{ \n\tcolor:#cc0022;\n\tfill:#cc0022;\n}\n<!--for router status S-->\n.section_title \n{\n\tfont-size: 22px !important; \n\tcolor:#000 !important;\n\tbackground:#e1e1e1!important;\n\tpadding: 8px!important;\n    margin:0px 0px !important;\n}\n#workBtn:hover{\n\tcursor: pointer;\n}\n\n\n.VM_tmp_section \n{\n    background: #aaaaa;\n    padding: 13px 16px;\n    font-size: 21px;\n\tcolor: #666666;\n}\n\n.VM_inner_div\n{\n    margin-top:50px!important;\n    margin-left:20px!important; \n    margin-right:20px!important;\n}\n\n.VM_outer_div\n{   \n    margin: 0px 0px!important;\n    border:1px solid #e1e1e1;\n    width:830px;\n    border-top:1px solid #fff;\n    Z-index:1\n}\n.content-container div {\n  clear: both;\n  /* margin: 30px 0px; */\n}\n.VM_tab_blank\n{\n    margin:0px 0px!important;\n    width:5px; \n    height:53px; \n    border-bottom: 1px solid #e1e1e1;\n}\n.VM_tab_td{\n  padding-left: 0px!important;\n  padding-bottom: 0px!important;\n  padding-top: 0px!important;\n  padding-right: 0px!important;\n}\n.VM_tab_blank_free\n{   \n    height:53px; \n    border-bottom: 1px solid #e1e1e1;\n\tmargin:0px 0px!important;\n}\n<!--for router status E-->\n</style>\n</head>\n<body>\n<div class=\"content-container contentSpace\">\n\t<div name=\"p_title\" class=\"page-title dynamic\" id=\"c_mu21\"></div>\n\t<div name=\"s_title\"></div>\n\t<div id=\"main_page\">\t\t\n\t<!-------------------------------------------------------------------------------------------------------------------------------->\n    <div class=\"\" style=\"margin-top: 50px;\">    \n    \t    \n    \t    <div style=\"margin-bottom:0px;\">\n    \t    <nobr>\n    \t    <table id=\"VM_rsbar\" style=\"padding-right: 0px;\" class=\"\" cellpadding=\"0\" cellspacing=\"0\">\n    \t\t\t\t<tr>\n                        <td class=\"VM_tab_td\"><div id=\"rs20\" name=\"title_Status\" class=\"VM_tab_selected dynamic\" onclick=\"Section_CMStatus();\"></div></td>\n                        <td class=\"VM_tab_td\"><div class=\"VM_tab_blank\"></div></td>\n                        <td class=\"VM_tab_td\"><div id=\"rs29\" name=\"title_Downstream\" class=\"VM_tab dynamic\"  onclick=\"Section_DS();\">Downstream</div></td>\n                        <td class=\"VM_tab_td\"><div class=\"VM_tab_blank\"></div></td>\n                        <td class=\"VM_tab_td\"><div id=\"rs30\" name=\"title_Upstream\" class=\"VM_tab dynamic\"  onclick=\"Section_US();\">Upstream</div></td>\n                        <td class=\"VM_tab_td\"><div class=\"VM_tab_blank\"></div></td>\n                        <td class=\"VM_tab_td\"><div id=\"rs31\" name=\"title_Configuration\" class=\"VM_tab dynamic\"  onclick=\"Section_Config();\">Configuration</div></td>\n                        <td class=\"VM_tab_td\"><div class=\"VM_tab_blank\"></div></td>\n                        <td class=\"VM_tab_td\"><div id=\"rs22\" name=\"title_Networklog\" class=\"VM_tab dynamic\"  onclick=\"Section_Netlog();\">Network log</div></td>\n\t\t\t\t\t\t<td class=\"VM_tab_td\"><div class=\"VM_tab_blank_free\"></div></td>\n    \t\t\t\t</tr>\n    \t\t</table>\n    \t    </nobr>\n    \t\t</div>\n    \t    \n    \t    <div class=\"VM_outer_div\" >\n    \t    \n    \t    <!--<div class=\"\" style=\"position: relative;right:20px;top:20px; color:#ff0000; font-size:17px;\" align=\"right\">Refresh data</div>-->\n    \t    <div style=\"position: relative;right:20px;top:20px; font-size:17px; margin:0px 0px;\" align=\"right\">\n    \t        <a href=\"javascript:void(0)\" class=\"simple_links dynamic\" id=\"rs32\" name=\"VM_refresh\" onclick=\"\">Refresh data</a> \n    \t    </div>\n    \t     \n    \t    <!----Cable Modem Status------------------------------------------------------------------------------->\t\n    \t    \n    \t    <div id=\"VM_div_CMstatus\" name=\"RouterStatusDiv\" class=\"VM_inner_div\" >\n        \t\n        \t\t\n    \t\t\t<table id=\"t-cm-cmstatus\" style=\"display:\" class=\"data-tables\" cellpadding=\"0\" cellspacing=\"0\">\n    \t\t\t\t<tr id='trTitle'>\n\t\t\t\t\t\t<th colspan=\"3\" style=\"text-align: center\" class=\"\"><span id=\"rs17\" class=\"dynamic\"></span></th>\t\n    \t\t\t\t</tr>\n\t\t\t\t\t<tr>\n    \t\t\t\t\t<th width=\"60%\" class=\"\" style=\"border-left: 0px;\">\n    \t\t\t\t\t\t<span id=\"rs19\" class=\"dynamic\">Item</span>\n    \t\t\t\t\t</th>\n    \t\t\t\t\t<th width=\"25%\" class=\"\"><span id=\"rs20\" class=\"dynamic\">Status</span></th>\n    \t\t\t\t\t<th width=\"25%\" class=\"\"><span id=\"rs21\" class=\"dynamic\">Comments</span></th>\n    \n    \t\t\t\t</tr>\n    \t\t\t\t<tr id=\"cm-cmstatus\" name=\"cm-busyupdate\">\n    \t\t\t\t\t<td colspan=\"3\" id=\"c_fi71\" class=\"table-apply dynamic\" style=\"text-align:center\">\n    \t\t\t\t\t</td>\n    \t\t\t\t</tr>\n    \t\t\t</table>\n    \t\t<br>\n    \t    </div>\n    \t\n            <!-----DS & US------------------------------------------------------------------------------>\n            \n            <div id=\"VM_div_DS\" name=\"RouterStatusDiv\" class=\"VM_inner_div\">\n    \t\t<div class=\"section_title dynamic\" id=\"c_ns02\">Downstream bonded channels</div>\t\n    \t\t\n    \t\t\t<table id=\"t-cm-downstream\" style=\"display:\" class=\"data-tables\" cellpadding=\"0\" cellspacing=\"0\">\n    \t\t\t\t<tr>\n    \t\t\t\t\t<th width=\"15%\" class=\"