            "text": "<!doctype html>\n<html>\n<head>\n<title></title>\n<meta http-equiv=\"content-type\" content=\"text/html;charset=ISO-8859-1\">\n<META HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-cache\">\n<link href=\"css/style.css?v=20250108144525\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"css/overlay-wizards.css?v=20250108144525\" rel=\"stylesheet\" type=\"text/css\">\n<style>\nbody:after\n{\n\tcontent: url(../images/common_imgs/loading.gif);\n\tdisplay: none;\n}\n\n.content td {\n    padding: 0px 5px 15px 5px;\n}\n\nspan.login_link {\n    background: url(\"../images/common_imgs/arrow-blue-grad.svg\") no-repeat scroll left center / 8px auto transparent;\n    padding-left: 14px;\n    color: #0AD;\n    text-decoration: underline;\n    cursor: pointer;\n}\n\n.Paddingbottom0 td {padding-bottom: 0px;}\n.infobubblePosition { width:18px;height:18px;position:relative;left:5px;top:3px}\n.pwd-bar-size{width:220px;height:20px}\n\n</style>\n</head>\n<body style=\"display:none;\">\n<div id=\"overlayWarring\" style=\"display:none;\"></div>\n<div id=\"noticelogin\" style=\"display:none;\">\n\t<div class=\"overlay\" id=\"\" style=\"z-index: 11500;\"></div>\n\t<div class=\"overlaycontainer\" id=\"\" style=\"z-index: 12000;\">\n\t\t<div id=\"loginUserPassword\" class=\"overlaycontent_holder\">\n\t\t\t<div id=\"c_no00\" class=\"overlaycontent-title dynamic\"></div>\n\t\t\t<div id=\"c_lo01\" class=\"overlaycontent-infotext dynamic\"></div>\n\t\t\t<div class=\"overlaycontent\">    \n\t\t\t\t<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n\t\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_39\" align=\"right\"></td>\n\t\t\t\t\t\t<td align=\"left\">\n\t\t\t\t\t\t<div class=\"ShowAndHide\">\n\t\t\t\t\t\t\t<a onclick=\"ShowAndHide()\"><u id=\"c_84\" class=\"dynamic\"></u></a>\n\t\t\t\t\t\t\t<input id=\"loginPassword\" name=\"loginPassword\" value=\"\" class=\"default\" onblur=\"InputTextDefault('loginPassword','');\" onfocus=\"InputTextEnable('loginPassword','');\" autofocus=\"\" type=\"password\" maxlength=\"31\">\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t</tbody>\n\t\t\t\t</table>\n\t\t\t</div>\n\t\t\t<div style=\"padding-bottom:40px\"><input id=\"c_42\" name=\"id_common_login\" class=\"button_main dynamicValue\" value=\"\" onclick=\"NoticeLogin();\" onmouseover=\"$(this).addClass('button_main_hover');\" onmouseout=\"$(this).removeClass('button_main_hover');\" type=\"button\"></div>\n\t\t</div>\n\t</div>\n</div>\n<div id =\"guestcontent\" ></div>\n<div id =\"wificontent\" ></div>\n<div id =\"bubblecontent\" ></div>\n<div id =\"noticecontent\" ></div>\n<div id =\"TDWcontent\" ></div>\n<div class=\"top-nav\">\n    <div class=\"logo\"></div>\n\t<table align=\"right\" style=\"padding: 24px 0px;\">\n\t\t<tr>\n\t\t\t<td>\n\t\t\t\t<div class=\"logout\"><a href=\"javascript:void(0)\" style=\"position: relative;\" onclick=\"doLogout();\">&nbsp;&nbsp;<span id=\"c_mu30\" class=\"dynamic\"></span></a></div>\n\t\t\t</td>\n\t\t\t<td style=\"padding-left: 10px;\">\n\t\t\t\t<div class=\"language\">\n\t\t\t\t\t<span id=\"c_lg00\" class=\"dynamic\"></span> \n\t\t\t\t\t<span class=\"select\"><select class=\"default\" id=\"DropDownList-Lang\" style=\"width:121px;height:31px;\"></select></span>\n\t\t\t\t</div>\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n</div>\n<div class=\"content_holder\">\n<div class=\"navigation hideContent\">\n\t<ul class=\"levelmenu\" style=\"margin-bottom:0px; padding-bottom:0px\">\n\t\t<li>\n\t\t\t<a name=\"common_page/HomePage\" class=\"noChildMenu link level1\" href=\"javascript:void(0)\">\n\t\t\t<img src=\"images/common_imgs/Home-icon.svg\" class=\"menuIcon\"><span class=\"menuTitle dynamic\" id=\"c_mu01\"></span></a>\n\t\t</li>\n\t\t<li class=\"NAT PARCON\">\n\t\t\t<a name=\"gw_page/ParentalControl\" class=\"noChildMenu link level1\" href=\"javascript:void(0)\">\n\t\t\t<img src=\"images/common_imgs/ParentalControl-icon.svg\" class=\"menuIcon\"><span class=\"menuTitle dynamic\" id=\"c_mu02\"></span></a>\n\t\t</li>\n\t\t<li class=\"NAT\">\n\t\t\t<a name=\"common_page/DeviceConnectionStatus\" class=\"noChildMenu link level1\" href=\"javascript:void(0)\">\n\t\t\t<img src=\"images/common_imgs/ConnectedDevices-icon.svg\" class=\"menuIcon\"><span class=\"menuTitle dynamic\" id=\"c_mu03\"></span></a>\n\t\t</li>\n\t\t<li class=\"MODEMMODE\">\n\t\t\t<a name=\"common_page/Modem\" class=\"noChildMenu link level1\" href=\"javascript:void(0)\">\n\t\t\t<img src=\"images/common_imgs/modem.svg\" class=\"menuIcon\"><span class=\"menuTitle dynamic\" id=\"c_mu04\"></span></a>\n\t\t</li>\n\t\t<li>\n\t\t\t<a class=\"level1\" href=\"javascript:void(0)\" style=\" border-bottom : 0px;\">\n\t\t\t<img src=\"images/common_imgs/Settings-icon.svg\" class=\"menuIcon\"><span class=\"menuTitle haveChild dynamic\" id=\"c_mu05\"></span></a>\n\t\t\t<ul style=\"margin-bottom:25px\">\n\t\t\t\t<li class=\"menuline NAT\"><a class=\"Wireless_Network firstsub level2 dynamic\" href=\"javascript:void(0)\" id=\"c_mu06\"></a>\n\t\t\t\t\t<ul class=\"level3\">\n\t\t\t\t\t\t<li class=\"\"><a name=\"wifi_page/WirelessSignal\" class=\"link level3arrow dynamic\"  href=\"javascript:void(0)\" id=\"c_mu07\"></a></li>\n\t\t\t\t\t\t<li class=\"\"><a name=\"wifi_page/WirelessSecurity\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu08\"></a></li>\n\t\t\t\t\t\t<li class=\"\"><a name=\"wifi_page/GuestNetwork\" class=\"link level3arrow Guest_Networks dynamic\" href=\"javascript:void(0)\" id=\"c_mu09\"></a></li>\n\t\t\t\t\t\t<li class=\"\"><a name=\"wifi_page/WirelessWPS\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu10\"></a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"menuline NAT\"><a class=\"Security level2 dynamic\" href=\"javascript:void(0)\" id=\"c_mu08\"></a>\n\t\t\t\t\t<ul class=\"level3\">\n\t\t\t\t\t\t<li class=\"\"><a name=\"gw_page/FirewallFiltering\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu12\"></a></li>\n\t\t\t\t\t\t<li class=\"\"><a name=\"gw_page/MACFiltering\" class=\"link level3arrow MAC_Filtering dynamic\" href=\"javascript:void(0)\" id=\"c_mu13\"></a></li>\t\t\t\t\t\t\n\t\t\t\t\t\t<li class=\"\"><a name=\"gw_page/PortFiltering\" class=\"link level3arrow Port_Filtering dynamic\" href=\"javascript:void(0)\" id=\"c_mu14\"></a></li>\n\t\t\t\t\t\t<li class=\"PCP v4only\"><a name=\"gw_page/PortForwarding\" class=\"link level3arrow Port_Forwarding dynamic\" href=\"javascript:void(0)\" id=\"c_mu15\"></a></li>\n\t\t\t\t\t\t<li class=\"v4only\"><a name=\"gw_page/PortTriggering\" class=\"link level3arrow Port_Triggering dynamic\" href=\"javascript:void(0)\" id=\"c_mu16\"></a></li>\n\t\t\t\t\t\t<li class=\"v4only\"><a name=\"gw_page/DMZ\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu17\"></a></li>\t\t\t\t\t\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n\t\t\t\t<li class=\"menuline NAT\"><a name=\"gw_page/Settings\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu18\"></a></li>\n\t\t\t\t<li class=\"menuline NAT v4only\"><a name=\"gw_page/UPnP\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu19\"></a></li>\n\t\t\t\t<li class=\"menuline NAT DDNS\"><a name=\"gw_page/DDNS\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"g_ddns01\"></a></li>\n\t\t\t\t<li class=\"menuline\"><a class=\"Tools level2 dynamic\" href=\"javascript:void(0)\" id=\"c_mu20\"></a>\n\t\t\t\t\t<ul class=\"level3\">\n\t\t\t\t\t\t<li class=\"\"><a name=\"common_page/NetworkStatus\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu21\"></a></li>\n\t\t\t\t\t\t<li class=\"NAT\"><a name=\"common_page/Ping\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu22\"></a></li>\n\t\t\t\t\t\t<li class=\"NAT\"><a name=\"common_page/TRT\" class=\"link level3arrow TRT dynamic\" href=\"javascript:void(0)\" id=\"c_mu23\"></a></li>\n\t\t\t\t\t\t<li class=\"NAT\"><a name=\"gw_page/MTUSize\" class=\"link level3arrow dynamic\" href=\"javascript:void(0)\" id=\"c_mu24\"></a></li>\n\t\t\t\t\t</ul>\n\t\t\t\t</li>\n\t\t\t</ul>\n\t\t</li>\n\t\t<li>\n\t\t\t<a class=\"level1\" href=\"javascript:void(0)\">\n\t\t\t<img src=\"images/common_imgs/Admin-icon.svg\" class=\"menuIcon\"><span class=\"menuTitle haveChild dynamic\" id=\"c_mu25\"></span></a>\n\t\t\t<ul style=\"margin-bottom:25px\">\n\t\t\t\t<li class=\"menuline\"><a name=\"common_page/Admin\" class=\"link level2 firstsub noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu26\"></a></li>\n\t\t\t\t<li class=\"menuline\"><a name=\"common_page/Reboot\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu27\"></a></li>\n\t\t\t\t<li class=\"menuline NAT REMOTEACCESS\"><a name=\"common_page/RemoteAccess\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu28\"></a></li>\n\t\t\t\t<li class=\"menuline\"><a name=\"common_page/Info\" class=\"link level2 noChildSubMenu dynamic\" href=\"javascript:void(0)\" id=\"c_mu29\"></a></li>\n\t\t\t</ul>\n\t\t</li>\n    </ul>\n\t<br>\n</div>\n<div id =\"content\" class=\"left\" name=\"common_page/HomePage\"></div>\n</div>\n<script language=\"javascript\" src=\"js/jquery.min.js\"></script>\n<script language=\"javascript\" src=\"js/multi_langs.js?v=20250108144525\"></script>\n<script language=\"javascript\" src=\"js/common_api.js?v=20250108144525\"></script>\n<script language=\"javascript\" src=\"js/tendina.min.js\"></script>\n<script language=\"javascript\" src=\"js/jquery.svginject.js\"></script>\n<script language=\"javascript\" src=\"js/snap.svg-min.js\"></script>\n<script language=\"javascript\" src=\"js/jquery.svg.min.js\"></script>\n<script language=\"javascript\" src=\"js/jquery.svganim.min.js\"></script>\n<script language=\"javascript\" src=\"js/single_range.js\"></script>\n<script language=\"javascript\" src=\"js/sha256.js\"></script>\n<script type=\"text/javascript\" src=\"js/jquery.base64.js\"></script>\n<script type=\"text/javascript\" src=\"js/md5.js\"></script>\n<script type=\"text/javascript\" src=\"js/AES.js\"></script>\n<script type=\"text/javascript\" src=\"js/encrypt_cryptoJS.js\"></script>\n<script language=\"javascript\">\nvar timerId=0;//be used for setintrval\nvar reload = true;\n\nfunction RunTendina()\n{\n\t$('.levelmenu').tendina({\n\t\tanimate: true,\n\t\tspeed: 500,\n\t\t//activeMenu: $(\".string\"),\n\t\topenCallback: function(clickedEl) {\n\t\t},\n\t\tcloseCallback: function(clickedEl) {\n\t\t}\n\t})\n}\n\n$(document).ready( function() {\n\tcheckCmUpdating();\n\treload = true;\n\t_OpenServerAlert = true;\n\tRunTendina();\n\t$(\"body\").show();\n\t$(\".hideContent\").hide();\n\t$(\".PARCON\").remove();//CBN - 20151002 - remove parentalCtl temporarily \n\t\n\tif(GlobalSt[\"VMFuncEn\"] === true)\n\t\t$(\".PARCON\").remove();\n\tif(_GWOperMode == \"Disable\")\n\t{\n\t\t$(\".NAT\").remove();\n\t\t$(\".Tools\").addClass(\"firstsub\");\n\t}\n\telse if(_GwProvisionMode == \"IPv6\")\n\t{\n\t\tvar PCP = parseInt(_PortControl) & parseInt(_DsLite);\n\t\t$(\".v4only\").remove();\n\t\tif(PCP)\n\t\t{\n\t\t\t$(\".PCP\").show();\n\t\t}\n\n\t\tif(_DsLite == \"1\")\n\t\t{\n\t\t\t$(\".MODEMMODE\").remove();\n\t\t\t$(\".DDNS\").remove();\n\t\t}\n\t}\n\t\n\tif(GlobalSt[\"ShowDDNS\"] === false)\n\t\t$(\".DDNS\").remove();\n\tif(GlobalSt[\"HideModemMode\"] === true)\n\t\t$(\".MODEMMODE\").remove();\n\tif(GlobalSt[\"HideRemoteAccess\"] === true)\n\t\t$(\".REMOTEACCESS\").remove();\n\t\n\t/*for reload function_S*/\n\tif(location.pathname.match(\"index.html\")){\n\t\tgoto('common_page/HomePage.html','content');\n\t}else{\n\t\tif(typeof(Storage) !== \"undefined\") \n\t\t{\n\t\t\tif ((typeof(sessionStorage.currenturl) !== \"undefined\") \n\t\t\t\t&& (sessionStorage.currenturl !== \"undefined.html\"))\n\t\t\t{\n\t\t\t\tgoto(sessionStorage.currenturl,'content');\n\t\t\t}else{\n\t\t\t\tgoto('common_page/HomePage.html','content');\n\t\t\t}\n\t\t}else{\n\t\t\tgoto('common_page/HomePage.html','content');\n\t\t}\n\t}\n\t/*for reload function_E*/\n\tajaxGet({'fun':21},\"\",LangSetList);\n\t$(\"#loginPassword\").bind('input propertychange', function() {RemoveErrMsg(\"loginPassword\");});\n\t$(\"ul .level3\").each(function(){$(this).find('li').last().find('a').addClass('leastsub');});\n});\n\nvar dst,dst_id;\nvar _historypage;\nvar _historycontent=\"\";\nvar _currentpage=\"\";\nvar _currentcontent=\"\";\nfunction checkCmUpdating()\n{\n\tajaxGet({'fun':1},\"\",function(xmlResponse, node)\n\t{\n\t\tif($(xmlResponse).find('operStatus').text() != 1)\n\t\t{\n\t\t\tdoLogout();\n\t\t}\n\t});\n}\n\nfunction goto(url,id,renew)\n{\t\t\n\t$(\"#overlayWarring\").empty().hide();\n\tif (SetTimeout || (GlobalSt[\"goto\"]===true))\n\t\treturn;\n\t\t\n\tif(id=='content')\n\t{\n\t\tGlobalSt[\"goto\"] = true;\n\t\twindow.clearInterval(timerId);\n\t\t_historypage=_currentpage;\n\t\t_currentpage=url;\n\t\t_historycontent=_currentcontent;\n\t\t_currentcontent=id;\n\t}\n\tif(GetXmlResponseDone === true && NoticeCheckIsChange()===true)\n\t{\n\t\tdst = url;\n\t\tdst_id = id;\n\t\tNotice('common_page/Notice.html','noticecontent');\n\t\tGetXmlResponseDone = true;\n\t\tGlobalSt[\"goto\"] = false;\n\t}\n\telse\n\t{\n\t\tcbnAjaxInit();\n\t\tloadGlobalValue();\n\t\t$('html, body').animate({ scrollTop:0 }, 'fast');\n\t\t$(\"#bubblecontent\").empty();\n\t\t\n\t\tif(_WPSinterval==1){\n\t\t\t_WPSinterval=0;\n\t\t\twindow.clearInterval(WPSinterval);\n\t\t}\n\t\tgetUrlContent(url,id,renew);\n\t\treload = false;\n\t\tGetXmlResponseDone = false;\n\t\tNoticeCheckIsChange = nothingIsChange;\n\t}//end notice flag\n}\n\n$( \"a\" ).on( \"click\", function(event) {\n\tif(GlobalSt[\"waitTimeScreen\"]===true)\n\t\treturn;\n\tevent.preventDefault();\n\tvar thisCss = \"\" + $(this).attr(\"class\");\n\tif(thisCss.match(\"link\"))\n\t\tgoto($(this).attr(\"name\")+'.html','content');\t\t\t\n});\n\n$( \".haveChild\" ).parent().on( \"click\", function(event) {\n\tvar thisparent = $(this).parent();\n\tvar thisStyle = thisparent.find(\"ul\").attr(\"style\");\n\t$(\".menuTitle\").attr(\"style\",\"border-bottom: 1px solid #D3D3D3\");\n\tif(thisStyle.match(\"display: none;\"))\n\t\tthisparent.find(\".menuTitle\").attr(\"style\",\"border-bottom: 0px solid #D3D3D3\");\n\telse if (thisStyle.match(\"display: block;\"))\n\t\tthisparent.find(\".menuTitle\").attr(\"style\",\"border-bottom: 1px solid #D3D3D3\");\n});\n\n$( \".link\" ).on( \"click\", function(event) {\t\n\tevent.preventDefault();\n\tvar thisClass = $(this).attr(\"class\");\n\t$( \".link\" ).removeClass( \"select_subtitle\" );\n\t$(this).addClass(\"select_subtitle\");\n\t\t\t\n\tif(thisClass.match(\"noChildMenu\"))\n\t{\t\t\t\n\t\t$(\".level3arrow\").removeClass(\"level3_selected\");\n\t\t$(\".level2\").removeClass(\"level2_selected select_title\");\n\t}\n\telse if(thisClass.match(\"noChildSubMenu\"))\n\t{\n\t\t$(\".level2\").addClass(\"level2_selected\");\n\t\t$(\".level3arrow\").removeClass(\"level3_selected\");\n\t\t$(this).addClass(\"level2_selected\");\n\t}\n});\n\n$( \".level3arrow , .level2\" ).on( \"click\", function(event) {\n\tevent.preventDefault();\n\tvar thisClass = $(this).attr(\"class\");\t\n\t\n\tif(thisClass.match(\"level3arrow\"))\n\t{\t\t\t\t\n\t\t$(\".level3arrow\").removeClass(\"level3_selected\");\n\t\t$(\".noChildSubMenu\").removeClass(\"level2_selected select_title\");\n\t\t$(this).addClass(\"level3_selected\");\t\t\t\n\t}\n\telse if(thisClass.match(\"level2\"))\t\n\t{\n\t\t$(\".level2\").removeClass(\"level2_selected select_title\");\t\n\t\t$(this).addClass(\"level2_selected select_title\");\n\t\t\n\t\t$(\".noChildSubMenu\").each(function(){\n\t\t\tif($(this).attr(\"class\").match(\"select_subtitle\"))\n\t\t\t\t$(this).addClass(\"level2_selected select_title\");\n\t\t});\n\t}\n});\n\nfunction MenuSlideUp(url)\n{\n\tvar noChildMenu = [\t\"HomePage.html\", \"Modem.html\", \"DeviceConnectionStatus.html\", \"ParentalControl.html\"];\n\tvar noChildSubMenu = [\t\"UPnP.html\", \"Settings.html\", \"Info.html\", \"Admin.html\",\"Reboot.html\",\"RemoteAccess.html\"];\n\tvar menu = url.split(\"/\");\n\t\t\n\tif((jQuery.inArray(menu[1], noChildMenu))!=-1)\n\t{\n\t\t$(\".menuTitle\").attr(\"style\",\"border-bottom: 1px solid #D3D3D3\");\n\t\t$('.levelmenu').tendina(\"CBNslideUpAll\");\n\t}\n\tif((jQuery.inArray(menu[1], noChildSubMenu))!=-1)\n\t{\n\t\t$('.levelmenu').tendina(\"CBNslideUpLevel2\");\n\t}\n}\n\nfunction RecordURL(url)//for reload page\n{\n\tif(history.pushState) \n\t{\n\t\tif(url.match(\"HomePage.html\"))\n\t\t\thistory.pushState(null, \"\", \"index.html\");\n\t\telse\n\t\t\thistory.pushState(null, \"\", \"/\");\n\t}\n\tsessionStorage.currenturl = url;\n}\n\nfunction getUrlContent(url,position,renew)\n{\n\t$.get(url, function(result)\n\t{\n\t\tif(result.match(\"cbnLogin\"))\n\t\t\twindow.location.assign(\"../common_page/login.html\");\n\t\telse if(result.match(\"cbnFirstInstall\"))\n\t\t\twindow.location.assign(\"../common_page/FirstInstallation.html\");\n\t\telse if(result.match(\"cbnBlockContent\") || result.match(\"cbnAccessDenied\")){\n\t\t\twindow.location.assign(\"../common_page/Access-denied.html\");\n\t\t}\n\t\telse{\n\t\t\tif(position==\"content\" && url != \"undefined\")\n\t\t\t{\n\t\t\t\tvar URL = url;\n\t\t\t\tif(url.match(\"../\") == \"../\")\n\t\t\t\t\tURL = url.split(\"../\")[1];\n\t\t\t\t$(\"#content\").attr(\"name\",URL.slice(0,-5));\n\t\t\t\tcachefile(\"/js/checkpath.js?v=20250108144525\", function() {});\n\t\t\t}\n\t\t\t$result = $(result);\n\t\t\t$('#'+position).empty();\n\t\t\t$result.filter(\"div\").appendTo('#'+position);\n\t\t\t$result.filter(\"style\").appendTo('#'+position);\n\t\t\t$result.filter(\"#mainScript\").appendTo('#'+position);\n\t\t\t\tif(renew!=undefined)\n\t\t\t{\n\t\t\t\trenew();\n\t\t\t}\n\t\t}\n\t}, 'html').fail(function() {ReloadPage();});\n\tif(position=='content')\n\t{\n\t\tvar URL = url;\n\t\tif(url.match(\"../\") == \"../\")\n\t\t\tURL = url.s