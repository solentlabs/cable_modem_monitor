            "text": "@charset \"UTF-8\";\n@font-face {\n    font-family: TeleNeo-Regular;\n    src: url(../font/TeleNeo-Regular.otf);\n    src: url('../font/TeleNeo-Regular.woff2') format('woff2'),\n         url('../font/TeleNeo-Regular.woff') format('woff'),\n\t\t url('../font/TeleNeo-Regular.ttf') format('truetype'),\n         url('../font/TeleNeo-Regular.svg') format('svg');\n}\n@font-face {\n    font-family: TeleNeo-ExtraBold;\n    src: url(../font/TeleNeo-ExtraBold.otf);\n    src: url('../font/TeleNeo-ExtraBold.woff2') format('woff2'),\n         url('../font/TeleNeo-ExtraBold.woff') format('woff'),\n\t\t url('../font/TeleNeo-ExtraBold.ttf') format('truetype'),\n         url('../font/TeleNeo-ExtraBold.svg') format('svg');\n}\n@font-face {\n    font-family: TeleNeo-Bold;\n    src: url(../font/BloomSpeakOT-Bold.otf);\n\tsrc: url('../font/BloomSpeakOT-Bold.eot');\n    src: url('../font/BloomSpeakOT-Bold?#iefix') format('embedded-opentype'),\n         url('../font/BloomSpeakOT-Bold.woff') format('woff'),\n         url('../font/BloomSpeakOT-Bold.ttf') format('truetype'),\n         url('../font/BloomSpeakOT-Bold.svg#TeleNeo-Bold') format('svg');\n}\n\nhtml {\n    overflow-y: scroll; \n}\nul {\n    list-style: none outside none;\t\n}\n\n.levelmenu li a {\n    display: inline-block;\n}\n\n/*Alen */\nbody \n{\n\tbackground:#fff url(../images/common_imgs/page-background-MTAT.png) repeat-x; \n\tmargin: 0px auto; \n\tpadding:0px; \n\tfont-family:TeleNeo-Regular;\n}\n\n.top-nav \n{\n\tmargin: 0px auto;\n\twidth: 960px;\n\theight:80px;\n\tposition:relative;\n\tclear:both;\n}\n\n.content_holder\n{\n\tmargin: 0px auto; \n\twidth: 960px; \n\tposition:relative;\n}\n\n.logo \n{\n\tposition: absolute; \n\tleft:0px; \n\twidth:210px; \n\theight: 80px;\n\tpadding: 0px; \n\tbackground-image: url(../images/common_imgs/T_Logo_weiss_magenta.svg);\n\tbackground-size: auto 80px;\n    background-repeat: no-repeat;\n}\n\n.logout \n{\n\tright:230px;\n\tpadding:0px 30px;\n\tborder-right: 1px solid #FFFFFF;\n}\n.logout a \n{\n\tfont-size:20px;\n\tcolor: #FFFFFF;\n\ttext-decoration:none;\n\tbackground: url(../images/common_imgs/Logout-icon-MTAT.svg) no-repeat;\n\tpadding-left: 20px !important;\n\tbackground-size: 20px 20px;\n\tbackground-position: left;\n}\n.logout a:hover, .svg-inject.logout path a:hover \n{\n\tcolor:#FFFFFF;\n\tfill:#FFFFFF;\n}\n.logout svg \n{\n\twidth: 20px;\n\tmargin-right: 5px;\n\tvertical-align:bottom;\n\tpadding-bottom: 4px;\n}\n\n.language \n{\n\tright:0px;\n\tmargin:0px;\n\tfont-size:20px;\n\tcolor: #FFFFFF;\n\ttop: 2px;\n}\n\n.green, .svg-inject.green path, .svg-inject.green circle , .diag-svg-inject.green path, .diag-svg-inject.green circle,.PARCON-svg-inject.green path, .PARCON-svg-inject.green circle\n{ \n\tcolor:#20DAA0;\n\tfill:#20DAA0!important;\n}\n\n.orange, .svg-inject.orange path, .svg-inject.orange circle\n{ \n\tcolor:#ff6600;\n\tfill:#ff6600;\n}\n.red, .svg-inject.red path, .svg-inject.red circle , .diag-svg-inject.red path, .diag-svg-inject.red circle ,.PARCON-svg-inject.red path, .PARCON-svg-inject.red circle\n{ \n\tcolor:#cc0022;\n\tfill:#cc0022;\n}\n.lightblue, .svg-inject.lightblue path, .svg-inject.lightblue circle\n{ \n\tcolor:#00aadd;\n\tfill:#00aadd;\n}\n.darkblue, .svg-inject.darkblue path, .svg-inject.darkblue circle ,.PARCON-svg-inject.darkblue path, .PARCON-svg-inject.darkblue circle\n{ \n\tcolor:#224499;\n\tfill:#224499;\n}\n.purple, .svg-inject.purple path, .svg-inject.purple\n{\n\tcolor:#771199;\n\tfill:#771199;\n}\n\n.green_0, .diag-svg-inject.green_0 path, .diag-svg-inject.green_0 circle\n{ \n\tcolor:#ddea14;\n\tfill:#ddea14!important;\n}\n\n.green_25, .diag-svg-inject.green_25 path, .diag-svg-inject.green_25 circle\n{ \n\tcolor:#cdcc14;\n\tfill:#cdcc14!important;\n}\n\n.green_50, .diag-svg-inject.green_50 path, .diag-svg-inject.green_50 circle\n{ \n\tcolor:#d3cb2e;\n\tfill:#d3cb2e!important;\n}\n.green_75, .diag-svg-inject.green_75 path, .diag-svg-inject.green_75 circle\n{ \n\tcolor:#a9ca2f;\n\tfill:#a9ca2f!important;\n}\n\n.red_0, .diag-svg-inject.red_0 path, .diag-svg-inject.red_0 circle\n{ \n\tcolor:#ffbb1c;\n\tfill:#ffbb1c!important;\n}\n\n.red_25, .diag-svg-inject.red_25 path, .diag-svg-inject.red_25 circle\n{ \n\tcolor:#ff9e02;\n\tfill:#ff9e02!important;\n}\n\n.red_50, .diag-svg-inject.red_50 path, .diag-svg-inject.red_50 circle\n{ \n\tcolor:#ff6f15;\n\tfill:#ff6f15!important;\n}\n.red_75, .diag-svg-inject.red_75 path, .diag-svg-inject.red_75 circle\n{ \n\tcolor:#d74614;\n\tfill:#d74614!important;\n}\n.magenta, .svg-inject.magenta path, .svg-inject.magenta circle ,.PARCON-svg-inject.magenta path, .PARCON-svg-inject.magenta circle\n{ \n\tcolor:#E20074;\n\tfill:#E20074;\n}\n\n.spacer\n{ \n\theight: 30px;\n\tfloat:none;\n\tclear: both;\n}\n\n.navigation \n{\n\tposition: absolute; \n\tleft:0px; \n\ttop: 20px; \n\twidth:220px; \n\tpadding: 0px; \n\tmargin-left:10px;\n\tmargin-top: -1px;\n}\n\n.homeIcon\n{\t\n\ttop:2px;\n}\n\n.settingsIcon\n{\n\ttop:1px;\n}\n\n.modemstatusIcon\n{\n\ttop:4px;\n}\n\n.levelmenu\n{\n\tpadding: 0px 0px 10px 0px;/* width: 175px;*/\n}\n.levelmenu a \n{\n\tfont-size: 18px; \n\ttext-decoration:none; \n\tcolor:#666;\n}\n.levelmenu a:hover \n{\n\tcolor:#E20074;\n}\n.levelmenu a#selected \n{\n\tcolor:#E20074;\n}\n\n.level1 \n{ \n\tpadding: 20px 20px 10px 0px; \n\twidth: 230px;\n\tcolor:#000 !important;\n}\n.level1 a \n{\n\tfont-size: 18px; \n\ttext-decoration:none; \n}\n.level1 a:hover \n{\n\tcolor:#E20074;\n}\n\n.level1 span:hover \n{\n\tcolor:#E20074;\n}\n.level1 a#selected \n{\n\tcolor:#E20074;\n}\n\n.level3\n{\n\tmargin-left:-35px;\n}\n.level3arrow\n{\n\tbackground: url(../images/common_imgs/arrow-grey.svg) no-repeat 0px 4px ;\n\tbackground-size: 6px 10px;\n\tmargin-left:-3px;\n\tpadding-left:15px !important;\n\tpadding-bottom: 10px;\n}\n.level3_selected \n{\n\tbackground: url(../images/common_imgs/arrow-magenta.svg) no-repeat 0px 4px ;\n\tbackground-size: 6px 10px;\n}\n\n.level3 a \n{\n\tfont-size: 16px; \n\ttext-decoration:none; \n\tcolor:#666; \n}\n.level3 a:hover \n{\n\tcolor:#E20074;\n}\n\n.content-container\n{\n\twidth:670px; \n\tpadding-left: 30px;\n\tposition: absolute; \n\tleft:250px;\n}\n\n.content-container div \n{\n\tclear: both; \n\tmargin: 30px 0px;\n}\n\n.page-title\n{\n\tfont-family: TeleNeo-ExtraBold;\n\tfont-size:54px; \n\tcolor:#E20074; \n\tpadding-bottom: 3px;\n\ttext-align:center;\n}\n.page-title img \n{\n\twidth:64px;\n}\n\n.section_header \n{\n\tfont-family: TeleNeo-ExtraBold;\n\tfont-size:28px; \n\tcolor: #000000;\n}\n\n.section_title \n{\n\tfont-size: 22px !important; \n\tcolor:#000 !important;\n}\n\n.hp_title\n{\n\tfont-size: 32px !important; \n}\n\n.boxed_content div.section_title \n{\n\tbackground:#eaeaea!important;\n\tpadding: 8px!important;\n\tmargin: 20px 0px;\n}\n\n.general_text \n{\n\tfont-size:18px; \n\tcolor:#000000;\n}\n.general_text_disabled \n{\n\tfont-size:18px; \n\tcolor:#c9c9c9;\n}\n\n.checkbox \n{\n\twidth:23px; \n\theight:25px; \n\tmargin-right: 6px; \n\tfloat:left;\n}\n\nselect.optionTest\n{\n\tbackground:#fff; \n\tborder:2px solid #d3d3d3; \n\tborder-radius:3px; \n\tcolor:#666; \n\tfont-size:18px; \n\tfont-family:TeleNeo-Regular; \n\tpadding:3px 10px 3px 10px;\n\twidth:320px\n}\n\ninput.default, textarea.default ,select.default\n{\n\tbackground:#fff;\n\tborder:2px solid #d3d3d3;\n\tborder-radius:3px;\n\tcolor:#666;\n\tfont-size:18px;\n\tfont-family:TeleNeo-Regular;\n\tpadding:3px 10px 3px 10px;\n}\n\ninput.enabled, textarea.enabled \n{\n\tbackground:#fff;\n\tborder:1px solid #00aadd;\n\tborder-radius:3px;\n\tcolor:#666;\n\tfont-size:18px;\n\tfont-family:TeleNeo-Regular;\n\tpadding:4px 11px 4px 11px;\n\tbox-shadow: 0 0 4px #66bddc;\n}\n\ninput.disabled, textarea.disabled \n{\n\tbackground:#f1f1f1;\n\tborder:2px solid #d3d3d3;\n\tborder-radius:3px;\n\tcolor:#d3d3d3;\n\tfont-size:18px;\n\tfont-family:TeleNeo-Regular;\n\tpadding:3px 10px 3px 10px;\n}\n\ninput.devicename\n{\n\twidth:140px;\n}\n\nselect.disabled \n{\n    background-color:#f1f1f1 !important;\n}\n\ninput.error, textarea.error \n{\n\tbackground:#fff;\n\tborder:2.5px solid #FF3333;\n\tborder-radius:3px;\n\tcolor:#666;\n\tfont-size:18px;\n\tfont-family:TeleNeo-Regular;\n\tpadding:4px 11px 4px 11px;\n\tbox-shadow: 0 0 4px #FF3333;\n}\n\n.selectError\n{\n\tbox-shadow: 0 0 4px #FF3333 !important;\n\tborder: 1px solid #FF3333 !important;\n}\n\nselect.default\n{\n\tbackground-size: 16px auto;\n\tpadding:1px 10px;\n}\n\n.arrow-bottom \n{\n\tdisplay: inline-block;\n\tmargin-left: 5px;\n\tborder-top: 5px solid #A5A4A4;\n\tborder-right: 5px solid transparent;\t\t\t\t\n\tborder-left: 5px solid transparent;\t\t\n\twidth: 1px;\n\theight: 1px;\n}\n.arrow\n{\n\tposition : relative;top : 11px;bottom : 10px;left : 319px;right :10px;\n}\n:active\n{\n\toutline:none;\n}\n\n.select_title\n{\n\tcolor: #E20074 !important;\n}\n\n.select_subtitle\n{\n\tcolor:#E20074 !important; \n\tfont-size: 18px;\n}\n\na\n{\n\tblr:expression(this.onFocus=this.blur()); /* IE Opera */ \n\toutline:none; /* FF Opera */ \n\tcolor: inherit;} \na:focus\n{ \n\t-moz-outline-style: none; /* FF */ \n}\n\ntd.dataline {\t\n\tbackground-color:#c7c7c7;\n}\n\ntd.dataBackColor{\t\n\tbackground-color:#ededed;\n}\n\ntr.data{ \n background-color:#ededed;\n}\n\ntd{\n\tpadding-left: 0px;\n\tpadding-bottom: 5px;\n\tpadding-top: 5px;\n\tpadding-right: 5px;\n}\n\ndiv.divSelect\n{\n\tword-break:break-all;\n\tmargin:0px 10px 0px 10px;\t\n}\n\n\n/*zacks test arrow css*/\n.triangle-bottom {\n    width: 0;\n    height: 0;\n    border-style: solid;\n    border-width: 7px 5px 0 5px;\n    border-color: #767b80 transparent transparent transparent;  \n}\n\n\n.button_main \n{\n\tbackground:#E20074; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #fff; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #E20074; \n\tborder-radius:3px; \n\tcursor: pointer; \n\tbehavior: url(css/PIE.htc);\n}\n.button_main_hover \n{\n\tbackground:#E20074; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #fff; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #E20074; \n\tborder-radius:3px;\n\tbox-shadow: 0 0 4px #E20074;\t\n\tcursor: pointer; \n\tbehavior: url(css/PIE.htc);\n}\n.button_main_deactivated \n{\n\tbackground:#aaaaaa; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #c2c2c2; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #dedede; \n\tborder-radius:3px; \n\t/*cursor: pointer;*/ \n\tbehavior: url(css/PIE.htc);\n}\n\n.button_secondary \n{\n\tbackground:#FFFFFF url(../images/common_imgs/arrow-magenta.svg) no-repeat 92% center; \n\tbackground-size: 10px 17px; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #E20074; \n\tpadding: 10px 40px 8px 20px;\n\tborder:1px solid #d2d2d2; \n\tborder-radius:3px; \n\tcursor: pointer;\n\tbehavior: url(css/PIE.htc);\n}\n.button_secondary_hover \n{\n\tbackground:#FFFFFF url(../images/common_imgs/arrow-magenta.svg) no-repeat 92% center; \n\tbackground-size: 10px 17px;  \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #E20074; \n\tpadding: 10px 40px 8px 20px;\n\tborder:1px solid #E20074; \n\tborder-radius:3px;\n\tbox-shadow: 0 0 4px #E20074;\n\tcursor: pointer;\n\tbehavior: url(css/PIE.htc);\n}\n.button_secondary_deactivated \n{\n\tbackground:#FFFFFF url(../images/common_imgs/arrow-blue-deactivated.svg) no-repeat 92% center; \n\tbackground-size: 10px 17px; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px;\n\tcolor: #d8d8d8; \n\tpadding: 10px 40px 8px 20px;\n\tborder:1px solid #ebebeb; \n\tborder-radius:3px; \n\t/*cursor: pointer;*/\n\tbehavior: url(css/PIE.htc);\n}\n\n.button_secondary_arrowfree\n{\n\tbackground:#FFFFFF url() no-repeat 92% center; \n\tbackground-size: 10px 17px; \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #E20074; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #d2d2d2; \n\tborder-radius:3px; \n\tcursor: pointer;\n\tbehavior: url(css/PIE.htc);\n}\n.button_secondary_hover_arrowfree \n{\n\tbackground:#FFFFFF url() no-repeat 92% center; \n\tbackground-size: 10px 17px;  \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px; \n\tcolor: #E20074; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #E20074; \n\tborder-radius:3px; \n\tcursor: pointer;\n\tbehavior: url(css/PIE.htc);\n}\n.button_secondary_arrowfree_deactivated \n{\n\tbackground:#FFFFFF url() no-repeat 92% center; \n\tbackground-size: 10px 17px;\n\tfont-family: TeleNeo-Regular; \n\tfont-size: 20px;\n\tcolor: #d8d8d8; \n\tpadding: 10px 20px 8px 20px;\n\tborder:1px solid #d2d2d2; \n\tborder-radius:3px; \n\t/*cursor: pointer;*/\n\tbehavior: url(css/PIE.htc);\n}\n/*CBN_S - Chris - 20141002 add for img for position*/\ntd img.checkboxImg,span img.checkboxImg\n{\n\tposition: relative;\n\ttop: -4.5px;\n}\n\ntd img.radioImg,span img.radioImg\n{\n\tposition: relative;\n\ttop: -6.5px;\n}\ntd label,td span,div lable\n{\n\tposition: relative;\n\ttop: 1.5px;\n}\ntd span[name=ProductName]{\n    top: 0px;\n}\n.example_text {\n\tfont-size: 16px;\n\tcolor: #666;\n}\n/*CBN_E - Chris - 20141002*/\n\n.buttonTable \n{\n\twidth: 700px; /*right content width*/\n}\n.buttonTable tr,.buttonTable td\n{\n\tpadding : 0px;\n\tmargin : 0px;\n}\n.buttonTable td\n{\n\tpadding-bottom : 10px; /*button padding: 10px 20px 8px 20px;*/\n}\n.buttonLine\n{\n\tborder-bottom: 1px solid #d3d3d3; \n\tmargin-top:35px;\n\tmargin-bottom:30px\n}\n\n.contentSpace \n{\n\tmargin-top:0px !important;\n}\ndiv.general_textSpace\n{\n\tmargin-top:40px;\n}\n\n.button_containers\n{\n\tbackground:#FFFFFF;\n\tfont-family: TeleNeo-Regular;\n\tfont-size: 22px;\n\tcolor:#000;\n\tpadding: 40px 19px;\n\tborder:1px solid #d2d2d2; \n\tborder-radius:3px; \n\ttext-align:center;\n\twidth: 183px;\n\theight: 130px; \n\tfloat: left; \n}\n\n.button_containers svg , .button_containers img\n{ \n\theight: 60px;\n\twidth: 60px;\n\tborder:0px;\n\tmargin-bottom: 15px;\n}\n\na.button_containers\n{\n\ttext-decoration:none\n}\n\na:hover .button_containers \n{ \n\ttext-decoration:none;\n\tborder:1px solid #E20074;\n\tbox-shadow: inset 0 0 30px #f5d7e6;\n}\n\n.modemstatus td, .connected-devices td\n{ \n\tfont-size:16px;\n\tcolor:#666;\n\tpadding-right: 30px;\n\ttext-align:center;\n\t\n}\n\n.modemstatus svg , .modemstatus img\n{ \n\theight: 30px;\n\twidth: 30px;\n}\n.connected-devices svg , .connected-devices img\n{ \n\theight: 45px;\n}\n\n#dot\n{ \n\theight: 12px;\n}\n\n.data-tables \n{\n\tborder: 1px solid #f2f2f2;\n}\n.data-tables th \n{\n\tbackground: #f2f2f2;\n\tpadding: 15px 20px;\n\tfont-size:16px;\n\tcolor: #000000;\n\tfont-weight:normal;\n\tborder: 1px solid #ffffff;\n\tborder-width:0px 1px 0px 1px;\n\ttext-align:left;\n}\n.data-tables td \n{\n\tbackground: #ffffff;\n\tpadding: 15px 20px;\n\tfont-size:16px;\n\tcolor: #666666;\n\tborder: 1px solid #f2f2f2;\n}\n.data-tables svg \n{\n\theight: 18px;\n\tmargin-right: 5px;\n}\n\n.boxed_content \n{\n\tbackground:#FFFFFF;\n\tcolor:#000;\n\tpadding: 40px 19px;\n\tborder:1px solid #d2d2d2;\n\tborder-radius:3px;\n\ttext-align:center;\n\tfloat: left;\n\twidth: 630px;\n}\n/*CBN_S - Chris - 20141031 - add for menu layout*/\n.menuTitle\n{\n\tfont-size: 20px;\n\ttext-decoration: none;\n\tmargin-left: 8px;\n\tdisplay: inline-block;\n\twidth: 185px;\n\tpadding-bottom: 10px;\n\tborder-bottom: 1px solid #D3D3D3;\n\tmargin-bottom: 5px;\n\tposition:relative;\n}\n.firstsub\n{\n\tpadding-top: 0px !important;\n}\n.level2\n{\n\tpadding: 20px 20px 10px 0px;\n\tfont-size: 18px !important;\n}\n.menuline\n{\n\twidth: 185px;\n\tborder-bottom: 1px solid #D3D3D3;\n}\n.leastsub\n{\n\tmargin-bottom:10px;\n}\n\n.menuIcon\n{\n\tposition:relative;\n\twidth:26px;\n\ttop:4px\n}\n/*CBN_E - Chris - 20141031 - add for menu layout*/\n\n.error-msg-small {\n    font-size: 16px; \n    color:#cc0022; \n}\n.error-msg-small img {\n    width: 29px;\n\theight: 29px;\n}\n\n.tip {\n    background:#771199; border-radius:3px; \n    font-size:16px; \n    color: #fff; \n    padding:2px 4px; \n    float: left;\n}\n.tip-copy {\n    font-size:16px; \n    color: #771199; \n    padding:2px 4px; \n    float: left;\n}\n\n.time-slider {\n    position:relative; \n    margin: 20px 0px; \n    height: 70px;\n}\n.data-slider {\n    position:absolute; left:0px; top: 4px; \n    font-size:14px; \n    color: #666; \n    table-layout:fixed;\n}\n.slider-off {\n    position:absolute; left:0px; top: 37px; \n    background:#e0e0e0; \n    border-radius:3px; \n    width: inherit; \n    height:15px; \n    z-index:50;\n\tcursor: pointer;\n}\n.slider-bar{\n\twidth: inherit; \n}\n.slider-on {\n    position:absolute; top: 37px; \n    background:#E20074; \n    border-radius:3px; \n    width: 168px; \n    height:15px; \n    z-index:100;\n\tcursor: pointer;\n}\n.slider-handle, .slider-handle-add, .slider-handle-remove {\n    position:absolute; top:0px; \n    z-index:150; \n    width:66px; \n    height:74px; \n    cursor: move; \n    font-size:16px; \n    color: #dbdbdb; \n    text-align:center; \n    padding-top: 3.5px;\n}\n\n.slider-handle {\n\tbackground:url(../images/common_imgs/slider-handle.svg) no-repeat; \n\tbackground-size:66px 62px;\n}\n\n.slider-handle-remove{\n\tpadding-top: 0px;\n\tpointer-events: none;\n\theight:62px !important;\n}\n.slider-handle-add { \n    filter:alpha(opacity=70); \n    opacity:.7; \n    cursor:crosshair; \n\tpadding-top: 0px;\n\tpointer-events: none;\n\theight:62px !important;\n}\n/*\n.handlerset {\n\twidth:66px;\n\theight:74px;\n\tz-index:155;\n\tposition:relative;\n}\n*/\n.slide-time {\n\tfont-size:15px;\n\tcolor: #fff;\n\ttext-align:center;\n\tpadding-top: 3px;\n\tposition:absolute;\n\ttop:0px;\n\twidth:66px;\n}\n\n.infobubble-down, .infobubble-up, .infobubble-left, .infobubble-right { \n    font-size:15px; color: #E20074; \n    padding: 10px; \n    font-family: TeleNeo-Regular; \n    border: 1px solid #dbdbdb; \n    max-width:220px;\n}\n.infobubble-down {\n    background:#ededed; \n    border-bottom: 0px;\n}\n.infobubble-up {\n    background:#ededed; \n    border-top: 0px;\n}\n.infobubble-left {\n    background:#ededed;\n    border-left: 0px;\n}\n.infobubble-right {\n    background:#ededed; \n    border-right: 0px;\n}\n.focusedContentWords{\n\tfont-weight:bold;\n\tcolor:#000;\n}\n\n/* home page */\n.green, .svg-inject-P2.green path, .svg-inject-P2.green circle , .diag-svg-inject-P2.green path, .diag-svg-inject-P2.green circle,.PARCON-svg-inject-P2.green path, .PARCON-svg-inject-P2.green circle\n{ \n\tcolor:#11aa44;\n\tfill:#11aa44!important;\n}\n\n.red, .svg-inject-P2.red path, .svg-inject-P2.red circle , .diag-svg-inject-P2.red path, .diag-svg-inject-P2.red circle\n{ \n\tcolor:#cc0022;\n\tfill:#cc0022;\n}\n\n.green, .svg-inject-MTA.green path, .svg-inject-MTA.green circle , .diag-svg-inject-MTA.green path, .diag-svg-inject-MTA.green circle,.PARCON-svg-inject-MTA.green path, .PARCON-svg-inject-MTA.green circle,\n.green, .svg-inject-CM.green path, .svg-inject-CM.green circle , .diag-svg-inject-CM.green path, .diag-svg-inject-CM.green circle,.PARCON-svg-inject-CM.green path, .PARCON-svg-inject-CM.green circle\n{ \n\tcolor:#11aa44;\n\tfill:#11aa44!important;\n}\n\n.red, .svg-inject-MTA.red path, .svg-inject-MTA.red circle , .diag-svg-inject-MTA.red path, .diag-svg-inject-MTA.red circle,\n.red, .svg-inject-CM.red path, .svg-inject-CM.red circle , .diag-svg-inject-CM.red path, .diag-svg-inject-CM.red circle\n{ \n\tcolor:#cc0022;\n\tfill:#cc0022;\n}\n/* home page */\n\n/*Parentalctl page_S*/\n#parental th[name=hour]:hover,#parental td[name=daily]:hover,\n#MacFilterTimeTable th[name=hour]:hover,#MacFilterTimeTable td[name=daily]:hover,\n#IPFilterTimeTable th[name=hour]:hover,#IPFilterTimeTable td[name=daily]:hover {\n    background-color: #0AD;\n\tcursor: pointer;\n} \n\n#parental td \n{\n\tborder: 1px solid #d3d3d3;\n\twidth : 20px;\n\theight:\t20px;\n}\n.parentaltable td\n{\n\tpadding-left: 0px;\n\tpadding-bottom: 0px;\n\tpadding-top: 0px;\n\tpadding-right: 0px;\n}\n#parental th \n{\n\tborder-right: 1px solid #d3d3d3;\n\tpadding: 0px;\n}\n.click\n{\n\tbackground-color: #0AD;\n\tcursor: not-allowed;\n}\n.exclick\n{\n\tborder: 1px solid #d3d3d3;\n\twidth : 20px;\n\theight:\t20px;\n\tpadding: 0px;\n\tbackground-color: #0AD;\n}\n#GeneralTime-slider div\n{\n\tmargin:0px;\n\tclear: none;\n}\n.applyclick\n{\n\tcursor: pointer;\n\tcolor:#00aadd;\n}\n.disable_applyclick\n{\n\tcursor: default;\n\tcolor: #d3d3d3;\n}\n.nopadding\n{\n\tpadding-left: 0px;\n\tpadding-bottom: 0px;\n\tpadding-top: 0px;\n\tpadding-right: 0px;\n\twidth:200px;\n}\n.addtime{ cursor: cell; }\n#slider-range{ height:10px; }\n.parentaltext{ color:#00aadd; padding: 0px; }\n/*Parentalctl page_E*/\n\n/*select arrow_S*/\n.select {\n  display: inline-block;\n  position: relative;\n  border: 2px solid #D3D3D3;\n  border-radius: 3px;\n}\n.select:before, .select:after {\n  content: \" \";\n  position: absolute;\n  pointer-events: none;\n}\n.select:before {\n  width: 1.5em;\n  height: 100%;\n  top: 0;\n  right: 0;\n  background-color: #FFF;\n  border-radius:2px;\n}\n.select:after {\n  border-left: 6px solid transparent;\n  border-right: 6px solid transparent;\n  border-top: 6px solid #bbb;\n  right: 0.5em;\n  top: 50%;\n  margin-top: -3px;\n}\n.select select {\n  -webkit-appearance: none;\n  -moz-appearance: none;\n  text-indent: 0.01px;\n  text-overflow: '';\n  box-shadow: none;\n  border: none;\n  outline: none;\n  background: none repeat scroll 0% 0% #FFF;\n  color: #666;\n  font-size: 18px;\n  font-family: TeleNeo-Regular;\n  padding: 3px 10px;\n  width: 320px;\n}\n.select select::-ms-expand {\n  display: none;\n}\n/*select arrow_E*/\n\n.selectArrowDisable {\n  display: inline-block;\n  position: relative;\n  border: 2px solid #D3D3D3;\n  border-radius: 3px;\n}\n.selectArrowDisable:before, .selectArrowDisable:after {\n  content: \" \";\n  position: absolute;\n  pointer-events: none;\n}\n.selectArrowDisable:before {\n  width: 1.5em;\n  height: 100%;\n  top: 0;\n  right: 0;\n  background-color: #f1f1f1;\n}\n.selectArrowDisable:after {\n  border-left: 6px solid transparent;\n  border-right: 6px solid transparen