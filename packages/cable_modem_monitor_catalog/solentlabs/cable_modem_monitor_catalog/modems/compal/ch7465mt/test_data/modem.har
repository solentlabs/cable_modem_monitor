          "content": {
            "size": 4783,
            "mimeType": "text/html",
            "compression": 0,
            "text": "<!DOCTYPE html>\n<html>\n<head>\n<title>Mercury EMTA style guide</title>\n<meta http-equiv=\"content-type\" content=\"text/html;charset=ISO-8859-1\">\n<META HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-cache\">\n<script src=\"../js/checkpath.js?v=20250108144525\"></script>\n</head>\n<body>\n<div class=\"content-container contentSpace\">\n\t<div class=\"page-title dynamic\" id=\"c_mu04\">\n\t\tModem mode\n\t</div>\n\t\n\t\t<div id=\"main_page\">\n\t\t\n\t\t<div class=\"ShowSuccessOrError\" id=\"ShowResult\">\n\t\t\t\n\t\t\t\n\t\t</div>\n\t\t\n\t\t\t<div class=\"general_text dynamic\" style=\"margin: 5px 0px;\" id=\"g_mm01\">\n\t\t\t\tModem mode disables all routing of the Mercury device, so you can connect your own wireless router to Mercury modem.\n\t\t\t</div>\n\t\t\t<div class=\"general_text\">\n\t\t\t\t<table>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td style=\"padding-right:40px\">\n\t\t\t\t\t\t\t<div class=\"\" style =\"display:inline;margin: 10px 0px;\">\n\t\t\t\t\t\t\t\t<span class=\"checkbox\"><img src=\"../images/common_imgs/radio-box-default.png\" id='icbOptNATOff' onclick=RadioOption('icbOptNATOff','cbOptNAT') name = \"cbOptNAT\" class=\"radioImg\"></span> \n\t\t\t\t\t\t\t\t<input  type=\"radio\" name=\"cbOptNAT\" value=2 id=\"cbOptNATOff\" style=\"display:none\";>\n\t\t\t\t\t\t\t\t<label>\n\t\t\t\t\t\t\t\t\t<span class=\"dynamic\" id=\"g_mm02\"></span>\n\t\t\t\t\t\t\t\t</label>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t<div class=\"\" style =\"display:inline;margin: 10px 0px;\">\n\t\t\t\t\t\t\t\t<span class=\"checkbox\"><img src=\"../images/common_imgs/radio-box-default.png\" id='icbOptNATOn' onclick=RadioOption('icbOptNATOn','cbOptNAT') name = \"cbOptNAT\" class=\"radioImg\"></span> \n\t\t\t\t\t\t\t\t<input  type=\"radio\" name=\"cbOptNAT\" value=1 id=\"cbOptNATOn\" style=\"display:none\";>\n\t\t\t\t\t\t\t\t<label>\n\t\t\t\t\t\t\t\t\t<span class=\"dynamic\" id=\"g_mm03\"></span>\n\t\t\t\t\t\t\t\t</label>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t\t<!-- CBN_S - 20181121 - Rex - Implement CR132 -->\n\t\t\t\t\t\t<td><img src=\"images/common_imgs/info-icon.svg\" class=\"infobubblePosition\" id=\"ModemModeMessage\" name=\"info1\" onmouseover=\"\" onmouseout=\"InfoCircleOption('ModemModeMessage','','7');\"></td>\n\t\t\t\t\t\t<!-- CBN_E - 20181121 - Rex - Implement CR132 -->\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t<table class=\"buttonTable\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td >\n\t\t\t\t\t\t\t<div class=\"buttonLine\" style=\"margin-top:40px;\"></div>\n\t\t\t\t\t\t</td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td align=\"right\">\n\t\t\t\t\t\t\t<a class=\"button_main dynamic\" onmouseover=\"$(this).addClass('button_main_hover');\" onmouseout=\"$(this).removeClass('button_main_hover');\" id=\"c_02\" onclick=\"javascript:SetModemMode();\">Apply changes</a>\n\t\t\t\t\t\t<td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\t\n\t\t\t\t<br>\n\t\t\t</div>\n\t\t</div>\n\t<!-- CBN_S - 20181121 - Rex - Implement CR132 for VIRGINMEDIA -->\n\t<div id=\"ModemModeInfo\" style=\"display:none\">\n\t\t<table class=\"contentFont\" align=\"center\">\n\t\t\t<tbody>\n\t\t\t\t<tr>\n\t\t\t\t\t<td align=\"center\">\n\t\t\t\t\t\t<span class=\"section_title dynamic\" id=\"c_fi31\"></span>\n\t\t\t\t\t\t<br class=\"bropen\">\n\t\t\t\t\t\t<br class=\"bropen\">\n\t\t\t\t\t\t<span class=\"section_title dynamic\" id=\"bi_10\"></span>\n\t\t\t\t\t</td>\n\t\t\t\t</tr>\n\t\t\t</tbody>\n\t\t</table>\n\t</div>\n\t<!-- CBN_E - 20181121 - Rex - Implement CR132 for VIRGINMEDIA -->\n\t<div id = \"wait-massage\"></div>\n\t<br><br>\n</div>\n\n<script language=\"javascript\" id=\"mainScript\">\nvar o_data = {};\nvar change;\n$( document ).ready(function() {\n\t/* CBN_S - 20181121 - Rex - Implement CR132 */\n\tBubbleSMWIstring='bi_10';\n\t$('#ModemModeMessage').attr(\"onmouseover\",\"InfoCircleOption('ModemModeMessage',BubbleSMWIstring,'7');\");\n\t/* CBN_E - 20181121 - Rex - Implement CR132 */\n\tajaxGet({'fun':107},\"\",getNAPT_mode);\n\tNoticeStrart(\"c_mu04\",\"SetModemMode()\");\n\tchange = false;\n});\t\n\nfunction getNAPT_mode(xmlResponse, node)\n{\t\n\to_data.NAT = $(xmlResponse).find('NAPT_mode').text();\n\tswitch(o_data.NAT){\n\t\tcase '1':\n\t\t\tRadioOption('icbOptNATOn','cbOptNAT');\t\t\t\n\t\t\tbreak;\n\t\tcase '2':\n\t\t\tRadioOption('icbOptNATOff','cbOptNAT');\t\t\t\n\t\t\tbreak;\n\t\tdefault:\t\t\t\n\t\t\tRadioOption('icbOptNATOff','cbOptNAT');\n\t\t\t\n\t\t}\t\n\tupdateContent();\n\tGetXmlResponseDone = true;\n}\n\nfunction setWanSetting()\n{\n\tvar data;\n\tvar NAT = $('input[name=cbOptNAT]:checked').val();\t\n\t\n\tdata = {'fun':108,'NAT':NAT};\t\n\t$(\".section_header\").hide();\n\t$(\"div[id=main_page]\").hide();\n\t$(\"br\").hide();\n\t/* CBN_S - 20181121 - Rex - Implement CR132 for VIRGINMEDIA */\n\tif(o_data.NAT == '1' && _OperatorId == \"VIRGINMEDIA\")\n\t{\n\t\t$(\"#ModemModeInfo\").show();\n\t\t$(\".bropen\").show();\n\t}\n\t/* CBN_E - 20181121 - Rex - Implement CR132 for VIRGINMEDIA */\n\twaitTimeScreen(\"../common_page/Modem.html\",150,\"c_43\",\"wait-massage\",updatesuccess);\n\tajaxGet({'fun':1},\"\",function(xmlResponse, node)\n\t{\n\t\tif($(xmlResponse).find('operStatus').text() != 1)\n\t\t{\n\t\t\tdoLogout();\n\t\t}else\n\t\t{\n\t\t\tajaxSetNoTokenUpdate(data);\n\t\t}\n\t});\n}\n\nfunction SetModemMode()\n{\n\ttimeoutCheck(updateerror);\n}\n\nfunction checkIsChange()\n{\n\tchange = false;\n\tif(o_data.NAT != $('input[name=cbOptNAT]:checked').val())\n\t\tchange = true;\n\treturn change;\n}\n</script>\n</body>\n</html>\n"
