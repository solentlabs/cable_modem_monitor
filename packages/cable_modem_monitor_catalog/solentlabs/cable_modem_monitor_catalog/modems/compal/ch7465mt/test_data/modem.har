            "text": "<!DOCTYPE html>\n<html>\n<head>\n<title>Mercury EMTA style guide</title>\n<meta http-equiv=\"content-type\" content=\"text/html;charset=ISO-8859-1\">\n<META HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-cache\">\n<script src=\"../js/checkpath.js?v=20250108144525\"></script>\n</head>\n<body>\n<div class=\"content-container contentSpace\" >\n\t<div class=\"page-title dynamic\" id=\"c_mu29\">\n\t\tInfo\t\t\n\t</div>\n\t<div class=\"section_header dynamic\" id=\"c_if00\">Mercury device information</div>\n\t<div id=\"main_page\">\n\t<div class=\"general_text dynamic\" style=\"margin: 5px 0px;\" id=\"c_if01\">The information below shows current status of this Mercury modem.</div>\n\t<div class=\"general_text\">\n\t<table border=0 cellpadding=5>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if02\">Standard specification compliant</td>\t\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"docsis_mode\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if03\">Hardware version</td>\t\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"hw_ver\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if04\">Software version</td>\t\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"sw_ver\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if05\">Cable modem MAC address</td>\t\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"mac_addr\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if07\">Cable modem serial number</td>\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"serial_num\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if08\">System up time</td>\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td ><b id=\"sys_uptime\"></b></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"dynamic\" id=\"c_if09\">Network access</td>\n\t\t\t<td>:</td>\t\t\t\n\t\t\t<td><b id=\"nw_access\"></b></td>\n\t\t</tr>\n\t</table>\n\t</div>\n\t</div>\n\t<br>\n\t<div class=\"section_header dynamic ModemMode\" id=\"c_cd01\">WAN IP settings</div>\n\t<div id=\"main_page\" class=\"ModemMode\">\n\t<div class=\"general_text dynamic\" style=\"margin: 5px 0px;\" id=\"c_cd02\">\n\t\tThe current settings of Mercury modem interface are displayed below.\n\t</div>\n\t\t<div class=\"general_text\">\t\t\t\t\n\t\t\t<table border=0 cellpadding=5 cellpadding=5 >\n\t\t\t\t<tbody>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\" dynamic\" id=\"c_14\">MAC address</td>\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"WanMAC\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr><td colspan=\"3\">&nbsp;</td></tr>\n\t\t\t\t</tbody>\n\t\t\t\t<tbody id=\"wan-status-v6\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_19\">IPv6 address</td>\t\n\t\t\t\t\t\t<td>:</td>\n\t\t\t\t\t\t<td><b id=\"WanIPv6\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_20\">IPv6 default gateway</td>\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"wan_ip6_def_gateway\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_21\">IPv6 lease time</td>\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"v6LeaseTime\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_22\">IPv6 lease expire</td>\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"v6LeaseExpire\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_23\">IPv6 DNS servers</td>\t\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"WanDNSv6\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr><td colspan=\"3\">&nbsp;</td></tr>\n\t\t\t\t</tbody>\n\t\t\t\t<tbody id=\"wan-status-v4\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_24\">IPv4 address</td>\t\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td ><b id=\"WanIPv4\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_25\">Default gateway</td>\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td><b id=\"def_gateway\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_26\">IPv4 lease time</td>\t\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td><b id=\"LeaseTime\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_27\">IPv4 lease expire</td>\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td><b id=\"LeaseExpire\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_28\">IPv4 DNS servers</td>\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td><b id=\"WanDNSv4\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr><td colspan=\"3\">&nbsp;</td></tr>\n\t\t\t\t</tbody>\t\n\t\t\t\t<tbody id=\"ipv6-ds-lite_conf-table\">\n\t\t\t\t\t<tr class=\"ipv6-ds-lite_status\">\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_29\">IPv6 DS-Lite status</td>\t\n\t\t\t\t\t\t<td>:</td>\t\t\t\t\t\t\n\t\t\t\t\t\t<td><b id=\"ds_lite_status\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"ipv6-ds-lite_addr\">\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_30\">DS-Lite-FQDN</td>\n\t\t\t\t\t\t<td>:</td>\n\t\t\t\t\t\t<td><b id=\"ds_lite_fqdn\"></b></td>\n\t\t\t\t\t</tr>\n\t\t\t\t\t<tr class=\"ipv6-ds-lite_addr\">\n\t\t\t\t\t\t<td class=\"dynamic\" id=\"c_31\">DS-Lite-address</td>\n\t\t\t\t\t\t<td>:</td>\n\t\t\t\t\t\t<td><b id=\"aftr_server_addr\"></b></td>\n\t\t\t\t\t</tr> \n\t\t\t\t</tbody>\n\t\t\t</table>\n\t\t</div>\n\t</div>\n\t<br>\n</div>\n<script language=\"javascript\" id=\"mainScript\">\n\tvar checkIsChange = function() { return false; };\n\t$( document ).ready(function() {\n\n\t\tajaxGet({'fun':2},\"\",getCmSystemInformation);\n\t\tajaxGet({'fun':107},\"\",getCmgwBasicWan);\n\t\t$('#wan-status-v6 , #wan-status-v4 , #ipv6-ds-lite_conf-table , .ModemMode').hide();\n\t\tupdateContent();\n\t});\n\n\tfunction getCmSystemInformation(xmlResponse, pNode) {\n\t\tvar protoMap = { 'Allowed': 'c_66', 'Not allowed': 'c_67'};\n\t\tvar docsis_mode_val = $(xmlResponse).find('cm_docsis_mode').text();\n\t\tvar hw_ver_val = $(xmlResponse).find('cm_hardware_version').text();\n\t\tvar mac_addr_val = $(xmlResponse).find('cm_mac_addr').text();\n\t\tvar serial_num_val = $(xmlResponse).find('cm_serial_number').text();\n\t\tvar sys_uptime_val = $(xmlResponse).find('cm_system_uptime').text();\n\t\tvar nw_access_val = $(xmlResponse).find('cm_network_access').text();\n\t\t\n\t\t$('#docsis_mode').html(docsis_mode_val);\n\t\t$('#hw_ver').html(hw_ver_val);\n\t\t$('#sw_ver').html(_SwVersion);\n\t\t$('#mac_addr').html(mac_addr_val);\n\t\t$('#serial_num').html(serial_num_val);\n\t\t$('#sys_uptime').html(sys_uptime_val);\n\t\t$('#nw_access').html(\"<span class='dynamic' id='\" +protoMap[nw_access_val]+\"'></span>\");\t\t\n\t}\n\t\n\tfunction getCmgwBasicWan(xmlResponse, node)\n\t{\n\t\tvar none_str = \"<span id='c_st42' class='dynamic'></span>\";\n\t\tvar time_array = new Array();\n\t\tvar LeaseTime = $(xmlResponse).find('LeaseTime').text();\n\t\t\n\t\tif(LeaseTime==\"\"||LeaseTime==\"None\")\n\t\t\tLeaseTime = none_str;\n\t\t\n\t\tvar LeaseExpire = $(xmlResponse).find('LeaseExpire').text();\n\t\ttime_array\t=LeaseExpire.split(\" \");\n\t\tif(LeaseExpire==\"\"||LeaseTime==\"None\"||time_array[5]==\"1970\")\n\t\t\tLeaseExpire = none_str;\n\t\t\n\t\tvar ipv6_LeaseTime = $(xmlResponse).find('ipv6_LeaseTime').text();\n\t\ttime_array = ipv6_LeaseTime.split(\" \");\n\t\tif(ipv6_LeaseTime==\"\"||LeaseTime==\"None\"||time_array[5]==\"1970\")\n\t\t\tipv6_LeaseTime = none_str;\n\t\t\t\n\t\tvar ipv6_LeaseExpire = $(xmlResponse).find('ipv6_LeaseExpire').text();\n\t\tif(ipv6_LeaseExpire==\"\"||LeaseTime==\"None\")\n\t\t\tipv6_LeaseExpire = none_str;\n\t\t\t\n\t\tvar WanIPv4 = $(xmlResponse).find('WanIP').text();\n\t\tif(WanIPv4==\"\")\n\t\t{\n\t\t\tWanIPv4 = none_str;\n\t\t\tLeaseTime = none_str;\n\t\t\tLeaseExpire = none_str;\n\t\t}\n\t\t\n\t\tvar WanIPv6 = $(xmlResponse).find('wan_ipv6_addr').find('wan_ipv6_addr_entry');\n\t\tvar wan_ip6_def_gateway = $(xmlResponse).find('WanDhcpv6Srv').text();\n\t\tvar WanMAC = $(xmlResponse).find('WanMAC').text();\n\t\tvar WanDNSIPv4 = $(xmlResponse).find('wan_ipv4_dnsaddr').find('wan_ipv4_dnsaddr_entry');\n\t\tvar WanDNSIPv6 = $(xmlResponse).find('wan_ipv6_dnsaddr').find('wan_ipv6_dnsaddr_entry');\n\t\tvar listWanIPv6 = \"\";\n\t\tvar listWanDNSIPv4 = \"\";\n\t\tvar listWanDNSIPv6 = \"\";\n\t\tvar ds_lite_status =$(xmlResponse).find('dslite_enable').text();\n\t\t\n\t\tWanIPv6.each(function(){\n\t\t\tlistWanIPv6 += $(this).text()+\"<br />\";\n\t\t});\n\t\tWanDNSIPv4.each(function(){\n\t\t\tlistWanDNSIPv4 += $(this).text()+\"&emsp;\";\n\t\t});\n\t\tWanDNSIPv6.each(function(){\n\t\t\tlistWanDNSIPv6 += $(this).text()+\"<br />\";\n\t\t});\n\t\t$('#WanIPv6').html(listWanIPv6);\n\t\tif($('#WanIPv6').html()==\"\")\n\t\t{\n\t\t\t$('#WanIPv6').html(none_str);\n\t\t\tipv6_LeaseTime = none_str;\n\t\t\tipv6_LeaseExpire = none_str;\n\t\t}\t\n\t\t$('#WanDNSv6').html(listWanDNSIPv6);\n\t\tif($('#WanDNSv6').html()==\"\")\n\t\t\t$('#WanDNSv6').html(none_str);\n\t\t\t\n\t\t$('#v6LeaseTime').html(ipv6_LeaseTime);\n\t\t$('#v6LeaseExpire').html(ipv6_LeaseExpire);\n\t\t$('#wan_ip6_def_gateway').html(wan_ip6_def_gateway);\n\t\t$('#WanIPv4').html(WanIPv4);\n\t\t\n\t\t$('#WanDNSv4').html(listWanDNSIPv4);\n\t\tif($('#WanDNSv4').html()==\"\")\n\t\t\t$('#WanDNSv4').html(none_str);\n\t\t\t\n\t\t$('#LeaseTime').html(LeaseTime);\n\t\t$('#LeaseExpire').html(LeaseExpire);\n\t\t$('#def_gateway').html($(xmlResponse).find('gateway_address').text());\t\t\n\t\t$('#WanMAC').html(WanMAC);\n\t\t$('#ds_lite_fqdn').html($(xmlResponse).find('dslite_fqdn').text());\n\t\t$('#aftr_server_addr').html($(xmlResponse).find('dslite_addr').text());\t\t\n\t\t\n\t\tif(ds_lite_status == \"1\")\n\t\t{\n\t\t\t$('#ds_lite_status').html(\"<span id='c_00' class='dynamic' style='top: 0px;'></span>\");\n\t\t\t$('.ipv6-ds-lite_status,.ipv6-ds-lite_addr').show();\n\t\t}\n\t\telse if(ds_lite_status == \"0\")\n\t\t{\n\t\t\t$('#ds_lite_status').html(\"<span id='c_01' class='dynamic' style='top: 0px;'></span>\");\n\t\t\t$('.ipv6-ds-lite_status').show();\n\t\t\t$('.ipv6-ds-lite_addr').hide();\n\t\t}\t\t\n\n\t\t$('#wan-status-v4,#wan-status-v6,#ipv6-ds-lite_conf-table').hide();\n\t\tif($(xmlResponse).find('NAPT_mode').text()==\"1\")\n\t\t{\n\t\t\tif(_GwProvisionMode==\"IPv6\")\n\t\t\t{\n\t\t\t\t$('#wan-status-v6').show();\n\t\t\t\tif(ds_lite_status == \"1\")\n\t\t\t\t\t$('#ipv6-ds-lite_conf-table').show();\n\t\t\t}\n\t\t\telse if(_GwProvisionMode==\"IPv4\")\n\t\t\t\t$('#wan-status-v4').show();\n\t\t\telse if(_GwProvisionMode==\"IPv4/IPv6\")\n\t\t\t\t$('#wan-status-v6,#wan-status-v4').show();\n\t\t\t$('.ModemMode').show();\n\t\t}else if($(xmlResponse).find('NAPT_mode').text() == \"2\")\n\t\t{\n\t\t\t$('.ModemMode').remove();\n\t\t}\n\t\tupdateContent();\n\t}\n</script>\n</body>\n</html>\n"
