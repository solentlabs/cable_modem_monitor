            "text": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title></title>\n<style type=\"text/css\">\ndiv.clearnone {\n\tclear:none;\n\tmargin: 0px 0px;\n}\n.quickWizard {width:105%;}\n.clientinfo\n{\n\tfloat: left; \n\tpadding:0px 15px 0px 15px !important; \n\tmargin:0px 0px 10px 0px !important\n}\n</style>\n</head>\n<body>\n<div class=\"content-container\">\n\t<div class=\"page-title dynamic\" style=\"margin-bottom: 0px;padding-bottom: 0px;\" id=\"c_45\"></div>\n\t\n\t<div id=\"home_main_page\" style=\"margin: 0px 0px; display:none;\">\n\t<div class=\"section_header ModemMode dynamic\" id=\"c_hp00\"></div>\n\t\n\t<!------------------------------------------Use our quick wizards-------------------------------------------------->  \n\t<div class=\"quickWizard ModemMode\">\n\t\t<a href=\"javascript:void(0)\"><div class=\"button_containers clearnone wificontent css_td\"  onclick=\"goto('common_page/WiFiConfigWizard.html','wificontent'); window.clearInterval(timerId);\"><img src=\"images/wifi_imgs/wifi-icon.svg\" class=\"svg-inject darkblue\"><br><span id=\"c_hp01\" class=\"dynamic\"></span></div></a>\n\t\t<a href=\"javascript:void(0)\"><div class=\"button_containers clearnone TDWcontent css_td\"  onclick=\"goto('common_page/DiagnosticsWizard.html','TDWcontent');\"><img src=\"images/common_imgs/Diagnostic-icon.svg\" class=\"svg-inject darkblue\"><br><span id=\"c_hp02\" class=\"dynamic\"></span></div></a>\n\t\t<a href=\"javascript:void(0)\"><div class=\"button_containers clearnone guestcontent css_td\"  onclick=\"goto('common_page/GuestWizard.html','guestcontent'); window.clearInterval(timerId);\"><img src=\"images/wifi_imgs/GuestNetwork.svg\" class=\"svg-inject darkblue\"><br><span id=\"c_hp03\" class=\"dynamic\"></span></div></a>\n\t</div>\n\t<div class=\"spacer ModemMode\" style=\"margin: 0px 0px;\"></div>\n\t<div class=\"section_header dynamic\" style=\"margin: 0px 0px; padding: 35px 0px 25px !important;\" id=\"c_hp04\"></div>\n\t<div class=\"boxed_content\" style=\"margin: 0px 0px;\">\n\n\t<table class=\"modemstatus\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\n\t\t\t<tr>\n\t\t\t\t<td class=\"section_title dynamic hp_title\" colspan=\"3\" id=\"c_hp05\"></td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td rowspan=\"4\"><img src=\"images/common_imgs/modem.svg\" style=\"height: 85px!important;  width:85px; position: relative;top:-5px;\"></td>\n\t\t\t\t<td style=\"padding: 0px 10px 0px 0px;\">\n\t\t\t\t\t<img src=\"images/wifi_imgs/wifi-icon.svg\" class=\"svg-inject-P2 green\" id=\"wifiicon\">\n\t\t\t\t</td>\n\t\t\t\t<td style=\"text-align:left;\">\n\t\t\t\t\t<span class=\"dynamic\" id=\"c_mu06\"></span> <span>(</span><span id=\"wifistatus\" class=\"green\" style=\"white-space:nowrap; position: relative;\">loading</span><span>)</span>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 0px 10px 0px 0px;\">\n\t\t\t\t\t<img src=\"images/common_imgs/Internet.svg\" class=\"svg-inject-CM green\" id=\"cmicon\">\n\t\t\t\t</td>\n\t\t\t\t<td style=\"text-align:left;\">\n\t\t\t\t\t<span class=\"dynamic\" id=\"c_47\"></span> <span>(</span><span id=\"cmstatus\" name=\"cmstatus\" class=\"green\" style=\"white-space:nowrap; position: relative;\">loading</span><span>)</span>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t<tr>\n\t\t\t\t<td style=\"padding: 0px 10px 0px 0px;\">\n\t\t\t\t\t<img src=\"images/common_imgs/Telephony.svg\" class=\"svg-inject-MTA green\" id=\"mtaicon\">\n\t\t\t\t</td>\n\t\t\t\t<td style=\"text-align:left;\">\n\t\t\t\t\t<span class=\"dynamic\" id=\"c_48\"></span> <span>(</span><span id=\"mtastatus_line1\" class=\"green\" style=\"white-space:nowrap; position: relative;\">loading</span><span>)</span><br>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t</table>\n\t<div class=\"spacer ModemMode\" style=\"margin: 0px 0px;\"></div>\n\t\t\t<!------------------------------------WIFI client------------------------------------------> \n\t\t\t<div class=\"section_title ModemMode\" id=\"wifi-client-div\"><span id=\"c_hp06\" class=\"dynamic\"></span>&nbsp;<label id=\"wifinum\"></label></div>\n\t\t\t<table class=\"connected-devices\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\" id=\"wifi-client-tr-img\"></table>\n\t\t\t<div id=\"wifiSpacer\" class=\"spacer ModemMode\" style=\"margin: 0px 0px;\" ></div>\n\t\t\t<!------------------------------------Ethernet client------------------------------------------>\n\t\t\t<div class=\"section_title ModemMode\"><span id=\"c_hp07\" class=\"dynamic\"></span>&nbsp;<label id=\"ethnum\"></label></div>\n\t\t\t<table class=\"connected-devices\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\" id=\"eth-client-tr-img\" ></table>\t\t\t\n\t\t</div><!--end boxed_content-->\t\n\t\t<div class=\"spacer\" style=\"margin: 0px 0px;\"></div>\n\t</div> <!--end main page-->\n\t<div id = \"wait-massage\"></div>\t\n</div>\n\n<script language=\"javascript\" src=\"../js/checkpath.js?v=20250108144525\"></script>\n<script language=\"javascript\" id=\"mainScript\">\n\tvar key1=0;\n\tvar key2=0;\n\tvar key3=1;\n\tvar HomeInfo = {'EthNum':0, 'EthCspan': 0, 'WifiNum':0, 'WifiCspan': 0};\n\tvar interval=self.setInterval(\"clock()\",500);\n\tvar Device_index = 0;\n\tvar Device_connect;\n\tvar CustomerMac;\n\tfunction clock()\n\t{   \n\t\tif(key1&&key2&&key3){\n\t\t\t\t$(\"#home_main_page\").show();\n\t\t\t\twindow.clearInterval(interval);\n\t\t}\n\t}\n\t\n\t$(document).ready(function(){\n\t\tif(_GWOperMode == \"Disable\")\n\t\t{\n\t\t\t$(\".wificontent img,.guestcontent img\").removeClass(\"darkblue\");\n\t\t\t$(\".wificontent,.guestcontent\").prop(\"onclick\",\"\");\n\t\t\t$(\".ModemMode\").remove();\n\t\t}\n\t\tif(_OperatorId == \"MTAT\")\n\t\t{\n\t\t    $(\".wificontent img,.guestcontent img,.TDWcontent img\").removeClass(\"darkblue\").addClass(\"magenta\");\n\t\t}\n\t\t$(\"#home_main_page\").hide();\n\t\tajaxGet({'fun':315},\"\",getXmlHomepageInfo);\n\t\tajaxGet({'fun':500},\"\",getMtaStatus);\n\t\t\n\t\t$('.svg-inject').svgInject();\n\t\t\n\t\tajaxGet({'fun':323},\"\",getXmlWirelessWPSstatus);\n\t\t\t\n\t\tsetTimeout(function(){\n\t\t\tajaxGet({'fun':123},\"\",getLanUserInfo);\n\t\t}, 1000);\n\t\tNoticeStrart(\"w_sec12\",\"CheckDeviceName()\");\n\t\tupdateContent();\n\t});\n\tvar WpsCurrentStatus;\t\n\tvar BssEnable2g,BssEnable5g;\n\t\n\t/*----------------------20141127 get wificlient info----------------------------\n\tvar client2gNum=0,client5gNum=0;\n\tvar SSIDArray2G,MacArray2G;\n\n\tfunction getClientInfo(xmlResponse){\n\t\tconsole.log(xmlResponse);\n\t\tvar client2g = $(xmlResponse).find('Client2G');\n\t\tvar client5g = $(xmlResponse).find('Client5G');\n\t\t\n\t\tclient2g.find('clientinfo').each(function(index){\n\t\t\t\tclient2gNum++;\n\t\t});\n\t\t\n\t\tMacArray2G = new Array(client2gNum);\n\t\tSSIDArray2G = new Array(client2gNum);\n\t\t\n\t\tclient2g.find('clientinfo').each(function(index){\n\t\t\t\tSSIDArray2G[index]=$(this).find(\"SSID\").text();\n\t\t\t\tMacArray2G[index]=$(this).find(\"MAC\").text();\n\t\t});\n\n\t\t//for (i = 0 ; i < client2gNum ; i++) {}\n\t}*/\n\t\n\t//-------MTA status----------\n\tvar MTAArray = new Array(2);\n\t\n\tfunction getMtaStatus(xmlResponse){\n\n\t\t\t$(xmlResponse).find('Line').each(function(index){\n\n\t\t\t\tMTAArray[index] = $(this).find(\"mtastatus\").text();\t\n\n\t\t\t});\n\n\t\t\t//$('#mtastatus_line1').html(MTAArray[0]+\" -tel1\");\n\t\t\t//$('#mtastatus_line2').html(MTAArray[1]+\" -tel2\");\n\t\t\t\n\t\t\t//check mta status\n\t\t\t//todo: CALL status\n\t\t\tvar MTALine = \"\";\n\t\t\tvar Lang_ID = \"\";\n\n\t\t\tif(MTAArray[0]==\"ready\"){\n\t\t\t\t\n\t\t\t\tswitch(MTAArray[1]){\n\t\t\t\t\t\n\t\t\t\t\tcase 'ready':\n\t\t\t\t\t\tLang_ID = \"c_st02\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"green\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA green  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'Disabled':\n\t\t\t\t\t\tLang_ID = \"c_st02\";\n\t\t\t\t\t\tMTALine = \" TEL1\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"green\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA green  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'error':\n\t\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t\tMTALine = \" TEL2\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'not ready':/* CBN - 20180927 - Rex - Fix CH7465LG-400 */\n\t\t\t\t\t\tLang_ID = \"c_st02\";\n\t\t\t\t\t\tMTALine = \" TEL1\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"green\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA green  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t\t$('.svg-inject-MTA').svgInject();\n\t\t\t\t\n\t\t\t}else if(MTAArray[0]==\"not ready\"){\n\t\t\t\t//not ready\n\t\t\t\tswitch(MTAArray[1]){\n\t\t\t\t\t\n\t\t\t\t\tcase 'not ready':\n\t\t\t\t\tcase 'Disabled':\n\t\t\t\t\t\tLang_ID = \"c_st03\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'error':\n\t\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t\tMTALine = \" TEL2\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'ready':/* CBN - 20180927 - Rex - Fix CH7465LG-400 */\n\t\t\t\t\t\tLang_ID = \"c_st02\";\n\t\t\t\t\t\tMTALine = \" TEL2\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"green\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA green  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t\t$('.svg-inject-MTA').svgInject();\n\n\t\t\t}else if(MTAArray[0]==\"Disabled\"){\n\t\t\t\t\n\t\t\t\tswitch(MTAArray[1]){\n\t\t\t\t\t\n\t\t\t\t\tcase 'ready':\n\t\t\t\t\t\tLang_ID = \"c_st02\";\n\t\t\t\t\t\tMTALine = \" TEL2\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"green\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA green  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'not ready':\n\t\t\t\t\t\tLang_ID = \"c_st03\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'Disabled':\n\t\t\t\t\t\tLang_ID = \"c_01\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"grey\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA grey  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'error':\n\t\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t\tMTALine = \" TEL2\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t\t$('.svg-inject-MTA').svgInject(); \n\n\t\t\t}else{//error\n\t\t\t\tswitch(MTAArray[1]){\n\t\t\t\t   \n\t\t\t\t\tcase 'ready':\n\t\t\t\t\tcase 'not ready':\n\t\t\t\t\tcase 'Disabled':\n\t\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t\tMTALine = \" TEL1\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase 'error':\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t\t$('#mtastatus_line1').attr(\"class\",\"red\");\n\t\t\t\t\t\t$('#mtaicon').attr(\"class\",\"svg-inject-MTA red  replaced-svg\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t\t$('.svg-inject-MTA').svgInject();\n\n\t\t\t}\n\t\t\t$('#mtastatus_line1').html('<span id=\"'+Lang_ID+'\" class=\"dynamic\" style=\"top:0px\"></span><span style=\"top:0px\">'+MTALine+'</span>');\n\t\t\tkey1=1;\n\t\t\tupdateContent();\n\t}\n\n\tfunction getXmlHomepageInfo(xmlResponse, node){\n\t\tBandmode = $(xmlResponse).find('Bandmode').text();\n\t\tBssEnable2g = $(xmlResponse).find('BssEnable2g').text();\n\t\tBssEnable5g = $(xmlResponse).find('BssEnable5g').text();\n\t\tWiFiChipStatus = $(xmlResponse).find('WiFi_chip_status').text();\n\t\t//-------CM status----------\n\t\tvar cmStatus = $(xmlResponse).find('cm_status').text();\n\t\t\n\t\tvar DocsisStatus = {\n\t\t\t\"Unsupported_status\" :\"c_st06\",\n\t\t\t\"DS scanning\" :\"c_st07\",\n\t\t\t\"US ranging\" :\"c_st08\",\n\t\t\t\"Requesting CM IP address\" :\"c_st09\",\n\t\t\t\"Obtaining ToD\" :\"c_st10\",\n\t\t\t\"Obtaining Configuration File\" :\"c_st35\",\n\t\t\t\"Online\" :\"c_st11\",\n\t\t\t\"Registration failure\" :\"c_st12\",\n\t\t\t\"Access denied\" :\"c_st13\",\n\t\t\t\"Partial Service (DS only)\" :\"c_st14\",\n\t\t\t\"Partial Service (US only)\" :\"c_st36\",\n\t\t\t\"Partial Service (US+DS)\" :\"c_st37\",\n\t\t\t\"Network Standy Mode\" :\"c_st38\",\n\t\t\t\"Fail safe mode\" :\"c_st15\",\n\t\t\t\"Software download active\" :\"c_st16\",\n\t\t\t\"Modem Mode\" :\"c_mu04\",\n\t\t\t\"No RF signal detected\" :\"c_st17\"\n\t\t}\n\t\t$('span[name=\"cmstatus\"]').attr(\"id\",DocsisStatus[cmStatus]);\n\t\tif(cmStatus==\"Online\" || cmStatus==\"Modem Mode\"){\n\t\t\t$('span[name=\"cmstatus\"]').attr(\"class\",\"green\").addClass(\"dynamic\");\n\t\t\t$('#cmicon').attr(\"class\",\"svg-inject-CM green  replaced-svg\");\n\t\t}else{\n\t\t\t$('span[name=\"cmstatus\"]').attr(\"class\",\"red\");\n\t\t\t$('#cmicon').attr(\"class\",\"svg-inject-CM red  replaced-svg\");\n\t\t}\n\t\t$('span[name=\"cmstatus\"]').addClass(\"dynamic\");\n\t\t$('.svg-inject-CM').svgInject(); \n\n\t\tkey2=1;\n\n\t\t//-------Wifi status----------\n\t\tajaxGet({'fun':326},\"\",getWiFiStatus);\n\t}\n\n\tfunction getWiFiStatus(xmlResponse){\n\t\t//-------Wifi status----------\n\t\tvar primary24g = $(xmlResponse).find('primary24g').text()==1?true:false;\n\t\tvar primary5g = $(xmlResponse).find('primary5g').text()==1?true:false;\n\t\tvar WIFIStatus = \"Off\";\n\t\tif(WiFiChipStatus==2){\n\t\t\tif(primary24g){\n\t\t\t\tif(primary5g){\n\t\t\t\t\tWIFIStatus = \"On\";\n\t\t\t\t}else{\n\t\t\t\t\tWIFIStatus = \"2G\";\n\t\t\t\t}\n\t\t\t}else{\n\t\t\t\tif(primary5g){\n\t\t\t\t\tWIFIStatus = \"5G\";\n\t\t\t\t}\n\t\t\t}\n\t\t}else{//wifi error\n\t\t\tWIFIStatus = \"Error\";\n\t\t}\n\t\tshowWIFIStatus(WIFIStatus);\n\t\t$('.svg-inject-P2').svgInject();\n\t\tupdateContent();\n\t}\n\t\n\tfunction getXmlWirelessWPSstatus(xmlResponse, node){\n\n\t\tWpsCurrentStatus = $(xmlResponse).find('WPS_stat').text();\n\t\tif(WpsCurrentStatus==\"down\"){\n\t\t}else{\n\t\t\tshowWIFIStatus('WPSinprogress');\n\t\t}\n\t\tupdateLanUserTable();\n\t}\n\t\n\tfunction showWIFIStatus(opt){\n\t\tvar Wifi_Status = \"\";\n\t\tvar Lang_ID = \"\";\n\t\tswitch(opt){\n\t\t\tcase 'On':\n\t\t\t\t\tLang_ID = \"c_st39\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"green\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 green  replaced-svg\");\n\t\t\tbreak;\n\t\t\tcase '2G':\n\t\t\t\t\tLang_ID = \"c_st00\";\n\t\t\t\t\tWifi_Status = \" - 2.4GHz\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"green\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 green  replaced-svg\");\n\t\t\tbreak;\n\t\t\tcase '5G':\n\t\t\t\t\tLang_ID = \"c_st00\";\n\t\t\t\t\tWifi_Status = \" - 5GHz\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"green\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 green  replaced-svg\");\n\t\t\tbreak; \n\t\t\tcase 'Off':\n\t\t\t\t\tLang_ID = \"c_st01\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"grey\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 grey  replaced-svg\");\n\t\t\tbreak;\n\t\t\tcase 'WPSinprogress':\n\t\t\t\t\tLang_ID = \"c_st29\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"green\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 green  replaced-svg\");\n\t\t\tbreak;\n\t\t\tcase 'Error':\n\t\t\t\t\tLang_ID = \"c_st30\";\n\t\t\t\t\t$('#wifistatus').attr(\"class\",\"red\");\n\t\t\t\t\t$('#wifiicon').attr(\"class\",\"svg-inject-P2 red  replaced-svg\");\n\t\t\tbreak;\n\t\t}\n\t\t$('#wifistatus').html('<span id=\"'+Lang_ID+'\" class=\"dynamic\" style=\"top:0px\"></span><span style=\"top:0px\">'+Wifi_Status+'</span>');\n\t\tupdateContent();\n\t}\t\n\t\n\t//-------LanUser Func--------\t\n\t\n\tfunction getLanUserInfo(xmlResponse){\n\t\tHomeInfo = {'EthNum':0, 'EthCspan': 0, 'WifiNum':0, 'WifiCspan': 0};\n\t\t$(\"#eth-client-tr-img , #wifi-client-tr-img\").empty();\n\t\tvar ethernet = $(xmlResponse).find('Ethernet');\n\t\tvar wifi = $(xmlResponse).find('WIFI');\n\t\t\n\t\tethernet.find('clientinfo').each(function(){\n\t\t\tHomeInfo['EthNum']++;\n\t\t});\n\t\twifi.find('clientinfo').each(function(){\n\t\t\tHomeInfo['WifiNum']++;\n\t\t});\n\t\t\n\t\tfor(var client=0 ; client<2; client++)\n\t\t{\n\t\t\tvar Cspan = (client==0)?\"EthCspan\":\"WifiCspan\";\n\t\t\tvar AppendTo = (client==0)?$('#eth-client-tr-img'):$('#wifi-client-tr-img');\n\t\t\tvar ClientType = (client==0)?\"EthNum\":\"WifiNum\";\n\t\t\tif(HomeInfo[ClientType] > 0)\n\t\t\t{\n\t\t\t\tvar TrS = \"\";\n\t\t\t\tHomeInfo[Cspan] = Math.floor(parseInt(HomeInfo[ClientType])/4) +1;\n\t\t\t\tfor(var i = 0;i<HomeInfo[Cspan];i++)\n\t\t\t\t\tTrS += '<tr></tr>';\n\t\t\t\t$(TrS).appendTo(AppendTo);\n\t\t\t}\n\t\t}\n\n\t\t$('[name=\"clientinfo\"]').remove();\n\t\t\n\t\tAddLanUserClient(ethernet,\"ethernet\");\n\t\tAddLanUserClient(wifi,\"wifi\");\n\t\tkey3=1;\n\t\tGetXmlResponseDone = true;\n\t\tupdateContent();\n\t}\n\t\n\tfunction addWifiClient(HostName,WifiIndex,icontext){\n\t\t\t\n\t\t\tif(icontext == \"\")\n\t\t\t{\n\t\t\t\tvar dvIcon=\"Laptop-Icon.svg\";\n\t\t\t\tif(HostName.indexOf('android')!=-1){\n\t\t\t\t\tdvIcon=\"Mobile-icon.svg\";\n\t\t\t\t}else if(HostName.indexOf('Phone')!=-1){\n\t\t\t\t\tdvIcon=\"Mobile-icon.svg\";\n\t\t\t\t}else if(HostName.indexOf('tablet')!=-1){\n\t\t\t\t\tdvIcon=\"Tablet-icon.svg\";\n\t\t\t\t}else if(HostName.indexOf('iPad')!=-1){\n\t\t\t\t\tdvIcon=\"Tablet-icon.svg\";\n\t\t\t\t}\n\t\t\t}else\n\t\t\t{\n\t\t\t\tvar dvIcon=icontext;\n\t\t\t}\n\n\t\t\tvar entry1 = $('\\\n\t\t\t\t<td id=\"WiFiclientinfo'+WifiIndex+'\" name=\"clientinfo\" class=\"clientinfo\">\\\n\t\t\t\t<svg version=\"1.1\" id=\"Layer_2\" style=\"height:12px; width:14px;\"  x=\"0px\" y=\"0px\" viewBox=\"0 0 69.3 69.3\" style=\"enable-background:new 0 0 69.3 69.3;\" xml:space=\"preserve\">\\\n\t\t\t\t<linearGradient id=\"SVGID_1_\" gradientUnits=\"userSpaceOnUse\" x1=\"34.6512\" y1=\"69.3023\" x2=\"34.6512\" y2=\"0\">\\\n\t\t\t\t<stop offset=\"0\" style=\"stop-color:#6D676C\"/>\\\n\t\t\t\t<stop offset=\"1\" style=\"stop-color:#939598\"/>\\\n\t\t\t\t</linearGradient><circle class=\"green\" cx=\"34\" cy=\"34\" r=\"32\"/>\\\n\t\t\t\t</svg><br>\\\n\t\t\t\t<img id=\"WiFiDeviceImg'+WifiIndex+'\" src=\"images/common_imgs/'+dvIcon+'\">\\\n\t\t\t\t<br><span id=\"WiFiClientHostName'+WifiIndex+'\" class=\"general_text\" onclick=\"$(\\'#WiFiEditDeviceName'+WifiIndex+'\\').show(); displaynumber('+WifiIndex+',\\'WiFi\\'); window.clearInterval(timerId);\" style=\"font-size:16px; width:120px; display:inline-block ;word-break:break-all;\"></span>\\\n\t\t\t\t<div id=\"WiFiEditDeviceName'+WifiIndex+'\" style=\"position:relative; clear: both; margin: 6px 0px; margin-bottom: 6px; display:none;\">\\\n\t\t\t\t<input id=\"WiFiDeviceMac'+WifiIndex+'\" size=\"17\" maxlength=\"17\" type=\"hidden\">\\\n\t\t\t\t<input id=\"WiFioldDeviceIcon'+WifiIndex+'\" size=\"18\" maxlength=\"18\" type=\"hidden\">\\\n\t\t\t\t<input id=\"WiFiDeviceName'+WifiIndex+'\" type=\"text\" class=\"default devicename\" onfocus=\"$(this).addClass(\\'enabled\\'); RemoveDeviceNameErrMsg();\" onblur=\"$(this).removeClass(\\'enabled\\');\"><br>\\\n\t\t\t\t<span id=\"WiFiEditDeviceNametype\" class=\"select\" style=\"margin-left:85px;\">\\\n\t\t\t\t<select id=\"WiFiDeviceSelect'+WifiIndex+'\" style=\"width:160px\" size=\"1\" onchange=\"changeIcon('+WifiIndex+');\">\\\n\t\t\t\t\t<option value=\"0\" class=\"dynamic\" id=\"w_sec25\"></option>\\\n\t\t\t\t\t<option value=\"1\" class=\"dynamic\" id=\"w_sec26\"></option>\\\n\t\t\t\t\t<option value=\"2\" class=\"dynamic\" id=\"w_sec27\"></option>\\\n\t\t\t\t\t<option value=\"3\" class=\"dynamic\" id=\"w_sec28\"></option>\\\n\t\t\t\t\t<option value=\"4\" class=\"dynamic\" id=\"w_sec29\"></option>\\\n\t\t\t\t\t<option value=\"5\" class=\"dynamic\" id=\"w_sec30\"></option>\\\n\t\t\t\t\t<option value=\"6\" class=\"dynamic\" id=\"w_sec31\"></option>\\\n\t\t\t\t</select>\\\n\t\t\t\t</span>\\\n\t\t\t\t<input id=\"c_35\" type=\"button\" class=\"button_main dynamicValue\" style=\"margin: 0px 0px 0px 0px;\" value=\"Apply\" onclick=\"CheckDeviceName();\" onmouseover=\"$(this).addClass(\\'button_main_hover\\');\" onmouseout=\"$(this).removeClass(\\'button_main_hover\\');\">\\\n\t\t\t\t<table id=\"WiFiDeviceNameErrorMessage'+WifiIndex+'\" style=\"display:none;\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" align=\"center\"><tbody><tr><td valign=\"middle\" style=\"padding:0px 8px 0px 0px;\" class=\"error-msg-small\"><img src=\"images/common_imgs/error-icon.svg\"></td>\\\n\t\t\t\t<td valign=\"middle\" style=\"padding:0px;white-space:nowrap;\"><div class=\"dynamic error-msg-small\" id=\"wm71\" name=\"WiFiDeviceNameErrorContent'+WifiIndex+'\" style=\"margin:0\"></div></td>\\\n\t\t\t\t</tr></tbody></table>\\\n\t\t\t\t</div>\\\n\t\t\t\t</td>\\\n\t\t\t');\n\t\t\tentry1.appendTo($('#wifi-client-tr-img')).find(\"#WiFiClientHostName\"+WifiIndex+\"\").text(HostName);\n\t\t\t$('#WiFiDeviceName'+WifiIndex+'').val(HostName);\n\t\t\t$('#WiFiDeviceMac'+WifiIndex+'').val(CustomerMac);\n\t\t\t$('#WiFioldDeviceIcon'+WifiIndex+'').val(dvIcon);\n\t}\n\t\n\tfunction addEthClient(HostName,EthIndex,icontext){\n\n\t\t\tif(icontext == \"\")\n\t\t\t{\n\t\t\t\tvar dvIcon=\"Unknown-device.svg\";\n\t\t\t\tif(HostName.indexOf('mac')!=-1){\n\t\t\t\t\tdvIcon=\"Laptop-Icon.svg\";\n\t\t\t\t}else if(HostName.indexOf('Mac')!=-1){\n\t\t\t\t\tdvIcon=\"Laptop-Icon.svg\";\n\t\t\t\t}\n\t\t\t}else\n\t\t\t{\n\t\t\t\tvar dvIcon=icontext;\n\t\t\t}\n\n\t\t\tvar entry1 = $('\\\n\t\t\t\t<td id=\"Ethclientinfo'+EthIndex+'\" name=\"clientinfo\" class=\"clientinfo\">\\\n\t\t\t\t<svg version=\"1.1\" id=\"Layer_2\" style=\"height:12px; width:14px;\"  x=\"0px\" y=\"0px\" viewBox=\"0 0 69.3 69.3\" style=\"enable-background:new 0 0 69.3 69.3;\" xml:space=\"preserve\">\\\n\t\t\t\t<linearGradient id=\"SVGID_1_\" gradientUnits=\"userSpaceOnUse\" x1=\"34.6512\" y1=\"69.3023\" x2=\"34.6512\" y2=\"0\">\\\n\t\t\t\t<stop offset=\"0\" style=\"stop-color:#6D676C\"/>\\\n\t\t\t\t<stop offset=\"1\" style=\"stop-color:#939598\"/>\\\n\t\t\t\t</linearGradient><circle class=\"green\" cx=\"34\" cy=\"34\" r=\"32\"/>\\\n\t\t\t\t</svg><br>\\\n\t\t\t\t<img id=\"EthDeviceImg'+EthIndex+'\" src=\"images/common_imgs/'+dvIcon+'\">\\\n\t\t\t\t<br><span id=\"EthClientHostName'+EthIndex+'\" class=\"general_text\" onclick=\"$(\\'#EthEditDeviceName'+EthIndex+'\\').show(); displaynumber('+EthIndex+',\\'Eth\\'); window.clearInterval(timerId);\" style=\"font-size:16px; width:120px; display:inline-block ;word-break:break-all;\"></span>\\\n\t\t\t\t<div id=\"EthEditDeviceName'+EthIndex+'\" style=\"position:relative; clear: both; margin: 6px 0px; margin-bottom: 6px; display:none;\">\\\n\t\t\t\t<input id=\"EthDeviceMac'+EthIndex+'\" size=\"17\" maxlength=\"17\" type=\"hidden\">\\\n\t\t\t\t<input id=\"EtholdDeviceIcon'+EthIndex+'\" size=\"18\" maxlength=\"18\" type=\"hidden\">\\\n\t\t\t\t<input id=\"EthDeviceName'+EthIndex+'\" type=\"text\" class=\"default devicename\" onfocus=\"$(this).addClass(\\'enabled\\'); RemoveDeviceNameErrMsg();\" onblur=\"$(this).removeClass(\\'enabled\\');\"><br>\\\n\t\t\t\t<span id=\"EthEditDeviceNametype\" class=\"select\" style=\"margin-left:85px;\">\\\n\t\t\t\t<select id=\"EthDeviceSelect'+EthIndex+'\" style=\"width:160px\" size=\"1\" onchange=\"changeIcon('+EthIndex+');\">\\\n\t\t\t\t\t<option value=\"0\" class=\"dynamic\" id=\"w_sec25\"></option>\\\n\t\t\t\t\t<option value=\"1\" class=\"dynamic\" id=\"w_sec26\"></option>\\\n\t\t\t\t\t<option value=\"2\" class=\"dynamic\" id=\"w_sec27\"></option>\\\n\t\t\t\t\t<option value=\"3\" class=\"dynamic\" id=\"w_sec28\"></option>\\\n\t\t\t\t\t<option value=\"4\" class=\"dynamic\" id=\"w_sec29\"></option>\\\n\t\t\t\t\t<option value=\"5\" class=\"dynamic\" id=\"w_sec30\"></option>\\\n\t\t\t\t\t<option value=\"6\" class=\"dynamic\" id=\"w_sec31\"></option>\\\n\t\t\t\t</select>\\\n\t\t\t\t</span>\\\n\t\t\t\t<input id=\"c_35\" type=\"button\" class=\"button_main dynamicValue\" style=\"margin: 0px 0px 0px 0px;\" value=\"Apply\" onclick=\"CheckDeviceName();\" onmouseover=\"$(this).addClass(\\'button_main_hover\\');\" onmouseout=\"$(this).removeClass(\\'button_main_hover\\');\">\\\n\t\t\t\t<table id=\"EthDeviceNameErrorMessage'+EthIndex+'\" style=\"display:none;\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" align=\"center\"><tbody><tr><td valign=\"middle\" style=\"padding:0px 8px 0px 0px;\" class=\"error-msg-small\"><img src=\"images/common_imgs/error-icon.svg\"></td>\\\n\t\t\t\t<td valign=\"middle\" style=\"padding:0px;white-space:nowrap;\"><div class=\"dynamic error-msg-small\" id=\"wm71\" name=\"EthDeviceNameErrorContent'+EthIndex+'\" style=\"margin:0\"></div></td>\\\n\t\t\t\t</tr></tbody></table>\\\n\t\t\t\t</div>\\\n\t\t\t\t</td>\\\n\t\t\t');\n\t\t\tentry1.appendTo($('#eth-client-tr-img')).find(\"#EthClientHostName\"+EthIndex+\"\").text(HostName);\n\t\t\t$('#EthDeviceName'+EthIndex+'').val(HostName);\n\t\t\t$('#EthDeviceMac'+EthIndex+'').val(CustomerMac);\n\t\t\t$('#EtholdDeviceIcon'+EthIndex+'').val(dvIcon);\n\t}\n\n\tfunction AddLanUserClient(clientinfo,ConnectType){\n\t\t\n\t\tvar count=0;\n\t\tvar WifiIndex = 0;\n\t\tvar EthIndex = 0;\n\t\tclientinfo.find('clientinfo').each(function(){\t\n\t\t\t\n\t\t\tcount++;\n\t\t\tvar HostName = $(this).find('hostname').text();\n\t\t\tvar IPv4Addr = $(this).find('IPv4Addr').text();\n\t\t\tvar IPv6Addr = $(this).find('IPv6Addr').text();\n\t\t\tvar CustomerHostName = $(this).find('xmlhostname').text();\n\t\t\tvar CustomerIcon = $(this).find('xmlicon').text();\n\t\t\tCustomerMac = $(this).find('MACAddr').text();\n\n\t\t\tif(ConnectType == \"ethernet\"){\n\t\t\t\tEthIndex++;\n\t\t\t\tif(CustomerHostName != \"\")\n\t\t\t\t{\n\t\t\t\t\taddEthClient(CustomerHostName,EthIndex,CustomerIcon);\n\t\t\t\t}else\n\t\t\t\t{\n\t\t\t\t\tif(HostName != \"Unknown\"){\n\t\t\t\t\t\taddEthClient(HostName,EthIndex,CustomerIcon);\n\t\t\t\t\t}else if(IPv4Addr != \"\"){\n\t\t\t\t\t\taddEthClient(IPv4Addr,EthIndex,CustomerIcon);\n\t\t\t\t\t}else{\n\t\t\t\t\t\taddEthClient(IPv6Addr,EthIndex,CustomerIcon);\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}else if(ConnectType == \"wifi\"){\n\t\t\t\tWifiIndex++ ;\n\t\t\t\tif(CustomerHostName != \"\")\n\t\t\t\t{\n\t\t\t\t\taddWifiClient(CustomerHostName,WifiIndex,CustomerIcon);\n\t\t\t\t}else\n\t\t\t\t{\n\t\t\t\t\tif(HostName != \"Unknown\"){\n\t\t\t\t\t\taddWifiClient(HostName,WifiIndex,CustomerIcon);\n\t\t\t\t\t}else if(IPv4Addr != \"\"){\n\t\t\t\t\t\taddWifiClient(IPv4Addr,WifiIndex,CustomerIcon);\n\t\t\t\t\t}else{\n\t\t\t\t\t\taddWifiClient(IPv6Addr,WifiIndex,CustomerIcon);\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t});\n\t\t\n\t\tif(WifiIndex==0){\n\t\t\t$(\"#wifiSpacer\").show();\n\t\t}else{\n\t\t\t$(\"#wifiSpacer\").hide();\n\t\t}\n\t\tif(ConnectType == \"ethernet\"){\n\t\t\t$('#ethnum').html(count)\n\t\t}else if(ConnectType == \"wifi\"){\n\t\t\t$('#wifinum').html(count);\n\t\t}\n\t}\n\n\tfunction Refresh(){\n\t\tajaxGet({'fun':123},\"\",getLanUserInfo);\n\t}\n\t\n\tfunction updateLanUserTable()\n\t{\n\t\tif(GlobalSt[\"goto\"] === false && window.location.pathname === \"/index.html\")\n\t\t{\n\t\t\ttimerId = self.setInterval(\"ajaxGet({'fun':123},'',getLanUserInfo);\",10000);\n\t\t}\n\t}\n\n\tfunction checkIsChange()\n\t{\n\t\tif(Device_index == 0)\n\t\t{\n\t\t\treturn false;\n\t\t}\n\t\tvar Device_img = document.getElementById(\"\"+Device_connect+\"DeviceImg\"+Device_index+\"\").getAttribute(\"src\");\n\t\tif($('#'+Device_connect+'ClientHostName'+Device_index+'').text() != $('#'+Device_connect+'DeviceName'+Device_index+'').val()\n\t\t\t|| !Device_img.includes($('#'+Device_connect+'oldDeviceIcon'+Device_index+'').val()))\n\t\t{\n\t\t\treturn true;\n\t\t}\n\t\treturn false;\n\t}\n\n\tfunction RemoveDeviceNameErrMsg()\n\t{\n\t\t$('#'+Device_connect+'DeviceName'+Device_index+'').removeClass('error');\n\t\t$('#'+Device_connect+'DeviceNameErrorMessage'+Device_index+'').hide();\n\t}\n\n\tfunction CheckDeviceName()\n\t{\n\t\tvar deviceHostname = $('#'+Device_connect+'DeviceName'+Device_index+'').val();\n\t\tvar wmsg = \"\";\n\t\tRemoveDeviceNameErrMsg();\n\n\t\tif($('#'+Device_connect+'DeviceName'+Device_index+'').val().length > 30)\n\t\t{\n\t\t\twmsg = \"wm71\";\n\t\t}else if(!isVerifyDeviceName(deviceHostname))\n\t\t{\n\t\t\twmsg = \"wm61\";\n\t\t}\n\n\t\tif(wmsg != \"\")\n\t\t{\n\t\t\t$(\"div[name='\"+Device_connect+\"DeviceNameErrorContent\"+Device_index+\"']\").attr(\"id\",wmsg);\n\t\t\t$('#'+Device_connect+'DeviceName'+Device_index+'').addClass('error');\n\t\t\t$('#'+Device_connect+'DeviceNameErrorMessage'+Device_index+'').show();\n\t\t\treturn updateContent();\n\t\t}\n\t\tgotoPagetop();\n\t\tDeviceNameOverlay();\n\t}\n\n\tfunction ChangeDeviceInfo(){\n\t\t$('#overlayWarring').empty().hide();\n\t\tif(checkIsChange())\n\t\t{\n\t\t\tvar deviceMac = $('#'+Device_connect+'DeviceMac'+Device_index+'').val();\n\t\t\tvar deviceHostname = $('#'+Device_connect+'DeviceName'+Device_index+'').val();\n\t\t\tvar Device_str = document.getElementById(\"\"+Device_connect+\"DeviceImg\"+Device_index+\"\").getAttribute(\"src\");\n\t\t\tvar Device_img = Device_str.slice(19);\n\t\t\tvar data = {'fun':149,'mac':deviceMac,'hostname':deviceHostname,'icon':Device_img};\n\t\t\tajaxSet(data,function(){$(\"#home_main_page\").hide();waitTimeScreen(\"../common_page/HomePage.html\",5,\"c_43\",\"wait-massage\",updatesuccess);},ShowError,updateerror);\n\t\t}else\n\t\t{\n\t\t\t$(\"#home_main_page\").hide();\n\t\t\twaitTimeScreen(\"../common_page/HomePage.html\",1,\"c_43\",\"wait-massage\");\n\t\t\treturn;\n\t\t}\n\t}\n\t\n\tfunction ShowError()\n\t{\n\t\tif(_server[\"Msg\"].match(\"30\"))\n\t\t{\n\t\t\t$(\"div[name='\"+Device_connect+\"DeviceNameErrorContent\"+Device_index+\"']\").attr(\"id\",\"wm71\");\n\t\t}else if(_server[\"Msg\"].match(\"invalid\"))\n\t\t{\n\t\t\t$(\"div[name='\"+Device_connect+\"DeviceNameErrorContent\"+Device_index+\"']\").attr(\"id\",\"wm61\");\n\t\t}\n\t\t$('#'+Device_connect+'DeviceName'+Device_index+'').addClass('error');\n\t\t$('#'+Device_connect+'DeviceNameErrorMessage'+Device_index+'').show();\n\t\tupdateContent();\n\t}\n\n\tfunction displaynumber(index, connect)\n\t{\n\t\tDevice_index = index;\n\t\tDevice_connect = connect;\n\n\t\t$(\"td.clientinfo\").hide();\n\t\t$('td#'+connect+'clientinfo'+index).show();\n\t\t$('#'+connect+'ClientHostName'+index).hide();\n\t}\n\n\tfunction changeIcon(index)\n\t{\n\t\tif($('#'+Device_connect+'DeviceSelect'+index+'').val() != 0)\n\t\t{\n\t\t\tvar deviceicon = \"Unknown-device.svg\";\n\t\t\tswitch($('#'+Device_connect+'DeviceSelect'+index+'').val())\n\t\t\t{\n\t\t\t\tcase '1': //Desktop computer\n\t\t\t\t\tdeviceicon = \"DesktopPC-icon.svg\";\n\t\t\t\tbreak;\n\t\t\t\tcase '2': //Laptop\n\t\t\t\t\tdeviceicon = \"Laptop-Icon.svg\";\n\t\t\t\tbreak;\n\t\t\t\tcase '3': //Mobile\n\t\t\t\t\tdeviceicon = \"Mobile-icon.svg\";\n\t\t\t\tbreak;\n\t\t\t\tcase '4': //Tablet\n\t\t\t\t\tdeviceicon = \"Tablet-icon.svg\";\n\t\t\t\tbreak;\n\t\t\t\tcase '5': //Printer\n\t\t\t\t\tdeviceicon = \"Printer-icon.svg\";\n\t\t\t\tbreak;\n\t\t\t}\n\t\t\t$('#'+Device_connect+'DeviceImg'+index+'').attr(\"src\",\"images/common_imgs/\"+deviceicon+\"\");\n\t\t}\n\t}\n\n\tfunction DeviceNameOverlay()\n\t{\n\t\t$(\"#overlayWarring\").empty();\n\t\tvar entry = $('\\n\\\n\t\t\t\t\t<div class=\"overlay\" id=\"\" style=\"z-index: 11500;\"></div>\\n\\\n\t\t\t\t\t<div class=\"overlaycontainer\" id=\"\" style=\"z-index: 12000;\">\\n\\\n\t\t\t\t\t<div class=\"close\" onclick=\"CancelChange();\" style=\"cursor: pointer;\"><img src=\"images/common_imgs/close.png\"> <div class=\"closetext dynamic\" id=\"c_51\">Close</div></div>\\\n\t\t\t\t\t\t<div class=\"overlaycontent_holder\">\\n\\\n\t\t\t\t\t\t\t<div class=\"overlaycontent-title dynamic\" id=\"c_no00\"></div>\\n\\\n\t\t\t\t\t\t\t<div id=\"\" class=\"overlaycontent-infotext\">\\n\\\n\t\t\t\t\t\t\t<span id=\"wm70\" class=\"dynamic\"></span>\\n\\\n\t\t\t\t\t\t\t</div>\\n\\\n\t\t\t\t\t\t\t<div style=\"padding-bottom: 40px;\">\\n\\\n\t\t\t\t\t\t\t\t<input type=\"button\" id=\"c_55\" value=\"\" class=\"button_secondary_arrowfree dynamicValue\" style=\"margin: 0px 30px 0px 0px;\" onclick=\"CancelChange();\" onmouseover=\"$(this).addClass(\\'button_secondary_hover_arrowfree\\');\" onmouseout=\"$(this).removeClass(\\'button_secondary_hover_arrowfree\\');\">\\n\\\n\t\t\t\t\t\t\t\t<input type=\"button\" id=\"c_54\" value=\"\" class=\"button_main dynamicValue\" style=\"margin: 0px 0px 0px 0px;\" onclick=\"ChangeDeviceInfo()\" onmouseover=\"$(this).addClass(\\'button_main_hover\\');\" onmouseout=\"$(this).removeClass(\\'button_main_hover\\');\">\\n\\\n\t\t\t\t\t\t\t</div>\\n\\\n\t\t\t\t\t\t</div>\\n\\\n\t\t\t\t\t</div>\\n\\\n\t\t\t\t\t');\n\t\t$(\"#overlayWarring\").append(entry).show();\n\t\tupdateContent();\n\t}\n\n\tfunction CancelChange()\n\t{\n\t\tajaxGet({'fun':123},\"\",getLanUserInfo);\n\t\ttimerId = self.setInterval(\"ajaxGet({'fun':123},'',getLanUserInfo);\",10000);\n\t\tsetTimeout(function(){$('#overlayWarring').empty().hide();}, 1000);\n\t}\n</script>\n</body>\n</html>\n"
