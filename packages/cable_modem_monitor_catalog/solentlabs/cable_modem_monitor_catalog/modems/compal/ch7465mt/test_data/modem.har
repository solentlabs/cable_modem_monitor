          "content": {
            "size": 10059,
            "mimeType": "text/html",
            "compression": 0,
            "text": "<!DOCTYPE html>\n<html>\n<head>\n<title>Mercury EMTA style guide</title>\n<meta http-equiv=\"content-type\" content=\"text/html;charset=ISO-8859-1\">\n<META HTTP-EQUIV=\"Cache-Control\" CONTENT=\"no-cache\">\n<script src=\"../js/checkpath.js?v=20250108144525\"></script>\n</head>\n<body>\n<div class=\"content-container contentSpace\">\n\t<div class=\"page-title dynamic\" id=\"c_mu27\">\n\t\tReload and Reboot\n\t</div>\n\t\t<div class=\"section_header dynamic\" id=\"c_rr00\">Backup configuration settings</div>\n\t\t\t<div id=\"main_page\" class=\"general_text\">\n\t\t\t\t<div class=\"dynamic\" id=\"c_rr01\">Clicking on the button Backup to save your Mercury modem's current settings into the computer.</div>\n\t\t\t\t<div>\n\t\t\t\t\t<a class=\"button_secondary_arrowfree dynamic\" id=\"c_rr02\" style = \"margin: 0px 0px 0px 0px;\" onclick=\"backupfile();\" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">Backup</a>\n\t\t\t\t</div>\t\n\t\t\t</div>\n\t\t<br>\n\t\t<div class=\"section_header dynamic\" id=\"c_rr03\">Reload configuration settings</div>\n\t\t\t<div id=\"main_page\" class=\"general_text\" style=\"margin-bottom:0px;\">\n\t\t\t\t<div class=\"dynamic\" id=\"c_rr04\">Use to reset your Mercury modem with settings previously saved in the computer.</div>\n\t\t\t\t<div>\n\t\t\t\t\t<table id=\"util_tracert\">\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td><label class=\"dynamic\" id=\"c_rr05\">Configuration file</label></td>\n\t\t\t\t\t\t\t<td align=right>\n\t\t\t\t\t\t\t\t&nbsp;\t\t\t\t\n\t\t\t\t\t\t\t\t<input type=\"text\" class=\"default\" onBlur=\"InputTextDefault('ConfPath','')\" onFocus=\"InputTextEnable('ConfPath','');\" name=\"ConfPath\" id=\"ConfPath\" size=\"32\" maxlength=\"31\" value=\"\" disabled=\"disabled\">\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr style=\"display:none\">\n\t\t\t\t\t\t\t<td colspan=2>\n\t\t\t\t\t\t\t\t<table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" class=\"error-msg-small errM\" id=\"restoreFail\" style=\"padding-top: 5px; display: table;\">\n\t\t\t\t\t\t\t\t\t<tbody>\n\t\t\t\t\t\t\t\t\t\t<tr><td valign=\"middle\" style=\"padding:0px 8px 0px 0px;\"><img src=\"../images/common_imgs/error-icon.svg\"></td>\n\t\t\t\t\t\t\t\t\t\t\t<td valign=\"middle\" style=\"padding:0px;\"></td></tr>\n\t\t\t\t\t\t\t\t\t</tbody>\n\t\t\t\t\t\t\t\t</table>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td colspan=2>\n\t\t\t\t\t\t\t\t<br>\n\t\t\t\t\t\t\t\t<a class=\"button_secondary_arrowfree dynamic\" id=\"c_rr06\" style = \"margin: 0px 15px 0px 0px;\" onclick=\"triggerRestoreFile();RemoveErrMsg('ConfPath');\" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">Select file</a>\n\t\t\t\t\t\t\t\t<a class=\"button_secondary_arrowfree dynamic\" id=\"c_rr07\" style = \"margin: 0px 0px 0px 0px;\" onclick=\"reloadfile()\" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">Reload</a>\n\t\t\t\t\t\t\t\t<br>\n\t\t\t\t\t\t\t\t<form id=\"my-form\" method=\"post\" enctype=\"multipart/form-data\" action=\"javascript:void(0)\">\n\t\t\t\t\t\t\t\t\t<input type=\"file\" name=\"file\" id=\"chooseRestoreFile\" style=\"display:none\"/>\n\t\t\t\t\t\t\t\t\t<button type=\"submit dynamic\" id=\"c_rr08\" style=\"display:none\">Upload Files!</button>\n\t\t\t\t\t\t\t\t</form>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\t\t\t\t\t\t\n\t\t\t\t\t</table>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t<br>\n\t\t<div class=\"section_header dynamic resetDefault\" id=\"c_rr09\">Restore factory defaults</div>\n\t\t<div id=\"main_page\" style=\"margin:0px\" class=\"resetDefault\">\n\t\t\t<div class=\"general_text\">\n\t\t\t\t<div class=\"general_text dynamic\" style=\"margin: 5px 0px;\" id=\"c_rr10\">\n\t\t\t\t\tResetting the cable modem to its factory default configuration will remove all stored parameters learned by the cable modem during prior initializations. The process to get back online from a factory default condition could take from 3 to 5 minutes. Please refer to the cable modem user guide for details on the power up sequence.\n\t\t\t\t</div>\t\n\t\t\t\t<div class=\"general_text\">\n\t\t\t\t\t<a class=\"button_secondary_arrowfree dynamic\" id=\"c_rr11\" style = \"margin: 0px 0px 0px 0px; \" onclick=\"NoticeStart('RestoreFactoryDefaults()');\" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">Restore default</a>\t\t\t\t\t\t\n\t\t\t\t\t<!--input type=\"submit\"class=\"css_btn_class_misc\" value=\"Restore default\"-->\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t<br class=\"resetDefault\">\n\t\t<div class=\"section_header reboot dynamic\" id=\"c_rr12\">Restart modem</div>\n\t\t<div id=\"main_page\" style=\"margin:0px\" class=\"reboot\">\n\t\t\t<div class=\"general_text\">\n\t\t\t\t<div class=\"general_text dynamic\" style=\"margin: 5px 0px;\" id=\"c_rr13\">\n\t\t\t\t\tClicking on the button Reboot will restart modem immediately which process takes around 1 minute to complete.\n\t\t\t\t</div>\n\t\t\t\t<div class=\"general_text\">\n\t\t\t\t\t<a class=\"button_secondary_arrowfree dynamic\" id=\"c_rr14\" name=\"id_common_restart_cable_modem\" onclick=\"NoticeStart('Reboot_GwInit()');\" style = \"margin: 0px 0px 0px 0px; \" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">Reboot</a>\t\t\t\t\t\t\n\t\t\t\t\t<!--input type=\"submit\"class=\"css_btn_class_misc\" value=\"Restore default\"-->\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t<div id = \"wait-massage\"></div>\n\t<br>\n</div>\n<script language=\"javascript\" id=\"mainScript\">\nvar checkIsChange = function() { return false; };\n$(document).ready( function() {\n\tif(_Interface ==\"WAN\")\n\t{\n\t\t$(\".resetDefault\").remove();\n\t}\n\tupdateContent();\n});\n\nfunction NoticeStart(CurrentPageApplyFunction){\n    \n    //_CurrentPage=CurrentPage;\n    _CurrentPageApplyFunction=CurrentPageApplyFunction;\n    Notice('common_page/Notice.html','noticecontent');\n\n}\n/*--------------------------------Restore Factory Defaults Start--------------------------------*/\nfunction RestoreFactoryDefaults()\t\n{\n\tif(_Interface ==\"WAN\")\n\t\treturn false;\n\t$(\".section_header\").hide();\n\t$(\"div[id=main_page]\").hide();\n\t$(\"br\").not(\"#defaultInfo\").hide();\n\twaitTimeScreen(\"../common_page/Reboot.html\",200,\"c_rr15\",\"wait-massage\");\n\tajaxGet({'fun':1},\"\",function(xmlResponse, node)\n\t{\n\t\tif($(xmlResponse).find('operStatus').text() != 1)\n\t\t{\n\t\t\tdoLogout();\n\t\t}else\n\t\t{\n\t\t\tajaxSetNoTokenUpdate({'fun':7});\t\n\t\t}\n\t});\n}\n/*--------------------------------Restore Factory Defaults End-----------------------------------*/\n/*----------------------------------------Reboot Start-------------------------------------------*/\n\nfunction Reboot_GwInit()\n{\n\t$(\".section_header\").hide();\n\t$(\"div[id=main_page]\").hide();\n\t$(\"br\").hide();\n\twaitTimeScreen(\"common_page/Reboot.html\",200,\"c_rr16\",\"wait-massage\");\n\tajaxGet({'fun':1},\"\",function(xmlResponse, node)\n\t{\n\t\tif($(xmlResponse).find('operStatus').text() != 1)\n\t\t{\n\t\t\tdoLogout();\n\t\t}else\n\t\t{\n\t\t\tajaxSetNoTokenUpdate({'fun':8});\t\n\t\t}\n\t});\n}\n\n/*----------------------------------------Reboot End-------------------------------------------*/\n/*----------------------------------------Restore Start-------------------------------------------*/\nvar RestoreFileSize = 0;\nvar fileAPI = (window.File && window.FileReader && window.FileList && window.Blob);\nfunction triggerRestoreFile()\n{\n\t$(\"#util_tracert tr:eq(1)\").hide();\n\t$('#chooseRestoreFile').trigger('click');\n}\n\n$( \"#chooseRestoreFile\" ).change(function() {\n\tvar path = $(this).val();\n\tif(path.match(\"fakepath\"))\n\t{\n\t\tpath = $(\"input[type=file]\").val().split(\"C:\\\\fakepath\\\\\")[1];\n\t\t$(\"#ConfPath\").val(path);\n\t}\n\telse\n\t{\n\t\t$(\"#ConfPath\").val(path);\n\t}  \n});\n\nfunction backupfile()\n{\n\tvar RandomNum = Math.floor(Math.random()*50000);\n\tvar data =  \"filename=\"+_ConfigModelName+\"-Cfg.bin&=\"+RandomNum;\n\twindow.location.href = '../xml/getter.xml?'+data;\n}\n\nfunction reloadfile()\n{\n\t$(\"#util_tracert tr:eq(1)\").hide();\n\tvar thisfile = $(\"#ConfPath\").val();\n\t\n\tif (thisfile==\"\")\n\t\tInputErrMsg(\"ConfPath\",\"wm32\",\"\");\n\telse\n\t\t$('#c_rr08').trigger('click');\n}\n\n$(':file').change(function(){\n\n\tif (fileAPI) {\n\t\tvar file = this.files[0];\n\t\tRestoreFileSize = file.size;\n\t} else{\n\t\t$(\"#my-form\").attr(\"action\",\"../xml/getter.xml?Restore=0\");\n\t}\n});\n\nvar explorer = window.navigator.userAgent ;  \nvar browser='';\nif (explorer.indexOf(\"Firefox\") >= 0)\n{ \n    browser='Firefox';  \n}else if (explorer.indexOf(\"Chrome\") >= 0)\n{\n    browser='Chrome';  \n}else if (explorer.indexOf(\"Trident/7.0\") >= 0)\n{\n    browser='IE11';  \n}\n\nvar WaitTimeValue;\nif(browser=='Chrome')\n{\n\tWaitTimeValue=180;\n}else \n{\n\tWaitTimeValue=200;\n}  \n \nif(fileAPI)\n{\t\n\t$('#my-form').submit( function(e){\n\tvar formdata = new FormData(this);\n\tif($(\"#ConfPath\").val()==\"\")\n\t\treturn;\n\t\t\n\tif(RestoreFileSize==\"\")\n\t\tRestoreFileSize = 0 ;\n\t\n\t$(\".section_header,div[id=main_page],br\").hide();\n\twaitTimeScreen(\"\",1,\"c_43\",\"wait-massage\");\n\n\tcbnAjax({\n\t\ttype:\"POST\",\n\t\turl:\"../xml/getter.xml\",\n\t\tasync:false,\n\t\tdata: {'fun':1},\n\t\tdataType:\"xml\",\n\t\tbeforeSend: function(){\n\t\t\tGlobalSt[\"waitTimeScreen\"] = true;\n\t\t},\n\t\terror:function(xmlResponse) { \n\t\t\twindow.location.assign(\"../common_page/login.html\");\n\t\t},\n\t\tsuccess:function(xmlResponse) {\n\t\tif($(xmlResponse).find('operStatus').text() != 1)\n\t\t{\n\t\t\tdoLogout();\n\t\t}else\n\t\t{\n\t\t\t$.ajax( {\n\t\t\t\turl: \"../xml/getter.xml?Restore=\"+RestoreFileSize,\n\t\t\t\ttype: 'POST',\n\t\t\t\tdata: formdata,\n\t\t\t\tprocessData: false,\n\t\t\t\tcontentType: false,\n\t\t\t\tdataType:\"text\",\n\t\t\t\tsuccess: function(res, status, xhr) {\n\t\t\t\tif(res.match('cbn') && res.match('Login'))\n\t\t\t\t{\n\t\t\t\t\twindow.location.assign(\"../common_page/login.html\");\n\t\t\t\t}\n\t\t\t\telse if(res.match('RestoreSuccess'))\n\t\t\t\t{\n\t\t\t\t\twaitTimeScreen(\"../common_page/Reboot.html\",WaitTimeValue,\"c_rr16\",\"wait-massage\");\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\t\t\t\t$(\"#wait-massage\").empty();\n\t\t\t\t\t$(\".section_header,div[id=main_page],br,#util_tracert tr:eq(1)\").show();\n\t\t\t\t\t$(\"#restoreFail td:eq(1)\").text(getLanguageResourcesById(\"wm33\"));\n\t\t\t\t}\n\t\t\t\t},\n\t\t\t\terror: function(){\n\t\t\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\t\t\t$(\"#wait-massage\").empty();\n\t\t\t\t$(\".section_header,div[id=main_page],br,#util_tracert tr:eq(1)\").show();\n\t\t\t\t$(\"#restoreFail td:eq(1)\").text(getLanguageResourcesById(\"wm31\"));\n\t\t\t\t}\n\t\t\t});\n\t\t}\t\n\t\t}\n\t});\n    e.preventDefault();\n\t});\n}\n/*----------------------------------------Restore End-------------------------------------------*/\n</script>\n</body>\n</html>\n"
