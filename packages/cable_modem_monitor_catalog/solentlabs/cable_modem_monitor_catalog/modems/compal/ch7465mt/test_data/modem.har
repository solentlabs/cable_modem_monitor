            "text": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>Mercury EMTA style guide</title>\n\n</head>\n<body>\n  \n<div class=\"overlay\" id=\"overlay-div\" style=\"display:none;\"></div>\n\n<!-----------------wifi step1---------------------->\n\n<div class=\"overlaycontainer\" id=\"Notice-div-Step1\" style=\"display:none;\">\n    <div class=\"close\" onclick=\"Cancel(); updateMenuLink();\" style=\"cursor: pointer;\"><img src=\"images/common_imgs/close.png\"> <div class=\"closetext\" style=\"position:relative;\"><span style=\"position:relative;top:2px\" class=\"dynamic\" id=\"c_51\"></span></div></div>\n\n    <div id=\"Notice\" class=\"overlaycontent_holder\">            \n\t<div name=\"NoticeTitle\" class=\"overlaycontent-title dynamic\" id=\"c_no00\">Notice!</div>\n    <div id=\"message_content\" class=\"overlaycontent-infotext\" style=\"width:720px; padding-left:60px; padding-bottom:40px\">\n    </div>\n    <div class=\"overlaycontent\">\n        <div>\n            <input type=\"button\" id=\"c_st26\" value=\"\" class=\"button_secondary_arrowfree dynamicValue\" style=\"margin: 0px 30px 0px 0px; \" onclick=\"\" onmouseover=\"$(this).addClass('button_secondary_hover_arrowfree');\" onmouseout=\"$(this).removeClass('button_secondary_hover_arrowfree');\">\n            <input type=\"button\" id=\"c_02\" value=\"\" class=\"button_main dynamicValue\" style=\"margin: 0px 0px 0px 0px;\" onclick=\"gotoPagetop();\" onmouseover=\"$(this).addClass('button_main_hover');\" onmouseout=\"$(this).removeClass('button_main_hover');\">\n        </div>\n    </div>\n    </div><!--overlaycontent_holder-->\n\t<!-----------------Restore Infos-------------------------->\n\t<div id=\"InfoMsg\" class=\"overlaycontent_holder\" style=\"display:none;\">\n\t\t<div name=\"InfoTitle\"class=\"overlaycontent-title\">WiFi connection is lost</div>\n\t\t<div name=\"Info_content\" class=\"overlaycontent-infotext\" style=\"width:720px; padding-left:60px\"></div>\n\t\t<div name=\"defaultInfo\" class=\"overlaycontent\"></div>\n\t</div>\n</div> <!--Notice-div-Step1-->\n<!-----------------------loading page------------------------->\n<div class=\"overlaycontainer\" id=\"overlaycontainer-div-Loading\" style=\"display:none;\">\n\n    <div class=\"overlaycontent_holder\">\n    \t<div class=\"overlaycontent-title\">WiFi configuration</div>\n        <div class=\"overlaycontent-infotext\">Your modem is now configuring your new WiFi settings.<br>\n            You will need to reconnect your wireless devices with<br>\n            your new credentials.<br><br>\n            Thank you!\n\t\t</div>\n        <div class=\"overlaycontent\" style=\"margin-bottom:50px; font-size:24px;\">\n            <div class='contentFont' style=\"margin-top:30px\">\n                <span><img src='/images/common_imgs/loading.gif'/></span>\n            </div>        \n    \t</div> \n    </div> \n</div>\n\n<div class=\"overlaycontainer\" id=\"overlaycontainer-WPS-Loading\" style=\"display:none;\">\n\t<div class=\"close\" onclick=\"Cancel_stop();\" style=\"cursor: pointer;\"><img src=\"images/common_imgs/close.png\"> <div class=\"closetext dynamic\" id=\"c_51\">Close</div></div>\n    <div class=\"overlaycontent_holder\">\n    \t<div class=\"overlaycontent-title dynamic\" id=\"w_wps01\">WiFi Protected Set-up (WPS)</div>\n\t\t<br>\n        <div class=\"overlaycontent-infotext dynamic\" id=\"c_59\">Configuring wireless settings</div>\n        \n        <div class=\"overlaycontent\" style=\"font-size:24px;\">  \n            <div class='contentFont' style=\"margin-top:30px\">\n                <span><img src='/images/common_imgs/loading.gif'/></span>\n            </div>        \n    \t</div>\n    </div>\n</div>\n\n<div class=\"overlaycontainer\" id=\"overlaycontainer-WPS-errorpage\" style=\"display:none;\">\n\t<div class=\"close\" onclick=\"Cancel();\" style=\"cursor: pointer;\"><img src=\"images/common_imgs/close.png\"> <div class=\"closetext dynamic\" id=\"c_51\">Close</div></div>\n\t<div class=\"overlaycontent_holder\">\t\n\t\t<div class=\"overlaycontent-title dynamic\" id=\"w_wps01\"></div>\n\t\t<div class=\"overlaycontent\">\n\t\t\t<br>\n\t\t\t<img src=\"../images/common_imgs/error-icon.svg\" class=\"svg-inject green\" width=\"60\">\n\t\t</div>\t\n\t\t<div class=\"overlaycontent-infotext dynamic\" id=\"c_82\">Failed to connect device. Please try again.</div>\n\t\t<div>\n\t\t\t<input id=\"c_51\" type=\"button\" class=\"overlaybutton_secondary dynamicValue\" value=\"\" onclick=\"gotoPagetop(); Cancel();\" style=\"margin-right:40px;\" onmouseover=\"$(this).addClass('overlaybutton_secondary_hover');\" onmouseout=\"$(this).removeClass('overlaybutton_secondary_hover');\">\n\t\t\t<input id=\"c_61\" type=\"button\" class=\"overlaybutton_main dynamicValue\" value=\"\" onclick=\"gotoPagetop(); RetryWpsAddClient();\" onmouseover=\"$(this).addClass('overlaybutton_main_hover');\" onmouseout=\"$(this).removeClass('overlaybutton_main_hover');\">\n\t\t</div>\n\t</div>\n</div>\n\n<div class=\"overlaycontainer\" id=\"overlaycontainer-WPS-successpage\" style=\"display:none;\">\n\t\n\t<div class=\"close\" onclick=\"Cancel();\" style=\"cursor: pointer;\"><img src=\"images/common_imgs/close.png\"> <div class=\"closetext dynamic\" id=\"c_51\">Close</div></div>\n\t<div class=\"overlaycontent_holder\">\t\n\t\t<div class=\"overlaycontent-title dynamic\" id=\"w_wps01\"></div>\n\t\t<div class=\"overlaycontent\">\n\t\t\t<br>\n\t\t\t<img src=\"../images/common_imgs/allgood-icon.svg\" class=\"svg-inject green\" width=\"60\">\n\t\t</div>\t\n\t\t<div class=\"overlaycontent-infotext dynamic\" id=\"c_81\">Device connected successfully</div>\n\t\t<div>\n\t\t\t<input id=\"c_51\" type=\"button\" class=\"overlaybutton_secondary  dynamicValue\" value=\"\" onclick=\"gotoPagetop(); Cancel();\" onmouseover=\"$(this).addClass('overlaybutton_secondary_hover');\" onmouseout=\"$(this).removeClass('overlaybutton_secondary_hover');\">\n\t\t</div>\n\t</div>\n</div>\n\n<script language=\"javascript\" id=\"mainScript\">\n\tvar WPS_TIME = {\"Timeout\":300,\"Current\":0,\"TimeCheck\":5};\n    //alert(dst_id+\"    \"+dst+\"   \"+_CurrentPage+\"     \"+_CurrentPageApplyFunction)\n    $(document).ready(function(){\n\t\tif(_CurrentPageApplyFunction == \"RestoreFactoryDefaults()\" || _CurrentPageApplyFunction == \"Reboot_GwInit()\")\n\t\t{\t\t\t\n\t\t\tRebootInit();\n\t\t}\n\t\telse\n\t\t\tinit();\n        $('#overlay-div').show();\n\t\tif(_CurrentPageApplyFunction == \"setaddClient()\")\n\t\t{\n\t\t\tsetaddClient();\n\t\t\t$('#overlaycontainer-WPS-Loading').show();\n\t\t\tWPSInfo();\n\t\t}else\n        $('#Notice-div-Step1').show();\n        updateContent();\t\n    });\n    \n    function WPSInfo()\n\t{\n\t\tif(parseInt(WPS_TIME[\"Current\"])>=parseInt(WPS_TIME[\"Timeout\"])){\n\t\t\t$('#overlaycontainer-WPS-Loading').hide();\n\t\t\t$('#overlaycontainer-WPS-errorpage').show();\n\t\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\t}else{\n\t\t\tWPS_TIME[\"Current\"] += WPS_TIME[\"TimeCheck\"];\n\t\t\tajaxGet({'fun':323},\"\",function(xmlResponse, node)\n\t\t\t{\n\t\t\t\tif($(xmlResponse).find('WPS_stat').text()==\"down\")\n\t\t\t\t{\n\t\t\t\t\tif($(xmlResponse).find('WPS_result').text()==\"wps success\")\n\t\t\t\t\t{\n\t\t\t\t\t\t$('#overlaycontainer-WPS-Loading').hide();\n\t\t\t\t\t\t$('#overlaycontainer-WPS-successpage').show();\n\t\t\t\t\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\t\t\t\t}else if(parseInt(WPS_TIME[\"Current\"])>=parseInt(WPS_TIME[\"Timeout\"]))\n\t\t\t\t\t{\n\t\t\t\t\t\t$('#overlaycontainer-WPS-Loading').hide();\n\t\t\t\t\t\t$('#overlaycontainer-WPS-errorpage').show();\n\t\t\t\t\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\t\t\t\t}else\n\t\t\t\t\t{\n\t\t\t\t\t\tsetTimeout(function(){WPSInfo();}, 5000);\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tsetTimeout(function(){WPSInfo();}, 5000);\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t}\n\t\n\tfunction RetryWpsAddClient()\n\t{\n\t\tsetaddClient();\n\t\t$('#overlaycontainer-WPS-errorpage').hide();\n\t\t$('#overlaycontainer-WPS-Loading').show();\n\t\tWPS_TIME[\"Current\"] = 0;\n\t\tWPSInfo();\n    }\n\t\n    function init(){\n        \n        var message=\"<div class='dynamic' id='c_no01'></div>\"\n        //var message=\"We notice that you made some changes on the<br>\"+_CurrentPage+\" settings. Leaving the page without<br>applying them will result to losing your settings.<br>What would you like to do?\"\n        $(\"#message_content\").html(message);\n        setTimeout(function(){ $(\"#NoticeName\").html(getLanguageResourcesById(_CurrentPage)); }, 100);\n        \n        \n        $(\"#c_st26\").attr('onclick',\"Cancel();NoticeClear();goto('\"+dst+\"','\"+dst_id+\"');\")\n        $(\"#c_02\").attr('onclick',\"Cancel();\"+_CurrentPageApplyFunction);\n        //goto(dst,dst_id);\n    }\n    function RebootInit(){\n\n\t\t$(\"[name=NoticeTitle]\").attr(\"id\",\"c_rr17\");\n        $(\"#c_st26\").attr({'id':'c_st27','onclick':'Cancel()'});\n\t\tif(_CurrentPageApplyFunction == \"RestoreFactoryDefaults()\")\n\t\t{\n\t\t\tajaxGet({'fun':324},\"\",RestoreInfo);\n\t\t\t$(\"#c_02\").attr({\"onclick\":\"showRestoreInfo();\"+_CurrentPageApplyFunction,\"id\":\"c_rr22\"});\n\t\t\t$(\"#message_content\").html(\"<div class='dynamic' id='c_no09'></div>\");\n\t\t\t$(\"[name='InfoTitle']\").text(getLanguageResourcesById('c_rr21'));\n\t\t}\n\t\telse\n\t\t{\n\t\t\t\n\t\t\t$(\"#c_02\").attr({'onclick':\"Cancel();\"+_CurrentPageApplyFunction,'id':'c_st28'});\n\t\t\t$(\"#message_content\").html(\"<div class='dynamic' id='c_rr18'></div><div><span class='dynamic' id='c_rr19'></span><span class='dynamic' id='c_rr20'></span></div>\");\n\t\t}\n    }\n\tfunction RestoreInfo(xmlResponse)\n\t{\n\t    \n\t\tvar pwd = $(xmlResponse).find(\"loginPwd\").text(), SSID=WIFI_b72b4744\"WiFiSSID\").text(), WifiKey=PASS_05740f8f\"WiFikey\").text();\n\t\tvar msg = \"<div class='dynamic' id='c_no07'></div>\";\n\t\tvar Pwdcontent = \"<div class='darkblue dynamic' id='c_no05'>Your default Modem credentials</div><div>\"+getLanguageResourcesById('c_39')+\" : \"+pwd+\"</div>\";\n\t\tvar Wificontent = \"<div class='darkblue dynamic' id='c_no06'>Your default WiFi credentials</div><div>\"+getLanguageResourcesById('c_53')+\" : \"+SSID+\"</div><div>\"+getLanguageResourcesById('c_39')+\" : \"+WifiKey+\"</div>\";\n\t\t\n\t\t$(\"[name=Info_content]\").html(\"<div class='dynamic' id='c_no07'></div>\");\n\t\t$(\"[name=defaultInfo]\").html(Pwdcontent+\"<br id='defaultInfo'>\"+ Wificontent);\n\t}\n\tfunction showRestoreInfo()\n\t{\n\t\tupdateContent();\n\t\t$(\"#Notice\").fadeOut(500);\n\t\t$(\"#InfoMsg\").delay(400).fadeIn(500);\n\t\tsetTimeout(function(){Cancel();}, 60000);\t\n\t} \n      \n \tfunction Cancel()\n\t{\n        $(bubblecontent).empty();\n        $('#noticecontent').empty();\n\t}   \n\n\tfunction Cancel_stop()\n\t{\n\t\tGlobalSt[\"waitTimeScreen\"] = false;\n\t\tvar data = {'fun':329};\n\t\tajaxSet(data);\n\t\tReloadPage();\n\t}\n\n\tfunction updateMenuLink()\n\t{\n\t\tvar BackTo = $(\"#content\").attr(\"name\");\n\t\tvar MoveTo = $(\".select_subtitle\").attr(\"name\");\n\t\t\n\t\tif (BackTo.match(MoveTo)?false:true)\n\t\t{\n\t\t\tvar thisClass = \"\" + $(\"[name='\"+BackTo+\"']\").attr(\"class\");\n\t\t\tvar thisID = $(\"[name='\"+BackTo+\"']\").parent().parent();\n\t\t\t$('.levelmenu').tendina(\"CBNslideUpAll\");\n\t\t\t$(\".menuTitle\").attr(\"style\",\"border-bottom: 1px solid #D3D3D3\");\t\n\t\t\tdisplayCurrentPagesStyle(BackTo);\n\n\t\t\tsetTimeout(function(){ \n\t\t\t\tif(thisClass.match(\"level2\")){\n\t\t\t\t\tthisID.eq(1).prev().click();\n\t\t\t\t}else if(thisClass.match(\"level3arrow\")){\n\t\t\t\t\tthisID.parent().parent().eq(1).prev().click();\n\t\t\t\t\tthisID.prev().click();\n\t\t\t\t}\n\t\t\t}, 600);//speed: 500,\n\t\t}\n\t}\n</script>\n</body>\n</html>\n"
          },
