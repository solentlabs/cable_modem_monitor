            "text": "@charset \"UTF-8\";\n\n.overlay { position:absolute; left:0px; top:0px; z-index:10000; background-size:100% auto; width: 100%; height: 200%; filter:alpha(opacity=80); opacity:.8;}\n\n.overlaycontainer {position:absolute; left:0px; top:0px; z-index:11000; width:100%;  padding-top: 30px;}\n\n.close {position: absolute; top:30px; right:0px; height: 45px;  text-align: right;  }\n.close img {border:0px;}\n.closetext { float:right; padding: 5px 15px; font-size: 28px; color: #666; background:#fff; margin-left: 2px; height: 35px;}\na.closetext {text-decoration:none; color:#666;}\n\n.overlaycontent_holder {background:#ffffff; margin: 0px auto; max-width: 840px; position:relative; padding: 45px; text-align:center; }\n.overlaycontent-title {width:720px; padding-left:60px;font-family:TeleNeo-ExtraBold; font-size:60px; color:#E20074; text-align:center; padding-bottom: 20px;}\n.overlaycontent-infotext {width:720px; padding-left:60px;font-size:24px; color:#000000; text-align:center; padding-bottom: 30px;}\n.overlaycontent {font-size:20px; color:#666666; text-align:center; padding-bottom: 40px; margin:0px auto;}\n.overlaycontent td {padding: 0px 5px 15px 5px;}\n\na.simple_links {background:url(../images/common_imgs/arrow-magenta.svg) no-repeat left center; background-size: 8px 13px; padding-left: 14px; color:#E20074; text-decoration: underline; cursor: pointer;}\na:hover.simple_links {background:url(../images/common_imgs/arrow-magenta.svg) no-repeat left center; background-size: 8px 13px; padding-left: 14px; color:#E20074; text-decoration: underline; cursor: pointer;}\n\n.overlaybutton_main {background:#E20074; font-family: TeleNeo-Regular; font-size: 28px; color: #fff; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; cursor: pointer;}\n.overlaybutton_main_hover {background:#E20074; font-family: TeleNeo-Regular; font-size: 28px; color: #fff; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; box-shadow: 0 0 4px #E20074;}\n.overlaybutton_main_deactivated {background:#aaaaaa; font-family: TeleNeo-Regular; font-size: 28px; color: #c2c2c2; padding: 15px 30px 10px 30px; border:1px solid #dedede; border-radius:3px; }\n\n.overlaybutton_secondary {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; }\n.overlaybutton_secondary_hover {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; box-shadow: 0 0 4px #E20074; cursor: pointer;}\n.overlaybutton_secondary_deactivated {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #d8d8d8; padding: 15px 30px 10px 30px;border:1px solid #ebebeb; border-radius:3px; }\n\n.overlaybutton_back {background:#FFFFFF url(../images/common_imgs/arrow-magenta-grad-back.svg) no-repeat 30px 24px; -ms-background-position-y: 20px; background-size: 10px 17px; font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 47px;border:1px solid #d2d2d2; border-radius:3px; margin-right:40px; }\n.overlaybutton_back_hover {background:#FFFFFF url(../images/common_imgs/arrow-magenta-grad-back.svg) no-repeat 30px 24px; -ms-background-position-y: 20px; background-size: 10px 17px;  font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 47px;border:1px solid #E20074; border-radius:3px; box-shadow: 0 0 4px #E20074; margin-right:40px; cursor: pointer;}\n.overlaybutton_back_deactivated {background:#FFFFFF url(../images/common_imgs/arrow-back-deactivated.svg) no-repeat 30px 24px; -ms-background-position-y: 20px; background-size: 10px 17px; font-family: TeleNeo-Regular; font-size: 28px; color: #d8d8d8; padding: 15px 30px 10px 47px;border:1px solid #ebebeb; border-radius:3px; margin-right:40px;}\n\n\n.troubleshoot-indicator, .troubleshoot-indicator-msg {margin: 0px auto; width: 240px; position:absolute; left:345px; text-align:center; z-index: 50;}\n.troubleshoot-indicator-msg {z-index: 100; font-family:TeleNeo-Bold; font-size: 38px; color:#fff; height: 240px; padding-top:35px; line-height: 40px;}\n.troubleshoot-indicator-submsg {font-family:TeleNeo-Regular; font-size: 22px; color:#fff; line-height: 24px!important;}\n.troubleshoot-indicator-msg table {width: 150px; height: 150px;}\n.troubleshoot-copy {font-family:TeleNeo-Regular; font-size:20px; color: #666; text-align:center; padding-bottom: 40px; padding-top: 240px; width: 520px; margin:0px auto;}\n.trouble-redmsg {text-align:center; font-size:34px; color:#cc0022;}\n.trouble-greenmsg {text-align:center; font-size:34px; color:#20DAA0;}\n\n.section-title {text-align:center; font-size:24px; color:#000000;}\n.trouble-redstepmsg {text-align:center; font-size:24px; color:#cc0022;}\n.trouble-greenstepmsg {text-align:center; font-size:24px; color:#20DAA0;}\n\n.steps {background:#fff url(../images/common_imgs/troubleshoot-circle.svg) no-repeat center top;  background-size: 34px auto; padding:5px; width: 40px; color:#fff;}\n.steps-copy {padding: 5px 0px 10px 0px;}\n.steps a, .steps-copy a, .troubleshoot-copy a {color:#00aadd;}\n.steps a:hover, .steps-copy a:hover, .troubleshoot-copy a:hover {color:#E20074;}\n\n/*datetimepicker page_S*/\n.xdsoft_datetimepicker {\n\tbox-shadow: 0 5px 15px -5px rgba(0, 0, 0, 0.506);\n\tbackground: #fff;\n\tborder-bottom: 1px solid #bbb;\n\tborder-left: 1px solid #ccc;\n\tborder-right: 1px solid #ccc;\n\tborder-top: 1px solid #ccc;\n\tcolor: #333;\n\tfont-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n\tpadding: 8px;\n\tpadding-left: 0;\n\tpadding-top: 2px;\n\tposition: absolute;\n\tz-index: 9999;\n\t-moz-box-sizing: border-box;\n\tbox-sizing: border-box;\n\tdisplay: none;\n}\n\n.xdsoft_datetimepicker iframe {\n\tposition: absolute;\n\tleft: 0;\n\ttop: 0;\n\twidth: 75px;\n\theight: 210px;\n\tbackground: transparent;\n\tborder: none;\n}\n\n/*For IE8 or lower*/\n.xdsoft_datetim