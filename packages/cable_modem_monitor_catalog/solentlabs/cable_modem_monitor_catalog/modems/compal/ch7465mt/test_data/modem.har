            "text": "@charset \"UTF-8\";\n@font-face {\n    font-family: TeleNeo-Regular;\n    src: url(../font/TeleNeo-Regular.otf);\n    src: url('../font/TeleNeo-Regular.woff2') format('woff2'),\n         url('../font/TeleNeo-Regular.woff') format('woff'),\n\t\t url('../font/TeleNeo-Regular.ttf') format('truetype'),\n         url('../font/TeleNeo-Regular.svg') format('svg');\n}\n@font-face {\n    font-family: TeleNeo-ExtraBold;\n    src: url(../font/TeleNeo-ExtraBold.otf);\n    src: url('../font/TeleNeo-ExtraBold.woff2') format('woff2'),\n         url('../font/TeleNeo-ExtraBold.woff') format('woff'),\n\t\t url('../font/TeleNeo-ExtraBold.ttf') format('truetype'),\n         url('../font/TeleNeo-ExtraBold.svg') format('svg');\n}\n@font-face {\n    font-family: TeleNeo-Bold;\n    src: url(../font/BloomSpeakOT-Bold.otf);\n\tsrc: url('../font/BloomSpeakOT-Bold.eot');\n    src: url('../font/BloomSpeakOT-Bold?#iefix') format('embedded-opentype'),\n         url('../font/BloomSpeakOT-Bold.woff') format('woff'),\n         url('../font/BloomSpeakOT-Bold.ttf') format('truetype'),\n         url('../font/BloomSpeakOT-Bold.svg#TeleNeo-Bold') format('svg');\n}\n\nhtml {\n    /*overflow-y: scroll; */\n}\nbody {margin: 0px 0px; padding: 0px; font-family:TeleNeo-Regular;}\n\n.overlay { position:absolute; left:0px; top:0px; z-index:10000; background-size:100% auto; width: 100%; height: 100%; filter:alpha(opacity=80); opacity:.8;}\n.overlaycontainer {position:absolute; left:0px; top:0px; z-index:11000; width:100%;  padding-top: 30px;}\n\n\n.green, .svg-inject.green path, .svg-inject.green circle {color:#20daa0; fill:#20daa0!important;}\n.orange, .svg-inject.orange path, .svg-inject.orange circle {color:#ff6600; fill:#ff6600;}\n.red, .svg-inject.red path, .svg-inject.red circle  {color:#cc0022; fill:#cc0022;}\n.lightblue, .svg-inject.lightblue path, .svg-inject.lightblue circle  {color:#00aadd; fill:#00aadd;}\n.darkblue, .svg-inject.darkblue path, .svg-inject.darkblue circle  {color:#224499; fill:#224499;}\n.purple, .svg-inject.purple path, .svg-inject.purple  {color:#771199; fill:#771199;}\n.disabled, .svg-inject.disabled path, .svg-inject.disabled  {color:#999999; fill:#999999;}\n\n.logo\n{\n\tposition: absolute; top:30px; left:0px;width: 75px; height: 60px; background:#fff; text-align: center;\n\tbackground-image: url(../images/common_imgs/T_Logo_weiss_magenta.svg);\n    background-repeat: no-repeat;\n\tbackground-size: 60px;\n\tbackground-position: center;\npadding: 4px 4px 0px 4px;\n}\n.content_holder{background:url(../images/common_imgs/white-transparent90.png); margin: 0px auto; max-width: 840px;position:relative; padding: 45px 30px; text-align:center;}\n.content-title {width:720px; padding-left:60px;font-family:TeleNeo-ExtraBold; font-size:60px; color:#E20074; text-align:center; padding-bottom: 20px;}\n.content-infotext {width:720px; padding-left:60px;font-size:24px; color:#000000; text-align:center; padding-bottom: 30px;}\n.content {font-size:20px; color:#666666; text-align:center; padding-bottom: 40px; margin:0px auto;}\n.content td {padding: 0px 5px 15px 5px;}\n\na.simple_links {background:url(../images/common_imgs/arrow-magenta.svg) no-repeat left center; background-size: 8px 13px; padding-left: 14px; color:#E20074; text-decoration: underline; cursor: pointer;}\na:hover.simple_links {background:url(../images/common_imgs/arrow-magenta.svg) no-repeat left center; background-size: 8px 13px; padding-left: 14px; color:#E20074; text-decoration: underline; cursor: pointer;}\n\n.button_main {background:#E20074; font-family: TeleNeo-Regular; font-size: 28px; color: #fff; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; cursor: pointer;behavior: url(css/PIE.htc);}\n.button_main_hover {background:#E20074; font-family: TeleNeo-Regular; font-size: 28px; color: #fff; padding: 15px 30px 10px 30px;border:1px solid #E20074; border-radius:3px; box-shadow: 0 0 4px #E20074;cursor: pointer;behavior: url(css/PIE.htc);}\n.button_main_deactivated {background:#aaaaaa; font-family: TeleNeo-Regular; font-size: 28px; color: #c2c2c2; padding: 15px 30px 10px 30px; border:1px solid #dedede; border-radius:3px; cursor: pointer;behavior: url(css/PIE.htc);}\n\ninput.default {background:#fff; border:2px solid #d3d3d3; border-radius:3px; color:#c9c9c9; font-size:18px; font-family:TeleNeo-Regular; padding:3px 10px 3px 10px;}\ninput.enabled {background:#fff; border:1px solid #00aadd; border-radius:3px; color:#666; font-size:18px; font-family:TeleNeo-Regular; padding:4px 10px 4px 10px; box-shadow: 0 0 4px #66bddc;}\ninput.disabled {background:#f1f1f1; border:2px solid #d3d3d3; border-radius:3px; color:#d3d3d3; font-size:18px; font-family:TeleNeo-Regular; padding:3px 10px 3px 10px;}\n\n.bgcss{\n\tmargin:0;\n\tpadding:0;\t\t\n\tbackground-position: center center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: cover;\n\theight: 100%;\n\twidth: 100%;\n\tposition: fixed;\n}\n\n.button_secondary \n{\n\tbackground: #FFFFFF url(../images/common_imgs/arrow-magenta-grad-back.svg) no-repeat;\n\tbackground-size: 10px 17px;\n\tfont-family: TeleNeo-Regular;\n\tfont-size: 28px;\n\tcolor: #E20074;\n\tpadding: 15px 30px 10px 45px;\n\tborder: 1px solid #d2d2d2;\n\tborder-radius: 3px;\n\tcursor: pointer;\n\tbackground-position: 15% 58%;\n\tbehavior: url(css/PIE.htc);\n\t-ms-background-position-y: 20px;\n}\n\n.button_secondary_hover \n{\n\tbackground:#FFFFFF url(../images/common_imgs/arrow-magenta-grad-back.svg) no-repeat; \n\tbackground-size: 10px 17px;  \n\tfont-family: TeleNeo-Regular; \n\tfont-size: 28px; \n\tcolor: #E20074; \n\tpadding: 15px 30px 10px 45px;\n\tborder:1px solid #E20074; \n\tborder-radius:3px;\n\tbox-shadow: 0 0 4px #E20074;\n\tcursor: pointer;\n\tbackground-position: 15% 58%;\n\tbehavior: url(css/PIE.htc);\n\t-ms-background-position-y: 20px;\n}\n\t\n.overlay-loader { position:absolute;top:-0.05%;left:0px; padding: 45px 30px; text-align:center; z-index:20000; background:url(../images/common_imgs/white-transparent70.png); text-align:center; display:none; width :840px ;height:450px;}\n.overlaycontent-title-loader {font-family:TeleNeo-ExtraBold; font-size:70px; color:#E20074; text-align:center; padding-bottom: 35px;}\n.overlaycontent-infotext-loader {font-size:28px; color:#000000; text-align:center; padding-bottom: 40px;width:580px; padding-left:130px;}\n\t\n.overlaybutton_secondary {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 30px;border:1px solid #d2d2d2; border-radius:3px; cursor: pointer;}\n.overlaybutton_secondary_hover {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #E20074; padding: 15px 30px 10px 30px;border:1px solid #00aadd; border-radius:3px; box-shadow: 0 0 4px #66bddc;}\n.overlaybutton_secondary_deactivated {background:#FFFFFF; font-family: TeleNeo-Regular; font-size: 28px; color: #d8d8d8; padding: 15px 30px 10px 30px;border:1px solid #ebebeb; border-radius:3px; }\n\ninput.error, textarea.error \n{\n    background:#fff;\n    border:2.5px solid #FF3333;\n    border-radius:3px;\n    color:#666;\n    font-size:18px;\n    font-family:TeleNeo-Regular;\n    padding:4px 11px 4px 11px;\n    box-shadow: 0 0 4px #FF3333;\n}\n\n.error-msg-small \n{\n    font-size: 16px; \n    color:#cc0022; \n}\n    \n.error-msg-small img \n{\n    width: 29px;\n\theight: 29px;\n}\n\t\n.infobubble-down, .infobubble-up, .infobubble-left, .infobubble-right \n{ \n    font-size:15px; color: #E20074; \n    padding: 10px; \n    font-family: TeleNeo-Regular; \n    border: 1px solid #dbdbdb; \n    max-width:220px;\n}\n\n.infobubble-down {\n    background:#ededed; \n    border-bottom: 0px;\n}\n.infobubble-up {\n    background:#ededed; \n    border-top: 0px;\n}\n.infobubble-left {\n    background:#ededed;\n    border-left: 0px;\n}\n.infobubble-right {\n    background:#ededed; \n    border-right: 0px;\n}\n.nowrap{white-space: nowrap;}\n"
