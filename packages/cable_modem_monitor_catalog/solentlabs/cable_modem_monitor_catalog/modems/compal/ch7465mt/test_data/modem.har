            "text": "/*\r\n\tcheckpath.js\r\n*/\r\nfunction checkpath(){\r\n\tvar path = window.location.pathname;\r\n\tupdateGlobalSt();\r\n\tif(path === \"/\" || path === \"/index.html\")\r\n\t{\r\n\t\tvar URL = $(\"#content\").attr(\"name\");\r\n\t\tvar MoveTo = $(\".select_subtitle\").attr(\"name\");\r\n\t\tif (URL.match(MoveTo)?false:true)\r\n\t\t{\r\n\t\t\tsyncMenuConent(MoveTo);\r\n\t\t}\r\n\t}\r\n\telse\r\n\t\twindow.location.replace(\"/index.html\");\r\n}\r\n\r\nfunction updateGlobalSt(){\r\n\tif(GlobalSt != undefined){\r\n\t\tGlobalSt[\"waitTimeScreen\"] = false;\r\n\t\tGlobalSt[\"goto\"] = false;\r\n\t}else{\r\n\t\tGlobalSt = {\"VMFuncEn\" : false, \"waitTimeScreen\" : false , \"HideModemMode\" : true, \"title\": \"Connect Box\" ,\"goto\":false, \"HideRemoteAccess\":false};\r\n\t}\r\n}\r\n\r\nfunction syncMenuConent(MoveTo){\r\n\tNoticeCheckIsChange = nothingIsChange;\r\n\t$(\"#content\").empty();\r\n\tgoto(MoveTo+'.html','content');\r\n}\r\ncheckpath();"
