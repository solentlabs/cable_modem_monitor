            "text": "function CBN_Encrypt(EncryptString)\r\n{\r\n\tvar str = readCookie('sessionToken');\r\n\tconsole.log(str+\" \"+EncryptString);//DBG\r\n\tvar key = CryptoJS.SHA256(str);\r\n\tvar iv = CryptoJS.MD5(str);\r\n\tvar ciphertext = CryptoJS.AES.encrypt(//ciphertext=>binary and base64\r\n\t\t\t\t\t\tCryptoJS.enc.Utf8.parse(EncryptString),\r\n\t\t\t\t\t\tkey,\r\n\t\t\t\t\t\t{\r\n\t\t\t\t\t\t\tiv: iv,\r\n\t\t\t\t\t\t\tmode: CryptoJS.mode.CBC,\r\n\t\t\t\t\t\t\tpadding: CryptoJS.pad.Pkcs7\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t).toString();\r\n\tciphertext = CryptoJS.enc.Base64.parse(ciphertext);//ciphertext=>parse base64 and binary to string\r\n\treturn $.base64.encode( \":\" +ciphertext.toString());\r\n}\r\n\r\nfunction CBN_Decrypt(DecryptString)\r\n{\r\n\tDecryptString = $.base64.decode(DecryptString);\r\n\tDecryptString = DecryptString.substring(DecryptString.lastIndexOf(\":\") + 1);\r\n\tDecryptString = CryptoJS.enc.Hex.parse(DecryptString);\r\n\tDecryptString = DecryptString.toString(CryptoJS.enc.Base64);\r\n\tCSRF_Token = readCookie('sessionToken');\r\n\tvar key = CryptoJS.SHA256(CSRF_Token);\r\n\tvar iv = CryptoJS.MD5(CSRF_Token);\r\n\tvar bytes = CryptoJS.AES.decrypt(\r\n\t\t\tDecryptString,\r\n\t\t\tkey,\r\n\t\t\t{\r\n\t\t\t\tiv: iv,\r\n\t\t\t\tmode: CryptoJS.mode.CBC,\r\n\t\t\t\tpadding: CryptoJS.pad.Pkcs7\r\n\t\t\t});\r\n\tvar originalText = bytes.toString(CryptoJS.enc.Utf8);\r\n\treturn originalText;\r\n}\r\n\r\nfunction testread()\r\n{\r\n\tvar t = document.cookie.split('=');\r\n\tconsole.log('test:' + t[1]);\r\n}"
