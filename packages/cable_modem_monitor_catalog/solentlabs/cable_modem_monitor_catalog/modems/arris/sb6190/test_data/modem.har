bmg6 {}\n\n\n\n/* Wrappers for footer group (fg) */\n#fg1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid green;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fg1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\t\n#fg2 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid green;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fg2 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\t\n/* Wrappers for footer group (fg) */\n#fg3 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid green;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fg3 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\t\n#fg4 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid green;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fg4 {\n\t\twidth:\t\t\t\t957px;\n\t\t}\n\t/* pplu */\t\n\n#fg5 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid green;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fg5 {\n\t\twidth:\t\t\t\t869px;\n\t\theight:\t\t\t\t51px;\n\t\t}\n\t/* pplu */\n\n/* Unused. Available. */\n#fg6 {}\n#fg7 {}\n\n\n#logo_bottom {\n\tposition:\t\t\t\trelative;\n\tfloat:\t\t\t\t\tleft;\n\tborder:\t\t\t\t\t0px solid purple;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#logo_bottom {\n\t\t/* 1.5U */\n\t\ttop:\t\t\t\t5px;\n\t\t}\n\t/* pplu */\n\t\n\n#copyright {\n\tposition:\t\t\t\trelative;\n\tfloat:\t\t\t\t\tright;\n\tborder:\t\t\t\t\t0px solid purple;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#copyright {\n\t\t/* 1.5U */\n\t\ttop:\t\t\t\t19px;\n\t\twidth:\t\t\t\t429px;\n\t\theight:\t\t\t\t14px;\n\t\t}\n\t/* pplu */\n\n\n\n\n/* Wrappers for footer group bottom light (fgbl) */\n#fgbl1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fgbl1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n#fgbl2 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#fgbl2 {\n\t\twidth:\t\t\t\t100%;\n\t\t}