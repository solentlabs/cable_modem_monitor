            "text": "/*  I M A G E   A N D   C O L O R   S T Y L E S  */\n/*  Motorola Mobility - January 2013 - for SBG6582 */\n\n/*  Image and color styles are the image-loading styles\n\tand also the color style choices for framework items,\n\texcluding typographic objects. Always in pixels / hex. */\n\n#preloaded-images {\n\tposition:\t\t\t\t\tabsolute;\n\toverflow:\t\t\t\t\thidden;\n\tleft:\t\t\t\t\t\t-9999px;\n\ttop:\t\t\t\t\t\t-9999px;\n\tz-index:\t\t\t\t\t40000;\n\twidth:\t\t\t\t\t\t1px;\n\theight:\t\t\t\t\t\t1px;\n}\n\nbody {\n\tbackground-color:\t\t\t#31281F;\n\tbackground-image:\t\t\turl('/background.jpg'); \n\tbackground-repeat:\t\t\trepeat-x;\n}\n\nimg {\n\tborder:\t\t\t\t\t0px;\n\tpadding:\t\t\t\t0px;\n\tmargin:\t\t\t\t\t0px;\n}\n\n#hg1 {\n\tbackground-color:\t\t#2F2F2F;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg1 {}\n\t/* pplu */\n\n\n#hg2 {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg2 {\n\t\tbackground:             url('/back_header_compact.png');\n\t\tbackground-repeat:      repeat-x;\n\t\t}\n\t/* pplu */\n\n\n#hg3 {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg3 {\n\t\tbackground:             url('/back_ventHoles_compact.png');\n\t\tbackground-repeat:      repeat;\n\t\t}\n\t/* pplu */\n\t\nimg.binnacleWrapperShim  {\n\twidth:\t\t\t\t\t\t20px;\n\theight:\t\t\t\t\t\t43px;\n\t/* background-color:\t\t\tblue; */\n\tz-index:\t\t\t\t\t500;\n}\n\n#binnacleWrapperLeft {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperLeft {\n\t\tbackground:             url('/back_binnacleEndcaps.png');\n\t\tbackground-repeat:      no-repeat;\n\t\tbackground-position:\t0px 0px;\n\t\t}\n\t/* pplu */\n\n\t\n#binnacleWrapperMiddle {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperMiddle {\n\t\tbackground:             url('/back_binnacle.png');\n\t\tbackground-repeat:      repeat-x;\n\t\t}\n\t/* pplu */\t\n\n#binnacleWrapperRight {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperRigh