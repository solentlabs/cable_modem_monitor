            "text": "/*  L A Y O U T   S T Y L E S  */\n/*  Motorola Mobility - January 2013 - for SBG6582 */\n/*  Layout styles are the definitions for the box model\n\tframework/page layout. Always in pixels. */\n\n\n/* Wrappers for page (pw) */\n#pw1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid red;\n\tmin-width:\t\t\t980px;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#pw1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n/* Unused. Available. */\n#pw2 {}\n#pw3 {}\n#pw4 {}\n\n\n\n\n/* Wrappers for header group (hg) */\n#hg1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid blue;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n#hg2 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid blue;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg2 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n#hg3 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid blue;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg3 {\n\t\twidth:\t\t\t\t100%;\n\t\theight:\t\t\t\t113px;\n\t\t}\n\t/* pplu */\n\n\n#hg4 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid blue;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg4 {\n\t\twidth:\t\t\t\t957px;\n\t\theight:\t\t\t\t140px;\n\t\t}\n\t/* pplu */\n\t\n#hg5 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid blue;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#hg5 {\n\t\twidth:\t\t\t\t869px;\n\t\theight:\t\t\t\t140px;\n\t\t}\n\t/* pplu */\n\n\n/* Unused. Available. */\n#hg6 {}\n#hg7 {}\n\n\n#logo {\n\tposition:\t\t\t\trelative;\n\tfloat:\t\t\t\t\tleft;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#logo {\n\t\ttop:\t\t\t\t16px;\n\t\theight:\t\t\t\t42px;\n\t\t}\n\t/* pplu */\n\t\n#binnacleWrapper1 {\n\tposition:\t\t\t\trelative;\n\toverflow:\t\t\t\tvisible;\n\tfloat:\t\t\t\t\tright;\n\tz-index:\t\t\t\t800;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapper1 {\n\t\ttop:\t\t\t\t34px;\n\t\theight:\t\t\t\t43px;\n\t\t}\n\t/* pplu */\n\n.binnacleItems_0 {\n\twidth:\t\t\t\t\t250px;\n}\n\n.binnacleItems_1 {\n\twidth:\t\t\t\t\t290px;\n}\n\n.binnacleItems_2 {\n\twidth:\t\t\t\t\t330px;\n}\n\n.binnacleItems_3 {\n\twidth:\t\t\t\t\t370px;\n}\n\n.binnacleItems_4 {\n\twidth:\t\t\t\t\t410px;\n}\n\n.binnacleItems_5 {\n\twidth:\t\t\t\t\t450px;\n}\n\n.binnacleItems_6 {\n\twidth:\t\t\t\t\t490px;\n}\n\n.binnacleItems_7 {\n\twidth:\t\t\t\t\t530px;\n}\n\n.binnacleItems_8 {\n\twidth:\t\t\t\t\t570px;\n}\n\n.binnacleItems_9 {\n\twidth:\t\t\t\t\t140px;\n}\n\n#binnacleWrapper2 {}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapper2 {\n\t\toverflow:\t\t\t\tvisible;\n\t\tpadding-left:\t\t\t20px;\n\t\tpadding-right:\t\t\t20px;\n\t\tz-index:\t\t\t\t801;\n\t\t}\n\t/* pplu */\n\t\n#binnacleWrapperLeft {\n\tposition:\t\t\t\tabsolute;\n\tleft:\t\t\t\t\t0px;\n\tz-index:\t\t\t\t802;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperLeft {\n\t\twidth:\t\t\t\t20px;\n\t\theight:\t\t\t\t43px;\n\t\t}\n\t/* pplu */\n\n#binnacleWrapperMiddle {\n\tposition:\t\t\t\tabsolute;\n\tleft:\t\t\t\t\t20px;\n\tright:\t\t\t\t\t20px;\n\tz-index:\t\t\t\t802;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperMiddle {\n\t\theight:\t\t\t\t43px;\n\t\t}\n\t/* pplu */\n\n#binnacleWrapperRight {\n\tposition:\t\t\t\tabsolute;\n\tright:\t\t\t\t\t0px;\n\tz-index:\t\t\t\t802;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleWrapperRight {\n\t\twidth:\t\t\t\t20px;\n\t\theight:\t\t\t\t43px;\n\t\t}\n\t/* pplu */\n\n#binnacleInnards {\n\tposition:\t\t\t\trelative;\n\toverflow:\t\t\t\tvisible;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleInnards {\n\t\ttop:\t\t\t\t9px;\n\t\theight:\t\t\t\t26px;\n\t\t}\n\t/* pplu */\n\n#binnacleModelName {\n\tposition:\t\t\t\trelative;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleModelName {\n\t\toverflow:\t\t\thidden;\n\t\theight:\t\t\t\t26px;\n\t\t}\n\t/* pplu */\n\t\n#binnacleModelName .registeredTrademark {\n\tposition:\t\t\trelative;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleModelName .registeredTrademark {\n\t\ttop:\t\t\t\t-0.4em;\n\t\t}\n\t/* pplu */\n\t\n\n#binnacleLogout {\n\tposition:\t\t\t\trelative;\n\tfloat:\t\t\t\t\tright;\n\t/* background-color:\t\tyellow; */\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleLogout {\n\t\ttop:\t\t\t\t\t4px;\n\t\tmargin-left:\t\t\t12px;\n\t\twidth:\t\t\t\t\t51px;\n\t\theight:\t\t\t\t\t19px;\n\t\t}\n\t/* pplu */\n\n#binnacleLogoutText {\t\t\n\tposition:\t\t\tabsolute;\n\tfloat:\t\t\t\t\tleft;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleLogoutText {\n\t\twidth:\t\t\t\t51px;\n\t\theight:\t\t\t\t19px;\n\t\t}\n\t/* pplu */\n\n.logoutButton {\n\tposition:\t\t\t\trelative;\n\tdisplay:\t\t\t\tinline;\n\tpadding:\t\t\t\t0px;\n\tmargin:\t\t\t\t\t0px;\n\tcursor:\t\t\t\t\tpointer;\n\t/* background-color:\t\tyellow; */\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.logoutButton {\n\t\twidth:\t\t\t\t\t51px;\n\t\theight:\t\t\t\t\t19px;\n\t\t}\n\t/* pplu */\n\t\n\n/*  F L O A T E R  */\n\n/* To use vertCenterWrap 1, 2, and 3, a height must be specified on\nthe vertCenterWrap1 classed div. Do this with another class on the\nsame div. */\n\n.vertCenterWrap1  {\n\tdisplay: \t\t\t\ttable; \n\t#position: \t\t\t\trelative; \n\toverflow: \t\t\t\thidden;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.vertCenterWrap1  {}\n\t/* pplu */\n\n.vertCenterWrap2 {\n\t#position: \t\t\t\tabsolute;\n\t#top: \t\t\t\t\t50%;\n\tdisplay: \t\t\t\ttable-cell;\n\tvertical-align: \t\tmiddle;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.vertCenterWrap2 {}\n\t/* pplu */\n\t\n.vertCenterWrap3 {\n\t#position:\t\t\t\trelative;\n\t#top:\t\t\t\t\t-50%;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.vertCenterWrap3 {}\n\t/* pplu */\n\n\t\n/*  H O M E  */\n\t\n#wrapperHome {\n\tmargin:\t\t\t\t\t0 auto;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#wrapperHome {\n\t\twidth:\t\t\t\t\t\t939px;\n\t\theight:\t\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\n\t\n#containerHomeItems {\n\tposition:\t\t\t\trelative;\n\tz-index:\t\t\t\t205;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#containerHomeItems {\n\t\tleft:\t\t\t\t\t30px;\n\t\twidth:\t\t\t\t\t879px;\n\t\theight:\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\n\t\n#homeLeftBarWrapper {\n\tfloat:\t\t\t\t\tleft;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarWrapper {\n\t\twidth:\t\t\t\t\t539px;\n\t\theight:\t\t\t\t\t215px;\n\t\tmargin-top:\t\t\t\t169px;\n\t\t}\n\t/* pplu */\n\n.homeLeftBarHitBox {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t210;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeLeftBarHitBox {\n\t\twidth:\t\t\t\t\t539px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\n\t\n#homeLeftBarContentWrapper {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t200;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarContentWrapper {\n\t\twidth:\t\t\t\t\t539px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\n\t\n#homeLeftBarContent {\n\tposition:\t\t\t\tabsolute;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarContent {\n\t\twidth:\t\t\t\t\t523px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\n\n#homeLeftBarContentIcon {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarContentIcon {\n\t\twidth:\t\t\t\t\t100px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\t\n\t\n#homeLeftBarContentText {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarContentText {\n\t\twidth:\t\t\t\t\t423px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\n\n.hlbcv1 {\n\tdisplay:\t\t\t\ttable;\n\tposition:\t\t\t\trelative;\n\toverflow:\t\t\t\thidden;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hlbcv1 {\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\t\n\t\n.hlbcv2 {\n\t*position: \t\t\t\tabsolute; \n\ttop: \t\t\t\t\t50%;\n\tdisplay: \t\t\t\ttable-cell;\n\tvertical-align: \t\tmiddle;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hlbcv2 {}\n\t/* pplu */\t\n\t\n.hlbcv3 {\n\tposition: \t\t\t\trelative;\n\ttop: \t\t\t\t\t-50%;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hlbcv3 {\n\t\tmargin-left:\t\t\t10px;\n\t\tmargin-right:\t\t\t20px;\n\t\t}\n\t/* pplu */\t\n\t\n.homeLeftBarUnderBox {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t190;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeLeftBarUnderBox {\n\t\twidth:\t\t\t\t\t539px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\t\n\n#homeLeftBarRightShadow  {\n\tfloat:\t\t\t\t\tright;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeLeftBarRightShadow  {\n\t\twidth:\t\t\t\t\t16px;\n\t\theight:\t\t\t\t\t143px;\n\t\t}\n\t/* pplu */\n\t\n#homeRightBarWrapper  {\n\tfloat:\t\t\t\t\tright;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapper {\n\t\twidth:\t\t\t\t\t340px;\n\t\theight:\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\t\n\t\n#homeRightBarWrapperSpacerTop.numVisibleItems_1  {\n\tfloat:\t\t\t\t\tleft;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_1 {\n\t\theight:\t\t\t\t\t200px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\t\n\t\n\n#homeRightBarWrapperSpacerTop.numVisibleItems_2  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_2 {\n\t\theight:\t\t\t\t\t162px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\n#homeRightBarWrapperSpacerTop.numVisibleItems_3  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_3 {\n\t\theight:\t\t\t\t\t120px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n#homeRightBarWrapperSpacerTop.numVisibleItems_4  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_4 {\n\t\theight:\t\t\t\t\t80px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n#homeRightBarWrapperSpacerTop.numVisibleItems_5  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_5 {\n\t\theight:\t\t\t\t\t50px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n#homeRightBarWrapperSpacerTop.numVisibleItems_6  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#homeRightBarWrapperSpacerTop.numVisibleItems_6 {\n\t\theight:\t\t\t\t\t5px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n.homeRightBarItemWrapper  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeRightBarItemWrapper {\n\t\theight:\t\t\t\t\t77px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n.homeRightBarHitBox  {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t210;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeRightBarHitBox {\n\t\theight:\t\t\t\t\t77px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\n.homeRightBarContentBox  {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t200;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeRightBarContentBox {\n\t\theight:\t\t\t\t\t77px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n.homeRightBarUnderBox   {\n\tposition:\t\t\t\tabsolute;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeRightBarUnderBox  {\n\t\theight:\t\t\t\t\t77px;\n\t\twidth:\t\t\t\t\t340px;\n\t\t}\n\t/* pplu */\n\t\n.homeMenuItemIcon  {\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeMenuItemIcon {\n\t\twidth:\t\t\t\t\t50px;\n\t\theight:\t\t\t\t\t50px;\n\t\tmargin-top:\t\t\t\t12px;\n\t\tmargin-left:\t\t\t18px;\n\t\tmargin-right:\t\t\t16px;\n\t\t}\n\t/* pplu */\n\t\n.homeMenuItemDescription  {\n\tfloat:\t\t\t\t\tright;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homeMenuItemDescription {\n\t\twidth:\t\t\t\t\t256px;\n\t\theight:\t\t\t\t\t77px;\n\t\t}\n\t/* pplu */\n\t\n.hmidv1 {\n\tdisplay:\t\t\t\ttable;\n\tposition:\t\t\t\trelative;\n\toverflow:\t\t\t\thidden;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hmidv1 {\n\t\theight:\t\t\t\t\t77px;\n\t\t}\n\t/* pplu */\n\t\n.hmidv2 {\n\t*position: \t\t\t\tabsolute; \n\ttop: \t\t\t\t\t50%;\n\tdisplay: \t\t\t\ttable-cell;\n\tvertical-align: \t\tmiddle;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hmidv2 {}\n\t/* pplu */\n\n.hmidv3 {\n\tposition: \t\t\t\trelative;\n\ttop: \t\t\t\t\t-50%;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.hmidv3 {\n\t\tmargin-right:\t\t\t10px;\n\t\t}\n\t/* pplu */\n\t\n#wrapperShadows {\n\tposition:\t\t\t\tabsolute;\n\tz-index:\t\t\t\t200;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#wrapperShadows {\n\t\twidth:\t\t\t\t\t939px;\n\t\theight:\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\n\t\n#containerPhotos {\n\tposition:\t\t\t\trelative;\n\tz-index:\t\t\t\t198;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#containerPhotos {\n\t\tleft:\t\t\t\t\t30px;\n\t\twidth:\t\t\t\t\t879px;\n\t\theight:\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\n\t\n.homePhoto {\n\tposition:\t\t\t\tabsolute;\n\tfloat:\t\t\t\t\tleft;\n\t}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.homePhoto {\n\t\twidth:\t\t\t\t\t879px;\n\t\theight:\t\t\t\t\t476px;\n\t\t}\n\t/* pplu */\n\n\n\n/*   H E L P   I L L U S T R A T I O N S  */\n\n.helpIllustrationWrap1 {\n\tdisplay:\t\t\tblock;\n\tposition:\t\t\trelative;\n\tfloat:\t\t\t\tleft;\n\twidth:\t\t\t\t850px;\n\theight:\t\t\t\t250px;\n\tmargin-top:\t\t\t10px;\n\tmargin-bottom:\t\t25px;\n}\n\n.helpIllustrationWrap2 {\n\tdisplay:\t\t\tblock;\n\tposition:\t\t\tabsolute;\n\twidth:\t\t\t\t850px;\n\theight:\t\t\t\t250px;\n\toverflow:\t\t\thidden;\n\tz-index:\t\t\t101;\n}\n\n.helpIllustrationTextWrap {\n\tdisplay:\t\t\tblock;\n\tposition:\t\t\tabsolute;\n\tz-index:\t\t\t101;\n}\n\n.helpIllustrationTextWrap span {\n\tdisplay:\t\t\tblock;\n\tposition:\t\t\trelative;\n}\n\n\n\n/* gap (vertical) wrappers, one id per gap\nAs the gaps are a reused, repeating element they are classed rather than IDed\nBut, one structural \"hook\" ID is provided around each gap\ntop menu top gap = tmtg \ntop menu bottom gap = tmbg\nbottom menu top gap = bmtg\nbottom menu bottom gap = bmbg\n*/\n#tmtg, #tmbg, #bmtg, #bmbg {}\n\n\n/* Wrappers for top menu top gap (tmtg) */\n.gap1 {\n\tmargin:\t\t\t\t0 auto;\n\twidth:\t\t\t\t100%;\n\tborder:\t\t\t\t0px solid black;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.gap1 {}\n\t/* pplu */\n\n.gap2 {\n\tmargin:\t\t\t\t0 auto;\n\twidth:\t\t\t\t100%;\n\tborder:\t\t\t\t0px solid black;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t.gap2 {\n\t\theight:\t\t\t\t14px;\n\t}\n\t/* pplu */\n\n\n/* Unused. Available. */\n.gap3 {}\n.gap4 {}\n\n\n\n/* Wrappers for top menu group (tmg) */\n#tmg1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#tmg1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\t\n\n#tmg2 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#tmg1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n\n#tmg3 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#tmg3 {\n\t\twidth:\t\t\t\t957px;\n\t\t}\n\t/* pplu */\n\t\n#tmg4 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid pink;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#tmg4 {\n\t\theight:\t\t\t\t49px;\n\t\twidth:\t\t\t\t869px;\n\t\t}\n\t/* pplu */\n\n/* Unused. Available. */\n#tmg5 {}\n#tmg6 {}\n\n\n\n/* Wrappers for body group (bg) */\n#bg1 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid yellow;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#bg1 {\n\t\twidth:\t\t\t\t100%;\n\t\t}\n\t/* pplu */\n\n#bg2 {\n\tmargin:\t\t\t\t0 auto;\n\tborder:\t\t\t\t0px solid purple;\n}\n\t/* blue - U11/7 - serves 102