            "text": "/*  M A S T E R   S T Y L E S H E E T   */\n\n* { \n\tmargin:0; padding:0; \n}\n\nhtml {\n\t/* solve IE7 font-scaling inconsistency */\n\tfont-size: \t\t\t\t\t100%;\n\t\n\t/* phase2 required to keep iPhone text size from enlarging on rotation\n\t\tfrom portrait to landscape \n\t-webkit-text-size-adjust: none; */\n\t}\n\nbody {\n\tfont-family:\t\t\t\thelvetica, arial, sans-serif;\n\t/* set base font size so EMs can be evenly used and applied. */\n\tfont-size:\t\t\t\t\t1.0em;\n\t/* SET NEXT LINE TO RED TO FIND UNMANAGED TEXT ITEMS */\n\tcolor:\t\t\t\t\t\t#000000;\n\t/* word-wrap:          \t\tbreak-word; */\n\twidth:\t\t\t\t\t\t100%;\n\t/* min-width set to ensure spread of page */\n\tmin-width:\t\t\t\t\t980px;\n\tmargin:\t\t\t\t\t\t0px;\n\tpadding:\t\t\t\t\t0px;\n\tborder:\t\t\t\t\t\t0px;\n\t/*  star text-align:\t\tcenter; */\n}\n\n\nh1,h2,h3,h4,h5,h6,ul,li,em,strong,pre,code{\n\tpadding:0;\n\tmargin:0;\n\tline-height:1em;\n\tfont-size:100%;\n\tfont-style: normal;\n}\n\ntable{\n\tfont-size:inherit;font:100%;\n\t}\n\t\nul{\n\tlist-style:none;\n}\n\n\n\n/**************** this container surrounds all other divs giving them their percentage-based width ******************************/\n.container {\n\tborder:\t\t\t\t0px solid yellow;\n\twidth:\t\t\t\t869px;\n\tmargin: 0 auto;\n\n}\n\n\n\n/*********** Text and content  ***********/\n\nh2 {\n\tfont-family:Arial, Helvetica, sans-serif;\n\tfont-size:.775em;\n\tmargin-bottom:0px;\n\tfont-style:italic;\n\twidth:100%;\n\tfloat:left;\n}\n\nh3 {\n\tfont-family:Arial, Helvetica, sans-serif;\n\tfont-size:1.45em;\n\tmargin-bottom:0.5em;\n\tfont-weight:bold;\n\twidth:100%;\n\tfloat:left;\n\tmargin-top:0.5em; \n\t\t\n}\t\n\nh4 {\n\tfont-family:Arial, Helvetica, sans-serif;\n\tfont-size:1.1em;\n\tmargin-bottom:0.5em;\n\tfont-weight:bold;\n\twidth:100%;\n\tfloat:left;\n\tmargin-top:0.5em; \n\t\t\n}\t\n\n.content {}\n\n.content p {\n\tfont-size:\t\t\t1.0em;\n}\n\n\n.introText {\n\tpadding-bottom:\t\t\t25px;\n}\n\n.introText p {\n\tdisplay:\t\t\tblock;\n\tfont-size:\t\t\t1.0em;\n\tline-height:\t\t1.4em;\n}\n\n.extendedText {}\n\n.subHeadcontent {\n\tfont-size:2.0em;\n\tfont-weight:bold;\n\tcolor:#000;\t\n}\n\n\n/*************** MtaProvisioning page controls and text wrap ***************/\n.wrapper {\n    border: 1px solid #666;\n\tline-height:inherit;\n    overflow:hidden;\n\tword-wrap:break-word;\n\twhite-space: pre-wrap;\n\tposition:\trelative;\n}\n\n.title {\n    background:#fff url(/header_bkg.png) repeat-x scroll center left; \n\tcolor:#fff; \n\tpadding:0.238em 0.938em;\n\tfont-family:Arial, Helvetica, sans-serif; \n\ttext-align:center; \n\tfont-size:1.34em;\n\tfont-weight:bold;\n}\n\n\n\n\n/*************** miscellaneous float/clear classes ***************/\n\n\n.clearfloat { /* this class can be placed on a <br /> or empty div as the final element following the last floated div (within the #container) */\n\tclear:both;\n\theight:0;\n\tfont-size: 1px;\n\tline-height: 0px;\n}\n\n\ninput[type=\"submit\"], input[type=\"reset\"], input[type=\"button\"] {\n\tfont-size:\t\t0.9em;\n\tpadding-left:\t3px;\n\tpadding-right:\t3px;\n\tpadding-top:\t3px;\n\tpadding-bottom:\t3px;\n\tmargin-left:\t3px;\n\tmargin-right:\t3px;\n\tmargin-top:\t\t1px;\n\tmargin-bottom:\t1px;\n\tposition:\t\trelative;\n\ttop:\t\t\t0px;\n\tdisplay:\t\tinline;\n}\n\n\ninput[type=\"file\"] {\n\tfont-size:\t\t0.9em;\n}\n\ninput[type=\"radio\"] {\n\tfont-size:\t\t0.9em;\n\tmargin-right:\t5px;\n\tposition:\t\trelative;\n\tdisplay:\t\tinline; \n\ttop:\t\t\t2px;\n}\n\n\n\n\n/********************* Top Bar Menu ***********************/\n\n#uberAwesomeMenu {\n\tposition:\t\t\trelative;\n\tlist-style: \t\tnone;\n\tz-index:\t\t\t500;\n\tmargin-left:\t\t0px;\n\t/* 79U */\n\twidth:\t\t\t\t869px;\n\t/* 7U */\n\theight:\t\t\t\t49px;\n\tfont-weight: \t\tbold;\n\tfont-size:\t\t\t0.7em;\n}\n\n#uberAwesomeMenu a {\n\ttext-decoration:\tnone;\n\tcolor:\t\t\t\t#000000;\n\tdisplay:\t\t\tblock;\n\twidth:\t\t\t\tinherit;\n\theight:\t\t\t\tinherit;\n}\n\n#uberAwesomeMenu li {\n    cursor: pointer;\n}\n\n#uberAwesomeMenu li.mainMenu {\t\n\tfloat:\t\t\t\tleft;\n\t/* 7U */\n\theight:\t\t\t\t49px;\n\tline-height:\t\t49px;\n\ttext-align:\t\t\tcenter;\n\tborder-left:\t\t1px solid black;\n\ttext-decoration:\tnone;\n\tcolor:\t\t\t\t#000000;\n\twidth:\t\t\t\tinherit;\n\theight:\t\t\t\tinherit;\n\tdisplay:\t\t\tblock;\n\tbackground: \t\turl('/px1_Ux.png');\n}\n\n#uberAwesomeMenu li.mainMenu:hover {\t\n\tbackground-color:\t#0199C6;\n\tcolor:\t\t\t\t#FFFFFF;\n}\n\n#uberAwesomeMenu li.mainMenu:hover a {\t\n\tcolor:\t\t\t\t#FFFFFF;\n}\n\n#uberAwesomeMenu.mainMenu li.mainMenuItems_4  {width: 216px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_5  {width: 172px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_6  {width: 143px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_7  {width: 123px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_8  {width: 107px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_9  {width: 95px;}\n#uberAwesomeMenu.mainMenu li.mainMenuItems_10  {width: 85px;}\n\n\n#uberAwesomeMenu ul.subMenu {\n\tbackground:\t\t\t#EEEEEE;\n\tborder-left:\t\t1px solid #0199C6;\n\tborder-right:\t\t1px solid #0199C6;\n\tborder-bottom:\t\t1px solid #0199C6;\n\t/* 19U */\n\twidth: \t\t\t\t209px;\n}\n\n#uberAwesomeMenu li.subMenu {\n\ttext-align:\t\t\tleft; \n\tfont-size:\t\t\t1.1em;\n\tfont-weight:\t\tbold;\n\t/* 5U */\n\tline-height:\t\t35px;\n\tborder-top:\t\t\t1px solid #CCCCCC;\n}\n\n#uberAwesomeMenu .subMenu a {\t\n\t/* 5U */\n\tline-height:\t\t35px;\n\tpadding-left:\t\t11px;\n}\n\n#uberAwesomeMenu .subMenu li a, #uberAwesomeMenu .subMenu li a:link, #uberAwesomeMenu .subMenu li a:visited, #uberAwesomeMenu .subMenu li a:active {\n\tcolor:\t\t\t\t#0199C6;\n}\n\n#uberAwesomeMenu .subMenu li a:hover {\n\tcolor:\t\t\t\t#FFFFFF;\n}\n\n#uberAwesomeMenu .subMenu li:hover {\n\tbackground-color:\t#0199C6;\n}\n\n#uberAwesomeMenu .subMenu li:hover a {\n\tcolor:\t\t\t\t#FFFFFF;\n}\n\n#uberAwesomeMenu .mainMenuLast {\n\t\tborder-right:\t1px solid black;\n}\n\n\n\n\n/* BOTTOM MENU STYLES */\n\n#uberSiteMap {\n\tposition:\t\t\trelative;\n\tlist-style: \t\tnone;\n\tz-index:\t\t\t200;\n\tmargin-left:\t\t0px;\n\t/* 79U */\n\twidth:\t\t\t\t869px;\n\t/* 7U */\n\tfont-weight: \t\tbold;\n\tfont-size:\t\t\t0.7em;\n\tpadding-bottom:\t\t0px;\n\tmargin-bottom:\t\t0px;\n}\n\n\n#uberSiteMap li.mainMenuB {\t\n\tfloat:\t\t\t\tleft;\n\ttext-align:\t\t\tleft;\n\t/* 2U */\n\tline-height:\t\t1.0em;\n\t/* 1U */\n\tpadding-top:\t\t11px;\n\tpadding-bottom:\t\t11px;\n}\n\n#uberSiteMap.mainMenuB li.mainMenuItems_4  {width: 209px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_5  {width: 165px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_6  {width: 135px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_7  {width: 114px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_8  {width: 97px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_9  {width: 85px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuItems_10  {width: 75px; padding-right: 11px;border: 0px solid purple;}\n#uberSiteMap.mainMenuB li.mainMenuLast {padding-right: 0px; border: 0px solid red;}\n\n#uberSiteMap .mainMenuB a, #uberSiteMap .mainMenuB a:link, #uberSiteMap .mainMenuB a:visited, #uberSiteMap .mainMenuB li a:active {\n\tcolor:\t\t\t\t#000000;\n\ttext-decoration:\tnone;\n}\n\n#uberSiteMap .mainMenuB a:hover {\n\tcolor:\t\t\t\t#0199C6;\n}\n\n#uberSiteMap ul.subMenuB {\n\t/* 0.5U */\n\tpadding-top:\t\t6px;\n}\n\n#uberSiteMap li.subMenuB {\n\ttext-align:\t\t\tleft; \n\tfont-size:\t\t\t1.0em;\n\tfont-weight:\t\tbold;\n\t/* 1.5U */\n\tline-height:\t\t1.0em;\n\t/* 0.5U */\n\tpadding-bottom:\t\t7px;\n}\n\n#uberSiteMap .subMenuB a {\t\n\t/* 1.5U */\n\ttext-decoration:\tnone;\n\tline-height:\t\t1.0em\n}\n\n#uberSiteMap .subMenuB li a, #uberSiteMap .subMenuB li a:link, #uberSiteMap .subMenuB li a:visited, #uberSiteMap .subMenuB li a:active {\n\tcolor:\t\t\t\t#666666;\n}\n\n#uberSiteMap .subMenuB li:hover a {\n\tcolor:\t\t\t\t#0199C6;\n}\n\n#uberSiteMap .mainMenuLast {}\n\n\n\n/************ Positioning for header and header elements, motorola logo, welcome, logout and breadcrumbs  ******************/\n\n/*********************** the header will extend the full width of the layout. **********************************************/\n\n\n.subHeader {\n\theight:\t\t\t\t57px;\n\tmargin-left:\t\t0px;\n\tpadding-top:\t\t20px;\n\tborder:\t\t\t\t0px solid blue;\n}\n\n\n/* hiding breadcrumbs */\n.breadcrumbs {\n\tdisplay:\t\tnone;\n}\n\n\n\n\n/**********************  Tables   *********************************/\n.techButton {\n\tfloat:left;\n}\n\n.simpleTable {\n\tfont-size:\t\t\t0.9em;\n\tborder-spacing: 0em;\n\twidth:100%;\n\tfloat:left;\n\tborder-collapse:collapse;\n\tmargin-bottom:20px;\n}\n\n.simpleTable th {\n    background:#7DD4EE url(/header_bkg.png) repeat-x; \n\tcolor:#fff; \n\tpadding:\t\t0px;\n\tpadding-left:\t10px;\n\tpadding-right:\t10px;\n\tpadding-top:\t5px;\n\tpadding-bottom:\t5px;\n\ttext-align:center; \n\tfont-size:1.4em;\n\tfont-weight:bold;\n\tbackground-position:\ttop;\n}\n\t\nth.subTitleRow {\n\tfont-size:\t\t\t1.0em;\n\ttext-align:\t\t\tleft;\n\tpadding-top:\t\t5px;\n\tpadding-bottom:\t\t5px;\n}\n\n.simpleTable tr { \n\tbackground:#FBFCFB url(/row_bkg.png) repeat-x;\n\tvertical-align:middle;\n\tcursor:default; \n\tbackground-position:\tbottom;\n}\n\n.simpleTable tr.even { \n\tbackground:#fff;\n\twidth:200%;\n\tz-index:0;\n\tcursor:default; \n}\n \n.simpleTable tr.none { \n\tbackground:#fff;\n\twidth:200%;\n\tz-index:0;\n\tcursor:default; \n }\n\n.simpleTable td {\n\tpadding:\t\t0px;\n\tpadding-left:\t10px;\n\tpadding-right:\t10px;\n\tpadding-top:\t3px;\n\tpadding-bottom:\t3px;\n\tcursor:\t\tdefault;\n\tvertical-align: middle;\n\theight:\t\t\t30px;\n}\n\n.simpleTable p {\n\tfont-size:12px;\n\tline-height:1.4;\n }\n\n.white\t{\n\tbackground-color:#FFFFFF;\n}\n\n\t\n.stClients {\n\twidth:100%;\n\tmargin-left:1.45em;\n\t}\n\t\n.stGuest {\n\twidth:95%;\n\tmargin-left:1.45em;\n\t}\n\t\n.stNarrow {\n\tmargin-top:25px;\n\twidth:95%;\n\tmargin-left:1.05em;\n}\n\n.stSlim {\n\tmargin-top:25px;\n\twidth:25%;\n\tmargin-left:4.38em;\n}\n\n.errorHighlight, .errorMessage, .warningHighlight, .warningMessage {\n\tcolor:\t\t\t#E31B23;\n\tfont-weight:\tbold;\n}\n\n.cautionHighlight, .cautionMessage {\n\tcolor:\t\t\t#E87511;\n\tfont-weight:\tbold;\n}\n\n.confirmHighlight, .confirmMessage {\n\tcolor:\t\t\t#3D8E33;\n\tfont-weight:\tbold;\n}\n\n\n/************************** Footer  *****************************/\n\n\n\n#siteMapBottom .siteMap {\n\tfont-size:\t\t\t\t0.7em;\n\ttext-align:\t\t\t\tleft;\n\tborder-spacing: 0px;\n\tposition:relative;\n\tpadding-bottom:10px;\n\tline-height:1.65em;\n}\n\n#siteMapBottom .siteMap th {\n\twidth:\t\t\t\t140px;\n\tfont-size:\t\t\t1.0em;\n\tfont-weight:bold;\n\tcolor:\t\t\t\t#252525;\n}\n\n#siteMapBottom .siteMap a, .siteMap a:link, .siteMap a:visited, .siteMap a:active {\n\tfont-size:10px;\n\tfont-weight:normal;\n\tcolor:\t\t\t\t#5A5A5A;\n\ttext-decoration:none;\n\tword-wrap:break-word;\n\tline-height:\t\t\t8px;\n}\n\n#siteMapBottom .siteMap a:hover {\n\ttext-decoration:\tunderline;\n\tcolor:\t\t\t\t#F4AF00;\n}\n\n\n\n/****************  Tabs  ************************************************************/\n\n.tabs {\n\tcursor:pointer;\t\t\n}\n\t\n.tabs > div {\n\tfloat:left;\n}\n\t\n\t\n.tabNormal, .tabSelected, .tabDisabled, .tabHover, .tabHoverDisabled {\n\tfont-weight:\t\t\tbold;\n\ttext-decoration:\t\tnone;\n\tpadding-left:\t\t\t20px;\n\tpadding-right:\t\t\t20px;\n\t-moz-border-radius: \t14px 14px 0 0;\n\t-webkit-border-radius: \t14px 14px 0 0;\n\tcursor:\t\t\t\t\tpointer;\t\n\t}\n\n.tabNormal {\n\tfont-size:\t\t\t\t1.1em;\n\tline-height:\t\t\t40px;\n\theight:\t\t\t\t\t40px;\n\tcolor: \t\t\t\t\t#AAA;\t\t\t\n\tbackground-color:\t\t#2493B5;\n\tborder-bottom: \t\t\t1px solid #999999;\n\tborder-left:\t\t\t1px solid #999999;\n}\n\n\n.tabSelected {\n\tfont-size:\t\t\t\t1.4em;\n\tline-height:\t\t\t40px;\n\theight:\t\t\t\t\t40px;\n\tcolor:\t\t\t\t\t#FFF;\n\tbackground-color:\t\t#19A6CF;\n\tborder-bottom: \t\t\t1px solid #19A6CF;\n\tborder-right:\t\t\t0px solid #FF0000;\n}\n\n.tabDisabled {\n\tcolor: #777;\t\t\t\n\tbackground-color:\t\t#DDD;\n\ttext-decoration:none;\n}\n\n.tabNormal.radioTab:hover {\n\tcolor: \t\t\t\t\t#fff;\t\t\t\t\n\tbackground:\t\t\t\t#02b9da;\n\ttext-decoration:\t\tnone;\n}\n\n.tabSelected.radioTab:hover {\n\tcolor: \t\t\t\t\t#fff;\t\t\t\t\n\tbackground:\t\t\t\t#19A6CF;\n\ttext-decoration:\t\tnone;\n}\n\n.tabNormal.tab24.radioTab:hover {\n\tcolor: \t\t\t\t\t#fff;\t\t\t\t\n\tbackground:\t\t\t\t#283E85;\n\ttext-decoration:\t\tnone;\n}\n\n.tabSelected.tab24.radioTab:hover {\n\tcolor: \t\t\t\t\t#fff;\t\t\t\t\n\tbackground:\t\t\t\t#283E85;\n\ttext-decoration:\t\tnone;\n}\n\n.tabHoverDisabled {\n\tcolor: \t\t\t\t\t#FFF;\t\t\t\n\tbackground-color:\t\t#7DD4EE;\n\ttext-decoration:\t\tnone;\n}\n\n.tab24.tabNormal {\n\tbackground-color:\t\t#4F5B85;\n}\n\n.tab24.tabSelected {\n\tbackground-color:\t\t#283E85;\n\tborder-bottom: \t\t\t1px solid #283E85;\n}\n\nth.tab24Row, .tab24Row th {\n\tcolor:\t\t\t\t\t#FFFFFF;\n\tbackground:\t\t\t\tnone;\n\tbackground:\t\t\t\turl(/header_bkg_alt2.png);\n\tbackground-repeat:\t\trepeat-x;\n\tbackground-position:\tbottom; \n\tbackground-color:\t\t#283E85;\n}\n\n#tabMessage {\n\tfloat:\t\t\t\t\tleft;\n\twidth:\t\t\t\t\t550px;\n\theight:\t\t\t\t\t40px;\n\tline-height:\t\t\t40px;\n\tpadding-left:\t\t\t30px;\n\tcolor:\t\t\t\t\t#363636;\n\tcursor:\t\t\t\t\tdefault;\n}\n\n\n\t\n/**************** Table help sections  ******************************/\n\n.helpClick {\n\twidth:\t\t60px;\n}\n\n.helpClick, .helpClickEmpty {\n\twidth:\t\t60px;\n}\n\n\n.helpPop, helpClickEmpty {\n\tpadding-left:25px;\n}\n\n.helpDetail TD {\n\tpadding:0px;\n\tmargin:0px;\n\tbackground-color: none;\n}\n\n.helpBox {\n\tfont-size:0.9em;\n\tline-height:1.4em;\n\ttext-align:\tleft;\n\tpadding:10px;\n\tbackground-color: #FDFDFD;\n\tborder-top:\t\t\t1px solid #CCCCCC;\n\tborder-bottom:\t\t1px solid #AAAAAA;\n\tborder-left:\t\t1px solid #AAAAAA;\n\tborder-right:\t\t1px solid #AAAAAA;\n\tline-height:\t\t1.4em;\n}\n\n\n\n\n.helpClick,\n#help div.arrow,\n#help2 div.arrow,\n#help3 div.arrow,\n#help4 div.arrow,\n#help5 div.arrow,\n#help6 div.arrow,\n#help7 div.arrow,\n#help8 div.arrow,\n#help9 div.arrow,\n#help10 div.arrow,\n#help11 div.arrow,\n#help12 div.arrow {\n\tbackground:transparent url(/arrows.png) no-repeat scroll 0px -16px;\n\tdisplay:block;\n\tposition:relative;\n\tcolor:#333;\n\tfont-size:1.0em;\n\tcursor:help;\n}\n\t\t\n#help div.arrow:hover,#help2 div.arrow:hover,#help3 div.arrow:hover,#help4 div.arrow:hover,#help5 div.arrow:hover,#help6 div.arrow:hover,#help7 div.arrow:hover,#help8 div.arrow:hover,#help9 div.arrow:hover,#help10 div.arrow:hover,#help11 div.arrow:hover,#help12 div.arrow:hover {\n\tcolor:#1BCBFE;\n\tcursor:help;\n}\n\t\t\ndiv.up,#help div.up,#help2 div.up,#help3 div.up,#help4 div.up,#help5 div.up,#help6 div.up,#help7 div.up,#help8 div.up,#help9 div.up,#help10 div.up,#help11 div.up,#help12 div.up { \n\tbackground-position:0px 0px;\n}\n\n\n#help2 div.arrow {\n\tbackground:transparent url(/arrows.png) no-repeat scroll 0.013em -1.333em;\n\tdisplay:block;\n\tposition:relative;\n\tcolor:#333;\n\tfont-size:1.0em;\n\tcursor:help;\n\t}\n\n#help2 div.up { \n\tbackground-position:0px 0px;\n}\n\n\n /********************** Show/Hide functionality. *****************************8*/\n \n\n\n.show {\n\tdisplay: block;\n}\n\n.hide {\n\tdisplay: none;\n}\n\n\n/********************** tool tips styles - old method (to be deleted) ********************/\n\n\na.tt{\n    position:relative;\n    z-index:24;\n    color:#3CA3FF;\n    text-decoration:none;\n\tcolor:#333333;\n\tcursor:help;\n}\n\na.tt span { \n\tdisplay: none; \n}\n\n\n\n\na.tt:hover { \n\tz-index:25; \n}\n\na.tt:hover span.tooltip {\n    display:block;\n    position:absolute;\n    top:0.375em; \n\tleft:1.4em;\n\tpadding: 0.125em 0 0 0;\n\twidth:200px;\n\tcolor: #333;\n\ttext-align: left;\n\tfilter: alpha(opacity:90);\n\tKHTMLOpacity: 0.90;\n\tMozOpacity: 0.90;\n\topacity: 0.90;\n\tline-height:17px;\n\tcursor:help;\n}\n\na.tt:hover span.top {\n\tdisplay: block;\n\tpadding: 30px 8px 0;\n    background: url(bubble.gif) no-repeat top;\n}\n\na.tt:hover span.middle {\n\tdisplay: block;\n\tpadding: 0 8px; \n\tbackground: url(bubble_filler.gif) repeat bottom; \n}\n\na.tt:hover span.bottom {\n\tdisplay: block;\n\tpadding:3px 8px 10px;\n\tcolor: #548912;\n\tbackground-image: url(bubble.gif);\n\tbackground-repeat: no-repeat;\n\tbackground-position: bottom;\n}\n\n\n/********************** tool tips styles **********************************/\n\n\n.ttRegion{\n\tposition:relative;\n\tz-index:24;\n\tcolor:#3CA3FF;\n\ttext-decoration:none;\n\tcolor:#333333;\n}\n\n.ttRegion .ttPopup{\n\tdisplay:block;\n\tposition:absolute;\n\ttop:0.675em; \n\tleft:0;\n\tpadding: 0.125em 0 0 0;\n\twidth:200px;\n\tcolor: #333;\n\ttext-align: left;\n\tfilter: alpha(opacity:90);\n\tKHTMLOpacity: 0.90;\n\tMozOpacity: 0.90;\n\topacity: 0.90;\n\tline-height:17px;\n\tdisplay:none;\n}\n\n.ttRegion .ttTop{\n\tdisplay: block;\n\tpadding: 30px 8px 0;\n\tbackground: url(/bubble_caution.png) no-repeat top;\n}\n\n.ttRegion .ttMiddle{ \n\tdisplay: block;\n\tpadding: 0 8px; \n\tbackground: url(/bubble_filler_caution.png) repeat bottom;\n\tdisplay:none;\n}\n\n.ttRegion .ttBottom{\n\tdisplay: block;\n\tpadding:3px 8px 10px;\n\tcolor: #548912;\n\tbackground-image: url(/bubble_caution.png);\n\tbackground-repeat: no-repeat;\n\tbackground-position: bottom;\n}\n\n.bttRegion{\n\tposition:relative;\n\tz-index:24;\n\tcolor:#3CA3FF;\n\ttext-decoration:none;\n\tcolor:#333333;\n}\n\n.bttRegion .bttPopup{\n\tdisplay:block;\n\tposition:absolute;\n\ttop:0.675em; \n\tleft:0;\n\tpadding: 0.125em 0 0 0;\n\twidth:200px;\n\tcolor: #333;\n\ttext-align: left;\n\tfilter: alpha(opacity:90);\n\tKHTMLOpacity: 0.90;\n\tMozOpacity: 0.90;\n\topacity: 0.90;\n\tline-height:17px;\n\tdisplay:none;\n}\n\n.bttRegion .bttTop{\n\tdisplay: block;\n\tpadding: 30px 8px 0;\n\tbackground: url(bubble.gif) no-repeat top;\n}\n\n.bttRegion .bttMiddle{ \n\tdisplay: block;\n\tpadding: 0 8px; \n\tbackground: url(bubble_filler.gif) repeat bottom; \n}\n\n.bttRegion .bttBottom{\n\tdisplay: block;\n\tpadding:3px 8px 10px;\n\tcolor: #548912;\n\tbackground-image: url(bubble.gif);\n\tbackground-repeat: no-repeat;\n\tbackground-position: bottom;\n}\n\n.hiddenDiv {\n\tdisplay: none;\n}\n\n.visibleDiv {\n\tdisplay: block;\n}\n\t\n\n\t\n\t/*********************** Hide/Show divs, truncate *******************************/\n\t\n\t\n.more-hidden {\n\tdisplay: none;\n}\n\n.moreText {\n\tfont-family:Arial, Helvetica, sans-serif;\n\tfont-size:.925em;\n\tfont-weight: 550;\n\tcolor:#00F;\n\ttext-decoration:none;\n}\n\n.moreText:hover {\n\tpadding-top:4px;\n\tpadding-bottom:4px;\n\ttext-decoration:underline;\n\tcursor:pointer;\n}\n\n.lessText {\n\tfont-size:.9255em;\n\tcolor:#00F;\n\tmargin-left:1.525em;\n\ttext-decoration:none;\n\n}\n\n.lessText:hover {\n\ttext-decoration:underline;\n\tcursor:pointer;\n}\n\n\n.complete{\n    display:none;\n}\n\n.more{\n    color:navy;\n    font-size:13px;\n    padding:3px;\n    cursor:pointer;\n}\n\n.nmodeHidden {\n\tdisplay:none;\n}\n\n.nmodeShow {\n\tvisibility:visible;\n}\n\n.wpsHidden {\n\tdisplay:none;\n}\n\n.wpsHideall {\n\tdisplay:none;\n}\n\n\t\n/****************************** spacers to control white space ************************************************/\n\n.spacer-10 {\n\theight:-10px;\n}\n.spacer5 {\n\theight:5px;\n}\n.spacer10 {\n\theight:10px;\n}\n.spacer20 {\n\theight:20px;\n}\n.spacer30 {\n\theight:30px;\n}\n.spacer40 {\n\theight:40px;\n}\n.spacer60 {\n\theight:60px;\n}\n.spacer70 {\n\theight:70px;\n}\n.spacer80 {\n\theight:80px;\n}\n.spacer100 {\n\theight:100px;\n}\n.spacer110 {\n\theight:110px;\n}\n.spacer120 {\n\theight:120px;\n}\n.spacer150 {\n\theight:150px;\n}\n.spacer250 {\n\theight:250px;\n}\n\n\n\n/*      N E W   S T Y L E S    */\n\n\n\n\t\n#binnacleLogoutText {\t\t\n\tfont-weight:\t\tbold;\n\ttext-align:\t\t\tcenter;\n\tcolor:\t\t\t\t#000000;\n}\n\t/* blue - U11/7 - serves 1024x768 screens */\n\t#binnacleLogoutText {\n\t\tline-height:\t\t19px;\n\t\tfont-size:\t\t\t8px;\n\t\t}\n\t/* pplu */\n\n#binnacleLogout a, #binnacleLogout a:link, #binnacleLogout a:active, #binnacleLogout a:visited, #binnacleLogout a:hover {\n\tcolor:\t\t\t\t#000000;\n\ttext-decoration:\tnone;\n}\n\n\n\n\n\n/*  H O M E  */\n\n/* style handle for hit area detection */\n.hitArea {\n\tcursor:\t\t\t\t\t\tpointer;\n\t}\n\n.hitChangeAreaHover {\n\tcursor:\t\t\t\t\t\tpointer;\n}\n\n.homeLeftBarHeaderText\t{\n\tfont-size:\t\t\t\t\t1.8em;\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-weight:\t\t\t\tbold;\n}\n\n.homeLeftBarSubheaderText {\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-weight:\t\t\t\tbold;\n}\n\n.homeMenuItemDescription {\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-size:\t\t\t\t\t1.2em;\n\tfont-weight:\t\t\t\tbold;\n}\n\n\n\n/*  W I Z A R D I N G    A N D   M O D A L   O V E R L A Y   I T E M S*/\n\n#wizardUnderlay, .modalUnderlayBlack, .modalUnderlayWhite {\n\tposition:\t\t\t\t\tfixed; \n\ttop:\t\t\t\t\t\t0px;\n\tleft:\t\t\t\t\t\t0px;\n\twidth:\t\t\t\t\t\t100%;\n\theight:\t\t\t\t\t\t100%;\n\topacity:\t\t\t\t\t0.7;\n\tfilter:\t\t\t\t\t\talpha(opacity=70);\n\tz-index:\t\t\t\t\t1500;\n}\n\n#wizardUnderlay, .modalUnderlayBlack {\n\tbackground:\t\t\t\t\t#000000;\n}\n\n.modalUnderlayWhite {\n\tbackground:\t\t\t\t\t#FFFFFF;\n}\n\n#wizardFloater {\n\tposition:\t\t\t\t\tabsolute;\n\ttop:\t\t\t\t\t\t55px;\n\tleft:\t\t\t\t\t\t130px;\n\twidth:\t\t\t\t\t\t756px;\n\theight:\t\t\t\t\t\t554px;\n\tbackground-image:\t\t\turl('/back_wizardFloater.png');\n\tbackground-repeat:\t\t\tno-repeat;\n\tz-index:\t\t\t\t\t2000;\n}\n\n#wizardContainer {\n\tposition:\t\t\t\t\tabsolute;\n\ttop:\t\t\t\t\t\t110px;\n\tleft:\t\t\t\t\t\t207px;\n\twidth:\t\t\t\t\t\t600px;\n\theight:\t\t\t\t\t\t401px;\n\tborder:\t\t\t\t\t\t1px solid #FFFFFF;\n\tz-index:\t\t\t\t\t2010;\n}\n\n#modalFloaterMessage {\n\tposition:\t\t\t\t\tabsolute;\n\ttop:\t\t\t\t\t\t55px;\n\tleft:\t\t\t\t\t\t130px;\n\twidth:\t\t\t\t\t\t693px;\n\theight:\t\t\t\t\t\t318px;\n\tbackground-image:\t\t\turl('/back_messageFloater.png');\n\tbackground-repeat:\t\t\tno-repeat;\n\tz-index:\t\t\t\t\t2000;\n}\n\n#modalContainerMessage {\n\tposition:\t\t\t\t\tabsolute;\n\ttop:\t\t\t\t\t\t90px;\n\tleft:\t\t\t\t\t\t176px;\n\twidth:\t\t\t\t\t\t602px;\n\theight:\t\t\t\t\t\t228px;\n\tborder:\t\t\t\t\t\t0px solid #FFFFFF;\n\tz-index:\t\t\t\t\t2010;\n}\n\n#modalContainerMessageTitle {\n\tposition:\t\t\t\t\trelative;\n\twidth:\t\t\t\t\t\t602px;\n\theight:\t\t\t\t\t\t38px;\n\tbackground-color:\t\t\t#0099B5;\n\tfont-weight:\t\t\t\tbold;\n}\n\n.modalContainerMessageTitleText {\n\tline-height:\t\t\t\t38px;\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-size:\t\t\t\t\t1.2em;\n\tpadding-left:\t\t\t\t10px;\n}\n\n.modalContainerMessageAlertText \t{\n\tmargin-top:\t\t\t\t\t15px;\n\tline-height:\t\t\t\t1.6em;\n\tcolor:\t\t\t\t\t\t#000000;\n\tfont-size:\t\t\t\t\t0.9em;\n}\n\n.modalContainerMessageAlertButtons {\n\tmargin-top:\t\t\t\t\t15px;\n\ttext-align:\t\t\t\t\tcenter;\n}\n\n#modalContainerMessageAlert {\n\tfloat:\t\t\t\t\t\tleft;\n\tmargin-left:\t\t\t\t10px;\n\twidth:\t\t\t\t\t\t390px;\n\theight:\t\t\t\t\t\t190px;\n}\n\n#modalContainerMessageAlertImage {\n\tfloat:\t\t\t\t\t\tright;\n\twidth:\t\t\t\t\t\t190px;\n\theight:\t\t\t\t\t\t190px;\n}\n\n#modalContainerMessageAlertImage img {\n\twidth:\t\t\t\t\t\t190px;\n\theight:\t\t\t\t\t\t190px;\n}\n\n#wizardTrack {\n\twidth:\t\t\t\t\t\t600px;\n\theight:\t\t\t\t\t\t401px;\n\tz-index:\t\t\t\t\t2020;\n}\n\n.wizardFrame {\n\tdisplay:\t\t\t\t\tblock;\n\tposition:\t\t\t\t\tabsolute;\n\ttop:\t\t\t\t\t\t0px;\n\tz-index:\t\t\t\t\t2030;\n}\n\n.wizardFrameHeaderBar, .wizardFrameBody, .wizardFrameButtonBar {\n\twidth:\t\t\t\t\t\t600px;\n\t}\n\n.wizardFrameHeaderBar {\n\tbackground-color:\t\t\t#000000;\n\theight:\t\t\t\t\t\t42px;\n\tbackground-image:\t\t\turl('/back_wizardContainerStrip.png');\n\tbackground-repeat:\t\t\trepeat-x;\n\tbackground-position:\t\t0px 0px;\n}\n\n.wizardFrameHeaderBarLeft {\n\tfloat:\t\t\t\t\t\tleft;\n\twidth:\t\t\t\t\t\t410px;\n\theight:\t\t\t\t\t\t42px;\n}\n\t\n.wizardIcon {\n\tfloat:\t\t\t\t\t\tleft;\n\ttop:\t\t\t\t\t\t0px;\n\tleft:\t\t\t\t\t\t0px;\n\tpadding:\t\t\t\t\t0px;\n\tmargin:\t\t\t\t\t\t0px;\n\twidth:\t\t\t\t\t\t42px;\n\theight:\t\t\t\t\t\t42px;\n}\n\n.wizardIconImage {\n\tbackground-image:\t\t\turl('/back_wizardIcon.png');\n\tbackground-repeat:\t\t\tno-repeat;\n\twidth:\t\t\t\t\t\t42px;\n\theight:\t\t\t\t\t\t42px;\n}\n\n.wizardName {\n\tfloat:\t\t\t\t\t\tleft;\n\ttop:\t\t\t\t\t\t0px;\n\tleft:\t\t\t\t\t\t42px;\n\tpadding:\t\t\t\t\t0px;\n\tmargin:\t\t\t\t\t\t0px;\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-size:\t\t\t\t\t1.3em;\n\tline-height:\t\t\t\t42px;\n\tfont-weight:\t\t\t\tbold;\n}\n\t\n.wizardStepIndicator {\n\ttext-align:\t\t\t\t\tright;\n\tpadding:\t\t\t\t\t0px;\n\tmargin:\t\t\t\t\t\t0px;\n\tpadding-right:\t\t\t\t18px;\n\tcolor:\t\t\t\t\t\t#FFFFFF;\n\tfont-size:\t\t\t\t\t1.0em;\n\tline-height:\t\t\t\t42px;\n\tfont-weight:\t\t\t\tbold;\n}\n\n.wizardFrameHeaderBarRight {\n\tfloat:\t\t\t\t\t\tright;\n\twidth:\t\t\t\t\t\t190px;\n\theight:\t\t\t\t\t\t42px;\n}\n\n.wizardFrameBody {\n\tbackground-color:\t\t\t#C2C2C2;\n\theight:\t\t\t\t\t\t300px;\n\tbackground-image:\t\t\turl(/'back_wizardContainerStrip.png');\n\tbackground-repeat:\t\t\trepeat-x;\n\tbackground-position:\t\t0px -42px;\n}\n\n.wizardFrameBodyLeft {\n\tfloat:\t\t\t\t\t\tleft;\n\twidth:\t\t\t\t\t\t410px;\n\theight:\t\t\t\t\t\t300px;\n}\n\n.wfblv1 {\n    display:\t\t\t\t\ttable;\n\theight:\t\t\t\t\t\t300px;\n\tposition:\t\t\t\t\trelative;\n\toverflow:\t\t\t\t\thidden;\n}\n\n.wfblv2 {\n    *position: \t\t\t\t\tabsolute; \n\ttop: \t\t\t\t\t\t50%;\n\tdisplay: \t\t\t\t\ttable-cell;\n\tvertical-align: \t\t\t