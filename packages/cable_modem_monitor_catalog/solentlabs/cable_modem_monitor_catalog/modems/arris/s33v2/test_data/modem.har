          "content": {
            "mimeType": "text/html",
            "size": 6825,
            "text": "\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\"\r\n\"http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd\">\r\n<html>\r\n<head>\r\n<title>Login</title>\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./css/styles.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./css/styles_layout.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./css/styles_images.css\" />\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/jquery.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/jquery.selectbox.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/Login.js?V=M2\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/SOAP/SOAPAction.js?V=M2\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/jquery.qrcode.min.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/initialJS.js\"></script>\r\n</head>\r\n<body id=\"loginBody\" name=\"loginBody\">\r\n\r\n<div class=\"translucent\" id=\"translucent\"></div> \r\n<div class=\"device_status\" id=\"device_status\">\r\n  <div class=\"device_status_head\">&nbsp;&nbsp;&nbsp;<span id=\"StatusSoftwareModelName\"></span> Device Status</div>\r\n\r\n      <table cellpadding=\"0\" cellspacing=\"5\" border=\"0\" width=\"100%\" id='logintb'>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>Firmware Version</td>\r\n          <td><input id='FirmwareVersion' type='text' value='' size='16' disabled></td>\r\n        </tr>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>Internet Connection</td>\r\n          <td><input id='InternetConnection' type='text' value='' size='16' disabled></td>\r\n        </tr>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>Downstream Frequency</td>\r\n          <td><input id='DownstreamFrequency' type='text' value='' size='16' disabled></td>\r\n        </tr>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>Downstream Signal Power</td>\r\n          <td><input id='DownstreamSignalPower' type='text' value='' size='16' disabled></td>\r\n        </tr>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>Downstream Signal SNR</td>\r\n          <td><input id='DownstreamSignalSnr' type='text' value='' size='16' disabled></td>\r\n        </tr>\r\n        <tr><td colspan=\"3\">&nbsp;</td></tr>\r\n        <tr>\r\n\t  <td width=\"15px\">&nbsp;</td>\r\n          <td>&nbsp;</td>\r\n          <td align=\"right\"><input id='close_status' type='button' value='Close'>&nbsp;&nbsp;&nbsp;&nbsp;</td>\r\n        </tr>\r\n      </table>\r\n</div>\r\n\r\n<div>\r\n\t  <!-- Header Area Begin -->\r\n<div class=\"header\">  \r\n    <div id=\"binnacleWrapper1\" class=\"binnacleItems_hide\">\r\n                <div id=\"binnacleWrapper2\" class=\"binnacleItems_hide\">\r\n                    <div id=\"binnacleWrapperLeft\"><img src=\"./image/px1_Ux.png\" alt=\"\" class=\"binnacleWrapperShim\"></div>\r\n                    <div id=\"binnacleWrapperRight\"><img src=\"./image/px1_Ux.png\" alt=\"\" class=\"binnacleWrapperShim\"></div>\r\n                    <div id=\"binnacleWrapperMiddle\">\r\n                        <div id=\"binnacleInnards\">                            \r\n\t\t\t\t\t\t\t<div id=\"binnacleIndicatorWrap\"></div>\r\n                            <div id=\"binnacleModelName\"><span id=\"StatusSoftwareModelName2\"></span></div>\r\n                        </div>\r\n                    </div>\r\n                <!-- end binnacleWrapper1/2 -->\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n    <div id=\"pw1\">\r\n   \r\n\t\t<div id=\"hg1\"><div id=\"hg2\"><div id=\"hg3\"><div id=\"hg4\"><div id=\"hg5\">\r\n\t\t\r\n            <div id=\"logo\"><a href=\"http://www.arris.com\"><img src=\"./image/px1_Ux.png\" alt=\"ARRIS Logo\" title=\"ARRIS Logo\" class=\"logo\"></a></div>\r\n\t\t<!-- end divs for hg -->\r\n\t\t</div></div></div></div></div>\r\n\t\t\r\n\t\t<!--gap--><div id=\"tmtg\"><div class=\"gap1\"><div class=\"gap2\"></div></div></div>\r\n\r\n\t\t<div id=\"bg1\"><div id=\"bg2\"><div id=\"bg3\">\r\n<!-- END pageheaderA.htm ADDITIONS -->\r\n<!-- END pageheaderA.htm -->\r\n<!-- ARRIS MENU Start-->\r\n<div id=\"topMenu\">\r\n</div>\r\n<!-- ARRIS MENU End -->\r\n\r\n<!-- START pageheaderB.htm -->\r\n\r\n<!-- START pageheaderB.htm ADDITIONS -->\r\n\t\t<!-- end divs for tmg -->\r\n\r\n\t\t\r\n\t\t\r\n<!-- END pageheaderB.htm ADDITIONS -->\r\n\r\n<!-- END pageheaderB.htm -->\r\n\t<!-- End Header -->\r\n\r\n\t<div class=\"container\">\r\n\t\t<div class=\"subHeader\">\r\n\t\t\t<div class=\"subHeadcontent\">Login</div>\r\n\t\t</div>\r\n\r\n\t<div class=\"SBCText\">\r\n\t\t<p>We recommend using our Mobile Application - <strong>SURFboard Central</strong> - for better experience configuring and accessing new features customized for your device.</p>\r\n\t</div>\r\n\t<div class=\"spacer20\"></div>\r\n\r\n\t<div class=\"content\">\r\n       \t<div class=\"introText\">\r\n    \t\t<p>The default user name is 'admin'.</p>\r\n    \t</div>\r\n    </div>\r\n\r\n<br clear=\"all\" class=\"clearfloat\">\r\n<div class=\"spacer30\"></div>\r\n\r\n<form id=\"login_form\" method=\"post\" action=\"##\">\r\n\t<table class=\"simpleTable\">\r\n\t\t<tr>\r\n\t\t\t<td><strong>Username</strong></td>\r\n\t\t\t<td><input type=\"text\" id=\"loginUsername\" name=\"username\" size=\"32\" autocomplete=\"off\"></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td><strong>Password</strong></td>\r\n\t\t\t<td id = \"textOrPsw\">\r\n\t\t\t\t<div id=\"s33-oldpassword\" class=\"password-wrap\">\r\n\t\t\t\t<div class=\"password-input\" id='loginPasswordinput'>\r\n\t\t\t\t<input type=\"password\" name=\"old_password\" id=\"loginWAP\" size=\"15\" maxlength=\"15\" value=\"\" class=\"bui-input\" autocomplete=\"off\" >\r\n\t\t\t\t</div>\t\r\n\t\t\t\t<i class=\"bt-showpwd off\" id='bt-showpwd'></i><i id='tiploginpwd'></i>\r\n\t\t\t\t</div>\t\t\t\r\n\t\t\t</td>\r\n\t\t</tr>\r\n              <tr>\r\n                      <td>&nbsp;</td><td>&nbsp;</td>\r\n              </tr>\r\n              <tr>\r\n                      <td>\r\n                              <input type=\"button\" id=\"login\" value=\"Apply\">\r\n                      </td>\r\n                      <td><input type=\"button\" id=\"DeviceStatus\" value=\"Device Status\"></td>\r\n              </tr>\r\n\t</table>\r\n\t\r\n\t<br clear=\"all\" class=\"clearfloat\">\r\n\t<div class=\"spacer30\"></div>\r\n\r\n</form>\t\r\n\r\n\r\n<br clear=\"all\" class=\"clearfloat\">\r\n<div class=\"spacer30\"></div>\r\n\r\n<br clear=\"all\" class=\"clearfloat\">\r\n<div class=\"spacer40\"></div>\r\n\r\n<!-- end .container --></div> \r\n\r\n<!-- START footer.htm ADDITIONS -->\r\n\t\t<!-- end divs for bc -->\r\n\t\t</div></div></div></div>\r\n\t\t\r\n\t\t<!--gap--><div id=\"bmtg\"><div class=\"gap1\"><div class=\"gap2\"></div></div></div>\r\n\t\t\r\n\t\t<div id=\"fg1\"><div id=\"fg2\"><div id=\"fg3\"><div id=\"fg4\"><div id=\"fg5\">\r\n\t\t\t\r\n\t\t\t<div id=\"logo_bottom\"><a href=\"http://www.arris.com\"><img src=\"./image/px1_Ux.png\" alt=\"ARRIS\" title=\"ARRIS\" class=\"logo_bottom\"></a></div>\r\n\r\n\t\t\t<div id=\"copyright\">\r\n\t\t\t</div>\r\n\r\n\t\t</div></div></div></div></div>\r\n\t\t\r\n\t\t\r\n\t\t<div id=\"fgbl1\"><div id=\"fgbl2\"><div id=\"fgbl3\"><img src=\"./image/px1_Ux.png\" alt=\"\" title=\"\" class=\"fgbl3\"></div></div></div>\r\n\r\n    \r\n    <!-- end divs for pw -->\r\n    </div>\r\n\r\n<!-- END footer.htm ADDITIONS -->\r\n</div>\r\n\r\n</body>\r\n</html>\r"
