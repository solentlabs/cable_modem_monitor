            "text": "/* Initial Javascript - JavaScript (Timmy Hsieh)*/\r\n/* Code Number: 130916\t\t\t\t\t\t\t*/\r\nvar iniDate = new Date().getTime();\r\nvar ini_ver = \"?\" + iniDate;\r\nvar g_copyright=\"<span>&copy; CommScope, Inc.  All rights reserved.  ARRIS, SURFBOARD and SURFBOARD MAX are trademarks of CommScope, Inc.  All other trademarks are the property of their respective owners.</span>\";\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/jquery.cookie.js\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/json2.js\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/comm.js\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/hmac_md5.js\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/libajax.js' + ini_ver + '\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/hnap.js' + ini_ver + '\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/i18n.js' + ini_ver + '\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/forbidview.js?V=M2\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/includeLang.js' + ini_ver + '\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/checkTimeout.js' + ini_ver + '\"></script>');\r\ndocument.write('<script type=\"text/javascript\" charset=\"utf-8\" src=\"./js/SOAP/SOAPLogin.js?V=M2\"></script>');\r\n"
