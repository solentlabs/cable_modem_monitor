            "size": 5180,
            "mimeType": "text/html",
            "text": "<!DOCTYPE HTML PUBLIC\n\"-//W3C//DTD HTML 4.01//EN\"\n\"http://www.w3.org/TR/html4/strict.dtd\">\n<html>\n<head>\n\t<title>Touchstone Status</title>\n\t<meta http-equiv=\"Pragma\" content=\"no-cache\">\n        <SCRIPT language=\"JavaScript\">\n        function clearcounters()\n        {\n            document.clear.submit();\n        }\n        </SCRIPT>\n    <link rel=\"stylesheet\" href=\"/arris_style.css\">\n</head>\n\n<body>\n<div class=\"wrapper\">\n\n\t<div class=\"header\">\n\t<div class=\"header_text\">\n\t\t<h1>Status</h1>\n\t</div>\n\t</div>\n\n\t<div id=\"navbar\">\n\t<ul>\n\t<li id=\"current\"><a style=\"width: 20.00%;\" href=\"status_cgi\">Status</a></li>\n<li><a style=\"width: 20.00%;\" href=\"vers_cgi\">HW/FW Versions</a></li>\n<li><a style=\"width: 20.00%;\" href=\"event_cgi\">Event Log</a></li>\n<li><a style=\"width: 20.00%;\" href=\"cm_state_cgi\">CM State</a></li>\n<li><a style=\"width: 20.00%;\" href=\"product_cgi\">Advanced</a></li>\n\n\t</ul>\n\t</div>\n\n\t<div class=\"main_body\">\n\t<p>\n\t<!-- INSERT ARRIS PAGE CONTENT HERE -->\n\n<table bgcolor=\"#0c055c\" cellpadding=\"0\" cellspacing=\"0\" cols=\"1\" width=\"770\">\n<tbody>\n<tr>\n  <td width=\"770\"><b><font color=\"#ffffff\" size=\"+1\">&nbsp;RF Parameters</font></b></td>\n</tr>\n</tbody></table>\n\n\n<h4> Downstream </h4>\n<table border=\"2\" cellpadding=\"0\" cellspacing=\"0\" width=\"770\">\n<tbody>\n<tr>\n  <td></td>\n  <td>DCID</td>\n  <td>Freq</td>\n  <td>Power</td>\n  <td>SNR</td>\n  <td>Modulation</td>\n  <td>Octets</td>\n  <td>Correcteds</td>\n  <td>Uncorrectables</td>\n</tr>\n<tr><td>Downstream 1</td><td>73</td><td>178.00 MHz</td><td>3.82 dBmV</td><td>34.48 dB</td><td>256QAM</td><td>12038669013</td><td>33958022</td><td>445244</td></tr><tr><td>Downstream 2</td><td>74</td><td>186.00 MHz</td><td>4.34 dBmV</td><td>33.38 dB</td><td>256QAM</td><td>10044551633</td><td>63659057</td><td>673370</td></tr><tr><td>Downstream 3</td><td>75</td><td>194.00 MHz</td><td>4.09 dBmV</td><td>37.09 dB</td><td>256QAM</td><td>10036101398</td><td>43399209</td><td>163191</td></tr><tr><td>Downstream 4</td><td>76</td><td>202.00 MHz</td><td>5.45 dBmV</td><td>36.17 dB</td><td>256QAM</td><td>10037564522</td><td>60277178</td><td>359926</td></tr><tr><td>Downstream 5</td><td>77</td><td>210.00 MHz</td><td>4.95 dBmV</td><td>39.40 dB</td><td>256QAM</td><td>10010673849</td><td>48522677</td><td>186584</td></tr><tr><td>Downstream 6</td><td>78</td><td>218.00 MHz</td><td>5.79 dBmV</td><td>38.26 dB</td><td>256QAM</td><td>10008042568</td><td>4390535</td><td>19645</td></tr><tr><td>Downstream 7</td><td>79</td><td>226.00 MHz</td><td>6.57 dBmV</td><td>39.85 dB</td><td>256QAM</td><td>10000911420</td><td>17719208</td><td>14855</td></tr><tr><td>Downstream 8</td><td>80</td><td>234.00 MHz</td><td>5.62 dBmV</td><td>40.37 dB</td><td>256QAM</td><td>9998464017</td><td>42073256</td><td>96046</td></tr>\n</tbody>\n</table>\n<table width=\"770\" border=\"0\"><tr><td align=\"right\">\n<form name=\"clear\" action=\"status_cgi\" method=post>\n    <a href=\"javascript: clearcounters()\">Reset FEC Counters</a>\n</form>\n</td></tr></table>\n<h4> Upstream </h4>\n<table border=\"2\" cellpadding=\"0\" cellspacing=\"0\" width=\"770\">\n<tbody>\n<tr>\n  <td></td>\n  <td>UCID</td>\n  <td>Freq</td>\n  <td>Power</td>\n  <td>Channel Type</td>\n  <td>Symbol Rate</td>\n  <td>Modulation</td>\n</tr>\n<tr>\n<tr><td>Upstream 1</td><td>6</td><td>47.00 MHz</td><td>46.25 dBmV</td><td>DOCSIS2.0 (ATDMA)</td><td>5120 kSym/s</td><td>32QAM</td><tr><td>Upstream 2</td><td>8</td><td>61.00 MHz</td><td>47.25 dBmV</td><td>DOCSIS2.0 (ATDMA)</td><td>5120 kSym/s</td><td>32QAM</td><tr><td>Upstream 3</td><td>7</td><td>54.00 MHz</td><td>45.75 dBmV</td><td>DOCSIS2.0 (ATDMA)</td><td>5120 kSym/s</td><td>32QAM</td><tr><td>Upstream 4</td><td>5</td><td>40.00 MHz</td><td>47.25 dBmV</td><td>DOCSIS2.0 (ATDMA)</td><td>5120 kSym/s</td><td>32QAM</td>\n</tbody>\n</table>\n\n\n<br>\n\n<table bgcolor=\"#0c055c\" cellpadding=\"0\" cellspacing=\"0\" cols=\"1\" width=\"770\"><tbody><tr>\n\n      <td width=\"770\"><b><font color=\"#ffffff\"size=\"+1\">\n&nbsp;Status\n</font></b></td></tr></tbody></table>\n<table cellpadding=\"0\" cellspacing=\"0\">\n<tbody><tr><td width=\"160\">System Uptime: </td><td>6 d:  2 h: 33  m</td></tr>\n<tr><td width=\"160\">Computers Detected:</td><td>staticCPE(0), dynamicCPE(1)\n</td></tr>\n<tr><td width=\"160\">CM Status:</td><td>OPERATIONAL</td></tr>\n<tr><td width=\"160\">Time and Date:</td><td>Wed 1970-01-07 02:32:17</td></tr>\n</tbody></table><br>\n<table bgcolor=\"#0c055c\" cellpadding=\"0\" cellspacing=\"0\" cols=\"1\" width=\"770\"><tbody><tr>\n    <td width=\"770\"><b><font color=\"#ffffff\" size=\"+1\">\n    &nbsp;Interface Parameters </font></b></td></tr></tbody></table><table border=\"2\" width=\"769\">\n  <tbody><tr>\n    <td width=\"100\">Interface Name</td>\n    <td width=\"90\">Provisioned</td>\n    <td width=\"60\">State</td>\n    <td width=\"100\">Speed (Mbps)</td>\n    <td width=\"144\">MAC address</td></tr>\n<tr><td>LAN</td><td>Enabled</td><td>Up</td><td>1000(Full)</td><td>XX:XX:XX:XX:XX:XX</td></tr>\n</tr><tr><td>CABLE</td>\n<td>Enabled</td>\n<td>Up</td>\n<td>-----</td>\n<td>XX:XX:XX:XX:XX:XX</td>\n</tr>\n\n</tbody></table>\n\n\t<!-- END ARRIS PAGE CONTENT -->\n\t</p>\n\t</div> <!-- main_body -->\n\n\t<div class=\"push\"></div>\n</div> <!-- wrapper -->\n\n<div class=\"footer\">\n    &#169 ARRIS Enterprises, Inc. 2017 All rights reserved.\n</div>\n</body>\n</html>\n"
