            "mimeType": "text/html",
            "text": "<!DOCTYPE HTML PUBLIC\n\"-//W3C//DTD HTML 4.01//EN\"\n\"http://www.w3.org/TR/html4/strict.dtd\">\n<html>\n<head>\n\t<title>Touchstone HW/FW Versions</title>\n\t<meta http-equiv=\"Pragma\" content=\"no-cache\">\n    <link rel=\"stylesheet\" href=\"/arris_style.css\">\n</head>\n\n<body>\n<div class=\"wrapper\">\n\n\t<div class=\"header\">\n\t<div class=\"header_text\">\n\t\t<h1>HW/FW Versions</h1>\n\t</div>\n\t</div>\n\n\t<div id=\"navbar\">\n\t<ul>\n\t<li><a style=\"width: 20.00%;\" href=\"status_cgi\">Status</a></li>\n<li id=\"current\"><a style=\"width: 20.00%;\" href=\"vers_cgi\">HW/FW Versions</a></li>\n<li><a style=\"width: 20.00%;\" href=\"event_cgi\">Event Log</a></li>\n<li><a style=\"width: 20.00%;\" href=\"cm_state_cgi\">CM State</a></li>\n<li><a style=\"width: 20.00%;\" href=\"product_cgi\">Advanced</a></li>\n\n\t</ul>\n\t</div>\n\n\t<div class=\"main_body\">\n\t<p>\n\t<!-- INSERT ARRIS PAGE CONTENT HERE -->\n\n<table bgcolor=\"#0c055c\" cellpadding=\"0\" cellspacing=\"0\" cols=\"1\" width=\"770\">\n       <tbody><tr><td width=\"770\"><b><font color=\"#ffffff\" size=\"+1\">&nbsp;Hardware Information\n       </font></b></td></tr></tbody></table>\n<table cellpadding=\"0\" cellspacing=\"0\">\n<tbody>\n<tr><td colspan=\"2\" height=\"2\" width=\"770\"></td></tr>\n<tr valign=\"top\">\n\t\t\t <td width=\"170\">System: </td>\n\t\t\t <td width=\"600\">ARRIS EuroDOCSIS 3.0 Touchstone WideBand Cable Modem<br>\n\t\t\t HW_REV: 1<br>\n\t\t\t VENDOR: Arris Interactive, L.L.C.<br>\n\t\t\t BOOTR: ***PUBLIC_IP***<br>\n\t\t\t SW_REV: 9.1.103S5R<br>\n\t\t\t MODEL: CM820B</td>\n</tr>\n\n<!--\n<tr valign=\"top\">\n\t\t\t <td width=\"170\">Product Type:</td>\n\t\t\t <td><?CM_PROD_TYPE></td>\n</tr>\n<tr valign=\"top\">\n\t\t\t <td width=\"170\">Product Release:</td>\n\t\t\t <td><?CM_PROD_REL></td>\n</tr>\n<tr valign=\"top\">\n\t\t\t <td width=\"170\">Flash Part:</td>\n\t\t\t <td><?CM_FLASH_PART></td>\n</tr>\n<tr valign=\"top\">\n\t\t\t <td width=\"170\">Downlo