            "mimeType": "text/html",
            "compression": 0,
            "text": "\r\n<html>\r\n\r\n<head>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"moto.css\" />\r\n<meta name=\"GENERATOR\" content=\"Microsoft FrontPage 5.0\">\r\n<meta name=\"ProgId\" content=\"FrontPage.Editor.Document\">\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-1252\">\r\n<title>Motorola Cable Modem : Status -> Connection</title>\r\n<script language=\"javascript\">\r\n<!-- hide me\r\n\r\nfunction checkForwarding(){return false;}function menuClick(value){    if(checkForwarding())    {        return false;    }    if(value == 'status')    {        window.location.href='MotoSwInfo.asp';    }}function menuMouseMove(value){    document.getElementById('tdStatus').style.backgroundColor = '#52555a';    document.getElementById('divStatus').style.display = 'none';    if(value == 'status')    {        document.getElementById('tdStatus').style.backgroundColor = '#868a8d';        document.getElementById('divStatus').style.display = 'block';    }}function gotoHome(){    if(checkForwarding())    {        return false;    }    window.location.href='MotoHome.asp';}function gotoPage(value){\tif(checkForwarding())\t{\t\treturn false;\t}\twindow.location.href=value;}\r\nvar isBridgeMode = 99;\r\nvar isIPv6Only = 0;\r\n\r\n/* Fill your java script code here */\r\nfunction RenewWanLease()\r\n{\n\twindow.document.MotoConnection.motoWanLeaseAction.value = 1;\r\n}\n\nfunction ReleaseWanLease()\n{\n\twindow.document.MotoConnection.motoWanLeaseAction.value = 2;\r\n}\n\r\nfunction do_checkstr(string)\n{\n\tvar detect = navigator.userAgent.toLowerCase();\n\tplace = detect.indexOf(string) + 1;\n\tthestring = string;\n\treturn place;\n}\n\r\nfunction GetBrowserOS()\n{\n\n\tvar detect = navigator.userAgent.toLowerCase();\n\tvar OS,browser,version,total,thestring, browseVer;\n\n\tif (do_checkstr('konqueror'))\n\t{\n\t\tbrowser = \"Konqueror\";\n\t\tOS = \"Linux\";\n\t}\n\telse if (do_checkstr('safari')) browser = \"safa\";\n\telse if (do_checkstr('omniweb')) browser = \"omni\";\n\telse if (do_checkstr('opera')) browser = \"oper\";\n\telse if (do_checkstr('webtv')) browser = \"webt\";\n\telse if (do_checkstr('icab')) browser = \"icab\";\n\telse if (do_checkstr('msie')) browser = \"msie\"; \n  \n\t//\tAdd firefox detection\n\telse if(navigator.userAgent.indexOf(\"Firefox\")!=-1){\n\t\tvar versionindex=navigator.userAgent.indexOf(\"Firefox\")+8\n\t\tif (parseInt(navigator.userAgent.charAt(versionindex))>=1)\n\t\tbrowser = \"fire\";\n\t}\n\telse if (!do_checkstr('compatible'))\n\t{\n\t\tbrowser = \"nets\"\n\t}\n\t\telse browser = \"unknown\";\n\n\tif (browser != \"unknown\")\n\t\tif (!OS)\n\t\t{\n\t\t\tif (do_checkstr('linux')) OS = \"lin\";\n\t\t\telse if (do_checkstr('x11')) OS = \"uni\";\n\t\t\telse if (do_checkstr('mac')) OS = \"mac\"\n\t\t\telse if (do_checkstr('win')) OS = \"win\"\n\t\t\telse OS = \"unknown\";\n\t\t}\n\n\tbrowseVer = browser + OS;\n\n\treturn browseVer;\n}\r\n\r\nfunction showhideWan(sh)\r\n{\r\n\tvar status;\r\n\tif (sh == 1) \r\n\t{        \r\n\t\tstatus = \"\";   \r\n\t}    \r\n\telse \r\n\t{   \r\n\t\tstatus = \"none\"  \r\n\t}   \r\n\r\n\tif (window.document.getElementById)\t\r\n\t{\t\t\r\n\t\t// standard\t\t\r\n\t\twindow.document.getElementById('wanInfo').style.display = status;\t\r\n\t\tif (isIPv6Only == 1)\r\n\t\t    window.document.getElementById('wanDnsInfo').style.display = \"none\";\r\n\t\telse\r\n\t\t    window.document.getElementById('wanDnsInfo').style.display = status;\t\r\n\t}\t\r\n\telse if (document.all)\t\r\n\t{\t\t\r\n\t\t// old IE\t\t\r\n\t\twindow.document.all['wanInfo'].style.display = status;\t\r\n\t\tif (isIPv6Only == 1)\r\n\t\t    window.document.all['wanDnsInfo'].style.display = \"none\";\r\n             else\r\n\t\t    window.document.all['wanDnsInfo'].style.display = status;\t\r\n\t}\t\r\n\telse if (document.layers)\t\r\n\t{\t\t\r\n\t\t// Netscape 4\t\t\r\n\t\twindow.document.layers['wanInfo'].display = status;\t\r\n\t\tif (isIPv6Only == 1)\r\n\t\t    window.document.layers['wanDnsInfo'].display = \"none\";\r\n             else\r\n\t\t    window.document.layers['wanDnsInfo'].display = status;\t\r\n\t}\r\n}\r\n\r\nfunction showhideIpProv(sh)\r\n{\r\n\tvar status;\r\n\tif (sh == 1) \r\n\t{        \r\n\t\tstatus = \"\";   \r\n\t}    \r\n\telse \r\n\t{   \r\n\t\tstatus = \"none\"  \r\n\t}   \r\n\r\n\tif (window.document.getElementById)\t\r\n\t{\t\t\r\n\t\t// standard\t\t\r\n\t\twindow.document.getElementById('ipProvConfig').style.display = status;\t\r\n\t}\t\r\n\telse if (document.all)\t\r\n\t{\t\t\r\n\t\t// old IE\t\t\r\n\t\twindow.document.all['ipProvConfig'].style.display = status;\t\r\n\t}\t\r\n\telse if (document.layers)\t\r\n\t{\t\t\r\n\t\t// Netscape 4\t\t\r\n\t\twindow.document.layers['ipProvConfig'].display = status;\t\r\n\t}\r\n}\r\nfunction showHidenWanInfo()\r\n{\r\n    if (isBridgeMode == 0)\r\n    {\r\n        showhideWan(0);\r\n    }\r\n    else\r\n    {\r\n        if (isBridgeMode == 99)\r\n        {\r\n            showhideIpProv(0);\r\n            showhideWan(0);\r\n        }\r\n        else\r\n        {\r\n            showhideWan(1);\r\n            //setAutoDNS();\r\n        }\r\n    }\r\n}\r\n\r\nfunction setAutoDNS()\r\n{\r\n    var i,currentcolor;\r\n    var OS = GetBrowserOS();\r\n    var tempelems = window.document.getElementById('dnsConfig').getElementsByTagName(\"*\");\r\n    var value = window.document.MotoConnection.motoAutoDNS.value;\r\n    var status = false;\r\n\r\n    if (value == 1)\r\n       status = true;\r\n    else\r\n       status = false;\r\n\t\r\n    if (status == false)\r\n        currentcolor = \"\";\r\n    else\r\n        currentcolor = \"#aca899\";\r\n\r\n    for (i = 0; i < tempelems.length;i++){\r\n\t    if (tempelems[i].disabled != undefined)\r\n                 tempelems[i].disabled = status;\r\n\r\n\t    if (OS.indexOf(\"msie\")!= -1){      //ie returns null, firefox uses undefined.....@#@%@^#@^\r\n                if (tempelems[i].style.color)\r\n\t                tempelems[i].style.color = currentcolor;\r\n\t    }\r\n\t    else{\r\n                if (tempelems[i].style.color != undefined)\r\n\t                tempelems[i].style.color = currentcolor;\r\n\t    }\r\n    }\r\n    // disable the element itself\r\n    var tempelems = window.document.getElementById('dnsConfig');\r\n    if (tempelems.disabled != undefined)\r\n         tempelems.disabled = status;\r\n\r\n    if (OS.indexOf(\"msie\")!= -1){      //ie returns null, firefox uses undefined.....@#@%@^#@^\r\n         if (tempelems.style.color)\r\n              tempelems.style.color = currentcolor;\r\n    }\r\n    else\r\n    {\r\n         if (tempelems.style.color != undefined)\r\n             tempelems.style.color = currentcolor;\r\n    }\r\n}\r\n\r\nfunction Apply(value)\r\n{\r\n    if((isBridgeMode != 0) && (isBridgeMode != 99) && (isIPv6Only != 1))\r\n    {\r\n       if(window.document.MotoConnection.motoAutoDNS.value == 0)\r\n       {\r\n           if((window.document.MotoConnection.motoPrimaryDnsIpAddressIP0.value == '' ||\r\n\t\t   window.document.MotoConnection.motoPrimaryDnsIpAddressIP1.value == '' ||\r\n\t\t   window.document.MotoConnection.motoPrimaryDnsIpAddressIP2.value == '' ||\r\n\t\t   window.document.MotoConnection.motoPrimaryDnsIpAddressIP3.value == '') &&\r\n\t\t  (window.document.MotoConnection.motoSecondaryDnsIpAddressIP0.value == '' ||\r\n\t\t   window.document.MotoConnection.motoSecondaryDnsIpAddressIP1.value == '' ||\r\n\t\t   window.document.MotoConnection.motoSecondaryDnsIpAddressIP2.value == '' ||\r\n\t\t   window.document.MotoConnection.motoSecondaryDnsIpAddressIP3.value == ''))\r\n           {\r\n               alert(\"Please enter at least one DNS Server Address.\");\r\n               return false;\r\n           }\r\n       }\r\n    }\r\n\twindow.document.MotoConnection.motoAutoDNSAction.value = value;\r\n\twindow.document.MotoConnection.submit();\r\n}\r\n\r\n\r\nfunction dnsEnableChanged()\r\n{\r\n    if(window.document.MotoConnection.motoAutoDNS.value == 0)\r\n    {\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP0.disabled = false;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP1.disabled = false;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP2.disabled = false;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP3.disabled = false;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP0.disabled = false;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP1.disabled = false;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP2.disabled = false;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP3.disabled = false;\r\n\t\t\t\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP0.value = MotoConnPriDns[0];\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP1.value = MotoConnPriDns[1];\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP2.value = MotoConnPriDns[2];\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP3.value = MotoConnPriDns[3];\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP0.value = MotoConnSecDns[0];\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP1.value = MotoConnSecDns[1];\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP2.value = MotoConnSecDns[2];\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP3.value = MotoConnSecDns[3];\r\n    }\r\n    else\r\n    {\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP0.disabled = true;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP1.disabled = true;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP2.disabled = true;\r\n        window.document.MotoConnection.motoPrimaryDnsIpAddressIP3.disabled = true;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP0.disabled = true;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP1.disabled = true;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP2.disabled = true;\r\n        window.document.MotoConnection.motoSecondaryDnsIpAddressIP3.disabled = true;\r\n    }\r\n}\r\n\r\nfunction ipProvModeChanged()\r\n{\r\n    if(window.document.MotoConnection.motoIpProvMode.value == 10)\r\n    {\r\n        showhideWan(0);\r\n    }\r\n    else\r\n    {\r\n        showhideWan(1);\r\n    }\r\n}\r\n\r\n// show me -->\r\n\r\n</script>\r\n</head>\r\n\r\n<body onLoad=\"showHidenWanInfo();\">\r\n\r\n<div class=\"moto-global\">\r\n<div class='moto-icon'><table class='table-icon' cellspacing='0' cellpadding='0'><tr><td class='td-icon' onmousemove=\"\" valign='middle'><table cellspacing='0' cellpadding='0'><tr><td onClick='gotoHome()'><a href='javascript:void(0);' class='loginfo'><img src='motolog.jpg' width='112px' height='82px'><span>Back</span></a></td><td class='td-menu' width='90px' id='tdBack' onclick=\"gotoHome()\">Back to<br>Basic Page</td></tr></table></td><td width='100px' class='td-menu' id='tdStatus' onmousemove=\"menuMouseMove('status')\" onclick=\"menuClick('status')\" style='background:#868a8d'>&nbsp;<br>Status</td><td width='20px'></td></tr></table></div><div id='divStatus' class='moto-menu' style='display:block'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='300px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoSwInfo.asp\")'>Software</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu-active' onClick='gotoPage(\"MotoConnection.asp\")'>Connection<br><img src='motoactive.jpg' /></td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoSecurity.asp\")'>Security</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoSnmpLog.asp\")'>Event&nbsp;Log</td><td width='30px' class='td-menu'></td></tr></table></div><div id='divBasic' class='moto-menu' style='display:none'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='150px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoRgSetup.asp\")'>Setup</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoRgDhcp.asp\")'>DHCP</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoRgDhcpV6.asp\")'>DHCPv6</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoRgIPv6.asp\")'>LAN&nbsp;IPv6</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoDdns.asp\")'>DDNS</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoBackup.asp\")'>Backup/Restore</td><td width='30px' class='td-menu'></td></tr></table></div><div id='divAdvanced' class='moto-menu' style='display:none'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='40px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoOption.asp\")'>Options</td><td width='30px' class='td-menu' ><img src='motovline.jpg'/></td><td class='td-menu'  onClick='gotoPage(\"MotoIpFilter.asp\")'>IP&nbsp;Filtering</td><td width='30px' class='td-menu' ><img src='motovline.jpg'/></td><td class='td-menu'  onClick='gotoPage(\"MotoMacFilter.asp\")'>MAC&nbsp;Filtering</td><td width='30px' class='td-menu' ><img src='motovline.jpg'/></td><td class='td-menu'  onClick='gotoPage(\"MotoPortFilter.asp\")'>Port&nbsp;Filtering</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoForwarding.asp\")'>Forwarding</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoPortTrigger.asp\")'>Port&nbsp;Triggers</td><td width='30px' class='td-menu' ><img src='motovline.jpg'/></td><td class='td-menu'  onClick='gotoPage(\"MotoRipSetup.asp\")'>RIP</td><td width='30px' class='td-menu' ><img src='motovline.jpg'/></td><td class='td-menu'  onClick='gotoPage(\"MotoDmzHost.asp\")'>DMZ</td><td width='30px' class='td-menu'></td></tr></table></div><div id='divWireless' class='moto-menu' style='display:none'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='200px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoWlanBasic.asp\")'>Basic</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanRadio.asp\")'>Radio</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanSecurity.asp\")'>WPS&nbsp;RADIUS&nbsp;WEP</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanAccess.asp\")'>Access</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanAdvanced.asp\")'>Advanced</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanWmm.asp\")'>WMM</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoWlanScanBridge.asp\")'>Scan/Bridge</td><td width='30px' class='td-menu'></td></tr></table></div><div id='divProtection' class='moto-menu' style='display:none'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='400px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoFirewallBasic.asp\")'>Firewall&nbsp;Basic</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoFirewallLog.asp\")'>Firewall&nbsp;EventLog</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoParentControl.asp\")'>Parental&nbsp;Control</td><td width='30px' class='td-menu'></td></tr></table></div><div id='divVPN' class='moto-menu' style='display:none'><table height='46' cellspacing='0' cellpadding='0'><tr><td width='650px' class='td-menu'></td><td class='td-menu' onClick='gotoPage(\"MotoVpnIpsec.asp\")'>IPsec</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoVpnL2tpPptp.asp\")'>L2TP/PPTP</td><td width='30px' class='td-menu'><img src='motovline.jpg'/></td><td class='td-menu' onClick='gotoPage(\"MotoVpnLog.asp\")'>Event&nbsp;Log</td><td width='30px' class='td-menu'></td></tr></table></div>\r\n\r\n\r\n<div id=\"moto-content\">\r\n\r\n<div class=\"moto-first-title\">\r\n\r\nConnection\r\n</div>\r\n<form action=/goform/MotoConnection method=POST name=\"MotoConnection\">\r\n\r\n\r\n<table id=\"ipProvConfig\" class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;eRouter</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'>&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n  <table class=\"moto-table-content\" cellspacing='0' cellpadding='0'>\r\n\r\n  </table>\r\n</td>\r\n</tr>\r\n</table>\r\n\r\n<br><br>\r\n<table class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;Startup Sequence</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'>&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n  <table class=\"moto-table-content\" cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n  <td class='moto-param-header'>&nbsp;&nbsp;&nbsp;Startup Step</td>\r\n  <td class='moto-param-header'>Status</td>\r\n  <td class='moto-param-header'>Comment</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Startup Step:<br>The Startup Sequence shows steps in your Cable Modem's registration process. <br>\r\nIf your modem doesn't come online, you can often tell which step is causing a problem by noting the first step that remains <b style=\"font-family:Moto Sans Semibold,verdana,helvetica\">In Progress</b>.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Acquire Downstream Channel</td>\r\n  <td class='moto-content-value'>759000000 Hz</td>\r\n  <td class='moto-content-value'>Locked</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Acquire Downstream Channel:<br>The first step your cable modem takes is to lock on a downstream channel. If this step fails, it could be because there is no live coax cable connected to your modem, or because the signal is too weak or noisy to connect successfully.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Upstream Connection</td>\r\n  <td class='moto-content-value'>OK</td>\r\n  <td class='moto-content-value'>Operational</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Upstream Connection:<br>The next step is to establish an upstream connection. If this step fails, it could be because the quality of the cable connection is marginal. (This step is sometimes referred to as the Connectivity State. This reflects negotiation of upstream frequency, time slot, synchronization for Forward Error Correction framing, and similar items.)</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Boot State</td>\r\n  <td class='moto-content-value'>OK</td>\r\n  <td class='moto-content-value'>Operational</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Boot State:<br>\r\n<script language=\"javascript\">\r\n<!-- hide me\r\nif ((isBridgeMode == 0)||(isBridgeMode == 99))\r\n  document.writeln(\"In this step, your cable modem receives an IP Address and time of day information from the network. <br>If this step fails, it may be because of a network issue, or a problem with your account.\");\r\nelse\r\n  document.writeln(\"In this step, your cable modem receives an IP Address and time of day information from the network. <br>If this step fails, it could be because your cable modem's eRouter setting is incompatible with your service provider. (See eRouter Provisioning Mode).\");\r\n// show me -->\r\n</script>\r\n  </span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Configuration File</td>\r\n  <td class='moto-content-value'>OK</td>\r\n  <td class='moto-content-value'>^1/0D0CC7F7/506/001</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Configuration File:<br>In the next step, your cable modem receives a configuration file from the network. This file configures your cable modem for the service level that you subscribe to. If this step fails, it could be because there is a problem with your account.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Security</td>\r\n  <td class='moto-content-value'>Enabled</td>\r\n  <td class='moto-content-value'>BPI+</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Security:<br>Finally, your cable modem exchanges tokens with your service provider to protect your Internet traffic. It is rare for this step to fail.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n</table>\r\n\r\n<br>\r\n<br>\r\n<table class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;Connection Status</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'>&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n  <table class=\"moto-table-content\" cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;System Up Time</td>\r\n  <td class='moto-content-value'>9 days 19h:29m:48s</td>\r\n  <td>&nbsp;</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>System Up Time:<br>How long your cable modem has been connected to the Internet.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td>&nbsp;&nbsp;&nbsp;Network Access</td>\r\n  <td class='moto-content-value'>Allowed</td>\r\n  <td>&nbsp;</td>\r\n  <td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Network Access:<br>Network Access indicates whether your cable company lets you access the Internet. If you are connected but do not have access to the Internet, there may be a problem with your account.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n</table>\r\n\r\n<br><br>\r\n<table class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;Downstream Bonded Channels</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>Downstream Bonded Channels:<br>Your cable modem is capable of connecting over multiple channels at the same time. When at least two channels are connected, this is called channel bonding. The Downstream Channel List shows the connection status of each channel, including indicators of connection quality. Channel bonding enables faster download speeds, and it also helps to smooth out spikes in traffic by spreading them across multiple channels.</span></a>&nbsp;&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td colspan=4>\r\n  <table class=\"moto-table-content\" cellspacing='0' cellpadding='0'>\r\n  <tr align='center'>\r\n  <td class='moto-param-header-s'>&nbsp;&nbsp;&nbsp;Channel</td>\r\n  <td class='moto-param-header-s'>Lock Status</td>\r\n  <td class='moto-param-header-s'>Modulation</td>\r\n  <td class='moto-param-header-s'>Channel ID</td>\r\n  <td class='moto-param-header-s'>Freq. (MHz)</td>\r\n  <td class='moto-param-header-s'>Pwr (dBmV)</td>\r\n  <td class='moto-param-header-s'>SNR (dB)</td>\r\n  <td class='moto-param-header-s'>Corrected</td>\r\n  <td class='moto-param-header-s'>Uncorrected</td>\r\n  </tr>\r\n<tr align='center'><td class='moto-content-value'>1</td><td class='moto-content-value'>Locked</td><td class='moto-content-value'>QAM256</td><td class='moto-content-value'>29</td><td class='moto-content-value'>759.0</td><td class='moto-content-value'>-1.9</td><td class='moto-content-value'>41.6</td><td class='moto-content-value'>13</td><td class='moto-content-value'>0</td></tr>\n<tr align='center'><td class='moto-content-value'>2</td><td class='moto-content-value'>Locked</td><td class='moto-content-value'>QAM256</td><td class='moto-content-value'>25</td><td class='moto-content-value'>735.0</td><td class='moto-content-value'>-2.3</td><td class='moto-content-value'>41.3</td><td class='moto-content-value'>0</td><td class='moto-content-value'>0</td></tr>\n<tr align='center'><td class='moto-content-value'>3</td><td class='moto-content-value'>Locked</td><td class='moto-content-value'>QAM256</td><td class='moto-content-value'>26</td><td class='moto-content-value'>741.0</td><td class='moto-content-value'>-2.4</td><td class='moto-content-value'>41.2</td