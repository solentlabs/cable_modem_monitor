          "content": {
            "size": 4820,
            "mimeType": "text/html",
            "compression": 0,
            "text": "\n<html>\n\n<head>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"moto.css\" />\n<meta name=\"GENERATOR\" content=\"Microsoft FrontPage 5.0\">\n<meta name=\"ProgId\" content=\"FrontPage.Editor.Document\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-1252\">\n<title>Motorola Cable Modem : Login</title>\n<script language=\"javascript\">\n<!-- hide me\n\nvar UserNameFlag = 0;\nvar PasswordFlag = 0;\nvar isEncryptPswd = 1;\n\nvar keyStr = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\";\n\nfunction encode(Str)\n{\n   Str = escape(Str);\n   var output = \"\";\n   var chr1, chr2, chr3 = \"\";\n   var enc1, enc2, enc3, enc4 = \"\";\n   var i = 0;\n\n   do {\n      chr1 = Str.charCodeAt(i++);\n      chr2 = Str.charCodeAt(i++);\n      chr3 = Str.charCodeAt(i++);\n      enc1 = chr1 >> 2;\n      enc2 = ((chr1 & 3) << 4) | (chr2 >> 4);\n      enc3 = ((chr2 & 15) << 2) | (chr3 >> 6);\n      enc4 = chr3 & 63;\n      if (isNaN(chr2))\n      {\n         enc3 = enc4 = 64;\n      }\n      else if (isNaN(chr3))\n      {\n         enc4 = 64;\n      }   \n      output = output + keyStr.charAt(enc1) + keyStr.charAt(enc2) + keyStr.charAt(enc3) + keyStr.charAt(enc4);\n      chr1 = chr2 = chr3 = \"\";\n      enc1 = enc2 = enc3 = enc4 = \"\";\n   } while (i < Str.length);\n   \n   return output;   \n}   \n\nfunction loginSubmit()\n{\n\tif((window.document.login.loginUsername.value == \"Username\") && (UserNameFlag == 0))\n\t{\n\t\twindow.document.login.loginUsername.value = \"\";\n\t}\n\tif((window.document.login.loginPassword.value == \"Password\") && (PasswordFlag == 0))\n\t{\n\t\twindow.document.login.loginPassword.value = \"\";\n\t}\n\twindow.document.login.loginText.disabled = true;\n\n\tif (isEncryptPswd == 1)\n\t{\n\t\t/*window.document.login.loginUsername.value = encode(window.document.login.loginUsername.value);*/\n\t\twindow.document.login.loginPassword.value = encode(window.document.login.loginPassword.value);\n\t}\n\n\t//window.document.login.submit();\n\t \n}\n\nfunction onFocusUsername()\n{\n\twindow.document.login.loginUsername.className = \"moto-username-input-active\";\n\twindow.document.login.loginUsername.value = \"\";\n}\n\nfunction onBlurUsername()\n{\n\tif(window.document.login.loginUsername.value == \"\")\n\t{\n\t\twindow.document.login.loginUsername.className = \"moto-username-input\";\n\t\twindow.document.login.loginUsername.value = \"Username\";\n\t}\n\telse\n\t{\n\t\tUserNameFlag = 1;\n\t}\n}\n\nfunction onFocusPassword()\n{\n\twindow.document.login.loginText.style.display = 'none';\n\twindow.document.login.loginPassword.style.display = '';\n\twindow.document.login.loginPassword.focus();\n/*\n\twindow.document.login.loginPassword.className = \"moto-password-input-active\";\n\twindow.document.login.loginPassword.value = \"\";\n\twindow.document.login.loginPassword.type = \"password\";\n*/\n}\n\nfunction onBlurPassword()\n{\n\tif(window.document.login.loginPassword.value == \"\")\n\t{\n\t\twindow.document.login.loginPassword.style.display = 'none';\n\t\twindow.document.login.loginText.style.display = '';\n\t}\n\telse\n\t{\n\t\tPasswordFlag = 1;\n\t}\n/*\n\tif(window.document.login.loginPassword.value == \"\")\n\t{\n\t\twindow.document.login.loginPassword.className = \"moto-password-input\";\n\t\twindow.document.login.loginPassword.value = \"Password\";\n\t\twindow.document.login.loginPassword.type = \"text\";\n\t}\n\telse\n\t{\n\t\tPasswordFlag = 1;\n\t}\n*/\n}\n// show me -->\n\n</script>\n</head>\n\n<body>\n\n<!--\n<div id=\"moto-login-top\">\n</div>\nModem\n#CE0000\n#CE0000\n#CE0000\n\"http://www.broadcom.com\"\n\"logo_new.gif\"\n#CE0000\n-->\n\n<form action=/goform/login method=POST name=\"login\" onsubmit=\"return loginSubmit()\"> \n<div id=\"moto-login\">\n\n<div id=\"moto-login-log\">\n<img src=\"motologin.jpg\" width='80px' height='80px' />\n</div>\n\n<div id=\"moto-login-welcome\">\n<span class=\"moto-login-welcome-text\">Welcome to Your<br>Motorola Cable Modem</span>\n</div>\n\n<div id=\"moto-username\">\n<input class=\"moto-username-input\" type=\"text\" name=\"loginUsername\" onfocus='onFocusUsername()' onblur='onBlurUsername()' value=\"Username\">\n</div>\n\n<div id=\"moto-password\">\n<input class=\"moto-password-input\" type=\"text\" name=\"loginText\" onfocus='onFocusPassword();' value=\"Password\">\n<input class=\"moto-password-input-active\" type=\"password\" name=\"loginPassword\" onblur='onBlurPassword();' value=\"\" style=\"display:none\">\n</div>\n\n<div id=\"moto-note\">\n<span class=\"moto-note-text\">&nbsp;&nbsp;</span>\n</div>\n\n<div id=\"moto-button\">\n<input type=\"submit\" class=\"moto-login-button\" value=\"Login\"></input>\n</div>\n\n<div id=\"moto-note\">\n<span class=\"moto-note-text\">You can find your username and password on your cable modem's bottom label.</span>\n</div>\n\n<div id=\"moto-copyright\">\n<span class=\"moto-copyright-text\">&copy; MTRLC LLC 2017. All rights reserved.<br>MOTOROLA and the Stylized M Logo are trademarks or registered trademarks of Motorola Trademark Holdings, LLC and are used under license.</span>\n</div>\n\n</div>\n</form>\n\n<!--\n#CE0000\n2001-2015 Broadcom Corporation\n-->\n\n</body>\n</html>\n\n\n"
          },
