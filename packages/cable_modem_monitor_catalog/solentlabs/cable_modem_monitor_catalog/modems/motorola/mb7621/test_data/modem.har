          ],
          "content": {
            "size": 6460,
            "mimeType": "text/html",
            "compression": 0,
            "text": "\r\n<html>\r\n\r\n<head>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"moto.css\" />\r\n<meta name=\"GENERATOR\" content=\"Microsoft FrontPage 5.0\">\r\n<meta name=\"ProgId\" content=\"FrontPage.Editor.Document\">\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-1252\">\r\n<title>Motorola Cable Modem : Home</title>\r\n<script language=\"javascript\">\r\n<!-- hide me\r\n\r\nfunction gotoAdvanced()\r\n{\r\nwindow.location.href=\"MotoSwInfo.asp\";\r\n}\r\n\r\nfunction Logout()\r\n{\r\nwindow.location.href=\"logout.asp\";\r\n}\r\n\r\nfunction CheckChinese(str)\r\n{\r\n\tvar reg = new RegExp(\"[\\\\u4E00-\\\\u9FFF]+\",\"g\");\r\n\treturn reg.test(str);\r\n}\r\n\r\n\n\t\tfunction Apply(value)\n\t\t{\n\n    \twindow.document.MotoHome.MotoHomeAction.value = value;\n    \twindow.document.MotoHome.submit();\n    }\r\n\r\n// show me -->\r\n\r\n</script>\r\n</head>\r\n\r\n<body>\r\n\r\n<div class=\"moto-global\">\r\n<div class=\"moto-icon\">\r\n\r\n<table class=\"table-icon\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td class=\"td-icon\" width=\"20%\" valign='middle'>\r\n<table cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td><img src='motolog.jpg' width='112px' height='82px'></td>\r\n</tr>\r\n</table>\r\n</td>\r\n<td width=\"55%\">&nbsp;</td>\r\n<td width=\"25%\">\r\n<input class=\"moto-home-button\" type=\"button\" name=\"\" value=\"Advanced\" onclick=\"gotoAdvanced()\">\r\n&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<a href=\"logout.asp\" class=\"moto-logout-button\"><span style='font-size: 18px;'>Logout</span></a></td>\r\n</tr>\r\n</table>\r\n\r\n</div>\r\n\r\n\r\n<div id=\"moto-content\">\r\n\r\n<div class=\"moto-first-title\">\r\nBasic Status and Settings\r\n</div>\r\n\r\n<form action=/goform/MotoHome method=POST name=\"MotoHome\">\r\n<table class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;Internet Connection</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'>&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n<tr>\r\n<td>\r\n  <table class=\"moto-table-content\" cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;Online</td>\r\n  <td class=\"moto-param-value\">Connected</td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td class=\"moto-param-help\"><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/>\r\n  <span>Online:<br>This tells you whether your cable modem is Connected to the Internet. </span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;Number of Channels Connected</td>\r\n  <td class=\"moto-param-value\"></td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td class=\"moto-param-help\"></td>\r\n  </tr>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Downstream</td>\r\n  <td class=\"moto-param-value\">24</td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td class=\"moto-param-help\"></td>\r\n  </tr>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Upstream</td>\r\n  <td class=\"moto-param-value\">4</td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td class=\"moto-param-help\"><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/>\r\n  <span>Number of Channels Connected:<br>This item shows how many channels are connected on your cable modem. <br>\r\n  Downstream channels carry data to your cable modem from the Internet.<br>\r\n  Upstream channels carry data from your cable modem to the Internet.<br>\r\n  The more connected channels, the higher the potential connection speed, and the smoother the delivery of content like streaming video and games.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n</table>\r\n\r\n  \r\n  \r\n  \r\n    \r\n  \r\n    \r\n  \r\n\r\n<br><br>\r\n<table class=\"moto-table-title\" cellspacing='0' cellpadding='0'>\r\n<tr>\r\n<td>\r\n  <table class='moto-table-content-title' cellspacing='0' cellpadding='0'>\r\n  <tr>\r\n<td class='moto-param-title'>&nbsp;&nbsp;&nbsp;Cable Modem Addresses and Version</td>\r\n<td class='moto-param-value'><img src=\"mototitle.jpg\"/></td>\r\n<td class='moto-param-value'>&nbsp;</td>\r\n<td class='moto-param-help'>&nbsp;</td>\r\n</tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n\r\n<tr>\n        <td>\n          <table class='moto-table-content' cellspacing='0' cellpadding='0'>\n          <tr>\n          <td class='moto-param-name'>&nbsp;&nbsp;&nbsp;MAC Address</td>\n          <td class='moto-param-value'>02:94:a1:4e:ca:a6</td>\n          <td class='moto-param-action'></td>\n          <td  class='moto-param-help'><a href='javascript:void(0);'  class='tooltip'><img src='motohelp.jpg'/><span>\n          MAC Address:<br>The MAC Address (physical address) of your cable modem.</span></a>&nbsp;&nbsp;</td>\n          </tr>\n\r\n\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;IP Address</td>\r\n  <td class=\"moto-param-value\">10.255.53.209</td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td  class=\"moto-param-help\"><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>\r\n  IP Address:<br>Assigned to your cable modem by your cable provider.<br>\r\n  The assignment is referred to as a Lease.<br>\r\n  This is an IPv4 Address, an earlier type of IP Address. Your cable provider may assign an IPv4 Address, an IPv6 Address, or both.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;IPv6 Address</td>\r\n  <td class=\"moto-param-value\">2001:db8::c71a:6299</td>\r\n  <td class=\"moto-param-action\"></td>\r\n  <td  class=\"moto-param-help\"><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>\r\n  IPv6 Address:<br>Assigned to your cable modem by your cable provider.<br>\r\n  The assignment is referred to as a Lease.<br>\r\n  IPv6 is a newer, longer style of IP Address. Your cable provider may assign an IPv4 Address, an IPv6 Address, or both.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  <tr>\r\n  <td class=\"moto-param-name\">&nbsp;&nbsp;&nbsp;Software Version</td>\r\n  <td class=\"moto-param-value\" colspan='2'>7621-5.7.1.5</td>\r\n  <td  class=\"moto-param-help\"><a href='javascript:void(0);'  class=\"tooltip\"><img src=\"motohelp.jpg\"/><span>\r\n  Software Version:<br>Version number of the software that runs on your cable modem.</span></a>&nbsp;&nbsp;</td>\r\n  </tr>\r\n  </table>\r\n</td>\r\n</tr>\r\n</table>\r\n\r\n<br>\r\n<!--\r\n<table class=\"moto-table-copyright\">\r\n<tr>\r\n<td>&copy; 2015 Zoom Telephonics, Inc., an official licensee of Motorola Mobility. All rights reserved.</td>\r\n</tr>\r\n</table>\r\n-->\r\n</form>\r\n\r\n</div>\r\n\r\n</div>\r\n\r\n\r\n</body>\r\n</html>\r\n\r\n"
