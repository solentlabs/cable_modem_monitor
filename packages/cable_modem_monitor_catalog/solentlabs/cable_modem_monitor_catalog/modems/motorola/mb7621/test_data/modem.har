            "mimeType": "text/html",
            "compression": 0,
            "text": "\n<html>\n\n<head>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"moto.css\" />\n<meta name=\"GENERATOR\" content=\"Microsoft FrontPage 5.0\">\n<meta name=\"ProgId\" content=\"FrontPage.Editor.Document\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-1252\">\n<title>Motorola Cable Modem : Logout</title>\n<script language=\"javascript\">\n\n\nfunction gotoLogin()\n{\nwindow.location.href=\"login.asp\";\n}\n\n\n\n</script>\n</head>\n\n<body>\n\n<div class=\"moto-global\">\n<div class=\"moto-icon\">\n\n<table class=\"table-icon\" cellspacing='0' cellpadding='0'>\n<tr>\n<td class=\"td-icon\" width=\"25%\" valign='middle'>\n<table cellspacing='0' cellpadding='0'>\n<tr>\n<td><img src='motolog.jpg' width='112px' height='82px'></td>\n</tr>\n</table>\n</td>\n<td width=\"55%\"> </td>\n<td width=\"20%\"></td>\n</tr>\n</table>\n\n</div>\n\n\n<div id=\"moto-content\">\n\n<div class=\"moto-first-title\">\nLogout\n</div>\n\n<table class=\"moto-table-title\">\n<tr>\n<td>\n\n  <table class=\"moto-table-content-title\" cellspacing='15'>\n\n  <tr>\n  <td  class='moto-param-value'>You are now logged out.</td>\n  </tr>\n\n  <tr> \n  <td align='center'>\n  <input class=\"moto-long-button\" type=\"button\" name=\"\" value=\"Back to Login\" onclick=\"gotoLogin()\">\n  \n  </td>\n  </tr>\n\n  </table>\n\n</td>\n</tr>\n</table>\n\n<!--\n<table class=\"moto-table-copyright\">\n<tr>\n<td>&copy; 2015 Zoom Telephonics, Inc., an official licensee of Motorola Mobility. All rights reserved.</td>\n</tr>\n</table>\n-->\n\n</div>\n\n</div>\n\n</body>\n</html>\n\n"
