          "content": {
            "size": 5757,
            "mimeType": "text/html",
            "compression": 0,
            "text": "\n<html id=\"html\">\r\n<head>\r\n<meta name=\"viewport\" content=\"width=1200\">\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\r\n<meta http-equiv=\"Pragma\" content=\"No-cache\" />\r\n<meta http-equiv=\"Cache-Control\" content=\"no-cache, must-revalidate\" />\r\n<meta http-equiv=\"Expires\" content=\"-1\" />\r\n<meta http-equiv=\"X-UA-Compatible\" content=\"chrome=1\">\r\n<link rel=\"shortcut icon\"  href=\"image/mobile_motologin.png\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/moto.css\" />\r\n<title>MB8611</title>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/localization/zh-cn.js?V=M2\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/jquery.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/jquery.selectbox-0.2_new.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/Login.js?V=M2\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/SOAP/SOAPAction.js?V=M2\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/jquery.qrcode.min.js\"></script>\r\n<script type=\"text/javascript\" charset=\"utf-8\" src=\"js/initialJS.js\"></script>\r\n\r\n<script language=\"javascript\">\r\n\r\nvar HNAP = new HNAP_XML();\r\n\r\nvar UserNameFlag = 0;\r\nvar PasswordFlag = 0;\r\nvar loginNum = 0;\r\n\r\nfunction onFocusUsername()\r\n{\r\n\tdocument.getElementById('loginUsername').className = \"moto-username-input-active\";\r\n\tdocument.getElementById('loginUsername').value = \"\";\r\n}\r\n\r\nfunction onBlurUsername()\r\n{\r\n\tif(window.document.frmLogin.loginUsername.value == \"\")\r\n\t{\r\n\t\twindow.document.frmLogin.loginUsername.className = \"moto-username-input\";\r\n\t\twindow.document.frmLogin.loginUsername.value = \"Username\";\r\n\t}\r\n\telse\r\n\t{\r\n\t\tUserNameFlag = 1;\r\n\t}\r\n}\r\n\r\nfunction onFocusPassword()\r\n{\r\n\twindow.document.frmLogin.loginText.style.display = 'none';\r\n\twindow.document.frmLogin.loginPassword.style.display = '';\r\n\twindow.document.frmLogin.loginPassword.focus();\r\n}\r\n\r\nfunction onBlurPassword()\r\n{\r\n\tif(window.document.frmLogin.loginPassword.value == \"\")\r\n\t{\r\n\t\twindow.document.frmLogin.loginPassword.style.display = 'none';\r\n\t\twindow.document.frmLogin.loginText.style.display = '';\r\n\t}\r\n\telse\r\n\t{\r\n\t\tPasswordFlag = 1;\r\n\t}\r\n\r\n}\r\n\r\n$(document).ready( function() {\r\n\t\tdocument.getElementById(\"moto-note\").innerHTML = \"&nbsp;\";\r\n});\r\n\r\nfunction OnClickLogin()\r\n\t{\r\n\t\tvar Login_Password=***REDACTED***\"loginPassword\").value;\r\n\t\tvar Login_Username = document.getElementById(\"loginUsername\").value;\r\n\t\tvar Login_Captcha = \"\";\r\n\r\n\t\tdocument.getElementById(\"LoginApply\").disabled = true;\r\n\t\tdocument.getElementById(\"moto-note\").innerHTML = \"&nbsp;\";\r\n\r\n\t\tloginNum++;\r\n\t\tdoLogin(Login_Username,Login_Password,Login_Captcha)\r\n\t\t.done(function(){\r\n\t\t    loginNum = 0;\r\n\t\t\tvar problem_goto_page = $.cookie('problem_page');\r\n\t\t\tif (typeof(problem_goto_page) != \"undefined\") {\r\n\t\t\t\t$.removeCookie('problem_page');\r\n\t\t\t\twindow.location.href = problem_goto_page;\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\r\n\t\t\tvar redirect_url = $.cookie(\"RedirectUrl\");\r\n\t\t\tif((redirect_url == null) || (redirect_url.indexOf(\"Login.html\") > 0) || (redirect_url.indexOf(\"html\") < 0))\r\n\t\t\t{\r\n\t\t\t\twindow.location.href = \"/MotoHome.html\";\t\r\n\t\t\t}\r\n\t\t\telse\t\t\t\t\t\t\t\t\r\n\t\t\t{\t\r\n\t\t\t\twindow.location.href = redirect_url;\t\t\r\n\t\t\t}\r\n\t\t})\r\n\t\t.fail(function(state){\r\n\t\t\tdocument.getElementById(\"LoginApply\").disabled = false;\r\n\t\t\tif (state == \"AUTH_FAIL\")\r\n\t\t\t\tdocument.getElementById(\"moto-note\").innerHTML = (\"Login is temporarily disabled for 5 minutes because of too many failed attempts.\");\r\n\t\t\telse{\r\n\t\t\t\tdocument.getElementById(\"moto-note\").innerHTML = (loginNum > 3?\"Login is temporarily disabled for 5 minutes because of too many failed attempts.\":\"Please enter a valid username and password.\");\r\n\t\t\t}\r\n\t\t});\t\t\r\n\t}\r\n\r\nfunction detect_KeyValue(e)\r\n{\r\n\tvar key=***REDACTED*** ? e.keyCode : e.which;\r\n\tif (key=***REDACTED*** 13)  \r\n\t{\r\n\t\tdocument.getElementById(\"LoginApply\").click();\r\n\t}\r\n}\r\n</script>\r\n</head>\r\n\r\n<body>\r\n\r\n\r\n<form action=\"/cgi-bin/moto/goform/MotoLogin\" method=\"POST\" name=\"frmLogin\">\r\n\r\n<div id=\"moto-login\">\r\n\r\n<div id=\"moto-login-log\">\r\n<img src=\"/image/motologin.jpg\" width='80px' height='80px' />\r\n</div>\r\n\r\n<div id=\"moto-login-welcome\">\r\n<span class=\"moto-login-welcome-text\">Welcome to Your<br>Motorola Cable Modem</span>\r\n</div>\r\n\r\n<div id=\"moto-username\">\r\n<input class=\"moto-username-input\" type=\"text\" id=\"loginUsername\" name=\"loginUsername\" onfocus='onFocusUsername()' onblur='onBlurUsername()' value=\"Username\" onkeydown=\"detect_KeyValue(event);\">\r\n</div>\r\n\r\n<div id=\"moto-password\">\r\n<input type=\"hidden\">\r\n<input class=\"moto-password-input\" type=\"text\" id=\"loginText\" name=\"loginText\" onfocus='onFocusPassword();' value=\"Password\" onpaste='return false' oncontextmenu='return false' oncopy='return false' oncut='return false'>\r\n<input type=\"hidden\">\r\n<input class=\"moto-password-input-active\" type=\"password\" id=\"loginPassword\" name=\"loginPassword\" onblur='onBlurPassword();' value=\"\" style=\"display:none\" onkeydown=\"detect_KeyValue(event);\" onpaste='return false' oncontextmenu='return false' oncopy='return false' oncut='return false'>\r\n</div>\r\n\r\n<div>\r\n<span id=\"moto-note\" class=\"moto-note-text\"></span>\r\n</div>\r\n\r\n<div id=\"moto-button\">\r\n<input class=\"moto-login-button\" type=\"button\" id=\"LoginApply\" name=\"LoginApply\" value=\"Login\" onclick=\"OnClickLogin();\"></input>\r\n</div>\r\n\r\n<div id=\"moto-note\">\r\n<span class=\"moto-note-text\">You can find your username and password on your cable modem's bottom label.</span>\r\n</div>\r\n\r\n<div id=\"moto-copyright\">\r\n<span class=\"moto-copyright-text\">&copy; MTRLC LLC 2020. All rights reserved.<br>MOTOROLA and the Stylized M Logo are trademarks or registered trademarks of Motorola Trademark Holdings, LLC and are used under license.</span>\r\n</div>\r\n\r\n</div>\r\n</form>\r\n\r\n\r\n</body>\r\n</html>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r"
