          "content": {
            "size": 122969,
            "mimeType": "text/html",
            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n\n<html>\n\n<head>\n\n<META name=\"description\" content='C3700-100NAS'>\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<META http-equiv=\"Pragma\" content=\"no-cache\">\n<META HTTP-equiv=\"Cache-Control\" content=\"no-cache\">\n<META HTTP-EQUIV=\"Expires\" CONTENT=\"Mon, 06 Jan 1990 ***IPv6*** GMT\">\n\n<meta http-equiv=\"content-type\" content=\"text/html; charset=ISO-8859-1\">\n<!--\n<meta http-equiv=\"refresh\" content=\"3\">\n-->\n<title>NETGEAR Gateway C3700-100NAS</title>\n<link rel=\"stylesheet\" href=\"css/table.css\">\n<link rel=\"stylesheet\" href=\"css/scrollbar.css\">\n<link rel=\"stylesheet\" href=\"css/button.css\">\n\n<script type=\"text/javascript\" src=\"jquery.js\"></script>\n\n<script type=\"text/javascript\" src=\"script/jquery.mousewheel.js\"></script>\n<script type=\"text/javascript\" src=\"script/jquery.jscrollpane.min.js\"></script>\n\n<script type=\"text/javascript\" src=\"script/script.js\"></script>\n<link rel=\"stylesheet\" href=\"form.css\">\n<!--STYLE TYPE=\"text/javascript\">\n    classes.num.all.fontFamily = \"Courier\";\n    classes.num.all.fontSize = \"10pt\" ;\n</style-->\n<script type=\"text/javascript\" src=\"func.js\"></script>\n<script type=\"text/javascript\" src=\"msg.js\"></script>\n<script type=\"text/javascript\" src=\"utility.js\"></script>\n<script type=\"text/javascript\" src=\"browser.js\"></script>\n\n<script type=\"text/javascript\" src=\"md5.js\"></script>\n<script type=\"text/javascript\" src=\"wep.js\"></script>\n<script type=\"text/javascript\">\n\nvar DisableFixedDNS = false;\nvar DisableFixedMAC = false;\nvar MacAddress;\nvar DodDisable = false;\nvar DodIndex = 1;\n\n    $(document).ready(function()\n    {\n        var form=document.forms[0];\n        var gui_region = form.curlang.value;\n\n        // Nick put bodyInit in here!!\n        BodyInit();\n\n        $('#INT_setup').click(function(ev){\n            parent.loadPage2(\"BasicSettingsBottom.htm\");\n        });\n\n        /*\n        // Chuck 20141001 I will set this later if need,\n        // because we won't link this to WirelessSettings in bridge mode with generic gui.\n        $('#wireless_setup').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n\n        $('#wireless_setup_5G').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n        */\n\n        $('#guest_setup1').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#guest_setup2').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#guest_setup_5G').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#LAN_setup').click(function(ev){\n            /* foxconn, khfan, remove, 2014/09/24\n               Defect # 126\n               C7000-100NAS: Security -- Some broken URL links are found by sortsite and error in URLs.\n             */\n            // parent.loadPage2(\"\");\n        });\n\n// Nick 20111114\n        $('#Moblile_setup').click(function(ev){\n            /* foxconn, khfan, remove, 2014/09/24\n               Defect # 126\n               C7000-100NAS: Security -- Some broken URL links are found by sortsite and error in URLs.\n             */\n            // parent.loadPage2(\"\");\n        });\n\n        $('.basic-text-menu').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-menu-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-menu-pr\");\n             }\n        });\n        $('.basic-text-subTitle').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-subTitle-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-subTitle-pr\");\n             }\n        });\n        $('.basic-text-content').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-content-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-content-pr\");\n             }\n        });\n        $('.box-header-text').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"box-header-text-pr\");\n             }else{\n                 $(this).removeClass(\"box-header-text-pr\");\n             }\n        });\n        /* checking long string */\n        if(trim($('.header-text1').text()).length>=36 | trim($('.header-text2').text()).length>=36){\n               $('#box-header-table1').addClass(\"box-header-table-large\");\n               $('#box-header-table2').addClass(\"box-header-table-large\");\n               $('#box-header-table1').removeClass(\"box-header-table\");\n               $('#box-header-table2').removeClass(\"box-header-table\");\n        }\n\n/* Nick override\n        if($('.header-text3').text().length>=36 | $('.header-text4').text().length>=36){\n               $('#box-header-table3').addClass(\"box-header-table-large\");\n               $('#box-header-table4').addClass(\"box-header-table-large\");\n               $('#box-header-table3').removeClass(\"box-header-table\");\n               $('#box-header-table4').removeClass(\"box-header-table\");\n        }\n*/\n        if(trim($('.header-text3').text()).length>=36 | trim($('.header-text41').text()).length>=36 | $('.header-text42').text().length>=36){\n               $('#box-header-table3').addClass(\"box-header-table-large\");\n               $('#box-header-table41').addClass(\"box-header-table-large\");\n               $('#box-header-table42').addClass(\"box-header-table-large\");\n               $('#box-header-table3').removeClass(\"box-header-table\");\n               $('#box-header-table41').removeClass(\"box-header-table\");\n               $('#box-header-table42').removeClass(\"box-header-table\");\n        }\n        if(trim($('.header-text5').text()).length>=36 | trim($('.header-text6').text()).length>=36){\n               $('#box-header-table5').addClass(\"box-header-table-large\");\n               $('#box-header-table6').addClass(\"box-header-table-large\");\n               $('#box-header-table5').removeClass(\"box-header-table\");\n               $('#box-header-table6').removeClass(\"box-header-table\");\n        }\n// Nick 20111115\n        if(trim($('.header-text7').text()).length>=36){\n               $('#box-header-table7').addClass(\"box-header-table-large\");\n               $('#box-header-table7').removeClass(\"box-header-table\");\n        }\n\n/* Terry 20111018, Workaround to fix buttons can't work in IE6/IE7 */\n              if (navigator.appVersion.indexOf(\"MSIE\") != -1 && parseFloat(navigator.appVersion.split(\"MSIE\")[1]) < 8) {\n                        document.getElementById('page-table1').style.filter=\"\";\n                        document.getElementById('page-table2').style.filter=\"\";\n              }\n\n              //$('.scroll-pane').jScrollPane('scrollbarMargin:5px');\n    });\n\n    function trim(value)\n    {\n        var ptntrim = /(^\\s*)|(\\s*$)/g;\n        return value.replace(ptntrim,\"\");\n    }\n\n    function setHelpIframeVisible(){\n        $('.bas-help-frame-div').css(\"visibility\",\"visible\");\n    }\n\n\n    function showHelpIframe() {\n\n\n        var imgSrc=document.getElementById('help-button');\n\n        if(imgSrc.src.search(\"down\")>=0)\n        {\n            $(\".bas-help-frame-div\").show();\n            imgSrc.src=\"img/helparrowup-icon.gif\";\n        }\n        else\n        {\n            $(\".bas-help-frame-div\").hide();\n            imgSrc.src=\"img/helparrowdown-icon.gif\";\n            setTimeout(setHelpIframeVisible,500);\n        }\n    }\n\n    function loadhelp(fname,anchname)\n    {\n        if ((loadhelp.arguments.length == 1 ) || (anchname == \"\" ))\n            $('#page').attr(\"src\",fname+\"_h.\"+\"htm\");\n        else\n            $('#page').attr(\"src\",fname+\"_h.\"+\"htm#\"  + anchname);\n    }\n\n\n\nfunction adjustPageLayout()\n{\n    //adjustButtonSize();\n    //Eason, 20141106, resize the tables' heigh when zoom in/out.\n    $('#page-table1').css(\"height\",0);\n    $('#page-table2').css(\"height\",0);\n    $('#page-table3').css(\"height\",0);\n    $('#page-table41').css(\"height\",0);\n    $('#page-table42').css(\"height\",0);\n    $('#page-table5').css(\"height\",0);\n    $('#page-table6').css(\"height\",0);\n        var table_height1 = $('#page-table1')[0].clientHeight+\"px\";\n        var table_height2 = $('#page-table2')[0].clientHeight+\"px\";\n        var table_height3 = $('#page-table3')[0].clientHeight+\"px\";\n// Nick        var table_height4 = $('#page-table4')[0].clientHeight+\"px\";\n        var table_height41 = $('#page-table41')[0].clientHeight+\"px\";\n        var table_height42 = $('#page-table42')[0].clientHeight+\"px\";\n        var table_height5 = $('#page-table5')[0].clientHeight+\"px\";\n        var table_height6 = $('#page-table6')[0].clientHeight+\"px\";\n\n        if($('#page-table1')[0].clientHeight >=  $('#page-table2')[0].clientHeight)\n            $('#page-table2').css(\"height\",table_height1);\n        else\n            $('#page-table1').css(\"height\",table_height2);\n\n/*\n        if($('#page-table3')[0].clientHeight >=  $('#page-table4')[0].clientHeight)\n            $('#page-table4').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height4);\n*/\n        if($('#page-table3')[0].clientHeight >=  $('#page-table41')[0].clientHeight)\n            $('#page-table41').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height41);\n\n        if($('#page-table3')[0].clientHeight >=  $('#page-table42')[0].clientHeight)\n            $('#page-table42').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height42);\n\n        if($('#page-table5')[0].clientHeight >=  $('#page-table6')[0].clientHeight)\n            $('#page-table6').css(\"height\",table_height5);\n        else\n            $('#page-table5').css(\"height\",table_height6);\n}\n\nfunction adjustButtonSize()\n{\n    if($('#reboot')[0].scrollHeight > 15 ||\n        $('#statistics')[0].scrollHeight > 15 ||\n        $('#status')[0].scrollHeight > 15)\n    {\n        $($('#reboot')[0].parentNode).addClass('page-table-button-large');\n        $($('#reboot')[0].parentNode).removeClass('page-table-button');\n        $($('#statistics')[0].parentNode).addClass('page-table-button-large');\n        $($('#statistics')[0].parentNode).removeClass('page-table-button');\n        $($('#status')[0].parentNode).addClass('page-table-button-large');\n        $($('#status')[0].parentNode).removeClass('page-table-button');\n    }\n    else\n    {\n        $($('#reboot')[0].parentNode).removeClass('page-table-button-large');\n        $($('#reboot')[0].parentNode).addClass('page-table-button');\n        $($('#statistics')[0].parentNode).removeClass('page-table-button-large');\n        $($('#statistics')[0].parentNode).addClass('page-table-button');\n        $($('#status')[0].parentNode).removeClass('page-table-button-large');\n        $($('#status')[0].parentNode).addClass('page-table-button');\n    }\n}\n\nfunction advButtonClick(index){\n\n    if(index==0) // Show Statistics\n        openStatisticsWindow();\n    else if(index==1)\n    {\n          openStatusWindow();\n    // document.forms[0].buttonSelect.value=\"1\";\n    }\n    else if(index==2)\n    {\n        if(confirm(\"Rebooting the gateway will disrupt active traffic on the network. Are you sure?\"))\n        {\n            document.forms[0].buttonSelect.value=\"2\";\n            document.forms[0].submit(document.forms[0]);\n        }\n    }\n    else if(index==3)\n    {\n        if(confirm(\"Loading the factory default settings will erase all the current settings. Are you sure?\"))\n        {\n            document.forms[0].buttonSelect.value=\"3\";\n            document.forms[0].submit(document.forms[0]);\n        }\n    }\n    // Nick 20110927\n}\n\nfunction openStatWindow() {\n    window.open(this.form.stat_page.value, '','height=350,status=yes');\n    return ture;\n}\n\n\nfunction openStatusWindow()\n{\n    var conn = document.forms[0].wantype.value;\n\n    // Chuck 20140902 fix mantis#12486\n    if(isUnsupportedMobileBrowser())\n    {\n        if (conn == \"dhcp\")\n        {\n            top.$.blockUI({\n                message: '<iframe width=\"400px\" height=\"550px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n                css: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n                onOverlayClick: closeIframe\n            });\n        }\n        else if (conn == \"pppoe\")\n        {\n            top.$.blockUI({\n                message: '<iframe width=\"400px\" height=\"450px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n                css: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n                onOverlayClick: closeIframe\n            });\n        }\n        else\n        {\n            top.$.blockUI({\n                message: '<iframe width=\"400px\" height=\"350px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n                css: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n                onOverlayClick: closeIframe\n            });\n        }\n    }\n    else\n    {\n        var winoptions;\n        if (conn == \"dhcp\")\n        //if (conn == \"dhcp\" || conn == \"pppoe\")\n                winoptions = \"width=400,height=460,status=yes,resizable=yes\";\n        else if (conn == \"pppoe\")\n        {\n            /*\n            if (\"0\" == \"1\")\n                    winoptions = \"width=400,height=600,status=yes,resizable=yes\";\n            else\n            */\n                        winoptions = \"width=400,height=360,status=yes,resizable=yes\";\n        }\n        else\n                winoptions = \"width=400,height=260,status=yes,resizable=yes\";\n\n\n        openDataSubWin('ConnectionStatusDhcp.htm',winoptions);\n        showDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n        // Chuck 20140902 fix mantis#12486\n        // Chuck 20150203 Fix TD#328: C7000-100NAS: User Interface -- GUI is stuck when closing \"connection status\" page quickly.\n        //if(!isOnBeforeUnloadSupported())\n        {\n            detectPoppedWindowStatus();\n        }\n    }\n}\n\n// Chuck 20140902 fix mantis#12486\n// We will use polling instead of onBeforeUnload in following browsers\n// PC: Opera with Presto,\n// iPad: Safari,\n// iPhone: Opera\n// Android Pad: Opera, Chrome(restoring delayed about 3 secs?), Firefox\n// Android Phone:\nfunction isOnBeforeUnloadSupported()\n{\n    if(navigator.userAgent.indexOf(\"Presto\") > -1\n        || navigator.userAgent.indexOf(\"iPad\") > -1\n        || navigator.userAgent.indexOf(\"iPhone\") > -1\n        || navigator.userAgent.indexOf(\"Android\") > -1\n        )\n    {\n        return false;\n    }\n\n    return true;\n}\n\n// Chuck 20140902 fix mantis#12486\n// Because the following browser can't handle the window opened by itself, we will use BlockUI instead of polling or onBeforeUnload to prevent user clicking the GUI when a statistic/connection status window is opening.\n// PC:\n// iPad: Opera Mini,\n// iPhone:\n// Android Pad: Dolphin Mini, UC, Safari, Native\n// Android Phone:\nfunction isUnsupportedMobileBrowser()\n{\n    /* Examples:\n     * iPad-Safari: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) Version/7.0 Mobile/11D201 Safari/9537.53\n     * iPad-Opera: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) OPiOS/8.0.2.80660 Mobile/11D201 Safari/9537.53\n     * iPad-Chrome: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) CriOS/36.0.1985.57 Mobile/11D201 Safari/9537.53 (000514)\n     * Android-Native: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/534.30 (KHTML, like Gecko) Version/4.0 Safari/534.30\n     * Android-Opera: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/35.0.1916.138 Safari/537.36 OPR/22.0.1485.81203\n     * Android-Chrome: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/36.0.1958.135 Safari/537.36\n     * PC-IE: Mozilla/5.0 (Windows NT 6.1; Trident/7.0; SLCC2; .NET CLR 2.0.50727; .NET CLR 3.5.30729; .NET CLR 3.0.30729; Media Center PC 6.0; InfoPath.3; .NET4.0C; .NET4.0E; rv:11.0) like Gecko\n     * PC-Opera: Opera/9.80 (Windows NT 6.1; U; zh-tw) Presto/2.10.289 Version/12.00\n     * PC-Chrome: Mozilla/5.0 (Windows NT 6.1) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/37.0.2062.102 Safari/537.36\n     */\n    var firstSupportedWebKit = \"AppleWebKit/535\";\n    if(navigator.userAgent.indexOf(\"iPad\") == -1\n        && navigator.userAgent.indexOf(\"iPhone\") == -1\n        && navigator.userAgent.indexOf(\"Android\") == -1\n        )\n    {\n        // Is PC browser.\n        return false;\n    }\n    else if(navigator.userAgent.indexOf(\"OPiOS\") > -1)\n    {\n        // Although the AppleWebKit version of Opera on iOS is greater than 534, but it still can't handle the opened window.\n        return true;\n    }\n    else if(navigator.userAgent.indexOf(\"AppleWebKit/\") > -1\n        && navigator.userAgent.substring(navigator.userAgent.indexOf(\"AppleWebKit/\")) < firstSupportedWebKit)\n    {\n        // The browser using the lower version (<=534) of AppleWebKit can't handle the window opened by itself.\n        return true;\n    }\n\n    return false;\n}\n\n// Chuck 20140902 fix mantis#12486\nvar intervalId;\nfunction detectPoppedWindowStatus()\n{\n    intervalId = setInterval(reloadPage, 200);\n}\n\nfunction openStatisticsWindow()\n{\n    var conn = document.forms[0].wantype.value;\n    var form=document.forms[0];\n    // Terry 20111017, Fix IE6/IE7/IE8 can't find curlang error\n    var gui_region = document.getElementsByName(\"curlang\")[0];\n    //var gui_region = form.curlang.value;\n\n    // Chuck 20140902 fix mantis#12486\n    if(isUnsupportedMobileBrowser())\n    {\n        top.$.blockUI({\n            message: '<iframe width=\"100%\" height=\"450px\" src=\"Statistic.htm\"></iframe>',\n            css: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n            onOverlayClick: closeIframe\n        });\n    }\n    else\n    {\n        var winoptions;\n        if(gui_region==\"German\"){\n           winoptions = \"width=1024,height=360,status=yes,resizable=yes\";\n           openDataSubWin('Statistic.htm',winoptions);\n           showDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n        }else{\n           winoptions = \"width=780,height=360,status=yes,resizable=yes\";\n           openDataSubWin('Statistic.htm',winoptions);\n           showDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n        }\n        // Chuck 20140902 fix mantis#12486\n        // Chuck 20150203 Fix TD#328: C7000-100NAS: User Interface -- GUI is stuck when closing \"connection status\" page quickly.\n        //if(!isOnBeforeUnloadSupported())\n        {\n            detectPoppedWindowStatus();\n        }\n    }\n}\n\nfunction setTimer()\n{\n    setTimeout(reloadPage,300);\n}\nfunction reloadPage()\n{\n    if(datSubWinVar.closed)\n    {\n        window.location.reload();\n        parent.document.getElementById(\"diablePage\").style.display = \"none\";\n        // Chuck 20140902 fix mantis#12486\n        // Chuck 20150203 Fix TD#328: C7000-100NAS: User Interface -- GUI is stuck when closing \"connection status\" page quickly.\n        //if(!isOnBeforeUnloadSupported())\n        {\n            clearInterval(intervalId);\n        }\n    }\n}\n\n// Chuck 20140902 fix mantis#12486\nfunction closeIframe()\n{\n    top.$.unblockUI();\n    window.location.reload();\n}\n\n// Chuck 20141106 change the way of determining whether to change the button size\nfunction modifyBtnCss()\n{\n    var arr = [\"reboot_btn\", \"status_btn\", \"statistics_btn\", \"reset_btn\"];\n\n    jQuery.each(arr, function(i, val){\n        var len = parent.calculate_string_pixel($(\"#\" + val).children().html());\n        var txt = trim($(\"#\" + val).children().html());\n        if(len > 125)\n        {\n            $(\"#\" + val).addClass('page-table-button-large');\n            $(\"#\" + val).removeClass('page-table-button');\n            $(\"#\" + val).children().css(\"word-break\", \"break-all\");\n        }\n        else\n        {\n            $(\"#\" + val).removeClass('page-table-button-large');\n            $(\"#\" + val).addClass('page-table-button');\n            $(\"#\" + val).children().css(\"word-break\", \"keep-all\");\n        }\n\n        return true;\n    });\n}\nfunction loadSettings()\n{\n    var cf=document.forms[0];\n\n    adjustPageLayout();\n     parent.$('#page2').css(\"visibility\",\"visible\");\n    parent.$('#page_contain2').removeClass('main-page-contain-loading');\n    modifyBtnCss();\n/*\n    if (cf.enable_apmode.value == 1)\n    {\n\n        var statusButton;\n        cf.Status.disabled = 'true';\n        statusButton=document.getElementsByName(\"Status\");\n        //statusButton.outerHTML='<button type=\"submit\" disabled=\"disabled\" value=\"Safely Remove USB Device\" name=\"Remove\" class=\"button-grey\" onClick=\"buttonClick(this,\\'Safely Remove USB Device\\');return remove_disk();\"><span class=\"roundleft_grey\">&nbsp;&nbsp; Safely Remove USB Device<\\/span><span class=\"roundright_grey\">&nbsp;&nbsp;&nbsp;&nbsp;<\\/span><\\/button>';\n        statusButton.outerHTML='<button type=\"button\" disabled=\"disabled\" class=\"button-grey\" style=\"float:left\" onClick=\"advButtonClick(1);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\" name=\"Status\">Connection Status<\\/button>';\n        //removeButton[0].style.cursor='default';\n    }\n*/\n}\n\nfunction InitTagValue()\n{\n/*\n  Hardware Version (td) | Firmware Version (td) | CableModem Serial Number (td) |\n  CM certificate | Cable MAC Address | Cable IP Mask | Cable Gateway | Cable DNS | Network Access |\n  Internet Mac address (td) | Internet IP Mask (td) | DHCP (td) | Internet Gateway |Internet Domain Name Server (td) |\n  LAN Mac address (td) | LAN IP Mask (td) | LAN DHCP (td)\n2.4G  Wireless SSID (td) | Wireless Region (td) | Wireless Channel (td) | Wireless Mode (td) | Wireless AP (td) | Wireless Broadcast Name (td) | Wireless Isolation (td)\n5G    Wireless SSID (td) | Wireless Region (td) | Wireless Channel (td) | Wireless Mode (td) | Wireless AP (td) | Wireless Broadcast Name (td) | Wireless Isolation (td)\n2.4G  Guest Network SSID (td) | Guest Network AP (td)\n5G  Guest Network SSID (td) | Guest Network AP (td)\nSystem Up Time | Current System Time\n*/\n    var tagValueList = 'C279T00-01|V2.02.18|***SERIAL***|1|XX:XX:XX:XX:XX:XX|---.---.---.---/-|---.---.---.---|---.---.---.---, ---.---.---.---, ---.---.---.---|Allowed|XX:XX:XX:XX:XX:XX|***PUBLIC_IP*** /255.255.224.0, <br>***IPv6*** /128|DHCP Client|***PUBLIC_IP***|***PUBLIC_IP***, ***PUBLIC_IP***, <br>***IPv6***, ***IPv6***|XX:XX:XX:XX:XX:XX|192.168.0.1/24|On|***SSID***|United States|Auto (6 (P) + 2 (S)) |Up to 300 Mbps|On|On|***SSID***-5G|United States|149 (S)+153 (P)|Up to 300 Mbps|On|On|---|Off|---|Off|26 days ***IPv6***|Wed Nov 26 ***IPv6*** 2025|Configured|Configured|---|---|---|---|security|security|none|none|1|0|---|---|---|---|---|---|---|---|0|1|1|0|1|';\n/*\n    var tagValueList = \"v1.0|v0.1|12345678|None\" +\n                \"|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***.13/24|***PRIVATE_IP***.254|***PUBLIC_IP***, ***PUBLIC_IP***|Enable\" +\n                \"|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***/24|DHCPClient|***PRIVATE_IP***|***PUBLIC_IP***, ***PUBLIC_IP***\" +\n                 \"|XX:XX:XX:XX:XX:XX|192.168.1.1/24|On\" +\n                \"|NETGEAR_24G|North American|Auto (1)|Up to 300Mbps|Off|On|Off\" +\n                \"|NETGEAR_5G|North American|Auto (1)|Up to 145Mbps|Off|On|Off\" +\n                \"|Guest1|Off|Guest1_5G|Off\" +\n                \"|Wednesday, 01 Jan 2003 ***IPv6***|Wednesday, 01 Jan 2003 ***IPv6***\" +\n                \"|Configured|UnConfigured\" +\n                \"|---|---|---|---|---|---\" +\n                \"|1|\" ;\n*/\n    return tagValueList.split(\"|\");\n}\n\nfunction InitUpdateView(tagValues)\n{\n    /* Hardware Version */\n    document.getElementById(\"HardwareVersion\").innerHTML = tagValues[0];\n\n    /* Firmware Version */\n    document.getElementById(\"FirmwareVersion\").innerHTML = tagValues[1];\n\n    /* CableModem Serial Number */\n    document.getElementById(\"CableModemSerialNumber\").innerHTML = tagValues[2];\n\n    /* CM certificate */\n    if (tagValues[3] == '1')\n        document.getElementById(\"CMcertificate\").innerHTML = 'Installed';\n    else\n        document.getElementById(\"CMcertificate\").innerHTML = 'Not Installed';\n\n\n    /* GUI Version */\n//    document.getElementById(\"GUIVersion\").innerHTML = tagValues[2];\n\n    // Cable MAC Address\n    document.getElementById(\"CableMACAddress\").innerHTML = tagValues[4];\n\n    // Cable IP Mask\n//    document.getElementById(\"CableIPMask\").innerHTML = tagValues[5];\n\n    /* Cable Gateway */\n//    document.getElementById(\"CableGateway\").innerHTML = tagValues[6];\n\n    /* Cable DNS */\n//    document.getElementById(\"CableDNS\").innerHTML = tagValues[7];\n\n    /* Network Access */\n//    document.getElementById(\"NetworkAccess\").innerHTML = tagValues[8];\n\n\n    /* Internet Mac address */\n    document.getElementById(\"InternetMAC\").innerHTML = tagValues[9];\n\n    /* Internet IP */\n    document.getElementById(\"InternetIPMASK\").innerHTML = tagValues[10];\n    if(tagValues[10] == \"&nbsp;\")\n    {\n       document.getElementById(\"interIPMask\").style.display = \"none\";\n       document.getElementById(\"interIPMaskLine\").style.display = \"none\";\n    }\n\n    /* Internet DHCP */\n    document.getElementById(\"InternetDHCP\").innerHTML = tagValues[11];\n\n    /* Internet Gateway */\n    if ((tagValues[12] == \"0.0.0.0\") || (tagValues[12] == \"---.---.---.---\") || tagValues[8] == \"Denied\")\n    {\n        $(\"#Internet\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        $(\"#Internet\").attr(\"src\", \"img/good-icon.gif\");\n    }\n\n    document.getElementById(\"InternetGateway\").innerHTML = tagValues[12];\n\n    /* Internet DNS */\n    if((tagValues[10] == \"---.---.---.---\") && (tagValues[12] == \"---.---.---.---\"))\n    {\n        document.getElementById(\"InternetDNS\").innerHTML = \"---.---.---.---\";\n    }\n    else\n    {\n        document.getElementById(\"InternetDNS\").innerHTML = tagValues[13];\n    }\n\n    /* LAN Mac address */\n    document.getElementById(\"LANMAC\").innerHTML = tagValues[14];\n\n    /* LAN IP */\n    document.getElementById(\"LANIPMASK\").innerHTML = tagValues[15];\n\n    /* LAN DHCP */\n    document.getElementById(\"LANDHCP\").innerHTML = tagValues[16];\n\n    /* LAN IP Subnet mask */\n//    document.getElementById(\"LANIPSubnet\").innerHTML = tagValues[11];\n\n    /* Wireless SSID */\n    document.getElementById(\"WirelessName\").innerHTML = piplineDecode(tagValues[17]);\n\n    /* Wireless Region */\n    document.getElementById(\"WirelessRegion\").innerHTML = tagValues[18];\n\n    /* Wireless Channel */\n    document.getElementById(\"WirelessChannel\").innerHTML = tagValues[19];\n\n    /* Wireless Mode */\n    document.getElementById(\"WirelessMode\").innerHTML = tagValues[20];\n\n    /* Wireless AP */\n    document.getElementById(\"WirelessAP\").innerHTML = tagValues[21];\n\n    /* Wireless Broadcast Name */\n    document.getElementById(\"WirelessBroadcastName\").innerHTML = tagValues[22];\n\n    /* Wireless SSID */\n    document.getElementById(\"WirelessName_an\").innerHTML = piplineDecode(tagValues[23]);\n\n    /* Wireless Region */\n    document.getElementById(\"WirelessRegion_an\").innerHTML = tagValues[24];\n\n    /* Wireless Channel */\n    document.getElementById(\"WirelessChannel_an\").innerHTML = tagValues[25];\n\n    /* Wireless Mode */\n    document.getElementById(\"WirelessMode_an\").innerHTML = tagValues[26];\n\n    /* Wireless AP */\n    document.getElementById(\"WirelessAP_an\").innerHTML = tagValues[27];\n\n    /* Wireless Broadcast Name */\n    document.getElementById(\"WirelessBroadcastName_an\").innerHTML = tagValues[28];\n\n    /* 2.4G SSID */\n    document.getElementById(\"GuestNetworkName1\").innerHTML = piplineDecode(tagValues[29]);\n    $('#GuestNetworkName1_B').html(piplineDecode(tagValues[29]));\n\n    /* 2.4G Wireless AP */\n    document.getElementById(\"GuestNetworkAP1\").innerHTML = tagValues[30];\n    $('#GuestNetworkAP1_B').html(tagValues[30]);\n\n    /* 5G SSID */\n    document.getElementById(\"GuestNetworkName1_an\").innerHTML = piplineDecode(tagValues[31]);\n\n    /* 5G Wireless AP */\n    document.getElementById(\"GuestNetworkAP1_an\").innerHTML = tagValues[32];\n\n    /* System Up Time */\n//    document.getElementById(\"SystemUpTime\").innerHTML = tagValues[33];\n\n    /* Current System Time */\n//    document.getElementById(\"CurrentSystemTime\").innerHTML = tagValues[34];\n\n    /* 2.4G WPS configured mode */\n    document.getElementById(\"WPSMode\").innerHTML = tagValues[35];\n\n    /* 5G WPS configured mode */\n    document.getElementById(\"WPSMode_an\").innerHTML = tagValues[36];\n\n    /* 2.4G Guest1 Broadcast */\n    document.getElementById(\"GuestNetworkBroadcast1\").innerHTML = tagValues[37];\n    $('#GuestNetworkBroadcast1_B').html(tagValues[37]);\n\n    /* 2.4G Guest1 Allow Guest */\n    document.getElementById(\"GuestNetworkAllow1\").innerHTML = tagValues[38];\n    $('#GuestNetworkAllow1_B').html(tagValues[38]);\n\n    /* 5G Guest1 Broadcast */\n    document.getElementById(\"GuestNetworkBroadcast1_an\").innerHTML = tagValues[39];\n\n    /* 5G Guest1 Allow Guest */\n    document.getElementById(\"GuestNetworkAllow1_an\").innerHTML = tagValues[40];\n\n\n    // 2.4G\n    if (tagValues[21] == \"Off\")\n    {\n        $(\"#WiFi24G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[41] == \"none\")\n        {\n            $(\"#WiFi24G\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi24G\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 5G\n    if (tagValues[27] == \"Off\")\n    {\n        $(\"#WiFi5G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[42] == \"none\")\n        {\n            $(\"#WiFi5G\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi5G\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 2.4G WiFi Guest\n    if (tagValues[30] == \"Off\" || tagValues[21] == \"Off\")\n    {\n        $(\"#WiFi24GGDual\").attr(\"src\", \"img/error-icon.gif\");\n        $(\"#WiFi24GG\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[43] == \"none\")\n        {\n            $(\"#WiFi24GGDual\").attr(\"src\", \"img/warning-icon.gif\");\n            $(\"#WiFi24GG\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi24GGDual\").attr(\"src\", \"img/good-icon.gif\");\n            $(\"#WiFi24GG\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 5G WiFi Guest\n    if (tagValues[32] == \"Off\" || tagValues[27] == \"Off\")\n    {\n        $(\"#WiFi5GG\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[44] == \"none\")\n        {\n            $(\"#WiFi5GG\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi5GG\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n\n    // Support dual band\n    if (tagValues[45] == '1')\n    {\n        $(\"#setting_5G1\").css ('display', 'none');\n        $(\"#setting_5G2\").css ('display', 'block');\n        $(\"#setting_5G3\").css ('display', 'block');\n        // COMHEM supported\n        if (tagValues[55] == \"1\")\n        {\n            $(\"#setting_5G1\").css ('display', 'none');  // Guest 2.4G\n            $(\"#setting_5G2\").css ('display', 'block');  // WiFi 5G\n            $(\"#setting_5G3\").css ('display', 'none');  // Guest 5G\n        }\n    }\n    else\n    {\n        $(\"#setting_5G1\").css ('display', 'block');\n        $(\"#setting_5G2\").css ('display', 'none');\n        $(\"#setting_5G3\").css ('display', 'none');\n\n        // COMHEM supported\n        if (tagValues[55] == \"1\")\n        {\n            $(\"#setting_5G1\").css ('display', 'none');  // Guest 2.4G\n            $(\"#setting_5G2\").css ('display', 'none');  // WiFi 5G\n            $(\"#setting_5G3\").css ('display', 'none');  // Guest 5G\n        }\n    }\n\n    // Rg/Bridge Mode\n    if (tagValues[56] == \"0\") // is bridge mode\n    {\n        // Bridge mode\n        $(\"#internetPort\").css ('display', 'none');  // Internet Port box\n        // Is not ComHem supported\n        // Chuck 20141001 show wireless column in bridge mode with generic gui\n        if (tagValues[58] == \"0\" && tagValues[59] == \"0\")\n        {\n            $(\"#setting_Wifi24G\").css ('display', 'none');  // WiFi 2.4G part\n            $(\"#setting_5G3\").css ('display', 'none');  // WiFi 5G part\n        }\n\n        //Eason, 20130121, bridge mode do not show LAN information\n        $('#LANMAC').html(\"--:--:--:--:--:--\");\n        $('#LANIPMASK').html(\"---.---.---.---\");\n        $('#LANDHCP').html(\"Off\");\n\n        // Chuck 20160901 MAC address of LAN port can't display in bridge mode\n        $(\"#LANPort-table\").hide();\n    }\n\n    if(tagValues[56] == \"1\") // is router mode\n    {\n        $('#wireless_setup').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n\n        $('#wireless_setup_5G').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n    }\n    else // is bridge mode\n    {\n        if(tagValues[59] == \"0\")\n        {\n            $('#wireless_setup').click(function(ev){\n                parent.loadPage2(\"WirelessSettings.htm\");\n            });\n\n            $('#wireless_setup_5G').click(function(ev){\n                parent.loadPage2(\"WirelessSettings.htm\");\n            });\n        }\n        else\n        {\n            // Chuck 20141001 do not link wireless column to WirelessSettings in bridge mode with generic gui\n        }\n    }\n\n\n    if (tagValues[46] == '1')\n    {\n        $(\"#setting_Mobile\").css ('display', 'block');\n    }\n    else\n    {\n        $(\"#setting_Mobile\").css ('display', 'none');\n    }\n\n    if (tagValues[46] == \"1\")\n    {\n        $(\"#Attached3G\").attr(\"src\", \"img/good-icon.gif\");\n    }\n    else\n    {\n        $(\"#Attached3G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n\n    $('#ModemIdentity').html(tagValues[47]);\n    $('#ModemSWVersion').html(tagValues[48]);\n    $('#ModemDriverVersion').html(tagValues[49]);\n    $('#ModemStatus').html(tagValues[50]);\n    $('#ModemIMSI').html(tagValues[51]);\n    $('#ModemIMEI').html(tagValues[52]);\n    $('#ModemOperator').html(tagValues[53]);\n    $('#ModemNetworkMode').html(tagValues[54]);\n\n    // Chuck 20141001 Do not show guest network column in bridge mode with generic gui\n    if (tagValues[57] == \"0\" || (tagValues[56] == \"0\" && tagValues[59] == \"1\"))\n    {// is admin access or is bridge mode and generic gui\n        $(\"#setting_5G1\").hide();  // Guest 2.4G\n        $(\"#setting_5G3\").hide();  // Guest 5G\n    }\n\n}\n\nfunction BodyInit()\n{\n    InitUpdateView(InitTagValue());\n    hiddenWifi('0');\n    initBridgeView('0');\n}\n\nfunction initBridgeView(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#LANPort-table\").hide();\n    }\n}\nfunction hiddenWifi(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#setting_Wifi24G\").hide();\n        $(\"#setting_5G3\").hide();\n    }\n}\nfunction ChangeResize()\n{\n    if(navigator.userAgent.indexOf(\"MSIE\") != -1){\n        $(parent.document).find('#page2').height(parseInt(parent.document.getElementById(\"page_contain2\").clientHeight));\n    }\n    $(\".scroll-pane\").css(\"height\",document.documentElement.clientHeight+\"px\");\n    if( !navigator.userAgent.match(/Android/i)\n       && !navigator.userAgent.match(/webOS/i)\n       && !navigator.userAgent.match(/iPhone/i)\n       && !navigator.userAgent.match(/iPad/i)\n       && !navigator.userAgent.match(/iPod/i)\n       && !navigator.userAgent.match(/BlackBerry/i)\n       && !navigator.userAgent.match(/Windows Phone/i)\n    ){\n        $('.scroll-pane').jScrollPane('scrollbarMargin:5px');\n    }\n    $(\".scroll-pane\").css(\"width\",\"670px\");\n    $(\".jspContainer\").css(\"width\",\"670px\");\n    $(\".jspPane\").css(\"width\",\"670px\");\n}\n\n//Eason, 20141106, resize the tables' high when zoom in/out.\nfunction change_zoom()\n{\n    var windowWidth = parent.window.innerWidth;\n    setInterval(function(){\n        if (parent.window.innerWidth == windowWidth) return;\n        windowWidth = parent.window.innerWidth;\n        adjustPageLayout();\n    }, 200);\n}\n\n</script>\n\n\n</head>\n\n<body onload=\"ChangeResize();change_zoom();loadSettings();\" onResize=\"ChangeResize();modifyBtnCss();\" bgcolor=\"#E5E5E5\" style=\"width:640px;margin:0px;padding:0px\">\n    <form action='/goform/RouterStatus?id=239640653' method=\"post\">\n        <div id=\"scroll-pane\" class=\"scroll-pane\" style=\"height:420px;width:670px;overflow:auto;scrolling:auto\">\n            <table>\n                <tr>\n                    <td>\n                        <div style=\"float:left;width:635px;positive:relative;border:0px;padding-left:3px;margin:0px\">\n                            <div id=\"cableInformation\" style=\"float:left;width:310px;positive:relative;border:0px;margin-top;0px\">\n                                <div id=\"box-header-table1\" class=\"box-header-table\">\n                                    <table>\n                                        <tr class=\"box-header\">\n                                            <td style=\"width:17px\">\n                                                <img alt=\"\" src=\"img/good-icon.gif\" style=\"padding-left:10px;padding-top:3px\" />\n                                            </td>\n                                            <td class=\"box-header-text header-text1\">\n                                                Cable Information\n                                            </td>\n                                        </tr>\n                                    </table>\n                                </div>\n                                <table style=\"width:305px;background-color:#FFFFFF;margin-left:5px;border-collapse:collapse;border-right:3px solid #D0D0D0\">\n                                    <tr align=\"left\" valign=\"bottom\">\n                                        <td>\n                                            <table id=\"page-table1\" class=\"page-table\" style=\"width:300px;background-color:#FFFFFF;height:150px\">\n                                                <tr style=\"height:6px;background-color:#FFFFFF\">\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                    </td>\n                                                </tr>\n                                                <tr><td colspan=\"2\"><table id=\"Modem-table\" cellspacing=\"0\" width=\"100%\">\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\" style=\"width:25%\">\n                                                        Hardware Version\n                                                    </td>\n                                                    <td class=\"basic-text-content\" style=\"width:75%\" id=\"HardwareVersion\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        Firmware Version\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"FirmwareVersion\">\n                                                