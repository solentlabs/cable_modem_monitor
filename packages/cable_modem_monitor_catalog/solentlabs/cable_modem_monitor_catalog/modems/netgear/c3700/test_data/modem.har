und-color:#FFFFFF\">\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\" style=\"width:25%\">\n                                                        MAC Address\n                                                    </td>\n                                                    <td class=\"basic-text-content\" style=\"width:75%\" id=\"InternetMAC\">\n                                                    </td>\n                                                    <!-- <td class=\"basic-text-content\" width=\"75%\">XX:XX:XX:XX:XX:XX</td>\n                                                    -->\n                                                </tr>\n                                                <!-- <tr>\n                                                <td colspan=\"2\" class=\"basic-table-seperate-border\"><div class=\"basic-table-seperate\"></div></td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                <td class=\"basic-text-menu\" >DHCP </td>\n                                                <td class=\"basic-text-content\" >On </td>\n                                                </tr>\n                                                -->\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n        