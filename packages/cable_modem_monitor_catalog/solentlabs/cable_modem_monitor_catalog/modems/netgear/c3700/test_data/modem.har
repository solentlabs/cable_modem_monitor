x; word-break: break-all;display: inline-block; margin-left: 7px;\">\n                                                                Connection Status\n                                                            </div>\n                                                        </button>\n                                                    </td>\n                                                </tr>\n                                            </table>\n                                            <input type=\"hidden\" style=\"float:left;height:0px\">\n                                        </td>\n                                    </tr>\n                                </table>\n                                <div class=\"page-table-bottom-2\">\n                                </div>\n                            </div>\n                        </div>\n                    </td>\n                </tr>\n                <tr>\n                    <td style=\"height:2px;\">\n                    </td>\n                </tr>\n                <tr>\n                    <td>\n                        <div class=\"adv-home-table-seperate\">\n                        </div>\n                        <div class=\"adv-home-table-seperate-2\">\n                        </div>\n                    </td>\n                </tr>\n                <tr>\n                    <td style=\"height:2px\">\n                    </td>\n                </tr>\n                <tr>\n                    <td>\n                        <table id='setting_Wifi24G' style='display:block'>\n                            <tr>\n                                <td>\n                                    <div style=\"float:left;width:635px;positive:relative;top:0px;padding-left:3px;\">\n                                        <div style=\"float:left;width:310px;positive:relative;top:0px\">\n                                            <div id=\"box-header-table3\" class=\"box-header-table\">\n                                                <table>\n                                                    <tr class=\"box-header\">\n                                                        <td style=\"width:17px\">\n                                                            <img alt=\"\" id='WiFi24G' src=\"img/warning-icon.gif\" style=\"padding-left:10px;padding-top:3px\"/>\n                                                        </td>\n                                                        <td class=\"box-header-text header-text3\" style=\"cursor:pointer;\" id=\"wireless_setup\">\n                                                            Wireless Settings (2.4GHz)\n                                                        </td>\n                                                    </tr>\n                                                </table>\n                                            </div>\n                                            <table style=\"width:305px;background-color:#FFFFFF;margin-left:5px;border-collapse:collapse;border-right:3px solid #D0D0D0\">\n                                                <tr align=\"left\" valign=\"bottom\">\n                                                    <td>\n                                                        <table id=\"page-table3\" class=\"page-table\" style=\"background-color:#FFFFFF;width:300px;height:150px\">\n                                                            <tr style=\"height:6px;background-color:#FFFFFF\">\n                                                                <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                                </td>\n                                                            </tr>\n                                                            <tr class=\"basic-text\">\n                                                                <td class=\"basic-text-menu\">\n                                                                    Name (S