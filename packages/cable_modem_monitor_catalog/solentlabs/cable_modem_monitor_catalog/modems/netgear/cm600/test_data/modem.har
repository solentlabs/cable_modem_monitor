          "content": {
            "size": 119050,
            "mimeType": "text/html",
            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n\n<html>\n\n<head>\n\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=7\">\n<META name=\"description\" content='CM600'>\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<META http-equiv=\"Pragma\" content=\"no-cache\">\n<META HTTP-equiv=\"Cache-Control\" content=\"no-cache\">\n<META HTTP-EQUIV=\"Expires\" CONTENT=\"Mon, 06 Jan 1990 ***IPv6*** GMT\">\n\n<meta http-equiv=\"content-type\" content=\"text/html; charset=ISO-8859-1\">\n<!--\n<meta http-equiv=\"refresh\" content=\"3\">\n-->\n<title>NETGEAR Gateway CM600</title>\n<link rel=\"stylesheet\" href=\"css/table.css\">\n<link rel=\"stylesheet\" href=\"css/scrollbar.css\">\n<link rel=\"stylesheet\" href=\"css/button.css\">\n\n<script type=\"text/javascript\" src=\"jquery.js\"></script>\n\n<script type=\"text/javascript\" src=\"script/jquery.mousewheel.js\"></script>\n<script type=\"text/javascript\" src=\"script/jquery.jscrollpane.min.js\"></script>\n\n<script type=\"text/javascript\" src=\"script/script.js\"></script>\n<link rel=\"stylesheet\" href=\"form.css\">\n<!--STYLE TYPE=\"text/javascript\">\n\tclasses.num.all.fontFamily = \"Courier\";\n\tclasses.num.all.fontSize = \"10pt\" ;\n</style-->\n<script type=\"text/javascript\" src=\"func.js\"></script>\n<script type=\"text/javascript\" src=\"msg.js\"></script>\n<script type=\"text/javascript\" src=\"utility.js\"></script>\n<script type=\"text/javascript\" src=\"browser.js\"></script>\n\n<script type=\"text/javascript\" src=\"md5.js\"></script>\n<script type=\"text/javascript\" src=\"wep.js\"></script>\n<script type=\"text/javascript\">\n<!--\nvar DisableFixedDNS = false;\nvar DisableFixedMAC = false;\nvar MacAddress;\nvar DodDisable = false;\nvar DodIndex = 1;\n\n    $(document).ready(function()\n    {\n        var form=document.forms[0];\n        var gui_region = form.curlang.value;\n\n        // Nick put bodyInit in here!!\n        BodyInit();\n\n        $('#INT_setup').click(function(ev){\n            parent.loadPage2(\"BasicSettingsBottom.htm\");\n        });\n\n        $('#wireless_setup').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n\n        $('#wireless_setup_5G').click(function(ev){\n            parent.loadPage2(\"WirelessSettings.htm\");\n        });\n\n        $('#guest_setup1').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#guest_setup2').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#guest_setup_5G').click(function(ev){\n            parent.loadPage2(\"GuestNetwork.htm\");\n        });\n\n        $('#LAN_setup').click(function(ev){\n            parent.loadPage2(\"WLG_adv_dual_band.htm\");\n        });\n\n        $('#Moblile_setup').click(function(ev){\n            parent.loadPage2(\"MobileBroadbandSettings.htm\");\n        });\n\n        $('.basic-text-menu').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-menu-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-menu-pr\");\n             }\n        });\n        $('.basic-text-subTitle').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-subTitle-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-subTitle-pr\");\n             }\n        });\n        $('.basic-text-content').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"basic-text-content-pr\");\n             }else{\n                 $(this).removeClass(\"basic-text-content-pr\");\n             }\n        });\n        $('.box-header-text').each(function(){\n             if(gui_region==\"Chinese\"){\n                 $(this).addClass(\"box-header-text-pr\");\n             }else{\n                 $(this).removeClass(\"box-header-text-pr\");\n             }\n        });\n        /* checking long string */\n        if(trim($('.header-text1').text()).length>=36 | trim($('.header-text2').text()).length>=36){\n               $('#box-header-table1').addClass(\"box-header-table-large\");\n               $('#box-header-table2').addClass(\"box-header-table-large\");\n               $('#box-header-table1').removeClass(\"box-header-table\");\n               $('#box-header-table2').removeClass(\"box-header-table\");\n        }\n\n/*override\n        if($('.header-text3').text().length>=36 | $('.header-text4').text().length>=36){\n               $('#box-header-table3').addClass(\"box-header-table-large\");\n               $('#box-header-table4').addClass(\"box-header-table-large\");\n               $('#box-header-table3').removeClass(\"box-header-table\");\n               $('#box-header-table4').removeClass(\"box-header-table\");\n        }\n*/\n        if(trim($('.header-text3').text()).length>=36 | trim($('.header-text41').text()).length>=36 | $('.header-text42').text().length>=36){\n               $('#box-header-table3').addClass(\"box-header-table-large\");\n               $('#box-header-table41').addClass(\"box-header-table-large\");\n               $('#box-header-table42').addClass(\"box-header-table-large\");\n               $('#box-header-table3').removeClass(\"box-header-table\");\n               $('#box-header-table41').removeClass(\"box-header-table\");\n               $('#box-header-table42').removeClass(\"box-header-table\");\n        }\n        if(trim($('.header-text5').text()).length>=36 | trim($('.header-text6').text()).length>=36){\n               $('#box-header-table5').addClass(\"box-header-table-large\");\n               $('#box-header-table6').addClass(\"box-header-table-large\");\n               $('#box-header-table5').removeClass(\"box-header-table\");\n               $('#box-header-table6').removeClass(\"box-header-table\");\n        }\n        if(trim($('.header-text7').text()).length>=36){\n               $('#box-header-table7').addClass(\"box-header-table-large\");\n               $('#box-header-table7').removeClass(\"box-header-table\");\n        }\n\n/* Workaround to fix buttons can't work in IE6/IE7 */\n\t\t\t  if (navigator.appVersion.indexOf(\"MSIE\") != -1 && parseFloat(navigator.appVersion.split(\"MSIE\")[1]) < 8) {\n\t\t\t\t\t\tdocument.getElementById('page-table1').style.filter=\"\";\n\t\t\t\t\t\tdocument.getElementById('page-table2').style.filter=\"\";\n\t\t\t  }\n\n\t\t\t  //$('.scroll-pane').jScrollPane('scrollbarMargin:5px');\n    });\n\n    function trim(value)\n    {\n        var ptntrim = /(^\\s*)|(\\s*$)/g;\n        return value.replace(ptntrim,\"\");\n    }\n\n    function setHelpIframeVisible(){\n        $('.bas-help-frame-div').css(\"visibility\",\"visible\");\n    }\n\n\n    function showHelpIframe() {\n\n\n        var imgSrc=document.getElementById('help-button');\n\n        if(imgSrc.src.search(\"down\")>=0)\n        {\n            $(\".bas-help-frame-div\").show();\n            imgSrc.src=\"img/helparrowup-icon.gif\";\n        }\n        else\n        {\n            $(\".bas-help-frame-div\").hide();\n            imgSrc.src=\"img/helparrowdown-icon.gif\";\n            setTimeout(setHelpIframeVisible,500);\n        }\n    }\n\n    function loadhelp(fname,anchname)\n    {\n        if ((loadhelp.arguments.length == 1 ) || (anchname == \"\" ))\n            $('#page').attr(\"src\",fname+\"_h.htm\");\n        else\n            $('#page').attr(\"src\",fname+\"_h.htm#\"  + anchname);\n    }\n\n\n\nfunction adjustPageLayout()\n{\n    adjustButtonSize();\n        var table_height1 = $('#page-table1')[0].clientHeight+\"px\";\n        var table_height2 = $('#page-table2')[0].clientHeight+\"px\";\n        var table_height3 = $('#page-table3')[0].clientHeight+\"px\";\n//         var table_height4 = $('#page-table4')[0].clientHeight+\"px\";\n        var table_height41 = $('#page-table41')[0].clientHeight+\"px\";\n        var table_height42 = $('#page-table42')[0].clientHeight+\"px\";\n        var table_height5 = $('#page-table5')[0].clientHeight+\"px\";\n        var table_height6 = $('#page-table6')[0].clientHeight+\"px\";\n\n        if($('#page-table1')[0].clientHeight >=  $('#page-table2')[0].clientHeight)\n            $('#page-table2').css(\"height\",table_height1);\n        else\n            $('#page-table1').css(\"height\",table_height2);\n\n/*\n        if($('#page-table3')[0].clientHeight >=  $('#page-table4')[0].clientHeight)\n            $('#page-table4').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height4);\n*/\n        if($('#page-table3')[0].clientHeight >=  $('#page-table41')[0].clientHeight)\n            $('#page-table41').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height41);\n\n        if($('#page-table3')[0].clientHeight >=  $('#page-table42')[0].clientHeight)\n            $('#page-table42').css(\"height\",table_height3);\n        else\n            $('#page-table3').css(\"height\",table_height42);\n\n        if($('#page-table5')[0].clientHeight >=  $('#page-table6')[0].clientHeight)\n            $('#page-table6').css(\"height\",table_height5);\n        else\n            $('#page-table5').css(\"height\",table_height6);\n}\n\nfunction adjustButtonSize()\n{\n    if($('#reboot')[0].scrollHeight > 15 ||\n        $('#statistics')[0].scrollHeight > 15 ||\n        $('#status')[0].scrollHeight > 15)\n    {\n        $($('#reboot')[0].parentNode).addClass('page-table-button-large');\n        $($('#reboot')[0].parentNode).removeClass('page-table-button');\n        $($('#statistics')[0].parentNode).addClass('page-table-button-large');\n        $($('#statistics')[0].parentNode).removeClass('page-table-button');\n        $($('#status')[0].parentNode).addClass('page-table-button-large');\n        $($('#status')[0].parentNode).removeClass('page-table-button');\n    }\n}\n\nfunction advButtonClick(index){\n\n    if(index==0) // Show Statistics\n        openStatisticsWindow();\n    else if(index==1)\n    {\n          openStatusWindow();\n\t// document.forms[0].buttonSelect.value=\"1\";\n    }\n    else if(index==2)\n    {\n        if(confirm(\"Rebooting the gateway will disrupt active traffic on the network. Are you sure?\"))\n        {\n//            document.forms[0].buttonSelect.value=\"2\";\n            document.forms[0].RsAction.value = 2;\n            document.forms[0].submit(document.forms[0]);\n//            window.location.href='Reboot.asp'\n        }\n    }\n    else if(index==3)\n    {\n        if(confirm(\"Loading the factory default settings will erase all the current settings. Are you sure?\"))\n        {\n//            document.forms[0].buttonSelect.value=\"3\";\n            document.forms[0].RsAction.value = 3;\n            document.forms[0].submit(document.forms[0]);\n        }\n    }\n}\n\nfunction openStatWindow() {\n\twindow.open(this.form.stat_page.value, '','height=350,status=yes');\n\treturn ture;\n}\n\n\nfunction openStatusWindow()\n{\n    var conn = document.forms[0].wantype.value;\n\n\tif(isUnsupportedMobileBrowser())\n\t{\n\t\tif (conn == \"dhcp\")\n\t\t{\n\t\t\ttop.$.blockUI({\n\t\t\t\tmessage: '<iframe width=\"400px\" height=\"550px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n\t\t\t\tcss: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n\t\t\t\tonOverlayClick: top.$.unblockUI\n\t\t\t});\n\t\t}\n\t\telse if (conn == \"pppoe\")\n\t\t{\n\t\t\ttop.$.blockUI({\n\t\t\t\tmessage: '<iframe width=\"400px\" height=\"450px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n\t\t\t\tcss: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n\t\t\t\tonOverlayClick: top.$.unblockUI\n\t\t\t});\n\t\t}\n\t\telse\n\t\t{\n\t\t\ttop.$.blockUI({\n\t\t\t\tmessage: '<iframe width=\"400px\" height=\"350px\" src=\"ConnectionStatusDhcp.htm\"></iframe>',\n\t\t\t\tcss: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n\t\t\t\tonOverlayClick: top.$.unblockUI\n\t\t\t});\n\t\t}\n\t}\n\telse\n\t{\n\t\tvar winoptions;\n\t\tif (conn == \"dhcp\")\n\t\t//if (conn == \"dhcp\" || conn == \"pppoe\")\n\t\t\t\twinoptions = \"width=400,height=460,status=yes,resizable=yes\";\n\t\telse if (conn == \"pppoe\")\n\t\t{\n\t\t\t/*\n\t\t\tif (\"0\" == \"1\")\n\t\t\t\t\twinoptions = \"width=400,height=600,status=yes,resizable=yes\";\n\t\t\telse\n\t\t\t*/\n\t\t\t\t\t\twinoptions = \"width=400,height=360,status=yes,resizable=yes\";\n\t\t}\n\t\telse\n\t\t\t\twinoptions = \"width=400,height=260,status=yes,resizable=yes\";\n\n\n\t\topenDataSubWin('ConnectionStatusDhcp.htm',winoptions);\n\t\tshowDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n\t\tif(!isOnBeforeUnloadSupported())\n\t\t{\n\t\t\tdetectPoppedWindowStatus();\n\t\t}\n\t}\n}\n\n// We will use polling instead of onBeforeUnload in following browsers\n// PC: Opera with Presto,\n// iPad: Safari,\n// iPhone: Opera\n// Android Pad: Opera, Chrome(restoring delayed about 3 secs?), Firefox\n// Android Phone:\nfunction isOnBeforeUnloadSupported()\n{\n\tif(navigator.userAgent.indexOf(\"Presto\") > -1\n\t\t|| navigator.userAgent.indexOf(\"iPad\") > -1\n\t\t|| navigator.userAgent.indexOf(\"iPhone\") > -1\n\t\t|| navigator.userAgent.indexOf(\"Android\") > -1\n\t\t)\n\t{\n\t\treturn false;\n\t}\n\n\treturn true;\n}\n\n// Because the following browser can't handle the window opened by itself, we will use BlockUI instead of polling or onBeforeUnload to prevent user clicking the GUI when a statistic/connection status window is opening.\n// PC:\n// iPad: Opera Mini,\n// iPhone:\n// Android Pad: Dolphin Mini, UC, Safari, Native\n// Android Phone:\nfunction isUnsupportedMobileBrowser()\n{\n\t/* Examples:\n\t * iPad-Safari: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) Version/7.0 Mobile/11D201 Safari/9537.53\n\t * iPad-Opera: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) OPiOS/8.0.2.80660 Mobile/11D201 Safari/9537.53\n\t * iPad-Chrome: Mozilla/5.0 (iPad; CPU OS 7_1_1 like Mac OS X) AppleWebKit/537.51.2 (KHTML, like Gecko) CriOS/36.0.1985.57 Mobile/11D201 Safari/9537.53 (000514)\n\t * Android-Native: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/534.30 (KHTML, like Gecko) Version/4.0 Safari/534.30\n\t * Android-Opera: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/35.0.1916.138 Safari/537.36 OPR/22.0.1485.81203\n\t * Android-Chrome: Mozilla/5.0 (Linux; U; Android 4.1.2; zh-tw; GT-N8010 Build/JZO54K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/36.0.1958.135 Safari/537.36\n\t * PC-IE: Mozilla/5.0 (Windows NT 6.1; Trident/7.0; SLCC2; .NET CLR 2.0.50727; .NET CLR 3.5.30729; .NET CLR 3.0.30729; Media Center PC 6.0; InfoPath.3; .NET4.0C; .NET4.0E; rv:11.0) like Gecko\n\t * PC-Opera: Opera/9.80 (Windows NT 6.1; U; zh-tw) Presto/2.10.289 Version/12.00\n\t * PC-Chrome: Mozilla/5.0 (Windows NT 6.1) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/37.0.2062.102 Safari/537.36\n\t */\n\tvar firstSupportedWebKit = \"AppleWebKit/535\";\n\tif(navigator.userAgent.indexOf(\"iPad\") == -1\n\t\t&& navigator.userAgent.indexOf(\"iPhone\") == -1\n\t\t&& navigator.userAgent.indexOf(\"Android\") == -1\n\t\t)\n\t{\n\t\t// Is PC browser.\n\t\treturn false;\n\t}\n\telse if(navigator.userAgent.indexOf(\"OPiOS\") > -1)\n\t{\n\t\t// Although the AppleWebKit version of Opera on iOS is greater than 534, but it still can't handle the opened window.\n\t\treturn true;\n\t}\n\telse if(navigator.userAgent.indexOf(\"AppleWebKit/\") > -1\n\t\t&& navigator.userAgent.substring(navigator.userAgent.indexOf(\"AppleWebKit/\")) < firstSupportedWebKit)\n\t{\n\t\t// The browser using the lower version (<=534) of AppleWebKit can't handle the window opened by itself.\n\t\treturn true;\n\t}\n\n\treturn false;\n}\n\nvar intervalId;\nfunction detectPoppedWindowStatus()\n{\n\tintervalId = setInterval(reloadPage, 200);\n}\n\nfunction openStatisticsWindow()\n{\n    var conn = document.forms[0].wantype.value;\n\tvar form=document.forms[0];\n\t// Fix IE6/IE7/IE8 can't find curlang error\n\tvar gui_region = document.getElementsByName(\"curlang\")[0];\n\t//var gui_region = form.curlang.value;\n\n\t// fix mantis#12486\n\tif(isUnsupportedMobileBrowser())\n\t{\n\t\ttop.$.blockUI({\n\t\t\tmessage: '<iframe width=\"100%\" height=\"450px\" src=\"Statistic.htm\"></iframe>',\n\t\t\tcss: {width: '100%', height: '0px', top: '0px', left: '0px', border: '0px', backgroundColor: 'transparent'},\n\t\t\tonOverlayClick: top.$.unblockUI\n\t\t});\n\t}\n\telse\n\t{\n\t\tvar winoptions;\n\t\tif(gui_region==\"German\"){\n\t\t   winoptions = \"width=1024,height=360,status=yes,resizable=yes\";\n\t\t   openDataSubWin('Statistic.htm',winoptions);\n\t\t   showDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n\t\t}else{\n\t\t   winoptions = \"width=780,height=360,status=yes,resizable=yes\";\n\t\t   openDataSubWin('Statistic.htm',winoptions);\n\t\t   showDisablePage(parent.document.getElementById(\"diablePage\"),datSubWinVar,parent.document.body.offsetWidth,parent.document.body.offsetHeight);\n\t\t}\n\t\t// Chuck 20140902 fix mantis#12486\n\t\tif(!isOnBeforeUnloadSupported())\n\t\t{\n\t\t\tdetectPoppedWindowStatus();\n\t\t}\n\t}\n}\n\nfunction setTimer()\n{\n    setTimeout(reloadPage,300);\n}\nfunction reloadPage()\n{\n    if(datSubWinVar.closed)\n    {\n        window.location.reload();\n        parent.document.getElementById(\"diablePage\").style.display = \"none\";\n\t\t// fix mantis#12486\n\t\tif(!isOnBeforeUnloadSupported())\n\t\t{\n\t\t\tclearInterval(intervalId);\n\t\t}\n    }\n}\n\n// fix mantis#12486\nfunction closeIframe()\n{\n\ttop.$.unblockUI();\n}\n\nfunction modifyBtnCss()\n{\n    $('button').each(function(){\n        var len = parent.calculate_string_pixel($(this).children().text());\n        var txt = trim($(this).children().text());\n        if(len > 137)\n        {\n            $(this).css(\"background\",\"none\");\n            $(this).css(\"position\",\"relative\");\n            $(this).css(\"z-index\",\"1\");\n            $(this).css(\"height\",\"32px\");\n            var img = document.createElement(\"img\");\n            img.style.position = \"absolute\";\n            img.src = \"img/page-table-button.gif\";\n            if(txt == \"Reboot\" || txt == \"Connection Status\")\n                img.style.left = 165+(txt == \"Connection Status\" ? $('#cableInformation')[0].offsetWidth:0)+\"px\";\n            else\n                img.style.left = 25+(txt==\"Show Statistics\" ? $('#cableInformation')[0].offsetWidth:0)+\"px\";\n            if(txt == \"Reboot\" || txt == \"Factory reset\"){\n                img.style.top = $('#cableInformation')[0].offsetHeight-32-$('.page-table-bottom-2')[0].offsetHeight+\"px\";\n            }\n            else{\n            \t  img.style.top = $('#internetPort')[0].offsetHeight-32-$('.page-table-bottom-2')[0].offsetHeight+\"px\";\n            }\n            img.style.width = \"137px\";\n            img.style.height = \"32px\";\n            $(this).parent().append(img);\n        }\n    });\n}\nfunction loadSettings()\n{\n    var cf=document.forms[0];\n\n    adjustPageLayout();\n \tparent.$('#page2').css(\"visibility\",\"visible\");\n    parent.$('#page_contain2').removeClass('main-page-contain-loading');\n    modifyBtnCss();\n/*\n\tif (cf.enable_apmode.value == 1)\n    {\n\n        var statusButton;\n        cf.Status.disabled = 'true';\n        statusButton=document.getElementsByName(\"Status\");\n        //statusButton.outerHTML='<button type=\"submit\" disabled=\"disabled\" value=\"Safely Remove USB Device\" name=\"Remove\" class=\"button-grey\" onClick=\"buttonClick(this,\\'Safely Remove USB Device\\');return remove_disk();\"><span class=\"roundleft_grey\">&nbsp;&nbsp; Safely Remove USB Device<\\/span><span class=\"roundright_grey\">&nbsp;&nbsp;&nbsp;&nbsp;<\\/span><\\/button>';\n        statusButton.outerHTML='<button type=\"button\" disabled=\"disabled\" class=\"button-grey\" style=\"float:left\" onClick=\"advButtonClick(1);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\" name=\"Status\">Connection Status<\\/button>';\n        //removeButton[0].style.cursor='default';\n    }\n*/\n}\n\nfunction InitTagValue()\n{\n/*\n  Hardware Version (td) | Firmware Version (td) | CableModem Serial Number (td) |\n  CM certificate | Cable MAC Address | Cable IP Mask | Cable Gateway | Cable DNS | Network Access |\n  Internet Mac address (td) | Internet IP Mask (td) | DHCP (td) | Internet Gateway |Internet Domain Name Server (td) |\n  LAN Mac address (td) | LAN IP Mask (td) | LAN DHCP (td)\n2.4G  Wireless SSID (td) | Wireless Region (td) | Wireless Channel (td) | Wireless Mode (td) | Wireless AP (td) | Wireless Broadcast Name (td) | Wireless Isolation (td)\n5G    Wireless SSID (td) | Wireless Region (td) | Wireless Channel (td) | Wireless Mode (td) | Wireless AP (td) | Wireless Broadcast Name (td) | Wireless Isolation (td)\n2.4G  Guest Network SSID (td) | Guest Network AP (td)\n5G  Guest Network SSID (td) | Guest Network AP (td)\nSystem Up Time | Current System Time\n*/\n    var tagValueList = '1.01B|V1.01.22|***SERIAL***|1|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***.173/16|***PRIVATE_IP***.254|203.0.113.1, ---.---.---.---, ---.---.---.---|Allowed|XX:XX:XX:XX:XX:XX|---.---.---.---|DHCP Client|---.---.---.---|203.0.113.1|XX:XX:XX:XX:XX:XX|192.168.0.1/24|Off||||||||||||||||||||||||||||||||0|---|---|---|---|---|---|---|---|0|0|1|0|';\n//    var tagValueList = 'c312|V1.01.02|12af23|1|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***.173/16|***PRIVATE_IP***.254|203.0.113.1, ---.---.---.---, ---.---.---.---|Allowed|XX:XX:XX:XX:XX:XX|---.---.---.---|DHCP Client|---.---.---.---|203.0.113.1|XX:XX:XX:XX:XX:XX|192.168.0.1/24|Off||||||||||||||||||||||||||||||||0|---|---|---|---|---|---|---|---|0|0|1|0|';\n/*\n    var tagValueList = \"v1.0|v0.1|12345678|None\" +\n                \"|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***.13/24|***PRIVATE_IP***.254|203.0.113.1, 203.0.113.1|Enable\" +\n                \"|XX:XX:XX:XX:XX:XX|***PRIVATE_IP***/24|DHCPClient|***PRIVATE_IP***|203.0.113.1, 203.0.113.1\" +\n                 \"|XX:XX:XX:XX:XX:XX|192.168.1.1/24|On\" +\n                \"|NETGEAR_24G|North American|Auto (1)|Up to 300Mbps|Off|On|Off\" +\n                \"|NETGEAR_5G|North American|Auto (1)|Up to 145Mbps|Off|On|Off\" +\n                \"|Guest1|Off|Guest1_5G|Off\" +\n                \"|Wednesday, 01 Jan 2003 ***IPv6***|Wednesday, 01 Jan 2003 ***IPv6***\" +\n                \"|Configured|UnConfigured\" +\n                \"|---|---|---|---|---|---\" +\n                \"|1|\" ;\n*/\n    return tagValueList.split(\"|\");\n}\n\nfunction InitUpdateView(tagValues)\n{\n    /* Hardware Version */\n    document.getElementById(\"HardwareVersion\").innerHTML = tagValues[0];\n\n    /* Firmware Version */\n    document.getElementById(\"FirmwareVersion\").innerHTML = tagValues[1];\n\n    /* CableModem Serial Number */\n    document.getElementById(\"CableModemSerialNumber\").innerHTML = tagValues[2];\n\n    /* CM certificate */\n    if (tagValues[3] == '1')\n        document.getElementById(\"CMcertificate\").innerHTML = 'Installed';\n    else\n        document.getElementById(\"CMcertificate\").innerHTML = 'Not Installed';\n\n\n    /* GUI Version */\n//    document.getElementById(\"GUIVersion\").innerHTML = tagValues[2];\n\n    // Cable MAC Address\n    document.getElementById(\"CableMACAddress\").innerHTML = tagValues[4];\n\n    // Cable IP Mask\n//    document.getElementById(\"CableIPMask\").innerHTML = tagValues[5];\n\n    /* Cable Gateway */\n//    document.getElementById(\"CableGateway\").innerHTML = tagValues[6];\n\n    /* Cable DNS */\n//    document.getElementById(\"CableDNS\").innerHTML = tagValues[7];\n\n    /* Network Access */\n//    document.getElementById(\"NetworkAccess\").innerHTML = tagValues[8];\n\n\n    /* Internet Mac address */\n    document.getElementById(\"InternetMAC\").innerHTML = tagValues[9];\n\n    /* Internet IP */\n    document.getElementById(\"InternetIPMASK\").innerHTML = tagValues[10];\n    if(tagValues[10] == \"&nbsp;\")\n    {\n       document.getElementById(\"interIPMask\").style.display = \"none\";\n       document.getElementById(\"interIPMaskLine\").style.display = \"none\";\n    }\n\n    /* Internet DHCP */\n    document.getElementById(\"InternetDHCP\").innerHTML = tagValues[11];\n\n    /* Internet Gateway */\n    if ((tagValues[12] == \"0.0.0.0\") || (tagValues[12] == \"---.---.---.---\"))\n    {\n        $(\"#Internet\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        $(\"#Internet\").attr(\"src\", \"img/good-icon.gif\");\n    }\n\n    document.getElementById(\"InternetGateway\").innerHTML = tagValues[12];\n\n    /* Internet DNS */\n    document.getElementById(\"InternetDNS\").innerHTML = tagValues[13];\n\n    /* LAN Mac address */\n    document.getElementById(\"LANMAC\").innerHTML = tagValues[14];\n\n    /* LAN IP */\n    document.getElementById(\"LANIPMASK\").innerHTML = tagValues[15];\n\n    /* LAN DHCP */\n    document.getElementById(\"LANDHCP\").innerHTML = tagValues[16];\n\n    /* LAN IP Subnet mask */\n//    document.getElementById(\"LANIPSubnet\").innerHTML = tagValues[11];\n\n    /* Wireless SSID */\n    document.getElementById(\"WirelessName\").innerHTML = piplineDecode(tagValues[17]);\n\n    /* Wireless Region */\n    document.getElementById(\"WirelessRegion\").innerHTML = tagValues[18];\n\n    /* Wireless Channel */\n    document.getElementById(\"WirelessChannel\").innerHTML = tagValues[19];\n\n    /* Wireless Mode */\n    document.getElementById(\"WirelessMode\").innerHTML = tagValues[20];\n\n    /* Wireless AP */\n    document.getElementById(\"WirelessAP\").innerHTML = tagValues[21];\n\n    /* Wireless Broadcast Name */\n    document.getElementById(\"WirelessBroadcastName\").innerHTML = tagValues[22];\n\n    /* Wireless Isolation */\n    document.getElementById(\"WirelessIsolation\").innerHTML = tagValues[23];\n\n    /* Wireless SSID */\n    document.getElementById(\"WirelessName_an\").innerHTML = piplineDecode(tagValues[24]);\n\n    /* Wireless Region */\n    document.getElementById(\"WirelessRegion_an\").innerHTML = tagValues[25];\n\n    /* Wireless Channel */\n    document.getElementById(\"WirelessChannel_an\").innerHTML = tagValues[26];\n\n    /* Wireless Mode */\n    document.getElementById(\"WirelessMode_an\").innerHTML = tagValues[27];\n\n    /* Wireless AP */\n    document.getElementById(\"WirelessAP_an\").innerHTML = tagValues[28];\n\n    /* Wireless Broadcast Name */\n    document.getElementById(\"WirelessBroadcastName_an\").innerHTML = tagValues[29];\n\n    /* Wireless Isolation */\n    document.getElementById(\"WirelessIsolation_an\").innerHTML = tagValues[30];\n\n    /* 2.4G SSID */\n    document.getElementById(\"GuestNetworkName1\").innerHTML = piplineDecode(tagValues[31]);\n    $('#GuestNetworkName1_B').html(piplineDecode(tagValues[31]));\n\n    /* 2.4G Wireless AP */\n    document.getElementById(\"GuestNetworkAP1\").innerHTML = tagValues[32];\n    $('#GuestNetworkAP1_B').html(tagValues[32]);\n\n    /* 5G SSID */\n    document.getElementById(\"GuestNetworkName1_an\").innerHTML = piplineDecode(tagValues[33]);\n\n    /* 5G Wireless AP */\n    document.getElementById(\"GuestNetworkAP1_an\").innerHTML = tagValues[34];\n\n    /* System Up Time */\n//    document.getElementById(\"SystemUpTime\").innerHTML = tagValues[35];\n\n    /* Current System Time */\n//    document.getElementById(\"CurrentSystemTime\").innerHTML = tagValues[36];\n\n    /* 2.4G WPS configured mode */\n    document.getElementById(\"WPSMode\").innerHTML = tagValues[37];\n\n    /* 5G WPS configured mode */\n    document.getElementById(\"WPSMode_an\").innerHTML = tagValues[38];\n\n    /* 2.4G Guest1 Broadcast */\n    document.getElementById(\"GuestNetworkBroadcast1\").innerHTML = tagValues[39];\n    $('#GuestNetworkBroadcast1_B').html(tagValues[39]);\n\n    /* 2.4G Guest1 Allow Guest */\n    document.getElementById(\"GuestNetworkAllow1\").innerHTML = tagValues[40];\n    $('#GuestNetworkAllow1_B').html(tagValues[40]);\n\n    /* 5G Guest1 Broadcast */\n    document.getElementById(\"GuestNetworkBroadcast1_an\").innerHTML = tagValues[41];\n\n    /* 5G Guest1 Allow Guest */\n    document.getElementById(\"GuestNetworkAllow1_an\").innerHTML = tagValues[42];\n\n\n    // 2.4G\n    if (tagValues[21] == \"Off\")\n    {\n        $(\"#WiFi24G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[43] == \"none\")\n        {\n            $(\"#WiFi24G\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi24G\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 5G\n    if (tagValues[28] == \"Off\")\n    {\n        $(\"#WiFi5G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[44] == \"none\")\n        {\n            $(\"#WiFi5G\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi5G\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 2.4G WiFi Guest\n    if (tagValues[32] == \"Off\" || tagValues[21] == \"Off\")\n    {\n        $(\"#WiFi24GGDual\").attr(\"src\", \"img/error-icon.gif\");\n        $(\"#WiFi24GG\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[45] == \"none\")\n        {\n            $(\"#WiFi24GGDual\").attr(\"src\", \"img/warning-icon.gif\");\n            $(\"#WiFi24GG\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi24GGDual\").attr(\"src\", \"img/good-icon.gif\");\n            $(\"#WiFi24GG\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n    // 5G WiFi Guest\n    if (tagValues[34] == \"Off\" || tagValues[28] == \"Off\")\n    {\n        $(\"#WiFi5GG\").attr(\"src\", \"img/error-icon.gif\");\n    }\n    else\n    {\n        if (tagValues[46] == \"none\")\n        {\n            $(\"#WiFi5GG\").attr(\"src\", \"img/warning-icon.gif\");\n        }\n        else\n        {\n            $(\"#WiFi5GG\").attr(\"src\", \"img/good-icon.gif\");\n        }\n    }\n\n\n    // Support dual band\n    if (tagValues[47] == '1')\n    {\n        $(\"#setting_5G1\").css ('display', 'none');\n        $(\"#setting_5G2\").css ('display', 'block');\n        $(\"#setting_5G3\").css ('display', 'block');\n        // GuestNetwork supported\n        if (tagValues[57] == \"1\")\n        {\n            $(\"#setting_5G1\").css ('display', 'none');  // Guest 2.4G\n            $(\"#setting_5G2\").css ('display', 'block');  // WiFi 5G\n            $(\"#setting_5G3\").css ('display', 'none');  // Guest 5G\n        }\n    }\n    else\n    {\n        $(\"#setting_5G1\").css ('display', 'block');\n        $(\"#setting_5G2\").css ('display', 'none');\n        $(\"#setting_5G3\").css ('display', 'none');\n\n        // GuestNetwork supported\n        if (tagValues[57] == \"1\")\n        {\n            $(\"#setting_5G1\").css ('display', 'none');  // Guest 2.4G\n            $(\"#setting_5G2\").css ('display', 'none');  // WiFi 5G\n            $(\"#setting_5G3\").css ('display', 'none');  // Guest 5G\n        }\n    }\n\n    // Rg/Bridge Mode\n    if (tagValues[58] == \"0\")\n    {\n        // Bridge mode\n        $(\"#internetPort\").css ('display', 'none');  // Internet Port box\n        // Is not GuestNetwork supported\n        if (tagValues[60] == \"0\")\n        {\n            $(\"#setting_Wifi24G\").css ('display', 'none');  // WiFi 2.4G part\n            $(\"#setting_5G3\").css ('display', 'none');  // WiFi 5G part\n        }\n\t\t//Eason, 20130121, bridge mode do not show LAN information\n\t\t$('#LANMAC').html(\"--:--:--:--:--:--\");\n\t\t$('#LANIPMASK').html(\"---.---.---.---\");\n\t\t$('#LANDHCP').html(\"Off\");\n    }\n\n    if (tagValues[48] == '1')\n    {\n        $(\"#setting_Mobile\").css ('display', 'block');\n    }\n    else\n    {\n        $(\"#setting_Mobile\").css ('display', 'none');\n    }\n\n    if (tagValues[48] == \"1\")\n    {\n        $(\"#Attached3G\").attr(\"src\", \"img/good-icon.gif\");\n    }\n    else\n    {\n        $(\"#Attached3G\").attr(\"src\", \"img/error-icon.gif\");\n    }\n\n    $('#ModemIdentity').html(tagValues[49]);\n    $('#ModemSWVersion').html(tagValues[50]);\n    $('#ModemDriverVersion').html(tagValues[51]);\n    $('#ModemStatus').html(tagValues[52]);\n    $('#ModemIMSI').html(tagValues[53]);\n    $('#ModemIMEI').html(tagValues[54]);\n    $('#ModemOperator').html(tagValues[55]);\n    $('#ModemNetworkMode').html(tagValues[56]);\n\n    if (tagValues[59] == \"0\")\n    {\n        $(\"#setting_5G1\").hide();  // Guest 2.4G\n        $(\"#setting_5G3\").hide();  // Guest 5G\n    }\n\n}\n\nfunction BodyInit()\n{\n    InitUpdateView(InitTagValue());\n    hiddenWifi('1');\n    initBridgeView('1');\n}\n\nfunction initBridgeView(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#LANPort-table\").hide();\n    }\n}\nfunction hiddenWifi(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#setting_Wifi24G\").hide();\n        $(\"#setting_5G3\").hide();\n    }\n}\nfunction ChangeResize()\n{\n    if(navigator.userAgent.indexOf(\"MSIE\") != -1){\n        $(parent.document).find('#page2').height(parseInt(parent.document.getElementById(\"page_contain2\").clientHeight));\n    }\n    $(\".scroll-pane\").css(\"height\",document.documentElement.clientHeight+\"px\");\n    if( !navigator.userAgent.match(/Android/i)\n       && !navigator.userAgent.match(/webOS/i)\n       && !navigator.userAgent.match(/iPhone/i)\n       && !navigator.userAgent.match(/iPad/i)\n       && !navigator.userAgent.match(/iPod/i)\n       && !navigator.userAgent.match(/BlackBerry/i)\n       && !navigator.userAgent.match(/Windows Phone/i)\n    ){\n        $('.scroll-pane').jScrollPane('scrollbarMargin:5px');\n    }\n    $(\".scroll-pane\").css(\"width\",\"670px\");\n    $(\".jspContainer\").css(\"width\",\"670px\");\n    $(\".jspPane\").css(\"width\",\"670px\");\n}\n//-->\n</script>\n\n\n</head>\n\n<body onload=\"loadSettings();ChangeResize();\" onResize=\"ChangeResize()\" bgcolor=\"#E5E5E5\" style=\"width:640px;margin:0px;padding:0px\">\n    <form action='/goform/RouterStatus' method=\"post\">\n        <input type=\"hidden\" value=\"\">\n        <div id=\"scroll-pane\" class=\"scroll-pane\" style=\"height:420px;width:670px;overflow:auto;scrolling:auto\">\n            <table>\n                <tr>\n                    <td>\n                        <div style=\"float:left;width:635px;positive:relative;border:0px;padding-left:3px;margin:0px\">\n                            <div id=\"cableInformation\" style=\"float:left;width:310px;positive:relative;border:0px;margin-top;0px\">\n                                <div id=\"box-header-table1\" class=\"box-header-table\">\n                                    <table>\n                                        <tr class=\"box-header\">\n                                            <td style=\"width:17px\">\n                                                <img alt=\"\" src=\"img/good-icon.gif\" style=\"padding-left:10px;padding-top:3px\" />\n                                            </td>\n                                            <td class=\"box-header-text header-text1\">\n                                                Cable Information\n                                            </td>\n                                        </tr>\n                                    </table>\n                                </div>\n                                <table style=\"width:305px;background-color:#FFFFFF;margin-left:5px;border-collapse:collapse;border-right:3px solid #D0D0D0\">\n                                    <tr align=\"left\" valign=\"bottom\">\n                                        <td>\n                                            <table id=\"page-table1\" class=\"page-table\" style=\"width:300px;background-color:#FFFFFF;height:150px\">\n                                                <tr style=\"height:6px;background-color:#FFFFFF\">\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                    </td>\n                                                </tr>\n                                                <tr><td colspan=\"2\"><table id=\"Modem-table\" cellspacing=\"0\" width=\"100%\">\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\" style=\"width:25%\">\n                                                        Hardware Version\n                                                    </td>\n                                                    <td class=\"basic-text-content\" style=\"width:75%\" id=\"HardwareVersion\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        Firmware Version\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"FirmwareVersion\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <!-- <tr class=\"basic-text\">\n                                                <td class=\"basic-text-menu\" >GUI Language Version</td>\n                                                <td class=\"basic-text-content\" id=\"HardwareVersion\"> V1.0.0.40_2.1.15.6</td>\n                                                </tr>\n                                                -->\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        Cable Modem Serial Number\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"CableModemSerialNumber\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        CM Certificate\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"CMcertificate\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        CM MAC\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"CableMACAddress\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                </table></td></tr>\n                                                <tr><td colspan=\"2\"><table id=\"LANPort-table\" cellspacing=\"0\" width=\"100%\">\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-subTitle\">\n                                                        LAN Port\n                                                    </td>\n                                                    <td class=\"basic-text-content\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        MAC Address\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"LANMAC\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        IP Address/Mask\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"LANIPMASK\">\n                                                    </td>\n                                                </tr>\n                                                <tr>\n                                                    <td colspan=\"2\" class=\"basic-table-seperate-border\">\n                                                        <div class=\"basic-table-seperate\">\n                                                        </div>\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\">\n                                                    <td class=\"basic-text-menu\">\n                                                        DHCP\n                                                    </td>\n                                                    <td class=\"basic-text-content\" id=\"LANDHCP\">\n                                                    </td>\n                                                </tr>\n                                                </table></td></tr>\n                                                <!-- <tr class=\"basic-text\">\n                                                <td class=\"basic-text-menu\" >Last Checked for Upgrade</td>\n                                                <td class=\"basic-text-content\" >3/31/2010 14:55</td>\n                                                </tr>\n                                                -->\n                                                <tr>\n                                                    <td class=\"basic-text-menu-bottom\">\n                                                        &nbsp;\n                                                    </td>\n                                                    <td class=\"basic-text-content-bottom\">\n                                                    </td>\n                                                </tr>\n                                                <tr class=\"basic-text\" style=\"align:center\">\n                                                    <td class=\"basic-table-seperate-border\" align=\"center\" style=\"height:20px;background-color:#FFFFFF;padding-top:5px;width:50%\">\n                                                        <button type=\"button\" class=\"page-table-button\" style=\"float:center;padding-left:15px\" onClick=\"advButtonClick(3);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\">\n                                                            <div id=\"reset\" style=\"width:125px;word-break:break-all;\">\n                                                                Factory reset\n                                                            </div>\n                                                        </button>\n                                                    </td>\n                                                    <td class=\"basic-table-seperate-border\" align=\"center\" style=\"height:20px;background-color:#FFFFFF;padding-top:5px;width:50%\">\n                                                        <button type=\"button\" class=\"page-table-button\" style=\"float:center;padding-left:4px\" onClick=\"advButtonClick(2);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\">\n                                                            <div id=\"reboot\" style=\"width:125px;word-break:break-all;\">\n                                                                Reboot\n                                                            </div>\n                                                        </button>\n                                                        <!-- Nick 20110927 <button type=\"button\" class=\"page-table-button\" style=\"float:left\"\n                                                        onClick=\"advButtonClick(2);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\"><span id=\"reboot\">Reboot</span></button>\n                                                        <button type=\"button\" class=\"page-table-button\" style=\"float:left\" onClick=\"advButtonClick(3);\" onMouseOver=\"changeCursorPointer();\" onMouseOut=\"changeCursorDefault();\"><span id=\"Docsis\">Docsis Status</span></button>\n                                                        -->\n                                                    </td>\n                                                </tr>\n                                            </table>\n                                        </td>\n                                    </tr>\n                                </table>\n                                <div class=\"page-table-bottom-2\">\n                                </div>\n                            </div>\n                            <div id='internetPort' style=\"float:left;width:310px;posision:relative;margin-left:5px\">\n                                <div id=\"box-header-table2\" class=\"box-header-table\">\n                                    <table>\n                                        <tr class=\"box-header\">\n                                            <td style=\"width:20px\">\n                                                <img alt=\"\" id='Internet' src=\"img/warning-icon.gif\" s