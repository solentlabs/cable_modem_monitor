n:center\">\n                                    <span id=\"Voice-status\" class=\"Status-normal\">\n                                        STATUS:&nbsp;&nbsp;&nbsp;\n                                        <span id=\"Voice-condition\" class=\"Condition-normal\">\n                                        </span>\n                                    </span>\n                                </td>\n                                <td id=\"voice2\">\n                                </td>\n                            </tr>\n                        </table>\n                    </div>\n                </div>\n            </td>\n            <td style=\"height:192px;width:192px;padding-left:5px;padding-top:5px\" id=\"ReadyShare\">\n                <div style=\"height:36px;width:192px;background-image:url('DashBackTop.gif'); background-repeat: no-repeat;\">\n                    <div style=\"height:31px;padding-top:5px;\">\n                        <span style=\"display:-moz-inline-box;display:inline-block;width:20px;height:100%;\">\n                            &nbsp;\n                        </span>\n                        <span style=\"height:100%;display:-moz-inline-box;display:inline-block;width:30px;\" id=\"ReadyShare-head\">\n                            &nbsp;\n                        </span>\n                    </div>\n                </div>\n                <div style=\"position:relative;top:-1px;height:115px;width:192px;background-image:url('DashBackCenter.gif'); background-repeat: no-repeat;text-align:center;border-bottom:1px inset #eaeaea;\">\n                    <div style=\"height:100%;width:188px;background-image:url('DashCenter.gif'); background-repeat: no-repeat;margin-left:2px;text-align:center;border-bottom:1px solid #d4d4d4;\">\n                        <img alt=\"\" src=\"img/ReadyShare.gif\">\n                        <br>\n                        <span class=\"subtext\" style=\"font-family:Arial;\">\n                            ReadySHARE\n               