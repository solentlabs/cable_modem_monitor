            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<html><head>\n<meta name=\"description\" content='C7000v2'>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<meta http-equiv=\"Pragma\" content=\"no-cache\">\n<meta http-equiv=\"Cache-Control\" content=\"no-cache\">\n<meta http-equiv=\"Expires\" content=\"Mon, 06 Jan 1990 00:00:01 GMT\">\n\n<title>NETGEAR Gateway C7000v2</title>\n<script type=\"text/javascript\">\n\nfunction doLoad()\n{\n    var unAuth = '0';\n    if(unAuth == \"0\")\n    {\n        document.formname.nowTime.value = new Date().getTime();\n        document.formname.submit();\n    }\n    else\n    {\n        closeWin();\n    }\n }\n\n function closeWin()\n {\n     top.close();\n }\n</script>\n</head>\n<body onload=\"doLoad()\" class=\"page-body\">\n    <div id=\"full-page-container\" style=\"text-align:center;\">\n        <form name=\"formname\" action='/goform/logout?id=1359801763' method=\"POST\">\n            <p>\n                &nbsp;\n            </p>\n            <table style=\"text-align:center;height:600px;width:90%;background-color:#e5e5e5;margin:auto\" border=\"0\" cellpadding=\"0\" cellspacing=\"2\">\n                <tbody>\n                    <tr>\n                        <td>\n                            <div style=\"text-align:center;font-size:18px;font-family:Arial, Helvetica, sans-serif\">\n                                <b>\n                                    Thank you for using the NETGEAR Web-based Gateway Configuration Utility.\n                                </b>\n                                <p>\n                                    <b>\n                                        Goodbye\n                                    </b>\n                                </p>\n                            </div>\n                        </td>\n                    </tr>\n 