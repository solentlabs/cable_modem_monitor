            "text": "P {\r\n\tLIST-STYLE-POSITION: outside; FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif\r\n}\r\nH1 {\r\n\tFONT-WEIGHT: bold; FONT-SIZE: 16px; COLOR: #09c; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif\r\n}\r\nBODY {\r\n\tFONT-SIZE: 12px; MARGIN: 6px; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif\r\n}\r\nTD {\r\n\tFONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif\r\n}\r\nA {\r\n\t COLOR: black; TEXT-DECORATION: none\r\n}\r\n.thead {\r\n\tFONT-WEIGHT: bold; FONT-SIZE: 12px; COLOR: #09c; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif; TEXT-ALIGN: center\r\n}\r\n.ttext {\r\n\tFONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif; TEXT-ALIGN: center\r\n}\r\n.subhead {\r\n\tFONT-WEIGHT: bold; FONT-SIZE: 12px; COLOR: #09c; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif\r\n}\r\n.num {\r\n\tFONT: 10pt \"Courier New\",Courier,serif; COLOR: black\r\n}\r\n\r\n.TableStyle\r\n{\r\n    white-space:nowrap; FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, Geneva, Swiss, SunSans-Regular, sans-serif; TEXT-ALIGN: center\r\n}\r\n\r\n.table_header{\r\n        color: #ffffff;\r\n        font-weight: Bold;\r\n        background-color: #767676;\r\n        text-decoration: underline;\r\n}\r\n\r\n.subheadtext {\r\n        cursor:pointer;\r\n}\r\n\r\n.acl_allowed {\r\n\tcolor: green;\r\n}\r\n\r\n.acl_blocked {\r\n\tcolor: red;\r\n}"
