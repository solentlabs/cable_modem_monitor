            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<html><head><title>NETGEAR Gateway C7000v2</title>\n<META content='C7000v2' name=\"description\">\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<META http-equiv=\"Pragma\" content=\"no-cache\">\n<META http-equiv=\"Cache-Control\" content=\"no-cache\">\n<META http-equiv=\"Expires\" content=\"Mon, 06 Jan 1990 00:00:01 GMT\">\n<SCRIPT type=\"text/javascript\" src=\"jquery.js?version=1.12.4\"></SCRIPT>\n<script type=\"text/javascript\" src=\"script/jquery.blockUI.js\"></script>\n\n<SCRIPT type=\"text/javascript\" src=\"script.js\"></SCRIPT>\n<LINK href=\"css/mainpage.css\" type=\"text/css\" rel=\"stylesheet\">\n<LINK href=\"css/tabs.css\" type=\"text/css\" rel=\"stylesheet\">\n<LINK href=\"css/button.css\" type=\"text/css\" rel=\"stylesheet\">\n<LINK href=\"css/menu.css\" type=\"text/css\" rel=\"stylesheet\">\n<SCRIPT type=\"text/javascript\">\n\t//<![CDATA[\nvar gui_lang_local;\nvar load_page = 0;\nvar is_loading_page = 0;\nvar adjustPageHeight = 0;\nvar num_nosubLarge = 0;\nvar num_submenuLarge = 0;\nvar page_contain_height = 0;\nvar ETHERNET_SUPPORT = false;\nvar ethernetConnect = false;\nfunction OnSubmitForm()\n{    \n\t\tvar text = $('#searchText').val();\n\t\t\n\t\tvar URItext = encodeURIComponent(text);\n\t\t\t\n\t\tURItext =  \"http://support.netgear.com/app/answers/list/kw/\" + URItext;\t\n\t\tdocument.searchform.action = URItext;\n\t\n\t\treturn true;\n    \n}\n$(window).on( \"load\", function() {\n\n    var isIE = navigator.userAgent.search(\"MSIE\") > -1; \n    var isFirefox = navigator.userAgent.search(\"Firefox\") > -1;\n    var isOpera = navigator.userAgent.search(\"Opera\") > -1;\n    var isSafari = navigator.userAgent.search(\"Safari\") > -1;\n\n    /*$('#lang_menu_li').css(\"float\", \"right\");\n      $('#lang_menu_li').css(\"padding-right\", \"25px\");\n      $('#lang_menu_li').css(\"margin-bottom\", \"10px\");*/\n    \n    if(1==\"1\" & 0)\n    {\n        if($('#firmware-update').hasClass(\"firmware-update-hint-long\")) {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"480px\");\n        } else if(isIE | isOpera | isSafari) {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"0px\");\n        } else if($('#firmware-update').hasClass(\"firmware-update-hint-long-long\")) {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"530px\");\n        }  else {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"410px\");\n        }\n    }\n    else\n    {\n        $('#ModuleName').css(\"position\", \"relative\");\n        $('#ModuleName').css(\"right\", \"0px\");    \n    }\n    \n    change_size();\n    \n    /*\n    if((isIE && ($(\"#firmware-update\").hasClass('firmware-update-hint') \n        || $(\"#firmware-update\").hasClass('firmware-update-hint-long') || $(\"#firmware-update\").hasClass('firmware-update-hint-long-long')))\n        || ((isFirefox || isOpera) && ($(\"#firmware-update\").hasClass('firmware-update-hint-long') || $(\"#firmware-update\").hasClass('firmware-update-hint-long-long'))))\n    { \n//      $('#lang_menu_li').css(\"position\", \"relative\");\n//      $('#lang_menu_li').css(\"top\", \"-24px\");\n    }   \n    */\n\n     if (!chgBrsLang()) /* no page is loadded */\n     {\n         if(0)\n         {\n         \t/* foxconn, khfan, remove, 2014/09/24\n               Defect # 126\n               C7000-100NAS: Security -- Some broken URL links are found by sortsite and error in URLs.\n             */\n            // loadPage(\"\");\n         }\n         else\n            loadPage(\"DashBoard.htm\");\n     }\n     \n     try {\n        document.execCommand(\"BackgroundImageCache\", false, true);  \n     } catch (e){}\n});\n\n$(document).ready(function(){\n      //$('#lang_menu').removeAttr(\"disabled\");\n    BodyInit();\n\n    adjustPageLayout();\n      \n      ; \n      $(\"#second\").hide();\n      var isie = navigator.userAgent.search(\"MSIE\") > -1;\n      var ap_mode_flag = document.getElementsByName(\"enable_apmode\");\n      var repeater_flag = document.getElementsByName(\"repeater\");\n      var repeater_an_flag = document.getElementsByName(\"repeater_an\");\n\n      if(ap_mode_flag[0].value==\"1\" || repeater_flag[0].value==\"1\" || repeater_an_flag[0].value==\"1\")\n      {\n          if($(\"#basic-int\").hasClass(\"basic-menu-div\"))\n          {\n              $(\"#basic-int\").addClass('basic-menu-div-gray');\n              $(\"#basic-int\").removeClass('basic-menu-div');\n          }\n          \n          if($(\"#basic-par\").hasClass(\"basic-menu-div\"))\n          {\n              $(\"#basic-par\").addClass('basic-menu-div-gray');\n              $(\"#basic-par\").removeClass('basic-menu-div');\n          }\n      }  \n      \n      $('#AdvanceTab').click(function(ev){        \n          $(\"#first\").hide();  \n          $(\"#second\").show();\n          $('.subHeader').hide(); \n          $(this).css(\"background\",\"url(img/tab-active.gif) no-repeat 0\");                       \n          $(\"#BasicTab\").css(\"background\",\"url(img/tab-nonactive.gif) no-repeat 0\");    \n          $('.noSubActive').removeClass('noSubActive');\n          $('.noSubActiveLarge').removeClass('noSubActiveLarge');\n          $('.SubMenuActive').addClass('SubMenu');\n          $('.SubMenuActive').removeClass('SubMenuActive');\n          $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n          $('.SubMenuActiveLarge').addClass('SubMenu');\n          $('.SubMenuActiveLarge').addClass('Large');\n          $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n          $('.SubActive').addClass('Sub');\n          $('.SubActive').removeClass('SubActive');\n          if($('#adv-home').hasClass('noSubLarge'))\n            $('#adv-home').addClass('noSubActiveLarge');\n          else\n            $('#adv-home').addClass('noSubActive');\n          $('.subHeader:visible').slideUp('fast');\n          loadPage2(\"RouterStatus.htm\");\n          ChangeResize('AdvanceTab');\n      });\n\n      $('#BasicTab').click(function(ev){\n          $(\"#second\").hide();\n          $(\"#first\").show();\n          $(this).css(\"background\",\"url(img/tab-active.gif) no-repeat 0\");\n          $(\"#AdvanceTab\").css(\"background\",\"url(img/tab-nonactive.gif) no-repeat 0\");\n          $('.subHeader').hide();\n          $('.menuActive').removeClass('menuActive');\n          $('#basic-home').addClass('menuActive');\n          loadPage(\"DashBoard.htm\");\n          ChangeResize('BasicTab');\n      });\n\n      $('.basic-menu-div').click(function(ev){\n         $('.menuActive').removeClass('menuActive');\n         $(this).addClass('menuActive');\n         var path = $(this).children(\"a\").attr(\"href\");\n         loadPage(path);\n         ev.preventDefault();\n\n      });\n\n\n      $('.noSub').on(\"click\",function(ev){              \n          $(\"#first\").hide();            \n          if( !$(this).hasClass('noSubGray') & !$(this).hasClass('noSubGrayLarge')){                  \n                $('.noSubActive').removeClass('noSubActive'); \n                $('.noSubActiveLarge').removeClass('noSubActiveLarge');  \n                $('.SubActive').addClass('Sub');\n                $('.SubActive').removeClass('SubActive');\n                $('.SubMenuActive').addClass('SubMenu'); \n                $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n                $('.SubMenuActiveLarge').addClass('SubMenu');\n                $('.SubMenuActiveLarge').addClass('Large');\n                $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n                $('.SubMenuActive').removeClass('SubMenuActive');\n                if($(this).hasClass('noSubLarge'))\n                    $(this).addClass('noSubActiveLarge'); \n                else\n                    $(this).addClass('noSubActive'); \n                $('.subHeader:visible').slideUp('fast');      \n                var path = $(this).children(\"a\").attr(\"href\");      \n                loadPage2(path);\n                ev.preventDefault();\n          }else{\n               return false;\n          }                               \n      });\n\n      $('.noSubLarge').on(\"click\",function(ev){              \n          $(\"#first\").hide();            \n          if( !$(this).hasClass('noSubGray') & !$(this).hasClass('noSubGrayLarge')){                  \n                $('.noSubActive').removeClass('noSubActive'); \n                $('.noSubActiveLarge').removeClass('noSubActiveLarge');  \n                $('.SubActive').addClass('Sub');\n                $('.SubActive').removeClass('SubActive');\n                $('.SubMenuActive').addClass('SubMenu'); \n                $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n                $('.SubMenuActiveLarge').addClass('SubMenu');\n                $('.SubMenuActiveLarge').addClass('Large');\n                $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n                $('.SubMenuActive').removeClass('SubMenuActive');\n                if($(this).hasClass('noSubLarge'))\n                    $(this).addClass('noSubActiveLarge'); \n                else\n                    $(this).addClass('noSubActive'); \n                $('.subHeader:visible').slideUp('fast');      \n                var path = $(this).children(\"a\").attr(\"href\");      \n                loadPage2(path);\n                ev.preventDefault();\n          }else{\n               return false;\n          }                               \n      });    \n      \n       $('.noSubGray').on(\"click\",function(){                    \n            return false;\n       });\n       $('.noSubGrayLarge').on(\"click\",function(){                    \n            return false;\n       });\n      \n     $('.basic-menu-div-gray').on(\"click\",function(){           \n         return false;\n     });      \n      \n\n      $('.SubMenu').on(\"click\",function(ev){     \n         $(\"#first\").hide();     \n         if( !$(this).hasClass('SubMenuDisable') && !$(this).hasClass('SubMenuLargeDisable')){  \n            $('.noSubActive').removeClass('noSubActive');\n            $('.SubMenuActive').addClass('SubMenu');\n            $('.SubMenuActive').removeClass('SubMenuActive');\n            $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n            $('.SubMenuActiveLarge').addClass('SubMenu');\n            $('.SubMenuActiveLarge').addClass('Large');\n            $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n            if($(this).hasClass('Large'))\n\t           $(this).addClass('SubMenuActiveLarge');\n\t        else\n\t           $(this).addClass('SubMenuActive');\n\t    $(this).removeClass('SubMenu');\n\t    $(this).removeClass('SubMenuLarge');\n            var path = $(this).children(\"a\").attr(\"href\");      \n            loadPage2(path);\n            ev.preventDefault();\n         }else{           \n            return false;\n         }\n      });\n\n\t  $('.SubMenuLarge').on(\"click\",function(ev){\n         $(\"#first\").hide();     \n         if( !$(this).hasClass('SubMenuDisable') && !$(this).hasClass('SubMenuLargeDisable')){  \n            $('.noSubActive').removeClass('noSubActive');\n            $('.SubMenuActive').addClass('SubMenu');\n            $('.SubMenuActive').removeClass('SubMenuActive');\n            $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n            $('.SubMenuActiveLarge').addClass('SubMenu');\n            $('.SubMenuActiveLarge').addClass('Large');\n            $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n            if($(this).hasClass('Large'))\n\t           $(this).addClass('SubMenuActiveLarge');\n\t        else\n\t           $(this).addClass('SubMenuActive');\n\t    $(this).removeClass('SubMenu');\n\t    $(this).removeClass('SubMenuLarge');\n            var path = $(this).children(\"a\").attr(\"href\");\n            loadPage2(path);\n            ev.preventDefault();\n         }else{\n            return false;\n         }\n      });\n      \n      $('.SubMenuActive').on(\"click\",function(ev){\n         $(\"#first\").hide();\n         var path = $(this).children(\"a\").attr(\"href\");      \n         loadPage2(path);\n         ev.preventDefault();\n      });\n      \n      $('.SubMenuActiveLarge').on(\"click\",function(ev){\n         $(\"#first\").hide();\n         var path = $(this).children(\"a\").attr(\"href\");      \n         loadPage2(path);\n         ev.preventDefault();\n      });\n    \n      \n      \n      $('#go').click(function(ev){     \n        var text = $('#searchText').val();\n        var URItext = encodeURIComponent(text);\n\t\t\n\t\t\n        URItext =  \"http://support.netgear.com/app/answers/list/kw/\" + URItext;\n        window.open(URItext,'_blank','fullscreen=yes,toolbar=yes,locaiton=yes,scrollbars=yes');\n      });\n     \n     $('.SubMenuDisable').on(\"click\",function(){           \n         return false;\n     });\n  \n    $('.SubMenuLargeDisable').on(\"click\",function(){         \n         return false;\n     });\n\n     advanceMenu();\n     /* Eason, 20141029, we don't need this now.\n     var isFF = navigator.userAgent.search(\"Firefox\") > -1;\n     $('.SubMenu').each(function(){\n         var len = calculate_string_pixel($(this).text());     \n         if(isFF)\n              len = len -1;\n         if(len >= 170){              \n              $(this).addClass('Large');\n              $(this).addClass('SubMenuLarge');              \n         }else{\n              $(this).removeClass('Large');\n              $(this).removeClass('SubMenuLarge');\n         }\n     });\n     */\n   \n     /*\n     $('.SubMenuDisable').each(function(){\n         if($(this).text().length >= 28){              \n              $(this).addClass('SubMenuDisableLarge');\n              $(this).removeClass('SubMenuDisable');\n         }                     \n     });\n    \n     $('.SubMenuLargeDisable').each(function(){\n         if($(this).text().length < 28){              \n              $(this).addClass('SubMenuDisable');\n              $(this).removeClass('SubMenuLargeDisable');\n         }                     \n     }); \n    */\n       \n      function advanceMenu() {\n         $('.subHeader').hide();\n        \n         $('.Sub').click(function() {                 \n              $('#first').hide();\n              var checkElement = $(this).next();                                                                               \n              if((checkElement.is('li')) && (checkElement.is(':visible'))) {\n                  $('.subHeader:visible').slideUp('fast');\n                  $(this).removeClass('SubActive');\n                  $(this).addClass('Sub');\n                  return false;\n              }\n              if((checkElement.is('li')) && (!checkElement.is(':visible'))) { \n                  $('.subHeader:visible').slideUp('fast');\n                  checkElement.slideDown('normal');      \n                  $('.SubActive').addClass('Sub');\n                  $('.SubActive').removeClass('SubActive');\n                  $(this).addClass('SubActive');\n                  $(this).removeClass('Sub');\n                  return false;\n              }\n              \n                            \n            }\n        );   \n                              \n               \n      }\n});   \n\nfunction isIE7()\n{\n\tif(navigator.userAgent.indexOf(\"MSIE 7\") > -1)\n\t{\n\t\treturn true;\n\t}\n\t\n\treturn false;\n}\n\nfunction adjustPageLayout()\n{\n\tnum_submenuLarge = 0;\n    $('.subMenu_text').each(function(){\n        if($(this)[0].clientHeight > 17){\n            if($(this)[0].parentNode.parentNode.parentNode.getAttribute('id') == \"adv_settings_header\")\n                num_submenuLarge++;\n            var menuHeight = $($(this)[0].parentNode.parentNode.parentNode).css('height');\n            var menuHeight2 = menuHeight.replace(\"px\", \"\");\n            $($(this)[0].parentNode.parentNode.parentNode).css('height',(parseInt(menuHeight2))+\"px\"); \n            $($(this)[0].parentNode.parentNode).addClass('Large');\n\n\t\t\tif($($(this)[0].parentNode.parentNode).hasClass('SubMenuActive'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('SubMenuActiveLarge');\n\t\t\telse if(!$($(this)[0].parentNode.parentNode).hasClass('SubMenuActiveLarge'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('SubMenuLarge');\n\n            $($(this)[0].parentNode.parentNode).removeClass('SubMenu');\n\t\t\t$($(this)[0].parentNode.parentNode).removeClass('SubMenuActive');\n        }else if($(this)[0].parentNode.parentNode.getAttribute('id') != \"pf_head\"){\n\t\t\tif($($(this)[0].parentNode.parentNode).hasClass('SubMenuActiveLarge'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('SubMenuActive');\n\t\t\telse if(!$($(this)[0].parentNode.parentNode).hasClass('SubMenuActive'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('SubMenu');\n\n            $($(this)[0].parentNode.parentNode).removeClass('Large');\n            $($(this)[0].parentNode.parentNode).removeClass('SubMenuLarge');\n\t\t\t$($(this)[0].parentNode.parentNode).removeClass('SubMenuActiveLarge');\n        }\n    });\n\n\tnum_nosubLarge = 0;\n    $('.nosub_text').each(function(){\n        if($(this)[0].clientHeight > 17){\n            num_nosubLarge++;\n            if($($(this)[0].parentNode.parentNode).hasClass('noSubGray'))\n                $($(this)[0].parentNode.parentNode).addClass('noSubGrayLarge');\n            else\n                $($(this)[0].parentNode.parentNode).addClass('noSubLarge');\n\t\t\t\t\n\t\t\tif($($(this)[0].parentNode.parentNode).hasClass('noSubActive'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('noSubActiveLarge');\n\n            $($(this)[0].parentNode.parentNode).removeClass('noSub');\n            $($(this)[0].parentNode.parentNode).removeClass('noSubGray');\n\t\t\t$($(this)[0].parentNode.parentNode).removeClass('noSubActive');\n        }else{\n\t\t\tif($($(this)[0].parentNode.parentNode).hasClass('noSubGrayLarge'))\n                $($(this)[0].parentNode.parentNode).addClass('noSubGray');\n            else\n                $($(this)[0].parentNode.parentNode).addClass('noSub');\n\t\t\t\t\n\t\t\tif($($(this)[0].parentNode.parentNode).hasClass('noSubActiveLarge'))\n\t\t\t\t$($(this)[0].parentNode.parentNode).addClass('noSubActive');\n\n            $($(this)[0].parentNode.parentNode).removeClass('noSubLarge');\n            $($(this)[0].parentNode.parentNode).removeClass('noSubGrayLarge');\n\t\t\t$($(this)[0].parentNode.parentNode).removeClass('noSubActiveLarge');\n        }\n    });       \n\n    adjustPageHeight = 16 * num_nosubLarge + 15 * num_submenuLarge;\n    /*\n    $('.basic-menu').css(\"height\",adjustPageHeight);\n    $('.advance-menu').css(\"height\",adjustPageHeight);\n    $('#basic-table').css(\"height\",adjustPageHeight);\n    $('#advance-table').css(\"height\",adjustPageHeight);    \n    */\n\n\tvar activeLength=0;\n\tvar activeLargeLength=0;\n    var heightpadding=9;\n\tvar oneItemHeight=21;\n\tvar oneLargeItemHeight=33;\n\n\tif(isIE7())\n\t{\n\t\toneItemHeight=24;\n\t\toneLargeItemHeight=36;\n\t}\n\n\t$('#set_hdr li').each(function(){\n        //alert ($(this)[0].getAttribute('id'));\n        if($($(this)[0]).css(\"display\") != \"none\"){\n\t\t\tif($($(this)[0]).hasClass(\"SubMenuLarge\")){\n\t\t\t\tactiveLargeLength++;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tactiveLength++;\n\t\t\t}\n        }\n\t\t\n    });\n    $('#set_hdr').height(activeLength * oneItemHeight + activeLargeLength * oneLargeItemHeight + heightpadding);\n\n    activeLength=0;\n\tactiveLargeLength=0;\n    $('#AdminULId li').each(function(){\n        //alert ($(this)[0].getAttribute('id'));\n        if($($(this)[0]).css(\"display\") != \"none\"){\n            if($($(this)[0]).hasClass(\"SubMenuLarge\")){\n\t\t\t\tactiveLargeLength++;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tactiveLength++;\n\t\t\t}\n        }\n    });\n    $('#AdminULId').height(activeLength * oneItemHeight + activeLargeLength * oneLargeItemHeight + heightpadding);\n\n    activeLength=0;\n\tactiveLargeLength=0;\n    $('#usb_hdr li').each(function(){\n        //alert ($(this)[0].getAttribute('id'));\n        if($($(this)[0]).css(\"display\") != \"none\"){\n            if($($(this)[0]).hasClass(\"SubMenuLarge\")){\n\t\t\t\tactiveLargeLength++;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tactiveLength++;\n\t\t\t}\n        }\n    });\n    $('#usb_hdr').height(activeLength * oneItemHeight + activeLargeLength * oneLargeItemHeight + heightpadding);\n\n    activeLength=0;\n\tactiveLargeLength=0;\n    $('#sec_hdr li').each(function(){\n        //alert ($(this)[0].getAttribute('id'));\n        if($($(this)[0]).css(\"display\") != \"none\"){\n            if($($(this)[0]).hasClass(\"SubMenuLarge\")){\n\t\t\t\tactiveLargeLength++;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tactiveLength++;\n\t\t\t}\n        }\n    });\n    $('#sec_hdr').height(activeLength * oneItemHeight + activeLargeLength * oneLargeItemHeight + heightpadding);\n\n\tactiveLength=0;\n\tactiveLargeLength=0;\n    $('#adv_hdr li').each(function(){\n        if($($(this)[0]).css(\"display\") != \"none\")\n\t\t{\n            if($($(this)[0]).hasClass(\"SubMenuLarge\"))\n\t\t\t{\n\t\t\t\tactiveLargeLength++;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tactiveLength++;\n\t\t\t}\n        }\n    });\n    $('#adv_hdr').height(activeLength * oneItemHeight + activeLargeLength * oneLargeItemHeight + heightpadding);\n}\nfunction checkTab(path)\n{\n    if($(\"#BasicTab\").hasClass('current'))\n        loadPage(path);\n    else\n    \t  loadPage2(path);\n    \t\n}\n\nfunction loadPage(path)\n{\n        $('.basic-menu').css(\"height\", page_contain_height);\n         load_page = 1;\n         if(path.search(\"DashBoard.htm\") != -1){\n            $('#page_contain').width(735);  \n            $('#page_contain').height(page_contain_height);  \n            $('#page_contain').css(\"margin-top\",\"5\");\n            if(get_browser() == \"IE\"){\n               $('#page_contain').html('<iframe id=\"page\" src=\"\" scrolling=\"no\" style=\"background-color:#E5E5E5;width:605px;height:425px;margin-top:0;margin-left:55px\" frameborder=\"0\" onFocus=\"this.blur()\"><\\/iframe>');\n            }else{  \n               $('#page').attr(\"scrolling\",\"no\");\n               $('#page').width(605);\n               $('#page').height(page_contain_height-45);\n               $('#page').css(\"margin-top\",\"0px\");\n               $('#page').css(\"margin-left\",\"55px\"); \n               \n            }      \n            $('#page').css(\"visibility\",\"hidden\");\n            $('#page_contain').addClass('main-page-contain-loading');\n            $('#page').delay(1000).attr(\"src\",path); \n                  \n            $('#page').on( \"load\", function(){\t             \n\t       $('#page').css(\"visibility\",\"visible\");\n               $('#page_contain').removeClass('main-page-contain-loading');    \n               \n            })     \n          \n         }else if(path.search(\"netgear\") != -1){\n            window.open(path,'_blank','fullscreen=yes,toolbar=yes,location=yes,scrollbars=yes');\n         }else{\n            $('#page_contain').width(735);  \n            $('#page_contain').height(page_contain_height);  \n            $('#page_contain').css(\"margin-top\",\"5px\");            \n            if(get_browser() == \"IE\"){\n             $('#page_contain').html('<iframe id=\"page\" src=\"\" scrolling=\"no\" style=\"background-color:#E5E5E5;width:685px;height:470px;margin-top:0px;margin-left:30px\" frameborder=\"0\" onFocus=\"this.blur()\"><\\/iframe>');\n            }else{  \n               $('#page').attr(\"scrolling\",\"no\");\n               $('#page').width(685);\n               $('#page').height(page_contain_height);\n               $('#page').css(\"margin-top\",\"0px\");\n               $('#page').css(\"margin-left\",\"30px\");                 \n                 \n            }     \n            $('#page').css(\"visibility\",\"hidden\");\n            $('#page_contain').addClass('main-page-contain-loading');             \n            $('#page').attr(\"src\",path); \n            $('#page').on( \"load\", function() \n            {\t             \n\t             $('#page').css(\"visibility\",\"visible\");\t\n\t             $('#page_contain').removeClass('main-page-contain-loading'); \n                   \n            });  \n                \n         }                      \n         \n         \n         return false;\n}\n\n\nfunction loadPage2(path) {  \n        load_page = 2;\n        while(is_loading_page==1){}\n\t\tis_loading_page=1;\n\t\t    $('.advance-menu').css(\"height\", page_contain_height);\n        if(path.search(\"RouterStatus.htm\") != -1){            \n           $('#page_contain2').width(700);  \n           $('#page_contain2').height(page_contain_height);  \n           if(get_browser() == \"IE\"){\n               $('#page_contain2').html('<iframe id=\"page2\" src=\"\" scrolling=\"no\" style=\"background-color:#E5E5E5;width:680px;height:470px;margin-top:0;margin-left:50px\" frameborder=\"0\" onFocus=\"this.blur()\"><\\/iframe>');\n           }else{  \n               $('#page2').attr(\"scrolling\",\"no\");\n               $('#page2').width(680);\n               $('#page2').height(page_contain_height);\n               $('#page2').css(\"margin-top\",\"0px\");\n               $('#page2').css(\"margin-left\",\"50px\");\n\n\n           }  \n           $('#page2').css(\"visibility\",\"hidden\");\n           $('#page_contain2').addClass('main-page-contain-loading');           \n           $('#page2').attr(\"src\",path);\n       \n           $('#page2').on( \"load\", function() \n           {\t             \n\t             $('#page2').css(\"visibility\",\"visible\");\n\t             $('#page_contain2').removeClass('main-page-contain-loading');                                              \n            }); \n        }else if(path.search(\"netgear\") != -1){\n            window.open(path,'_blank','fullscreen=yes,toolbar=yes,location=yes,scrollbars=yes');\n        }else{\n            $('#page_contain2').width(700);  \n            $('#page_contain2').height(page_contain_height);         \n                                    \n            \n            if(get_browser() == \"IE\"){\n               $('#page_contain2').html('<iframe id=\"page2\" src=\"\" scrolling=\"no\" style=\"background-color:#E5E5E5;width:685px;height:470px;overflow-x:hidden;margin-top:0px;margin-left:30\" frameborder=\"0\" onFocus=\"this.blur()\"><\\/iframe>');\n               $('#page2').css(\"margin-left\",\"30px\"); \n           }else{  \n               $('#page2').attr(\"scrolling\",\"no\");\n               $('#page2').css(\"overflow-x\",\"hidden\");\n               $('#page2').css(\"overflow-y\",\"hidden\");\n               $('#page2').width(685);\n               $('#page2').height(page_contain_height);\n               $('#page2').css(\"margin-top\",\"0px\");\n               $('#page2').css(\"margin-left\",\"30px\");  \n           }    \n           $('#page2').css(\"visibility\",\"hidden\");\n           $('#page_contain2').addClass('main-page-contain-loading');\n           $('#page2').attr(\"src\",path);\n           $('#page2').on( \"load\", function() \n           {\t             \n\t           $('#page2').css(\"visibility\",\"visible\");\n                   $('#page_contain2').removeClass('main-page-contain-loading');                                             \n            }); \n\n           \n        }       \n        is_loading_page=0;\n\t\t\n        return false;\n}\n \n\nfunction setParentalControls()\n{\n     var ParentalControls_Result = 0;\n                     \n     var support = 1;\n                                       \n     if(support == 0){\n          $('#PAR_menu').attr(\"href\",\"http://www.netgear.com/lpc\"); \n          $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");                  \n     }else{ \n         if(ParentalControls_Result == 0){\n             $('#PAR_menu').attr(\"href\",\"http://www.netgear.com/lpc\"); \n             $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");  \n         }else{          \n             $('#PAR_menu').attr(\"href\",\"http://netgear.opendns.com/\"); \n             $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");  \n         }\n     }                              \n}\n\n\nfunction ShowLanguageList()\n{\n    var form=document.forms[0];\n    // Nick 20120229, add multi-lang menu bar    \n    var lang = '';\n    var currentsupportlangs = lang.split(\" \");\n\t  var suportlanguage = form.srptlang.value.split(\" \");\n\t  var gui_region = '0';\n    var local_srpt = form.local_srptlang.value.split(\" \");\n\n    form.curlang.value = gui_region;\n    \n    document.getElementById(\"lang_menu\").options.remove(document.getElementById(\"lang_menu\").options[0]);\n    for(j=0; j < currentsupportlangs.length; j++)\n    {\n        for(i=0; i < suportlanguage.length; i++)\n        {\n            if (suportlanguage [i] == currentsupportlangs [j])\n            {\n            \t  var varItem;\n                if(currentsupportlangs[j] == gui_region){\n                    varItem = new Option(local_srpt[i], gui_region);\n                    document.getElementById(\"lang_menu\").options.add(varItem);\n                    document.getElementById(\"lang_menu\").options[document.getElementById(\"lang_menu\").options.length-1].selected = true;\n            \t  }else{\n            \t  \t  varItem = new Option(local_srpt[i], currentsupportlangs[j]);\n            \t  \t  document.getElementById(\"lang_menu\").options.add(varItem);\n                }\n                \n                if(suportlanguage[i] == gui_region){              \n                   gui_lang_local = local_srpt[i];             \n                }\n            }\n        }\n    }    \n               \n}\n\nfunction resetLanguageList()\n{\n    var i;\n    var form=document.forms[0];\n    var suportlanguage = document.getElementById(\"lang_menu\").options;\n    var gui_region = form.curlang.value;\n    var langList = document.getElementById(\"lang_menu\");\n\n    for(i=0; i < suportlanguage.length; i++)\n    {\n        if(suportlanguage[i].value == gui_region){       \n\t\t\t      langList.selectedIndex = i;\n            return;\n        }\n    }   \n}\n\nfunction calculate_string_pixel(str)\n{\n    var obj = document.getElementById(\"ruler\");\n    obj.innerHTML = str;\n    return obj.offsetWidth;\n\n}\n\nfunction chgLang()\n{\n    var form=document.forms[0];\n    var gui_region = form.curlang.value;\n    var choice = form.choicelang.value;    \n    // Nick 20120229, add multi-lang menu bar\n    var local_srpt = form.local_srptlang.value.split(\" \");\n    var current_local;\n    var suportlanguage = document.getElementById(\"lang_menu\").options;\n    for(i=0; i < suportlanguage.length; i++)\n    {\n        if(suportlanguage[i].value == form.choicelang.value){              \n            current_local = suportlanguage[i].innerHTML;             \n        }\n    }\n\n    if (choice != gui_region){      \n        ret = confirm(\"Do you want to switch from \"+ gui_lang_local + \"\"+\"( the current language ) to \"+\"\"+ current_local + \"?\");\n        if(ret==1){\n            form.submit();\n        }\n        else\n            resetLanguageList();\n    }\n}\n\nfunction chgBrsLang()\n{\n\tvar form=document.forms[0];\n        var gui_region = form.curlang.value;\n        var brslang = form.first_brs_lang.value;  \n\n    return false;\n// Nick 20110927\n        var choice = form.choicelang.value;     \n        var auto_block = form.auto_block.value; \n\n        if(choice === \"Auto\"){\n            if(auto_block == \"0\"){\n\n                if(gui_region != brslang){\n                    ret = confirm(\"Do you want to switch from \"+ gui_lang_local + \"\"+\"( the current language ) to \"+\"\"+ brslang + \"?\");\n                    // foxconn, khfan, remove, 2014/09/24\n                    // Defect # 126\n                    // C7000-100NAS: Security -- Some broken URL links are found by sortsite and error in URLs.\n                    /*\n                    if(ret==1){ \n                        if($(\"#BasicTab\").hasClass('current')){\n                           loadPage(\"\");\n                        }else{\n                           loadPage2(\"\");\n                        }\n                    }else{\n                        if($(\"#BasicTab\").hasClass('current')){\n                            loadPage(\"\");\n                        }else{\n                            loadPage2(\"\");\n                        }\n                   }\n                   */\n                   return true;\n               }\n            }\n        }\n        \n        return false;\n}\n\n// foxconn, khfan, remove, 2014/09/24\n// Defect # 126\n// C7000-100NAS: Security -- Some broken URL links are found by sortsite and error in URLs.\n/*\nfunction fw_upgrade_hint()\n{\n    if($(\"#BasicTab\").hasClass('current')){\n        loadPage(\"\");\n    }else{\n        loadPage2(\"\");\n    }    \n}\n*/\n\nfunction gui_logout()\n{\n    if($(\"#BasicTab\").hasClass('current')){\n        top.location.href=\"Logout.htm\";\n    }\n    else\n    {\n        top.location.href=\"Logout.htm\";\n    }\n}\n\n\nfunction change_size()\n{\n    setLanglistPosition();\n    ChangeResize();\n\t//setFooterClass();\n    //subpage_resize();\n}\n\n/*  0: Firemware Version\n    1: Guest Network Supported\n    2: MultiLang Supported\n    3: Rg/Bridge Mode\n    4: Voice Supported\n    5: MSO Supported\n    6: USB Hidden\n    7: WPS Wizard grayout\n    8: ETHER WAN Supported\n    9: ETHER WAN Enabled\n    10: Traffic Meter Supported\n    11: WiFi Schedule Supported\n    12: Access Control Supported\n    13: OpenDNS Supported\n*/\nfunction InitTagValue()\n{\n    var tagValueList = 'V1.03.08|0|0|0|0|retail|0|0|0|0|1|1|1|0|';\n//    var tagValueList = \"v0.1\";\n    return tagValueList.split(\"|\");\n}\n\nfunction InitUpdateView(tagValues)\n{\n    /* Firmware Version */\n    document.getElementById(\"FirmwareVersion\").innerHTML = tagValues[0];\n\n    /* multilang support */\n    if (tagValues[2] == \"0\")\n    {\n        $(\"#lang_menu_li\").hide();\n    }\n\n    /* Rg/Bridge mode */\n    if (tagValues[3] == \"1\")\n    {\n        // Basic menu\n        $(\"#basic-wls\").show();\n        $(\"#basic-atd\").show();\n        $(\"#basic-par\").show();\n        $(\"#basic-rea\").show();\n        $(\"#basic-gst\").show();\n        if(tagValues[8] == \"1\")\n        {\n            ETHERNET_SUPPORT = true;\n\n            if(tagValues[9] == \"1\")\n            {\n                ethernetConnect = true;\n                $(\"#basic-int\").hide();\n            } \n        }\n    }\n    else\n    {\n        // Basic menu\n        $(\"#basic-wls\").hide();\n        $(\"#basic-atd\").hide();\n        $(\"#basic-par\").hide();\n        $(\"#basic-rea\").hide();\n        $(\"#basic-gst\").hide();\n    \n        $(\"#wps-wizard\").hide();  \n        $(\"#setup_header\").hide();\n        $(\"#usb_header\").hide();\n        $(\"#security_header\").hide();\n        $(\"#AdminId li\").hide();\n        // always hide nat mode webpage\n        $(\"#adv_header\").hide();\n    }\n\n    /* Guest Network Supported */\n    if (tagValues[1] == \"1\")\n    {\n        $(\"#basic-gst\").hide();\n        $(\"#guest_set\").hide();\n    }\n\n    // Nick 20120507, new mta icon\n    // Voice Supported\n    if (tagValues[4] == \"1\")\n    {\n        $(\"#basic-par\").hide();\n        $(\"#basic-voice\").show();\n    }\n    else\n    {\n        if (tagValues[3] == \"1\")  //parental control is not support in bridge.\n            $(\"#basic-par\").show();\n        $(\"#basic-voice\").hide();\n    }\n    \n    if (tagValues[5] == \"akado\")\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/logo-akado.png\");\n\n        $(\"#toprightLogo\").show();\n        $(\"#toprightLogo\").attr(\"src\", \"img/Netgeargenie.png\");\n\n        $(\"#basic-rea\").hide();\n        $(\"#usb_header\").hide();\n        $(\"#advUSB\").hide();\n    }\n    else if(tagValues[5] == \"retail\")\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/logo_retail.png\");\n        $(\".topframe\").css(\"background-color\",\"#ffffff\");\n        $(\".topframe\").css(\"color\",\"#000000\");\n        $(\".tabs\").css(\"background-color\",\"#ffffff\");\n        // 20150203 Emerson add to replace the NetworkMap by AttachedDevices\n        $(\"#basic-atd\").html('<a href=\"AttachedDevices_new.htm\"><span>Attached Devices<\\/span><\\/a>');\n        $(\"#advNetworkMap\").attr(\"href\", \"AttachedDevices_new.htm\");\n        $(\"#advNetworkMap\").html('<span class=\"subMenu_text\">Attached Devices<\\/span>');\n        // 20150203 Emerson end\n\n        $(\"#toprightLogo\").hide();\n        $(\"#ipv6\").show();\n    }\n    else if(tagValues[5] == \"optus\") // Optus support\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/logo_retail.png\");\n        $(\".topframe\").css(\"background-color\",\"#ffffff\");\n        $(\".topframe\").css(\"color\",\"#000000\");\n        $(\".tabs\").css(\"background-color\",\"#ffffff\");\n\n        $(\"#toprightLogo\").hide();\n    }\n    else if(tagValues[5] == \"ono\")\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/Netgeargenie.png\");\n\n        $(\"#toprightLogo\").hide();\n        $(\"#remote\").hide();\n    }\n    else\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/Netgeargenie.png\");\n\n        $(\"#toprightLogo\").hide();\n    }\n    \n    // ComHem support\n    if(tagValues[5] == \"comhem\")\n    {\n        $(\"#email\").hide();\n        $(\"#parentalControls\").hide();\n        $(\"#advNetworkMap\").attr(\"href\", \"\");\n        $(\"#advWirelssSet\").html('Wireless Features');\n        // Show wifi related pages in bridge mode\n        if (tagValues[3] == \"0\")\n        {\n            $(\"#wps-wizard\").show();\n            $(\"#basic-wls\").show();\n            $(\"#setup_header\").show();\n            $(\"#set_hdr li\").hide();\n            $(\"#wireless_set\").show();\n            $(\"#adv_header\").show();\n            $(\"#WirelessRadarChList\").show();\n            $(\"#WirelessRadarApList\").show();\n            $(\"#adv_hdr li\").hide();\n            $(\"#adv_wireless_set\").show();\n        }\n    }\n    else if(tagValues[5] == \"yousee\") // YouSee support \n    {\n        $(\"#parentalControls\").hide();\n    }\n    else if(tagValues[5] == \"optus\") // Optus support \n    {\n        $(\"#BroadbandSetup\").show();\n        $(\"#QosSetup\").show();\n\t\t$(\"#QosSetup_hl\").attr(\"href\", \"\");\n    }\n\n    // USB Hidden\n    if (tagValues[6] == \"1\")\n    {\n        $(\"#basic-rea\").hide();\n        $(\"#usb_header\").hide();\n        $(\"#advUSB\").hide();\n    }  \n\n    // WPS Wizard\n    if(tagValues[7] == \"0\")\n    {\n        WPS_wizard_grayout();\n    }\n\n    // Chuck 20140501 Traffic Meter support \n\t// Chuck 20141001 Do not show Traffic Meter page in bridge mode\n    if(tagValues[10] == \"0\" || tagValues[3] == \"0\")\n    {\n        $(\"#traffic_meter\").hide();\n    }\n    else\n    {\n        $(\"#traffic_meter\").show();\n    }\n\n    // Chuck 20140610 for \"Turn off wireless signal by schedule \"\n    if(tagValues[11] == \"1\")\n    {\n        $(\"#adv_wireless_set\").children().attr('href','');\n    }\n    \n    // Chuck 20140610 add for \"Access Control\"\n    if(tagValues[12] == \"0\")\n    {\n        $(\"#access_ctrl\").hide();\n    }\n    else\n    {\n        $(\"#access_ctrl\").show();\n    }\n\n    if(tagValues[13] == \"0\")\n    {\n        $(\"#parentalControls\").hide();\n        $(\"#basic-par\").hide();\n    }\n}\n\nfunction BodyInit()\n{\n    ShowLanguageList();\n    InitUpdateView(InitTagValue());\n    hiddenWifi('0');\n    initBridgeView('0');\n}\nfunction initBridgeView(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#RouterMode\").hide();\n        $(\"#router_status_text\").html(\"Modem Status\");\n        $(\"#SetPassword\").show();\n    }\n}\nfunction hiddenWifi(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#basic-wls\").hide();\n        $(\"#basic-gst\").hide();\n        $(\"#wps-wizard\").hide();\n        $(\"#wireless_set\").hide();\n        $(\"#guest_set\").hide();\n        $(\"#wireless_hotspot\").hide();\n        $(\"#WirelessRadarChList\").hide();\n        $(\"#WirelessRadarApList\").hide();\n        $(\"#adv_wireless_set\").hide();\n    }\n}\nfunction ChangeResize(tab)\n{    \n    var unnecessaryHeight = $(\".topframe\")[0].clientHeight+$(\".tabs\")[0].clientHeight+$(\"#footer\")[0].clientHeight+parseInt($(\".basic-menu\").css(\"margin-top\").substring(0, $(\".basic-menu\").css(\"margin-top\").length-2),10)+(parseInt($(\"#hideDiv\")[0].clientHeight,10) == 0? 15:$(\"#hideDiv\")[0].clientHeight);\n    page_contain_height = document.documentElement.clientHeight-unnecessaryHeight > 470+adjustPageHeight ? document.documentElement.clientHeight-unnecessaryHeight : 470+adjustPageHeight;\n    \n    if(!tab)\n    {\n        if($(\"#BasicTab\").hasClass('current'))\n            tab = \"BasicTab\";\n        else\n        \t  tab = \"AdvanceTab\";\n    }\n    if(tab == \"BasicTab\"){\n        $('.basic-menu').css(\"height\", page_contain_height);  \n        $('#page_contain').height(parseInt(page_contain_height));  \n        $('#page').height(parseInt(page_contain_height));\n        if(navigator.userAgent.indexOf(\"MSIE 7\") != -1)\n            $('#page').contents().find('body').height(parseInt(page_contain_height));\n    } else {\n        $('.advance-menu').css(\"height\", page_contain_height);  \n        $('#page_contain2').height(parseInt(page_contain_height));  \n        $('#page2').height(parseInt(page_contain_height));\n        if(navigator.userAgent.indexOf(\"MSIE 7\") != -1)\n            $('#page2').contents().find('body').height(parseInt(page_contain_height));\n    }\n}\n\n//]]>\n</SCRIPT>\n\n<META content=\"MSHTML 6.00.2900.6129\" name=GENERATOR>\n</head>\n<body style=\"PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; PADDING-TOP: 0px; BACKGROUND-COLOR:#787878;\" onresize=\"adjustPageLayout();change_size();\">\n    <table id=\"all\" style=\"PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; PADDING-TOP: 0px\" cellSpacing=0 cellPadding=0 width=\"100%\">\n        <tbody>\n            <tr>\n                <td style=\"BACKGROUND-COLOR:#787878\">\n                    &nbsp;\n                </td>\n                <td style=\"WIDTH: 960px; HEIGHT: 610px\">\n                    <table class=\"topframe\" style=\"PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; WIDTH: 100%; PADDING-TOP: 0px; HEIGHT: 52px\" cellSpacing=0 cellPadding=0>\n                        <tbody>\n                            <tr>\n                                <td style=\"PADDING-LEFT: 20px\">\n                                    <img alt=\"\" id=\"topleftLogo\" style=\"LEFT: -7px; POSITION: relative\" src=\"\" />\n                                    <br>\n                                    <span id=\"ModuleName\">\n                                        <b>\n                                            C7000v2\n                                        </b>\n                                    </span>\n                                </td>\n                                <td style=\"PADDING-RIGHT: 25px; TEXT-ALIGN: right\">\n                                    <img alt=\"\" id=\"toprightLogo\" style=\"top:15px;POSITION: relative\" src=\"\" />\n                                    <button class=\"button-rule\" style=\"PADDING-LEFT: 10px;\" onclick=\"gui_logout();\" name=\"logout\" value=\"BUTTON\">\n                                        <span class=\"roundleft_button\">\n                                            &nbsp;&nbsp;&nbsp;&nbsp;Logout\n                                        </span>\n                                        <span class=\"roundright_button\">\n                                            &nbsp;&nbsp;&nbsp;&nbsp;\n                                        </span>\n                                    </button>\n                                    <br>\n                                    <BR style=\"LINE-HEIGHT: 8px\">\n                                    <b>\n                                        Firmware Version\n                                    </b>\n                                    <br>\n                                    <div id=\"FirmwareVersion\">\n                                    </div>\n                                </td>\n                            </tr>\n                        </tbody>\n                    </table>\n                    <table style=\"PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; WIDTH: 100%; PADDING-TOP: 0px; HEIGHT: 520px\" cellSpacing=0 cellPadding=0>\n                        <tr>\n                            <td>\n                                <!-- tabs -->\n                                <ul class=\"tabs\">\n                                    <li>\n                                        <a class=\"current\" id=\"BasicTab\" onfocus=\"this.blur()\" href=\"index.htm#\"><span>BASIC</span></a>\n                                    </li>\n                                    <li>\n                                        <a id=\"AdvanceTab\" onfocus=\"this.blur()\" href=\"index.htm#\"><span>ADVANCED</span></a>\n                                    </li>\n                                    <!-- <li>\n                                    <div class=\"button-rule\" id=\"firmware-update\" style=\"PADDING-LEFT: 10px\" onclick=\"fw_upgrade_hint();\">\n                                    <span class=\"roundleft_update\">&nbsp;&nbsp;A gateway firmware upgrade is available.</span>\n                                    <span class=\"roundright_update\">&nbsp;&nbsp;&nbsp;&nbsp;</span>\n                                    </div>\n                                    </li>\n                                    -->\n                                    <!-- Nick 20120229, add multi-lang menu bar -->\n                                    <li>\n                                        &nbsp;\n                                    </li>\n                                    <li id=\"lang_menu_li\" style=\"float:right;padding-right:25px;margin-bottom:10px\">\n                                        <form name=\"frmLanguage\" method=\"post\" action='/goform/Language?id=1808663262' style=\"margin:0px\">\n                                            <select class=\"selectbox\" id=\"lang_menu\" onchange=\"chgLang();this.blur();\" size=\"1\" name=\"choicelang\">\n                                                <option>\n                                                </option>\n                                            </select>\n                                            <!--<input type=\"hidden\" name=\"curlang\" value=\"Auto\">-->\n                                            <input type=\"hidden\" value=\"English\" name=\"curlang\">\n                                            <!--<input type=\"hidden\" name=\"curlang\" value=\"English\">-->\n                                            <input type=\"hidden\" value=\"Auto English German Chinese Korean Russian Spanish Polish French Italian Swedish Danish Nederlands Ellinika Norwegian Czech Slovenia Portuguese Hungarian Romanian Finnish Slovak Turkish French(Canadian)\"\n                                            name=\"local_srptlang\">\n                                            <input type=\"hidden\" value=\"Auto 0 6 14 10 17 20 13 5 8 21 2 11 3 12 1 19 15 7 16 4 18 22 23\"\n                                            name=\"srptlang\">\n                                            <!--<INPUT type=hidden value=\"Auto English German Chinese Korean Russian Spanish\n                                            Polish French Italian Swedish Danish Dutch Greek Norwegian Czech Slovenian Portuguese\n                                            Hungarian Romanian Finnish Slovak Turkey\" name=srptlang>-->\n                                            <input type=\"hidden\" value=\"Chinese\" name=\"first_brs_lang\">\n                                            <input type=\"hidden\" value=0 name=\"auto_block\">\n                                            <input type=\"hidden\" value=\"English\" name=\"gui_lang\">\n                                            <!--input type=\"hidden\" name=\"gui_lang_local\"-->\n                                        </form>\n                                    </li>\n                                    <!-- Nick 20120229, add multi-lang menu bar -->\n                                </ul>\n                                <!-- tab \"panes\" -->\n                                <div class=\"pane\">\n                                    <table style=\"PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; PADDING-TOP: 0px; HEIGHT: 480px\" cellSpacing=0 cellPadding=0 width=\"100%\">\n                                        <tbody>\n                                            <tr>\n                                                <td style=\"FONT-SIZE: 12px; WIDTH: 200px; FONT-FAMILY: Arial; BACKGROUND-COLOR:#e5e5e5\">\n                                                    <div class=\"basic-menu\">\n                                                        <div class=\"basic-menu-div\" id=\"basic-home\">\n                                                            <a href=\"DashBoard.htm\"><span>Home</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-int\">\n                                                            <a id=\"INT_menu\" href=\"DocsisOffline.htm\"><span>Cable Connection</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-wls\">\n                                                            <a id=\"WLS_menu\" href=\"\"><span>Wireless</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-atd\">\n                                                            <a href=\"\"><span>Network Map</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-par\">\n                                                            <a id=\"PAR_menu\" href=\"http://netgear.opendns.com/\"><span>Parental Controls</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-voice\">\n                                                            <a href=\"\"><span>Voice</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-rea\">\n                                                            <a href=\"\"><span>ReadySHARE</span></a>\n                                                        </div>\n                                                        <div class=\"basic-menu-div\" id=\"basic-gst\">\n                                                            <a href=\"\"><span>Guest Network</span></a>\n                                                        </div>\n                                                    </div>\n                                                </td>\n                                                <td style=\"WIDTH: 760px; FONT-FAMILY: Arial; HEIGHT: 480px; BACKGROUND-COLOR:#e5e5e5\">\n                                                    <div id=\"page_contain\">\n                                                        <iframe id=\"page\" style=\"MARGIN-LEFT: 55px; WIDTH: 600px; HEIGHT: 405px\" name=\"page\" src=\"\" frameborder=\"0\" scrolling=\"no\">\n                                                        </iframe>\n                                                    </div>\n                                                </td>\n                                            </tr>\n                                        </tbody>\n                                    </table>\n                                </div>\n                                <div class=\"pane\">\n                                    <table id=\"advance-table\" style=\"BORDER-RIGHT: 0px; PADDING-RIGHT: 0px; BORDER-TOP: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; BORDER-LEFT: 0px; WIDTH: 960px; PADDING-TOP: 0px; BORDER-BOTTOM: 0px; HEIGHT: 480px\" cellSpacing=0 cellPadding=0>\n                                        <tbody>\n                                            <tr style=\"HEIGHT: 480px\">\n                                                <td style=\"WIDTH: 215px; BACKGROUND-COLOR:#e5e5e5\">\n                                                    <ul class=\"advance-menu\">\n                                                        <li class=\"noSub\" id=\"adv-home\">\n                                                            <a href=\"RouterStatus.htm\"><span class=\"nosub_text\">ADVANCED Home</span></a>\n                                                        </li>\n                                                        <!-- // Nick 20110927 <li class=\"noSub\" id=\"wizard\">\n                                                        <a href=\"\"><span class=\"nosub_text\">Setup Wizard</span></a> \n                                                        </li>\n                                                        -->\n                                                        <li class=\"noSub\" id=\"wps-wizard\">\n                                                            <a href=\"\"><span class=\"nosub_text\">WPS Wizard</span></a>\n                                                        </li>\n                                                        <li class=\"Sub\" id=\"setup_header\">\n                                                            <a href=\"index.htm#\"><span>Setup</span></a>\n                                                        </li>\n                                                        <li class=\"subHeader\" id=\"set_hdr\">\n                                                            <ul style=\"WIDTH: 100%; HEIGHT: 112px\">\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"int_set\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Internet Setup</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\" id=\"wireless_set\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Wireless Setup</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"wan_set\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">WAN Setup</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"LAN_set\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">LAN Setup</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20111111-->\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"BroadbandSetup\" style=\"display:none\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Broadband Settings</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"MobileBroadbandSetup\" style=\"display:none\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Mobile Broadband Settings</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20111111-->\n                                                                <!-- // Nick 20111028-->\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"OnOLanSetup\" style=\"display:none\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Loopback IP</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20110922-->\n                                                                <li class=\"SubMenu\" id=\"QosSetup\" style=\"display:none\">\n                                                                <a id=\"QosSetup_hl\" onclick=\"return false\"><span>QoS Setup</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\" id=\"guest_set\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Guest Network</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\" id=\"wireless_hotspot\" style=\"display:none\">\n                                                                    <a id=\"wireless_hotspot_hl\" onclick=\"return false\"><span class=\"subMenu_text\">Wifi HotSpots</span></a>\n                                                                </li>\n                                                            </ul>\n                                                        </li>\n                                                        <li class=\"Sub\" id=\"usb_header\">\n                                                            <a href=\"index.htm#\"><span>USB Storage</span></a>\n                                                        </li>\n                                                        <li class=\"subHeader\">\n                                                            <ul style=\"WIDTH: 100%; HEIGHT: 80px\" id=\"usb_hdr\">\n                                                                <!-- <ul style=\"width:100%;height:60px\">\n                                                                -->\n                                                                <li class=\"SubMenu\">\n                                                                    <a onclick=\"return false\" href=\"\"><span style=\"BORDER-RIGHT: 0px; BORDER-TOP: 0px; BORDER-LEFT: 0px; BORDER-BOTTOM: 0px\">Basic Settings</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\" id=\"Advanced_Settings\">\n                                                                    <a onclick=\"return false\" href=\"\"><span>Advanced Settings</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\">\n                                                                    <a onclick=\"return false\" href=\"\"><span>Media Server</span></a>\n                                                                </li>\n                                                            </ul>\n                                                        </li>\n                                                        <li class=\"Sub\" id=\"security_header\">\n                                                            <a href=\"index.htm#\"><span>Security</span></a>\n                                                        </li>\n                                                        <li class=\"subHeader\">\n                                                            <ul style=\"WIDTH: 100%; HEIGHT: 110px\" id=\"sec_hdr\">\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"parentalControls\">\n                                                                    <a id=\"PAR_menu2\" href=\"index.htm#\" target=\"_blank\"><span class=\"subMenu_text\" style=\"BORDER-RIGHT: 0px; BORDER-TOP: 0px; BORDER-LEFT: 0px; BORDER-BOTTOM: 0px\">Parental Controls</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"access_ctrl\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=subMenu_text>Access Control</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"blk_site\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=subMenu_text>Block Sites</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"blk_serv\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Block Services</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"sche\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Schedule</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"email\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">E-mail</span></a>\n                                                                </li>\n                                                            </ul>\n                                                        </li>\n                                                        <li class=\"Sub\" id=\"administration\">\n                                                            <a href=\"index.htm#\"><span>Administration</span></a>\n                                                        </li>\n                                                        <li class=\"subHeader\" id='AdminId'>\n                                                            <ul id='AdminULId' style=\"WIDTH: 100%; HEIGHT: 200px\">\n                                                                <!-- Nick expand the height for speed test web page -->\n                                                                <li class=\"SubMenu\" id=\"router_status\">\n                                                                    <a onclick=\"return false\" href=\"RouterStatus.htm\"><span class=\"subMenu_text\" style=\"BORDER-RIGHT: 0px; BORDER-TOP: 0px; BORDER-LEFT: 0px; BORDER-BOTTOM: 0px\" id=\"router_status_text\">Gateway Status</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu SubMenuWDS\" id=\"RouterMode\">\n                                                                    <a onclick=\"return false\" href=\"RouterMode.htm\"><span class=\"subMenu_text\">Router Mode</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20111028-->\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"MtaStatus\" style=\"display: none;\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Voice Status</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20111028-->\n                                                                <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"logs\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Logs</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\">\n                                                                    <a id=\"advNetworkMap\" onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Network Map</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Backup Settings</span></a>\n                                                                </li>\n                                                                <li class=\"SubMenu\" id=\"SetPassword\">\n                                                                    <a onclick=\"return false\" href=\"\"><span class=\"subMenu_text\">Set Password</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20120409-->\n                                                                <li class=\"SubMenu\" id=eventlog>\n                                                                    <a onclick=\"return false\" href=\"eventLog.htm\"><span class=\"subMenu_text\">Event Log</span></a>\n                                                                </li>\n                                                                <!-- // Nick 20120409-->\n                                                                <!-- // Nick 20111028-->\n                                                                <