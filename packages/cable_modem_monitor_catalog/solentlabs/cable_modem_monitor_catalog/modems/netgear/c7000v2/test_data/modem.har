            "compression": 0,
            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n<html>\r\n<head>\r\n<META name=\"description\" content='C7000v2'>\r\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\r\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\r\n<META http-equiv=\"Pragma\" content=\"no-cache\">\r\n<META HTTP-equiv=\"Cache-Control\" content=\"no-cache\">\r\n<META HTTP-EQUIV=\"Expires\" CONTENT=\"Mon, 06 Jan 1990 00:00:01 GMT\">\r\n\r\n<link rel=\"stylesheet\" href=\"form.css\">\r\n<title>NETGEAR Gateway C7000v2</title>\r\n<link rel=\"stylesheet\" href=\"css/table.css\">\r\n<link rel=\"stylesheet\" href=\"css/scrollbar.css\">\r\n<link rel=\"stylesheet\" href=\"css/button.css\">\r\n\r\n<script type=\"text/javascript\" src=\"jquery.js\"></script>\r\n<script type=\"text/javascript\" src=\"script/jquery.mousewheel.js\"></script>\r\n<script type=\"text/javascript\" src=\"script/jquery.jscrollpane.min.js\"></script>\r\n\r\n<script type=\"text/javascript\" src=\"script/script.js\"></script>\r\n<script type=\"text/javascript\"><!--\r\n\r\nvar wan_status = 0;\r\n\r\n    $(document).ready(function()\r\n    {\r\n        BodyInit();\r\n        if(wan_status == \"1\")\r\n        {\r\n            location.href='DocsisStatus.htm';\r\n        }\r\n        $(\"#target\").submit(function() {\r\n            buttonFilter();\r\n        });\r\n\r\n    });\r\n\r\n\r\nfunction BodyInit()\r\n{\r\n    wan_status = 1;\r\n}\r\n\r\n//--></script></head>\r\n<body onLoad=\"'MNU_menu.htm'\" style=\"margin:0px;background-color:#e5e5e5\">\r\n    <form id=\"target\" name=\"msg\" action=\"message.cgi?id=777334267\" method=\"post\" onSubmit=\"return false\">\r\n        <input type=\"hidden\" name=\"buttonHit\">\r\n        <input type=\"hidden\" name=\"buttonValue\">\r\n        <table WIDTH=\"100%\" BORDER=\"0\" CELLSPACING=\"0\" CELLPADDING=\"4\">\r\n            <tr>\r\n                <td align=\"left\">\r\n                    <h1>\r\n                        Failure\r\n                    </h1>\r\n                </td>\r\n            </tr>\r\n        </table>\r\n        <table WIDTH=\"100%\" BORDER=\"0\" CELLSPACING=\"3\" CELLPADDING=\"0\">\r\n            <tr>\r\n                <td colspan=\"2\" style=\"background-image: url('liteblue.gif'); height: 12px;background-repeat: repeat-x;\">\r\n                    &nbsp;\r\n                </td>\r\n            </tr>\r\n        </table>\r\n        <table WIDTH=\"100%\" BORDER=\"0\" CELLSPACING=\"0\" CELLPADDING=\"4\">\r\n            <tr>\r\n                <td align=center>\r\n                    <b style=\"color:#ff0000\">\r\n                        Your modem is offline.\r\n                    </b>\r\n                </TD>\r\n            </TR>\r\n            <tr>\r\n                <td align=center>\r\n                    <b>\r\n                        Please check the RF connection.\r\n                    </b>\r\n                </TD>\r\n            </TR>\r\n        </table>\r\n        <table WIDTH=\"100%\" BORDER=\"0\" CELLSPACING=\"3\" CELLPADDING=\"0\">\r\n            <tr>\r\n                <td colspan=\"2\" style=\"background-image: url('liteblue.gif'); height: 12px;background-repeat: repeat-x;\">\r\n                    &nbsp;\r\n                </td>\r\n            </tr>\r\n        </table>\r\n        <table WIDTH=\"100%\" BORDER=\"0\" CELLSPACING=\"0\" CELLPADDING=\"4\">\r\n            <TR>\r\n                <td align=center>\r\n                    Click <b>OK</b> to go back to the Dashboard screen....\r\n                </TD>\r\n            </TR>\r\n            <TR>\r\n                <td align=center>\r\n                    <a style=\"color:blue;TEXT-DECORATION :UNDERLINE\" href=\"DocsisStatus.htm\">Click <b>Here</b> to go to setting....</a>\r\n                </TD>\r\n            </TR>\r\n            <TR>\r\n                <TD align=center>\r\n                    &nbsp;&nbsp;&nbsp;\r\n                    <button 