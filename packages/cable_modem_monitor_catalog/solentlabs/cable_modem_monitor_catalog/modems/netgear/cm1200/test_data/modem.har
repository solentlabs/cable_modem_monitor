                      &nbsp;\r\n                                        </div>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr id=\"ext_us_pwr_title\">\r\n                                    <td>\r\n                                        <b>\r\n                                            Extended Upstream Transmit Power\r\n                                        </b>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr id=\"ext_us_pwr_checkbox\">\r\n                                    <td>\r\n                                        <input type=\"checkbox\" id=\"ext_us_power\" name=\"ext_us_power\" value=\"ext_us_power\">Enable Extended Upstream Transmit Power\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td>\r\n                                        <div style=\"background-image:url('liteblue.gif');width:100%;background-repeat: repeat-x;\">\r\n                                            &nbsp;\r\n                                        </div>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td id=\"CurrentSystemTime\" style=\"font-size:13px;font-family:Helvetica;font-weight:bold\">\r\n                                        <b>\r\n                                            Current System Time:\r\n                                        </b>\r\n                                        --- --- -- --:--:-- ----\r\n                                        <br>\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td id=\"SystemUpTime\" style=\"font-size:13px;font-family:Helvetica;