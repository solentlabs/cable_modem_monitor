            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<html>\n<head>\n<title>NETGEAR Modem eMTA CM2050V</title>\n<META name=\"description\" content=\"CM2050V\">\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<META http-equiv=\"Pragma\" content=\"no-cache\">\n<META HTTP-equiv=\"Cache-Control\" content=\"no-cache\">\n<META HTTP-EQUIV=\"Expires\" CONTENT=\"Mon, 06 Jan 1990 00:00:01 GMT\">\n\n<script src=\"jquery.js\"></script>\n<script src=\"script/script.js\"></script>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/mainpage.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/tabs.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/button.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/menu.css\">\n<link rel=\"shortcut icon\" href=\"favicon.ico\">\n<script type=\"text/javascript\">\n\nfunction get_browser()\n{\n    //var isApple = /Safari/.test(navigator.userAgent) && /Apple Computer/.test(navigator.vendor);\n   if((navigator.userAgent.indexOf(\"iPad\") != -1) ||\n     (navigator.userAgent.indexOf(\"iPhone\") != -1) ||\n     (navigator.userAgent.indexOf(\"iPod\") != -1))\n        return \"iOS\";\n    else if(navigator.userAgent.indexOf(\"Mac OS X\") != -1)\n        return \"MAC\";\n    else if(navigator.userAgent.indexOf(\"Android\") != -1)\n        return \"Android\";\n    else if(navigator.userAgent.indexOf(\"Navigator\") != -1)\n        return \"Netscape\";\n    else if (!(false || !!document.documentMode) && !!window.StyleMedia)\n        return \"Edge\";\n    //else if(navigator.userAgent.indexOf(\"MSIE\") != -1)\n    else if(false || !!document.documentMode)\n        return \"IE\";\n    //else if(navigator.userAgent.indexOf(\"Chrome\") != -1)\n    else if(!!window.chrome && !!window.chrome.loadTimes)\n        return \"Chrome\";//bug 21975:spec1.9-p228,[usb] the real links are different for different browsers\n    //else if(navigator.userAgent.indexOf(\"Firefox\") != -1)\n    else if(typeof InstallTrigger !== 'undefined')\n        return \"Firefox\";\n    //else if((navigator.userAgent.indexOf(\"Safari\") != -1 ))\n    else if(/Safari/.test(navigator.userAgent) && /Apple Computer/.test(navigator.vendor))\n        return \"Safari\";\n    else if(navigator.userAgent.indexOf(\"Camino\") != -1)\n        return \"Camino\"; \n     else if(navigator.userAgent.indexOf(\"Gecko/index.html\") != -1)\n        return \"Gecko\"; \n    else if(navigator.userAgent.indexOf(\"Opera\") != -1)\n        return \"Opera\";\n    else\n        return \"\";\n}\n\n$(window).load(function() {\n    //alert(\"1\");\n    var isIE = navigator.userAgent.search(\"MSIE\") > -1; \n    var isFirefox = navigator.userAgent.search(\"Firefox\") > -1;\n    var isOpera = navigator.userAgent.search(\"Opera\") > -1;\n    var isSafari = navigator.userAgent.search(\"Safari\") > -1;\n\n    var isIE8=navigator.appVersion.indexOf(\"MSIE 8\") > -1;  \n    var form=document.forms[0];\n\n    change_size();\n});\n\n$(document).ready(function(){\n//alert(\"2*\");\n    BodyInit();\n    document.getElementById(\"password\").focus();\n});\n\nfunction change_size()\n{    //alert(\"17\");\n    //setLanglistPosition();\n    //setFooterClass();\n    //subpage_resize();\n}\n\n/*  0: Firemware Version\n    1: Guest Network Supported\n    2: MultiLang Supported\n    3: Rg/Bridge Mode\n    4: Voice Supported\n    5: MSO Supported\n    6: USB Hidden\n    7: WPS Wizard grayout\n    8: ETHER WAN Supported\n    9: ETHER WAN Enabled\n    10: Traffic Meter Supported\n    11: WiFi Schedule Supported\n    12: Access Control Supported\n    13: New Firmware\n    14: TimeZone\n    15: TimeZoneConfigured\n    16: IsLanAccess\n*/\nfunction InitTagValue()\n{\n    var tagValueList = '0';\n//    var tagValueList = \"v0.1\";\n    return tagValueList.split(\"|\");\n}\n\nfunction InitUpdateView(tagValues)\n{\n}\n\nfunction BodyInit()\n{\n    //Not support multi language\n    InitUpdateView(InitTagValue());\n}\n</script>\n\n<script>\nfunction myFunction() {\n    var x = document.getElementById(\"Demo\");\n    if (x.className.indexOf(\"w3-show\") == -1) {\n        x.className += \" w3-show\";\n    } else { \n        x.className = x.className.replace(\" w3-show\", \"\");\n    }\n}\n</script>\n<link href=\"css/custom.css\" rel=\"stylesheet\" type=\"text/css\">\n\n</head>\n\n<body style=\"padding:0;margin:0;overflow:none\" onload=\"change_size();\" onResize=\"change_size();\">\n  <table width=\"100%\" CELLPADDING=\"0\" CELLSPACING=\"0\" style=\"padding:0;margin:0;\" id=\"all\">\n    <tr width=\"100%\">\n      <td style=\"width:100%;height:100%\">\n      <div id=\"main_screen\">\n        <table style=\"height:100px;width:100%;margin:0;padding:0\" CELLPADDING=\"0\" CELLSPACING=\"0\" class=\"newtopframe\">\n          <tr>\n            <td style=\"padding-left:20px\">\n              <img style=\"position:relative;width: 216px\" src=\"img/NightHawk.png\" >\n              <br><span id=\"ModuleName\" style=\"position: relative; right: 0px;\"><b>My Modem:</b> Nighthawk CM2050V&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n            </td>\n            <td style=\"text-align:right;padding-right:25px\">\n              <ul class=\"tnb-right\">\n                  <li>\n                      <div class=\"w3-dropdown-click\">\n                          <a onclick=\"myFunction()\"><img src=\"img/tnb-ico1.png\" alt=\"\"></a>\n                          <div id=\"Demo\" class=\"w3-dropdown-content w3-bar-block tnb-submenu-bg\">\n                            <div id=\"search\">\n                                <input type=\"text\" id=\"search_text\" name=\"search\" value=\"Enter Search Item\" onkeypress=\"detectEnter('num',event);\" onFocus=\"this.select();\" >\n                                <input id=\"search_button\" class=\"search_button\" type=\"button\" name=\"dosearch\" value=\"GO\" onClick=\"do_search();\">\n                            </div>\n                          </div>\n                      </div>\n                  </li>\n                  <li><a href=\"javascript:;\"><img src=\"img/tnb-ico2.png\" alt=\"\"></a>\n                      <div class=\"tnb-submenu\">\n                        <a target=\"_blank\" href=\"http://downloadcenter.netgear.com/\">Documentation</a> \n                        <a target=\"_blank\" href=\"http://support.netgear.com/\">Online Support</a> \n                        <a target=\"_blank\" href=\"http://support.netgear.com/app/answers/detail/a_id/12923\">Gateway FAQ</a>\n                        <a target=\"_blank\" href=\"OpenSourceLicense.html\">Open Source</a>\n                      </div>\n                  </li>\n              </ul>\n              <br><br style='line-height:8px'>\n            </td>\n          </tr>\n        </table>\n         <div class=\"header-bar\"></div>\n          <table CELLPADDING=\"0\" CELLSPACING=\"0\" style=\"height:100%;width:100%;margin:0;padding:0\">\n                <td style=\"width=50%\" align=\"middle\">\n                    <table style=\"font-size:170%\">\n                        <form id=\"target\" name=\"loginform\" method=\"POST\" action=\"/goform/Login?id=1248795675\">\n                            <th colspan=\"2\" align=\"center\">Please enter password to login</tr>\n                            <tr><td align=\"right\">Username: </td><td>admin</td>\n                            <input type=\"hidden\" id=\"name\" name=\"loginName\" value=\"admin\">\n                            </tr>\n                            <tr></tr><tr></tr>\n                            <tr><td align=\"right\">Password: </td>\n                            <td><input type=\"password\" id=\"password\" name=\"loginPassword\"></td>\n                            </tr><tr>\n                            </tr><tr></tr>\n                            <tr><td></td><td align=\"right\">\n                            <input type=\"submit\" value=\"Login\" id=\"login\" style=\"font-size:100%\" />\n                            </td></tr>\n                        </form>\n                    </table>\n                </td>\n                <td>\n                    <img src=\"img/CM2050V.jpg\">\n                </td>\n          </table>\n        </div> <!--  id=main_screen-->\n      </div>\n      </td>\n    </tr>\n  </table>\n\n<!-- This JavaScript sn: ***REDACTED*** activates those tabs -->\n<div id=\"diablePage\" style=\"display:none;z-index:1;position: absolute;\"></div>\n</body>\n</html>\n"
