          "content": {
            "size": 73250,
            "mimeType": "text/html",
            "compression": 0,
            "text": "<!DOCTYPE html>\n<html>\n<head>\n<title>NETGEAR Modem eMTA CM2050V</title>\n<META name=\"description\" content=\"CM2050V\">\n<META http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n<META http-equiv=\"Content-Style-Type\" content=\"text/css\">\n<META http-equiv=\"Pragma\" content=\"no-cache\">\n<META HTTP-equiv=\"Cache-Control\" content=\"no-cache\">\n<META HTTP-EQUIV=\"Expires\" CONTENT=\"Mon, 06 Jan 1990 00:00:01 GMT\">\n\n<script src=\"jquery.js?version=1.12.4\"></script>\n<script src=\"script/script.js\"></script>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/mainpage.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/tabs.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/button.css\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/menu.css\">\n<link rel=\"shortcut icon\" href=\"favicon.ico\">\n<script type=\"text/javascript\">\nvar gui_lang_local;\nvar load_page = 0;\nvar is_loading_page = 0;\nvar adjustPageHeight = 0;\nvar num_nosubLarge = 0;\nvar num_submenuLarge = 0;\nfunction get_browser()\n{\n    //var isApple = /Safari/.test(navigator.userAgent) && /Apple Computer/.test(navigator.vendor);\n   if((navigator.userAgent.indexOf(\"iPad\") != -1) ||\n     (navigator.userAgent.indexOf(\"iPhone\") != -1) ||\n     (navigator.userAgent.indexOf(\"iPod\") != -1))\n        return \"iOS\";\n    else if(navigator.userAgent.indexOf(\"Mac OS X\") != -1)\n        return \"MAC\";\n    else if(navigator.userAgent.indexOf(\"Android\") != -1)\n        return \"Android\";\n    else if(navigator.userAgent.indexOf(\"Navigator\") != -1)\n        return \"Netscape\";\n    else if (!(false || !!document.documentMode) && !!window.StyleMedia)\n        return \"Edge\";\n    //else if(navigator.userAgent.indexOf(\"MSIE\") != -1)\n    else if(false || !!document.documentMode)\n        return \"IE\";\n    //else if(navigator.userAgent.indexOf(\"Chrome\") != -1)\n    else if(!!window.chrome && !!window.chrome.loadTimes)\n        return \"Chrome\";//bug 21975:spec1.9-p228,[usb] the real links are different for different browsers\n    //else if(navigator.userAgent.indexOf(\"Firefox\") != -1)\n    else if(typeof InstallTrigger !== 'undefined')\n        return \"Firefox\";\n    //else if((navigator.userAgent.indexOf(\"Safari\") != -1 ))\n    else if(/Safari/.test(navigator.userAgent) && /Apple Computer/.test(navigator.vendor))\n        return \"Safari\";\n    else if(navigator.userAgent.indexOf(\"Camino\") != -1)\n        return \"Camino\"; \n     else if(navigator.userAgent.indexOf(\"Gecko/index.html\") != -1)\n        return \"Gecko\"; \n    else if(navigator.userAgent.indexOf(\"Opera\") != -1)\n        return \"Opera\";\n    else\n        return \"\";\n}\n\nfunction OnSubmitForm()\n{    //alert(\"1*\");\n        var text = $('#searchText').val();\n        var URItext = encodeURIComponent(text);\n\n        URItext =  \"http://support.netgear.com/app/answers/list/kw/\" + URItext;\n        document.searchform.action = URItext;\n        return true;\n}\n$(window).on( \"load\", function() {\n    //alert(\"1\");\n    var isIE = navigator.userAgent.search(\"MSIE\") > -1; \n    var isFirefox = navigator.userAgent.search(\"Firefox\") > -1;\n    var isOpera = navigator.userAgent.search(\"Opera\") > -1;\n    var isSafari = navigator.userAgent.search(\"Safari\") > -1;\n\n    var isIE8=navigator.appVersion.indexOf(\"MSIE 8\") > -1;  \n    var form=document.forms[0];\n    var lang = form.curlang.value;\n    //notification of R7000 full feature\n    //\n\n    /*\n    //When the multilanguage droplsit switched to Japanese and Hungarian disappear. \n    if((isIE && isIE8 && lang == \"Japanese\") || (isIE && isIE8 && lang == \"Hungarian\"))\n    {\n        //alert(\"no change\");\n    }else\n    {\n    */\n        //alert(\"change\");\n        $('#lang_menu_li').css(\"float\", \"right\");\n         $('#lang_menu_li').css(\"padding-right\", \"25px\");\n        $('#lang_menu_li').css(\"margin-bottom\", \"10px\");\n        $('#lang_menu_li').hide();\n    /*\n    }\n    */\n\n\n\n    if(0==\"1\" & 0)\n    {\n        if($('#firmware-update').hasClass(\"firmware-update-hint-long\")) {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"480px\");\n        } else if(isSafari) {\n            //alert(\"\");\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"410px\");\n        } else if(isOpera) {\n            //alert(\"\");\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"0px\");\n        } else if(isIE) {\n            //alert(\"\");\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"-10px\");\n        } else if($('#firmware-update').hasClass(\"firmware-update-hint-long-long\")) {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"530px\");\n        }  else {\n            $('#ModuleName').css(\"position\", \"relative\");\n            $('#ModuleName').css(\"right\", \"410px\");\n        }\n    }\n    else\n    {\n        $('#ModuleName').css(\"position\", \"relative\");\n        $('#ModuleName').css(\"right\", \"0px\");\n    }\n\n    change_size();\n\n    /*\n    if((isIE && ($(\"#firmware-update\").hasClass('firmware-update-hint') \n        || $(\"#firmware-update\").hasClass('firmware-update-hint-long') || $(\"#firmware-update\").hasClass('firmware-update-hint-long-long')))\n        || ((isFirefox || isOpera) && ($(\"#firmware-update\").hasClass('firmware-update-hint-long') || $(\"#firmware-update\").hasClass('firmware-update-hint-long-long'))))\n    { \n//      $('#lang_menu_li').css(\"position\", \"relative\");\n//      $('#lang_menu_li').css(\"top\", \"-24px\");\n    }   \n    */\n\n\n    if(0)\n    {    \n            $(\"#second\").hide();  \n            $(\"#first\").show();\n            $(\"#basic-pane\").css(\"display\",\"block\");\n            $(\"#adv-pane\").css(\"display\",\"none\");\n            //$('#BasicTab').css(\"background\",\"url(../img/tab-active.gif) no-repeat 0\");\n            //$(\"#AdvanceTab\").css(\"background\",\"url(../img/tab-nonactive.gif) no-repeat 0\");\n            $('.subHeader').hide();\n            $('.menuActive').removeClass('menuActive');\n            loadPage(\"GstManagePage.htm\"); \n    }\n    else\n    {\n     if (!chgBrsLang()) /* no page is loadded */\n     {\n         if(0)\n            loadPage(\"WirelessSettings.htm\");\n/*\n         else if(==\"1\")\n            loadPage(\"BasicSettingsBottom.htm\");\n*/\n         else\n            loadPage(\"DashBoard.htm\");\n     }\n        }\n     try {\n        document.execCommand(\"BackgroundImageCache\", false, true);\n     } catch (e){}\n});\n\nfunction chgTimeZone()\n{\n    var form = document.forms[0];\n    var is_lan_access =  form.is_lan_access.value;\n    var timezone_configured =  form.time_zone_configured.value;\n    var time_zone = form.time_zone.value;\n    var target_time_zone = (new Date().getTimeZoneOffsetWithDst())/-60;\n    if (time_zone == \"55\")\n        time_zone= \"5.5\";\n    else if (time_zone == \"-35\")\n        time_zone = \"-3.5\";\n\n    // Abort if user is remote access. \n    if(is_lan_access == \"0\")\n        return -1;\n\n    // Abort if user is manual configured. \n    if(timezone_configured == \"1\")\n        return -1;\n\n    // Abort if timezone between router and local system is the same \n    if(time_zone == target_time_zone)\n        return -1;\n\n    ret = confirm(\"Need to auto config timezone?\");\n    if(ret)\n    {\n        console.log(\"loadPage\");\n        loadPage(\"AutoTimeZone.htm\");\n    }\n    return 0;\n}\n\n$(document).ready(function(){\n//alert(\"2*\");\n    //$('#lang_menu').removeAttr(\"disabled\");\n    BodyInit();\n    adjustPageLayout();\n    ;\n\n    liveMenuClick();\n    advanceMenu();\n    $('.subHeader').hide();\n    var pnpx = 0\n    if(pnpx == 1){\n        $(\"#AdvanceTab\").click();\n        $(\"#basic-pane\").css(\"display\",\"none\");\n        $(\"#adv-pane\").css(\"display\",\"block\");\n        pnpx = 0;\n    }\n});\n\nfunction checkMenuDisable()\n{    //alert(\"2\");\n    var basic_page = document.getElementById('page').contentWindow;\n    var advanced_page = document.getElementById('page2').contentWindow;\n\n    try {\n        if(basic_page.document.getElementsByName(\"disable_menu\")[0]) {\n            dieMenuClick();\n            setTimeout('checkMenuDisable()',1500); \n        } else if(advanced_page.document.getElementsByName(\"disable_menu\")[0]) {\n            dieMenuClick();\n            setTimeout('checkMenuDisable()',1500); \n        } else {\n            liveMenuClick();\n        }\n    }\n    catch (e){\n        liveMenuClick();\n    }\n}\n\nfunction dieMenuClick()\n{    //alert(\"3\");\n    $('.noSub').off(\"click\");\n    $('.noSubLarge').off(\"click\");\n    $('.noSubActive').off(\"click\");\n    $('.noSubActiveLarge').off(\"click\");\n    $('.SubMenu').off(\"click\");\n    $('.SubMenuLarge').off(\"click\");\n    $('.SubMenuActive').off(\"click\");\n    $('.SubMenuActiveLarge').off(\"click\");\n\n    $(\"#BasicTab\").off(\"click\");\n    $(\"#AdvanceTab\").off(\"click\");\n    $('.basic-menu-div').off(\"click\");\n\n    $('.basic-menu-div').on(\"click\", function(ev){ \n        return false;\n    });\n    $('.noSub , .noSubLarge , .noSubActive, .noSubActiveLarge').on(\"click\", function(ev){ \n        return false;\n    });\n\n    return true;\n}\n\nfunction liveMenuClick()\n{    //alert(\"4\");\n      var isie = navigator.userAgent.search(\"MSIE\") > -1;\n      var ap_mode_flag = document.getElementsByName(\"enable_apmode\");\n      var sta_mode_flag = document.getElementsByName(\"enable_stamode\");\n      var repeater_flag = document.getElementsByName(\"repeater\");\n      var repeater_an_flag = document.getElementsByName(\"repeater_an\");\n      //var downloader_flag = document.getElementsByName(\"have_usb_attached\");\n\n    $('.noSub , .noSubLarge , .noSubActive, .noSubActiveLarge').off(\"click\");\n    $('.basic-menu-div').off(\"click\");\n\n      if(ap_mode_flag[0].value==\"1\" || repeater_flag[0].value==\"1\" || repeater_an_flag[0].value==\"1\")\n      {\n          if($(\"#basic-int\").hasClass(\"basic-menu-div\"))\n          {\n              $(\"#basic-int\").addClass('basic-menu-div-gray');\n              $(\"#basic-int\").removeClass('basic-menu-div');\n              $('#basic-int').bind('contextmenu', function(e) {\n                e.preventDefault();\n              });\n          }\n          if($(\"#basic-par\").hasClass(\"basic-menu-div\")){\n              $(\"#basic-par\").addClass('basic-menu-div-gray');\n              $(\"#basic-par\").removeClass('basic-menu-div');\n              $('#basic-par').bind('contextmenu', function(e) {\n                e.preventDefault();\n              });\n        }\n      }\n      if( sta_mode_flag[0].value==\"1\" ){\n          if($(\"#basic-int\").hasClass(\"basic-menu-div\")){\n              $(\"#basic-int\").addClass('basic-menu-div-gray');\n              $(\"#basic-int\").removeClass('basic-menu-div');\n          }\n          if($(\"#basic-wls\").hasClass(\"basic-menu-div\")){\n              $(\"#basic-wls\").addClass('basic-menu-div-gray');\n              $(\"#basic-wls\").removeClass('basic-menu-div');\n          }\n          if($(\"#basic-par\").hasClass(\"basic-menu-div\")){\n              $(\"#basic-par\").addClass('basic-menu-div-gray');\n              $(\"#basic-par\").removeClass('basic-menu-div');\n          }\n          if($(\"#basic-gst\").hasClass(\"basic-menu-div\")){\n              $(\"#basic-gst\").addClass('basic-menu-div-gray');\n              $(\"#basic-gst\").removeClass('basic-menu-div');\n          }\n      }\n      if( $('#wizard').hasClass('noSubGray')){\n        $('#wizard').bind('contextmenu', function(e) {\n            e.preventDefault();\n        });\n      }\n    /*\n    if(downloader_flag[0].value==\"0\")\n    {\n        if($(\"#basic-dlr\").hasClass(\"basic-menu-div\"))\n        {\n            $(\"#basic-dlr\").addClass('basic-menu-div-gray');\n            $(\"#basic-dlr\").removeClass('basic-menu-div');\n        }\n    }\n    */\n      $('#AdvanceTab').on(\"click\", function(ev){\n          $(\"#first\").hide();  \n          $(\"#second\").show();\n          $('.subHeader').hide(); \n          //$(this).css(\"background\",\"url(../img/tab-active.gif) no-repeat 0\");\n          //$(\"#BasicTab\").css(\"background\",\"url(../img/tab-nonactive.gif) no-repeat 0\");\n          $('.noSubActive').removeClass('noSubActive');\n          $('.noSubActiveLarge').removeClass('noSubActiveLarge');\n          $('.SubMenuActive').addClass('SubMenu');\n          $('.SubMenuActive').removeClass('SubMenuActive');\n          $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n          $('.SubMenuActiveLarge').addClass('SubMenu');\n          $('.SubMenuActiveLarge').addClass('Large');\n          $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n          $('.SubActive').addClass('Sub');\n          $('.SubActive').removeClass('SubActive');\n          if($('#adv-home').hasClass('noSubLarge'))\n            $('#adv-home').addClass('noSubActiveLarge');\n          else\n            $('#adv-home').addClass('noSubActive');\n          $('.subHeader:visible').slideUp('fast');\n          loadPage2(\"RouterStatus.htm\");\n      });\n\n      $('#BasicTab').on(\"click\", function(ev){\n          $(\"#second\").hide();  \n          $(\"#first\").show();\n          //$(this).css(\"background\",\"url(../img/tab-active.gif) no-repeat 0\");\n          //$(\"#AdvanceTab\").css(\"background\",\"url(../img/tab-nonactive.gif) no-repeat 0\");\n          $('.subHeader').hide();\n          $('.menuActive').removeClass('menuActive');\n          $('#basic-home').addClass('menuActive');\n          loadPage(\"DashBoard.htm\");\n      });\n\n      $('.basic-menu-div').on(\"click\", function(ev){\n        if($(this)[0].getAttribute('id') != \"basic-dlr\")\n        {  \n          $('.menuActive').removeClass('menuActive');\n          $(this).addClass('menuActive');\n          var path = $(this).children(\"a\").attr(\"href\");\n          loadPage(path);\n        }\n         ev.preventDefault();\n\n      }); \n      /*\n      $('.basic-menu-eco-div').on(\"click\", function(ev){\n         $('.menuActive').removeClass('menuActive');\n         $(this).addClass('menuActive');\n         var path = $(this).children(\"a\").attr(\"href\");\n         loadPage(path);\n         ev.preventDefault();\n\n      });\n      */\n\n\n      $('.noSub').on(\"click\",function(ev){\n          $(\"#first\").hide(); \n          if( !$(this).hasClass('noSubGray') & !$(this).hasClass('noSubGrayLarge')){\n                $('.noSubActive').removeClass('noSubActive'); \n                $('.noSubActiveLarge').removeClass('noSubActiveLarge');\n                $('.SubActive').addClass('Sub');\n                $('.SubActive').removeClass('SubActive');\n                $('.SubMenuActive').addClass('SubMenu'); \n                $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n                $('.SubMenuActiveLarge').addClass('SubMenu');\n                $('.SubMenuActiveLarge').addClass('Large');\n                $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n                $('.SubMenuActive').removeClass('SubMenuActive');\n                if($(this).hasClass('noSubLarge'))\n                    $(this).addClass('noSubActiveLarge'); \n                else\n                    $(this).addClass('noSubActive'); \n                $('.subHeader:visible').slideUp('fast');\n                var path = $(this).children(\"a\").attr(\"href\");\n                loadPage2(path);\n                ev.preventDefault();\n          }else{\n               return false;\n          }\n      });\n\n      $('.noSubLarge').on(\"click\",function(ev){\n          $(\"#first\").hide();\n          if( !$(this).hasClass('noSubGray') & !$(this).hasClass('noSubGrayLarge')){\n                $('.noSubActive').removeClass('noSubActive'); \n                $('.noSubActiveLarge').removeClass('noSubActiveLarge');  \n                $('.SubActive').addClass('Sub');\n                $('.SubActive').removeClass('SubActive');\n                $('.SubMenuActive').addClass('SubMenu'); \n                $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n                $('.SubMenuActiveLarge').addClass('SubMenu');\n                $('.SubMenuActiveLarge').addClass('Large');\n                $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n                $('.SubMenuActive').removeClass('SubMenuActive');\n                if($(this).hasClass('noSubLarge'))\n                    $(this).addClass('noSubActiveLarge'); \n                else\n                    $(this).addClass('noSubActive'); \n                $('.subHeader:visible').slideUp('fast');\n                var path = $(this).children(\"a\").attr(\"href\");\n                loadPage2(path);\n                ev.preventDefault();\n          }else{\n               return false;\n          }\n      });\n\n       $('.noSubGray').bind(\"click\", function(e){\n            e.preventDefault();\n       });\n\n       $('.noSubGray').bind(\"contextmenu\", function(e){\n            e.preventDefault();\n       });\n\n       $('.noSubGrayLarge').on(\"click\",function(){\n            return false;\n       });\n\n       $('.basic-menu-div-gray').bind(\"click\", function(e){\n            e.preventDefault();\n       });\n\n       $('.basic-menu-div-gray').bind(\"contextmenu\", function(e){\n            e.preventDefault();\n       });\n\n\n      $('.SubMenu').on(\"click\",function(ev){\n         $(\"#first\").hide();\n         if( !$(this).hasClass('SubMenuDisable') && !$(this).hasClass('SubMenuLargeDisable')){  \n            $('.noSubActive').removeClass('noSubActive');\n            $('.noSubActiveLarge').removeClass('noSubActiveLarge');\n            $('.SubMenuActive').addClass('SubMenu');\n            $('.SubMenuActive').removeClass('SubMenuActive');\n            $('.SubMenuActiveLarge').addClass('SubMenuLarge');\n            $('.SubMenuActiveLarge').addClass('SubMenu');\n            $('.SubMenuActiveLarge').addClass('Large');\n            $('.SubMenuActiveLarge').removeClass('SubMenuActiveLarge');\n            if($(this).hasClass('Large'))\n               $(this).addClass('SubMenuActiveLarge');\n            else\n               $(this).addClass('SubMenuActive');\n        $(this).removeClass('SubMenu');\n        $(this).removeClass('SubMenuLarge');\n            var path = $(this).children(\"a\").attr(\"href\");\n            loadPage2(path);\n            ev.preventDefault();\n         }else{\n            return false;\n         }\n      });\n\n      $('.SubMenuActive').on(\"click\",function(ev){\n         $(\"#first\").hide();\n         var path = $(this).children(\"a\").attr(\"href\");\n         loadPage2(path);\n         ev.preventDefault();\n      });\n      \n      $('.SubMenuActiveLarge').on(\"click\",function(ev){\n         $(\"#first\").hide();\n         var path = $(this).children(\"a\").attr(\"href\");\n         loadPage2(path);\n         ev.preventDefault();\n      });\n\n\n\n      $('#go').click(function(ev){     \n        var text = $('#searchText').val();\n        var URItext = encodeURIComponent(text);\n\n        URItext =  \"http://support.netgear.com/app/answers/list/kw/\" + URItext;\n        window.open(URItext,'_blank','fullscreen=yes,toolbar=yes,locaiton=yes,scrollbars=yes');\n      });\n\n     $('.SubMenuDisable').on(\"click\",function(){\n         return false;\n     });\n\n    $('.SubMenuLargeDisable').on(\"click\",function(){\n         return false;\n     });\n\n     $('.SubMenuDisable').on( \"contextmenu\", function(){\n         return false;\n     });\n\n     $('.SubMenuLargeDisable').on( \"contextmenu\", function(){\n         return false;\n     });\n\n     /*\n     $('.SubMenuDisable').each(function(){\n         if($(this).text().length >= 28){\n              $(this).addClass('SubMenuDisableLarge');\n              $(this).removeClass('SubMenuDisable');\n         }\n     });\n\n     $('.SubMenuLargeDisable').each(function(){\n         if($(this).text().length < 28){\n              $(this).addClass('SubMenuDisable');\n              $(this).removeClass('SubMenuLargeDisable');\n         }\n     });\n    */\n}\n\nfunction advanceMenu() { //alert(\"5\");\n    $('.subHeader').hide();\n\n    $('.Sub').click(function() {\n        $('#first').hide();\n        var checkElement = $(this).next();\n        if((checkElement.is('li')) && (checkElement.is(':visible'))) {\n            $('.subHeader:visible').slideUp('fast');\n            $(this).removeClass('SubActive');\n            $(this).addClass('Sub');\n            return false;\n        }\n        if((checkElement.is('li')) && (!checkElement.is(':visible'))) { \n            $('.subHeader:visible').slideUp('fast');\n            checkElement.slideDown('normal');\n            $('.SubActive').addClass('Sub');\n            $('.SubActive').removeClass('SubActive');\n            $(this).addClass('SubActive');\n            $(this).removeClass('Sub');\n            return false;\n        }\n    });\n}\n\nfunction adjustPageLayout()\n{\n    //alert(\"6\");\n    var entry = 0;\n\n    $('.subMenu_text').each(function(){\n        if($(this)[0].clientHeight > 15){\n            if($(this)[0].parentNode.parentNode.parentNode.getAttribute('id') == \"adv_settings_header\")\n                num_submenuLarge++;\n            var menuHeight = $($(this)[0].parentNode.parentNode.parentNode).css('height');\n            var menuHeight2 = menuHeight.replace(\"px\", \"\");\n            // $($(this)[0].parentNode.parentNode.parentNode).css('height',(parseInt(menuHeight2)+12)+\"px\"); \n            $($(this)[0].parentNode.parentNode).addClass('Large');\n            if($($(this)[0].parentNode.parentNode).hasClass('SubMenuDisable')) {\n                    $($(this)[0].parentNode.parentNode).removeClass('SubMenuDisable');\n                    $($(this)[0].parentNode.parentNode).addClass('SubMenuLargeDisable');\n                } else\n                    $($(this)[0].parentNode.parentNode).addClass('SubMenuLarge');\n        }else{\n            $($(this)[0].parentNode.parentNode).removeClass('Large');\n            $($(this)[0].parentNode.parentNode).removeClass('SubMenuLarge');\n        }\n    });\n\n    $('.subMenu_text').each(function(){\n        if($(this)[0].parentNode.parentNode.parentNode.getAttribute('id') == \"security_settings_header\")\n            entry++;\n    });\n    $('#security_settings_header').css(\"height\", entry*18+20 + \"px\");\n\n    $('.nosub_text').each(function(){\n        if($(this)[0].clientHeight > 16){\n            num_nosubLarge++;\n            if($($(this)[0].parentNode.parentNode).hasClass('noSubGray'))\n                $($(this)[0].parentNode.parentNode).addClass('noSubGrayLarge');\n            else\n                $($(this)[0].parentNode.parentNode).addClass('noSubLarge');\n            $($(this)[0].parentNode.parentNode).removeClass('noSub');\n            $($(this)[0].parentNode.parentNode).removeClass('noSubGray');\n        }else{\n            $($(this)[0].parentNode.parentNode).removeClass('noSubLarge');\n            $($(this)[0].parentNode.parentNode).removeClass('noSubGrayLarge');\n        }\n    });\n\n    adjustPageHeight = 16 * num_nosubLarge + 15 * num_submenuLarge;\n    /*\n    $('.basic-menu').css(\"height\",adjustPageHeight);\n    $('.advance-menu').css(\"height\",adjustPageHeight);\n    $('#basic-table').css(\"height\",adjustPageHeight);\n    $('#advance-table').css(\"height\",adjustPageHeight);\n    */\n\n    var readyshareField = $(\"#USB_storage\");\n    var readyshareHeight = 0;\n    for (var i = 0; i < $(\"#USB_storage\").parent().children().length; i++) {\n      readyshareHeight += readyshareField[0].clientHeight;\n      readyshareField = readyshareField.next();\n    }\n\n    $(\"#USB_storage\").parent().css(\"height\",readyshareHeight + \"px\");\n}\n\nfunction loadPage(path)\n{    //alert(\"7\");\n         load_page = 1;\n        var page_contain_width = document.body.clientWidth-220 > 735 ? document.body.clientWidth-220 : 735;\n        var page_contain_height = document.documentElement.clientHeight-160 > 470+adjustPageHeight ? document.documentElement.clientHeight-160 : 470+adjustPageHeight;\n        $('.basic-menu').css(\"height\", page_contain_height);\n\n         if(path.search(\"DashBoard.htm\") != -1){\n            var page_width = page_contain_width - 130;\n            var page_height = page_contain_height - 45;\n\n            $('#page_contain').width(parseInt(page_contain_width));\n            $('#page_contain').height(parseInt(page_contain_height));\n            $('#page_contain').css(\"margin-top\",\"5\");\n            if(get_browser() == \"IE\"){\n               $('#page_contain').html(\"<iframe id=\\\"page\\\" src='' scrolling=\\\"no\\\" style=\\\" background-color:#E5E5E5;width:\"+page_width+\"px;height:\"+page_height+\"px;margin-top:0;margin-left:30px\\\" frameborder=\\\"0\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" onFocus=\\\"this.blur()\\\"></iframe>\");\n            }else{\n               $('#page').attr(\"scrolling\",\"no\");\n               $('#page').width(parseInt(page_width));\n               $('#page').height(parseInt(page_height));\n               $('#page').css(\"margin-top\",\"0\");\n               $('#page').css(\"margin-left\",\"30\");\n            }\n            $('#page').css(\"visibility\",\"hidden\");\n            $('#page_contain').addClass('main-page-contain-loading');\n            $('#page').delay(1000).attr(\"src\",path);\n\n            $('#page').on( \"load\", function(){\n                $('#page').css(\"visibility\",\"visible\");\n                $('#page_contain').removeClass('main-page-contain-loading');\n            })\n          \n         }else if(path.search(\"netgear\") != -1){\n            window.open(path,'_blank','fullscreen=yes,toolbar=yes,location=yes,scrollbars=yes');\n         }else{\n            var page_width = page_contain_width - 50;\n            var page_height = page_contain_height - 0;\n\n            $('#page_contain').width(parseInt(page_contain_width));\n            $('#page_contain').height(parseInt(page_contain_height));\n            $('#page_contain').css(\"margin-top\",\"5\");\n            if(get_browser() == \"IE\" || (get_browser() == \"Safari\" && path == \"AutoTimeZone.htm\")){\n             $('#page_contain').html(\"<iframe id=\\\"page\\\" src='' scrolling=\\\"no\\\" style=\\\"background-color:#E5E5E5;width:\"+page_width+\"px;height:\"+page_height+\"px;margin-top:0px;margin-left:30px\\\" frameborder=\\\"0\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" onFocus=\\\"this.blur()\\\"></iframe>\");\n            }else{  \n               $('#page').attr(\"scrolling\",\"no\");\n               $('#page').css(\"overflow-x\",\"hidden\");\n               $('#page').css(\"overflow-y\",\"hidden\");\n               $('#page').width(parseInt(page_width));\n               $('#page').height(parseInt(page_height));\n               $('#page').css(\"margin-top\",\"0\");\n               $('#page').css(\"margin-left\",\"30\");\n                 \n            }\n            $('#page').css(\"visibility\",\"hidden\");\n            $('#page_contain').addClass('main-page-contain-loading');\n            $('#page').attr(\"src\",path); \n            $('#page').on( \"load\", function() \n            {\n                 $('#page').css(\"visibility\",\"visible\");\n                 $('#page_contain').removeClass('main-page-contain-loading');\n            });\n         }\n         return false;\n}\n\n\nfunction loadPage2(path) {  //alert(\"8\");\n        load_page = 2;\n        while(is_loading_page==1){}\n        is_loading_page=1;\n        var page_contain_width = document.body.clientWidth-220 > 735 ? document.body.clientWidth-220 : 735;\n        var page_contain_height = document.documentElement.clientHeight-160 > 470+adjustPageHeight ? document.documentElement.clientHeight-160 : 470+adjustPageHeight;\n        $('.advance-menu').css(\"height\", page_contain_height);\n        var gui_region = document.forms[0].curlang.value;\n        if(gui_region==\"Spanish\"){\n        $('.advance-menu li.SubMenuLarge span').css(\"width\", \"175px\");\n        $('.advance-menu li.SubMenuActiveLarge span').css(\"width\", \"175px\");\n        }\n        if(path.search(\"RouterStatus.htm\") != -1){\n            var page_width = page_contain_width - 130;\n            var page_height = page_contain_height - 45;\n\n            $('#page_contain2').width(parseInt(page_contain_width));\n            $('#page_contain2').height(parseInt(page_contain_height));\n            $('#page_contain').css(\"margin-top\",\"5\");\n           if(get_browser() == \"IE\"){\n               $('#page_contain2').html(\"<iframe id=\\\"page2\\\" src='' scrolling=\\\"no\\\" style=\\\"background-color:#E5E5E5;width:\"+page_width+\"px;height:\"+page_height+\"px;margin-top:0;margin-left:30px\\\" frameborder=\\\"0\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" onFocus=\\\"this.blur()\\\"></iframe>\");\n           }else{  \n               $('#page2').attr(\"scrolling\",\"no\");\n               $('#page2').width(parseInt(page_width));\n               $('#page2').height(parseInt(page_height));\n               $('#page2').css(\"margin-top\",\"0\");\n               $('#page2').css(\"margin-left\",\"50\");\n\n\n           }  \n           $('#page2').css(\"visibility\",\"hidden\");\n           $('#page2').attr(\"src\",path);\n       \n           $('#page2').on( \"load\", function() \n           {\n                 $('#page2').css(\"visibility\",\"visible\");\n                 $('#page_contain2').removeClass('main-page-contain-loading');\n            }); \n        }else if(path.search(\"netgear\") != -1){\n            window.open(path,'_blank','fullscreen=yes,toolbar=yes,location=yes,scrollbars=yes');\n        }else{\n            var page_width = page_contain_width - 50;\n            var page_height = page_contain_height - 0;\n               \n            $('#page_contain2').width(parseInt(page_contain_width));\n            $('#page_contain2').height(parseInt(page_contain_height));\n            \n            if(get_browser() == \"IE\"){ //alert(\"8 * \");\n               $('#page_contain2').html(\"<iframe id=\\\"page2\\\" src='' scrolling=\\\"no\\\" style=\\\"background-color:#E5E5E5;width:\"+page_width+\"px;height:\"+page_height+\"px;overflow-x:hidden;margin-top:0px;margin-left:30px\\\" frameborder=\\\"0\\\" border=\\\"0\\\" cellspacing=\\\"0\\\" onFocus=\\\"this.blur()\\\"></iframe>\");\n           }else{  //alert(\"8 ** \");\n               $('#page2').attr(\"scrolling\",\"no\");\n               $('#page2').css(\"overflow-x\",\"hidden\");\n               $('#page2').css(\"overflow-y\",\"hidden\");\n               $('#page2').width(parseInt(page_width));\n               $('#page2').height(parseInt(page_height));\n               $('#page2').css(\"margin-top\",\"0\");\n               $('#page2').css(\"margin-left\",\"30\");  \n           }    \n           $('#page2').css(\"visibility\",\"hidden\");\n           $('#page_contain2').addClass('main-page-contain-loading');\n           $('#page2').attr(\"src\",path);\n           $('#page2').on( \"load\", function() \n           {                 \n                $('#page2').css(\"visibility\",\"visible\");\n                $('#page_contain2').removeClass('main-page-contain-loading');\n           });\n\n        }\n        is_loading_page=0;\n\n        return false;\n}\n\n\nfunction setParentalControls()\n{    //alert(\"9\");\n     var ParentalControls_Result = 0;\n\n     var support = 1;\n\n     if(support == 0){\n          $('#PAR_menu').attr(\"href\",\"http://www.netgear.com/lpc\");\n          $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");\n     }else{\n         if(ParentalControls_Result == 0){\n             $('#PAR_menu').attr(\"href\",\"http://www.netgear.com/lpc\");\n             $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");\n         }else{\n             $('#PAR_menu').attr(\"href\",\"http://netgear.opendns.com/\");\n             $('#PAR_menu2').attr(\"href\",\"http://www.netgear.com/lpc\");\n         }\n     }\n}\n\n\nfunction ShowLanguageList()\n{\n    var form=document.forms[0];\n    var suportlanguage = form.srptlang.value.split(\" \");\n    var gui_region = form.curlang.value;\n        var gui_lang = form.gui_lang.value;\n        var local_srpt = form.local_srptlang.value.split(\" \");\n        var i;\n    for(i=0; i < suportlanguage.length; i++)\n    {\n\n               if((suportlanguage[i] == gui_region) ||\n                   ((suportlanguage[i] == \"TraditionalChinese\") && (gui_region==\"TChinese\")) ||\n                ((suportlanguage[i] == \"SimplifiedChinese\") && (gui_region==\"Chinese\")))\n               {\n            document.write('<option value='+gui_region+' selected >'+local_srpt[i]+'</option>');\n        }else{\n            document.write('<option value='+suportlanguage[i]+'>'+local_srpt[i]+'</option>');\n                }\n\n  if(((suportlanguage[i] == \"TraditionalChinese\") && (gui_lang==\"TChinese\")) ||\n               ((suportlanguage[i] == \"SimplifiedChinese\") && (gui_lang==\"Chinese\")) ||\n                (suportlanguage[i] == gui_lang)){\n                   gui_lang_local = local_srpt[i];\n                }\n    }\n}\n\nfunction resetLanguageList()\n{    //alert(\"11\");\n    var i;\n    var form=document.forms[0];\n    var suportlanguage = form.srptlang.value.split(\" \");\n    var gui_region = form.curlang.value;\n    var langList = document.getElementById(\"lang_menu\");\n\n    for(i=0; i < suportlanguage.length; i++)\n    {\n           if((suportlanguage[i] == gui_region) ||\n                   ((suportlanguage[i] == \"TraditionalChinese\") && (gui_region==\"TChinese\")) ||\n                ((suportlanguage[i] == \"SimplifiedChinese\") && (gui_region==\"Chinese\")))\n        {       \n            langList.selectedIndex = i;\n            return;\n        }\n    }   \n}\n\nfunction calculate_string_pixel(str)\n{    //alert(\"12\");\n    var obj = document.getElementById(\"ruler\");\n    obj.innerHTML = str;\n    return obj.offsetWidth;\n\n}\n\nfunction chgLang()\n{    //alert(\"13\");\n    var form=document.forms[0];\n    var gui_region = form.curlang.value;\n    var choice = form.choicelang.value;\n    var auto_block = form.auto_block.value;      \n    var suportlanguage = form.srptlang.value.split(\" \");\n    var local_srpt = form.local_srptlang.value.split(\" \");\n\n    for(i=0; i < suportlanguage.length; i++)\n    {\n               if(suportlanguage[i] == choice)\n                   choice=local_srpt[i];\n    }\n\n    if (choice != gui_region){      \n        setTimeout(function(){\n            ret = confirm(\"Do you want to switch from \"+ gui_lang_local + \"\"+\"(the current language) to \"+\"\"+ choice + \"?\");\n            if(ret==1){\n                if($(\"#BasicTab\").hasClass('current')){\n                    loadPage(\"LANG_check_redirect.htm\");\n                }else{\n                    loadPage2(\"LANG_check_redirect.htm\");\n                }\n            }\n            else\n                resetLanguageList();\n        },10);\n    }\n}\n\nfunction chgBrsLang()\n{     //alert(\"14\");\n    var form=document.forms[0];\n        var gui_region = form.curlang.value;\n        var brslang = form.first_brs_lang.value;  \n        var choice = form.choicelang.value;     \n        var auto_block = form.auto_block.value; \n        var gui_lang = form.gui_lang.value;\n\n        if(choice === \"Auto\"){\n            if(auto_block == \"0\"){\n\n                if(gui_lang != brslang)\n                  {\n                    if(brslang==\"TChinese\")\n                        ret = confirm(\"Do you want to switch from \"+ gui_lang_local + \"\"+\"(the current language) to \"+\" Traditional Chinese?\");\n                    else\n                        ret = confirm(\"Do you want to switch from \"+ gui_lang_local + \"\"+\"(the current language) to \"+\"\"+ brslang + \"?\");\n                    if(ret==1){\n                        if($(\"#BasicTab\").hasClass('current')){\n                           loadPage(\"LANG_check_redirect2.htm\");\n                        }else{\n                           loadPage2(\"LANG_check_redirect2.htm\");\n                        }\n                    }else{\n                        if($(\"#BasicTab\").hasClass('current')){\n                            loadPage(\"auto_block.htm\");\n                        }else{\n                            loadPage2(\"auto_block.htm\");\n                        }\n                   }\n                   return true;\n               }\n            }\n        }\n        \n        return false;\n}\n\n\nfunction fw_upgrade_hint()\n{\n    if($(\"#BasicTab\").hasClass('current')){\n        loadPage(\"UPG_upgrade_ver_check.htm\");\n    }else{\n        loadPage2(\"UPG_upgrade_ver_check.htm\");\n    }    \n}\n\nfunction gui_logout()\n{    //alert(\"16\");\n    if($(\"#BasicTab\").hasClass('current')){\n        top.location.href=\"Logout.htm\";\n    }\n    else\n    {\n        top.location.href=\"Logout.htm\";\n    }\n}\n\n\nfunction change_size()\n{    //alert(\"17\");\n    setLanglistPosition();\n    //setFooterClass();\n    subpage_resize();\n}\n\nfunction enable_circle()\n{\n    if(document.forms[0].never_remind_me.checked==true)\n        $.post(\"circle.php\",{never_remind_me:\"1\"});\n\n    hide_circle_window();\n    $('.menuActive').removeClass('menuActive');\n    $('#basic-par').addClass('menuActive');\n    loadPage(\"Parental_controls.htm\");\n}\n\nfunction skip_circle()\n{\n    if(document.forms[0].never_remind_me.checked==true)\n        $.post(\"circle.php\",{never_remind_me:\"1\"});\n\n    hide_circle_window();\n}\n\nfunction show_circle_window()\n{\n/*\n    var no_remind_flag = document.getElementsByName(\"no_remind\");\n    var apmode_flag = document.getElementsByName(\"enable_apmode\");\n    var stamode_flag = document.getElementsByName(\"enable_stamode\");\n\n    if((no_remind_flag[0].value==\"1\") || (apmode_flag[0].value==\"1\") || (stamode_flag[0].value==\"1\"))\n    {\n        document.getElementById(\"circle-info-modal\").style.display=\"none\";\n    }\n    else\n    {\n        document.getElementById(\"circle-info-modal\").style.display=\"block\";\n        if($(window).height()>500)\n            document.getElementById(\"circle-info-modal\").style.top=($(window).height()-500)/2+\"px\";\n        else\n            document.getElementById(\"circle-info-modal\").style.top=\"0px\";\n\n        $(\"#container\").addClass(\"gray\");\n        $(\"#main_screen\").addClass(\"gray\");\n        document.getElementById(\"container\").style.display=\"none\";\n        document.getElementById(\"main_screen\").style.display=\"none\";\n    }\n*/\n/*\n    document.getElementById(\"circle-info-modal\").style.display=\"none\";\n*/\n}\n\nfunction hide_circle_window()\n{\n    document.getElementById(\"circle-info-modal\").style.display=\"none\";\n    document.getElementById(\"container\").style.display=\"block\";\n    document.getElementById(\"main_screen\").style.display=\"block\";\n}\n\n\n/*  0: Firemware Version\n    1: Guest Network Supported\n    2: MultiLang Supported\n    3: Rg/Bridge Mode\n    4: Voice Supported\n    5: MSO Supported\n    6: USB Hidden\n    7: WPS Wizard grayout\n    8: ETHER WAN Supported\n    9: ETHER WAN Enabled\n    10: Traffic Meter Supported\n    11: WiFi Schedule Supported\n    12: Access Control Supported\n    13: New Firmware\n    14: TimeZone\n    15: TimeZoneConfigured\n    16: IsLanAccess\n*/\nfunction InitTagValue()\n{\n    var tagValueList = 'V10.01.03|0|0|0|1|retail|0|0|0|0|0|0|0|1|0|';\n//    var tagValueList = \"v0.1\";\n    return tagValueList.split(\"|\");\n}\n\nfunction InitUpdateView(tagValues)\n{\n    var cf = document.forms[0];\n    /* Firmware Version */\n    document.getElementById(\"firm_version\").innerHTML = \"Firmware Version \" + tagValues[0];\n\n    /* Model Name */\n    document.getElementById(\"ModuleName\").innerHTML = '<b>My Modem:</b>' + 'Nighthawk CM2050V' + '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';\n\n    /* multilang support */\n    if (tagValues[2] == \"0\")\n    {\n        $(\"#lang_menu_li\").hide();\n    }\n\n    /* Rg/Bridge mode */\n    if (tagValues[3] == \"1\")\n    {\n        // Basic menu\n        $(\"#basic-wls\").show();\n        $(\"#basic-atd\").show();\n        $(\"#basic-par\").show();\n        $(\"#basic-rea\").show();\n        $(\"#basic-gst\").show();\n        if(tagValues[8] == \"1\")\n        {\n            ETHERNET_SUPPORT = true;\n\n            if(tagValues[9] == \"1\")\n            {\n                ethernetConnect = true;\n                $(\"#basic-int\").hide();\n                $(\"#eventlog\").hide();\n                $(\"#routerMode\").hide();\n            } \n        }\n    }\n    else\n    {\n        // Basic menu\n        $(\"#basic-wls\").hide();\n        $(\"#basic-atd\").hide();\n        $(\"#basic-par\").hide();\n        $(\"#basic-rea\").hide();\n        $(\"#basic-gst\").hide();\n\n        $(\"#wps-wizard\").hide();\n        $(\"#setup_header\").hide();\n        $(\"#usb_header\").hide();\n        $(\"#security_header\").hide();\n        $(\"#AdminId li\").hide();\n        // always hide nat mode webpage\n        $(\"#adv_header\").hide();\n        $(\"#attach_dev\").hide();\n        $(\"#NTP_setting\").hide();\n        $(\"#firmware_upgrade\").hide();\n        $(\"#config_backup\").hide();\n        $(\"#logs\").hide();\n        $(\"#orbi-alert\").hide();\n        $(\"#left_banner\").hide();\n    }\n\n    /* Guest Network Supported */\n    if (tagValues[1] == \"1\")\n    {\n        $(\"#basic-gst\").hide();\n        $(\"#guest_set\").hide();\n    }\n\n    // Nick 20120507, new mta icon\n    // Voice Supported\n    if (tagValues[4] == \"1\")\n    {\n        $(\"#basic-par\").hide();\n        $(\"#basic-voice\").show();\n    }\n    else\n    {\n        if (tagValues[3] == \"1\")  //parental control is not support in bridge.\n            $(\"#basic-par\").show();\n        $(\"#basic-voice\").hide();\n    }\n    \n    /*if(tagValues[5] == \"retail\")\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/logo_retail.png\");\n        $(\".topframe\").css(\"background-color\",\"#ffffff\");\n        $(\".topframe\").css(\"color\",\"#000000\");\n        $(\".tabs\").css(\"background-color\",\"#ffffff\");\n        // 20150203 Emerson add to replace the NetworkMap by AttachedDevices\n        $(\"#basic-atd\").html('<a href=\"AttachedDevices_new.htm\"><span>Attached Devices<\\/span><\\/a>');\n        $(\"#advNetworkMap\").attr(\"href\", \"AttachedDevices_new.htm\");\n        $(\"#advNetworkMap\").html('<span class=\"subMenu_text\">Attached Devices<\\/span>');\n        // 20150203 Emerson end\n\n        $(\"#toprightLogo\").hide();\n        $(\"#ipv6\").show();\n\n        // Chuck 20160815 Add support for Dynamic QoS page\n        $(\"#QosSetup\").show();\n        $(\"#QosSetup_hl\").attr(\"href\", \"\");\n\n        // Chuck 20160909 Add support for LED Settings page\n        $(\"#led_settings\").show();\n\n        // Chuck 20161115 Add support for Ethernet Port Aggregation page\n        $(\"#link_aggregation\").show();\n    }\n    else\n    {\n        $(\"#topleftLogo\").show();\n        $(\"#topleftLogo\").attr(\"src\", \"img/Netgeargenie.png\");\n\n        $(\"#toprightLogo\").hide();\n    }*/\n\n    // USB Hidden\n    if (tagValues[6] == \"1\")\n    {\n        $(\"#basic-rea\").hide();\n        $(\"#usb_header\").hide();\n        $(\"#advUSB\").hide();\n    }  \n\n    // WPS Wizard\n    if(tagValues[7] == \"0\")\n    {\n        WPS_wizard_grayout();\n    }\n\n    // Chuck 20140501 Traffic Meter support \n    // Chuck 20141001 Do not show Traffic Meter page in bridge mode\n    if(tagValues[10] == \"0\" || tagValues[3] == \"0\")\n    {\n        $(\"#traffic_meter\").hide();\n    }\n    else\n    {\n        $(\"#traffic_meter\").show();\n    }\n\n    // Chuck 20140610 for \"Turn off wireless signal by schedule \"\n    if(tagValues[11] == \"1\")\n    {\n        $(\"#adv_wireless_set\").children().attr('href','');\n    }\n    \n    // Chuck 20140610 add for \"Access Control\"\n    if(tagValues[12] == \"0\")\n    {\n        $(\"#access_control\").hide();\n    }\n    else\n    {\n        $(\"#access_control\").show();\n    }\n\n    //retail MTA pages support\n    if(tagValues[13] == \"0\")\n    {\n        $(\"#basic-callListRetail\").hide();\n        $(\"#MtaEventLogRetail\").hide();\n        $(\"#MtaCallListRetail\").hide();\n    }\n    else\n    {\n        $(\"#basic-callListRetail\").show();\n        $(\"#MtaEventLogRetail\").show();\n        $(\"#MtaCallListRetail\").show();\n    }\n\n    //retail LAG pages support\n    if(tagValues[14] == \"0\")\n    {\n        $(\"#PortTrunking_setting\").hide();\n    }\n    else\n    {\n        $(\"#PortTrunking_setting\").show();\n    }\n}\n\nfunction BodyInit()\n{\n    //Not support multi language\n    //ShowLanguageList();\n    InitUpdateView(InitTagValue());\n    hiddenWifi('1');\n    initBridgeView('1');\n}\nfunction initBridgeView(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#routerMode\").hide();\n        $(\"#router_status_text\").html(\"Modem Status\");\n        $(\"#SetPassword\").show();\n    }\n}\nfunction hiddenWifi(statusTag)\n{\n    if(statusTag == \"1\")\n    {\n        $(\"#basic-wls\").hide();\n        $(\"#basic-gst\").hide();\n        $(\"#wps-wizard\").hide();\n        $(\"#wireless_set\").hide();\n        $(\"#guest_set\").hide();\n        $(\"#wireless_hotspot\").hide();\n        $(\"#WirelessRadarChList\").hide();\n        $(\"#WirelessRadarApList\").hide();\n        $(\"#adv_wireless_set\").hide();\n    }\n}\n\n</script>\n\n<script>\nfunction myFunction() {\n    var x = document.getElementById(\"Demo\");\n    if (x.className.indexOf(\"w3-show\") == -1) {\n        x.className += \" w3-show\";\n    } else { \n        x.className = x.className.replace(\" w3-show\", \"\");\n    }\n}\n</script>\n<link href=\"css/custom.css\" rel=\"stylesheet\" type=\"text/css\">\n<style type=\"text/css\">\n.download-orbi-banner{\n    font-size: 14.4px;\n    text-decoration: none;\n    color: #fff;\n    border-radius: 6px;\n    background-color: #4a444d;\n    width: 480px;\n    padding: 18px 15px 18px 20px;\n    display: flex;\n    justify-content: space-between;\n    font-family: Arial;\n    margin-bottom: 10px;\n    margin-left: -80px;\n}\n.download-btn-orbi {\n    margin-right: 10px;\n    line-height: 24px;\n    padding-left: 8px;\n    padding-right: 8px;\n    text-decoration: none;\n    border-radius: 3px;\n    display: inline-block;\n    background-color: #ffffff;\n    font-size: 12px;\n    color: #4a444d;\n    transition: all .3s ease-in-out;\n    -moz-transition: all .3s ease-in-out;\n    -webkit-transition: all .3s ease-in-out;\n}\n.download-btn-orbi:hover {\n    opacity: .8;\n    transition: all .3s ease-in-out;\n    -moz-transition: all .3s ease-in-out;\n    -webkit-transition: all .3s ease-in-out;\n   }\n .none_button{\n    display:none;\n }  \n .block_button{\n    display:block;\n }\n</style>\n</head>\n<body style=\"padding:0;margin:0;overflow:none\" onload=\"change_size();show_circle_window();chgTimeZone();\" onResize=\"change_size();\">\n  <form name=\"frmLanguage\">\n  <table width=\"100%\" CELLPADDING=0 CELLSPACING=0 style=\"padding:0;margin:0;\" id=\"all\">\n    <tr width=\"100%\">\n      <td style=\"width:100%;height:100%\">\n      <div id=\"main_screen\">\n        <table style=\"height:100px;width:100%;margin:0;padding:0\" CELLPADDING=0 CELLSPACING=0 class=\"newtopframe\">\n          <tr>\n            <td style=\"padding-left:20px\">\n              <img style=\"position:relative;width: 216px\" src=\"img/NightHawk.png\" >\n              <br><span id=\"ModuleName\"><b>My Modem:</b> Nighthawk CM2050V&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<!--<b><font color=\"#EEDAOO\">Operation Mode:Access Point</font></b>--></span>\n            </td>\n            <td style=\"text-align:right;padding-right:25px\">\n              <ul class=\"tnb-right\">\n                  <li>\n                      <div class=\"w3-dropdown-click\">\n                          <a onclick=\"myFunction()\"><img src=\"img/tnb-ico1.png\" alt=\"\"></a>\n                          <div id=\"Demo\" class=\"w3-dropdown-content w3-bar-block tnb-submenu-bg\">\n                            <div id=\"search\">\n                                <input type=\"text\" id=\"search_text\" name=\"search\" value=\"Enter Search Item\" onkeypress=\"detectEnter('num',event);\" onFocus=\"this.select();\" >\n                                <input id=\"search_button\" class=\"search_button\" type=\"button\" name=\"dosearch\" value=\"GO\" onClick=\"do_search();\">\n                            </div>\n                          </div>\n                      </div>\n                  </li>\n\n                  <li><a href=\"javascript:;\"><img src=\"img/tnb-ico2.png\" alt=\"\"></a>\n                      <div class=\"tnb-submenu\">\n                        <a target=\"_blank\" href=\"http://downloadcenter.netgear.com/\">Documentation</a> \n                        <a target=\"_blank\" href=\"http://support.netgear.com/\">Online Support</a> \n                        <a target=\"_blank\" href=\"http://support.netgear.com/app/answers/detail/a_id/12923\">Gateway FAQ</a>\n                        <a target=\"_blank\" href=\"OpenSourceLicense.html\">Open Source</a>\n                      </div>\n                  </li>\n                  <li><a href=\"javascript:;\"><img src=\"img/tnb-ico3.png\" alt=\"\"></a>\n                      <div class=\"tnb-submenu\">\n                        <a target=\"_top\" href=\"Logout.htm\">Logout</a> \n                      </div>\n                  </li>\n              </ul>\n              <br><br style='line-height:8px'>\n              <div class=\"firm_version\" id=\"firm_version\">\n                  Firmware Version\n              </div>\n            </td>\n            <!--Add Banner-->\n            <td style=\"text-align:center;padding-top: 25px;\">\n                <div class=\"download-orbi-banner\" id=\"orbi-alert\" style=\"display:none\">Speed up your experience by using the Netgear App.\n                <div id=\"ios_button\" class=\"none_button\"><a href=\"http://nighthawk-app.com\" class=\"download-btn-orbi\" target=\"_blank\">GET</a> <a onclick=\"adsFunction()\" class=\"cross\"><img src=\"img/cross.png\" class=\"cross\" alt=\"\"></a></div>\n                <div id=\"android_button\" class=\"none_button\"><a href=\"http://nighthawk-app.com\" class=\"download-btn-orbi\" target=\"_blank\">Install</a> <a onclick=\"adsFunction()\" class=\"cross\"><img src=\"img/cross.png\" class=\"cross\" alt=\"\"></a></div>\n                <div id=\"other_button\" class=\"block_button\"><a href=\"http://nighthawk-app.com\" class=\"download-btn-orbi\" target=\"_blank\">Learn more</a> <a onclick=\"adsFunction()\" class=\"cross\"><img src=\"img/cross.png\" class=\"cross\" alt=\"\"></a></div>\n                <script>\n                    var device = get_browser();\n                    if(device==\"iOS\")\n                    {\n                        $(\"#other_button\").removeClass(\"block_button\");\n                        $(\"#other_button\").addClass(\"none_button\");\n                        $(\"#ios_button\").removeClass(\"none_button\");\n                        $(\"#ios_button\").addClass(\"block_button\");\n                    }\n\n                    if(device==\"Android\")\n                    {\n                        $(\"#other_button\").removeClass(\"block_button\");\n                        $(\"#other_button\").addClass(\"none_button\");\n                        $(\"#android_button\").removeClass(\"none_button\");\n                        $(\"#android_button\").addClass(\"block_button\");\n                    }\n\n                    function adsFunction()\n                    {\n                        document.getElementById(\"orbi-alert\").style.display=\"none\";\n                        $.post(\n                            \"/goform/NHbanner?id=412981797\",\n                            {action: \"cancel\"}, \n                            function(result)\n                            {\n                                if(result == \"OK\")\n                                {\n                                }\n                            });\n                    }\n                </script>\n            </td>\n          </tr>\n        </table>\n         <div class=\"header-bar\"></div>\n          <table CELLPADDING=0 CELLSPACING=0 style=\"height:520px;width:100%;margin:0;padding:0\">\n              <!--\n              <input type=\"hidden\" name=\"curlang\" value=\"Auto\">\n              -->\n                <input type=\"hidden\" name=\"curlang\" value=\"English\">\n              <!--\n                <input type=\"hidden\" name=\"curlang\" value=\"English\">\n              -->\n                <input type=\"hidden\" name=\"local_srptlang\" value=\"Auto English German Chinese Korean Russian Spanish Polish French Italian Swedish Danish Nederlands Ellinika Norwegian Czech Slovenia Portuguese Hungarian Romanian Finnish Slovak Turkish French(Canadian)\">\n                <input type=\"hidden\" name=\"srptlang\" value=\"Auto English German SimplifiedChinese TraditionalChinese Korean Russian Spanish Polish French Italian Swedish Danish Dutch Greek Norwegian Czech Slovenian Portuguese Hungarian Romanian Finnish Slovak Turkish Japanese\">\n                <input type=\"hidden\" name=\"select_region\" value=\"\">\n              <input type=\"hidden\" name=\"first_brs_lang\" value=\"English\">\n              <input type=\"hidden\" name=\"auto_block\" value=\"1\">\n              <input type=\"hidden\" name= \"gui_lang\" value=\"English\">\n              <input type=\"hidden\" name= \"gui_lang_local\" value=\"\">\n            <tr>\n              <td>\n              <!-- tabs -->\n                <ul class=\"tabs custom_tab\" width=\"100%\" >\n                  <li><a id=\"BasicTab\"class=\"current\" onFocus=\"this.blur()\" href=\"#\"><span>BASIC</span></a></li>\n                  <li><a id=\"AdvanceTab\" onFocus=\"this.blur()\" href=\"#\"><span>ADVANCED</span></a></li>\n                  <li><div id=\"firmware-update\" class=\"button-sty2\" onClick=\"fw_upgrade_hint();\" style=\"padding-left:17px; height:28px; position:relative; left:10px; display:none\">    A router firmware upgrade is available.</div></li>\n                  <li></li>\n                  <li id=\"lang_menu_li\" style=\"disply:none\" >\n       <select name=\"choicelang\" size=\"1\" id=\"lang_menu\"  class=\"selectbox\" onchange=\"chgLang();this.blur();\">\n                    </select>\n                  </li>\n                </ul>\n                <div class=\"tab_bdr\"></div>\n<!-- tab \"panes\" -->\n                <div class=\"pane\" id=\"basic-pane\">\n                  <table width=\"100%\" CELLPADDING=\"0\" CELLSPACING=\"0\" id=\"basic-table\" style=\"padding:0;margin:0;height:480px\">\n                    <tr>\n                      <td style=\"background-color:#FFFFFF;width:200px;font-size:12px;font-family:Arial;\">\n                      <div class=\"basic-menu basic-menu-custom\">\n                          <div class=\"basic-menu-div\" id=\"basic-home\"><a href=\"DashBoard.htm\"><span>Home</span></a></div>\n                          <div class=\"basic-menu-div\" id=\"basic-int\"><a href=\"DocsisOffline.htm\" id=\"INT_menu\"><span>Cable Connection</span></a></div>\n                          <div class=\"basic-menu-div\" id=\"basic-wls\"><a href=\"WirelessSettings.htm\" id=\"WLS_menu\"><span>Wireless</span></a></div>\n                          <div class=\"basic-menu-div\" id=\"basic-atd\"><a href=\"\"><span>Attached Devices</span></a></div>\n\n                          <!--\n                          <div class=\"basic-menu-div\" id=\"basic-qos\"><a href=\"QOS_down_streaming_iqos_basic.htm\"><span>QoS</span></a></div>\n                          -->\n                          <!--\n                          <div class=\"basic-menu-div\" id=\"basic-par\"><a href=\"Parental_controls.htm\"><span>Parental Controls</span></a></div>\n                          -->\n                          <div class=\"basic-menu-div\" id=\"basic-voice\"><a href=\"MtaStatusRetail.htm\"><span>Voice</span></a></div>\n                          <!--<div class=\"basic-menu-div\" id=\"basic-par\"><a href=\"https://www.netgear.com/lpc\" id=\"PAR_menu\"><span>Parental Controls</span></a></div>-->\n                          <div class=\"basic-menu-div\" id=\"basic-rea\"><a href=\"\"><span>ReadySHARE</span></a></div>\n                          <div class=\"basic-menu-div\" id=\"basic-gst\"><a href=\"\"><span>Guest Network</span></a></div>\n                          <div class=\"basic-menu-div\" id=\"basic-callListRetail\" style=\"display:none\"><a href=\"MtaCallListRetail.htm\"><span>eMTA Call List</span></a></div>\n                          <!--\n                          <div class=\"basic-menu-div\" id=\"basic-dlr\"><a href=\"\" id=\"DOW_menu\" ><span>NETGEAR Downloader (BETA)</span></a></div>\n                          -->\n                                <!--\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div>&nbsp;</div>\n                                <div class=\"basic-menu-eco-div\" id=\"basic-eco\"><a href=\"https://genie.netgear.com/\" id=\"ECO_menu\"><span>genie+ Marketplace</span></a></div>\n                                -->\n                        </div>\n                      </td>\n                      <td style=\"background-color:#FFFFFF;width:760px;height:480px;font-family:Arial;\">\n                        <div id=\"page_contain\" >\n                          <iframe id=\"page\" style=\"width:600px;height:405px;margin-left:30px\" name=\"page\"  frameborder=\"0\" border=\"0\" cellspacing=\"0\" scrolling=\"no\" onFocus=\"this.blur()\" src=\"\"></iframe>\n                        </div>\n                      </td>\n                    </tr>\n                  </table>\n                </div>\n                <div class=\"pane\" id=\"adv-pane\">\n                  <table CELLPADDING=0 CELLSPACING=0 id=\"advance-table\" style=\"padding:0;margin:0;height:480px;border:0;width:960px;\">\n                    <tr style=\"height:480px;\">\n                      <td style=\"background-color:#FFFFFF;width:200px;\">\n                       <div class=\"advance_menu_section\">\n                        <ul class=\"advance-menu\">\n                          <li class=\"noSub\" id=\"adv-home\"><a href=\"RouterStatus.htm\"><span class=\"nosub_text\">ADVANCED Home</span></a></li>\n                        <!--\n                          <li class=\"noSub\" id=\"wizard\"><a href=\"WIZ_select.htm\"><span class=\"nosub_text\">Setup Wizard</span></a></li>\n                        -->\n                          <!--<li class=\"noSub\" id=\"wizard\"><a href=\"WIZ_sel.htm\"><span class=\"nosub_text\">Setup Wizard</span></a></li>-->\n                          <li class=\" noSub\" id=\"wps-wizard\"><a href=\"AddWPSClient_TOP.htm\"><span class=\"nosub_text\">WPS Wizard</span></a></li>\n                          <li class=\"Sub\" id=\"setup_header\"><a href=\"#\"><span>Setup</span></a></li>\n                          <li  class=\"subHeader\" id=\"set_hdr\">\n                          <ul style=\"width:100%;height:100%\">\n\n                          <li class=\"SubMenu SubMenuWDS\" id=\"int_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Internet Setup</span></a></li>\n                          <li class=\"SubMenu SubMenu\" id=\"wireless_set\"><a href=\"WirelessSettings.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Wireless Setup</span></a></li>\n                          <li class=\"SubMenu SubMenuWDS\" id=\"wan_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">WAN Setup</span></a></li>\n                          <li class=\"SubMenu SubMenuWDS\" id=\"LAN_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">LAN Setup</span></a></li>\n              <li class=\"SubMenu SubMenuWDS\" id=\"Qos_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">QoS Setup</span></a></li>\n              <li class=\"SubMenu SubMenu\" id=\"guest_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Guest Network</span></a></li>\n                          </ul>\n                          </li>\n                          <li class=\"Sub\" id=\"usb_header\"><a href=\"#\"><span>USB Functions</span></a></li>\n                          <li  class=\"subHeader\">\n                          <ul style=\"width:100%;height:100%\">\n\n                            <!--\n                            <ul style=\"width:100%;height:100%\">\n                              -->\n                              <li class=\"SubMenu\" id=\"USB_storage\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">ReadySHARE Storage</span></a></li>\n                                  \n                                <li class=\"SubMenu\" id=\"USB_printer\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">ReadySHARE Printer</span></a></li>\n                                  \n                              <li class=\"SubMenu\" id=\"USB_vault\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">ReadySHARE Vault</span></a></li>\n                            </ul>\n                          </li>\n<!--\n                          <li class=\"noSubGray\" id=\"downloader_header\"><a href=\"#\"><span>NETGEAR Downloader (BETA)</span></a></li>\n                            <li  class=\"subHeader\">\n                            <ul style=\"width:100%;height:60px\">\n                              <li class=\"SubMenu\" id=\"down_set\"><a href=\"Download_settings.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Download Settings</span></a></li>\n                              <li class=\"SubMenu\" id=\"down_manage\"><a href=\"Download_manager.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Download Manager</span></a></li>\n\n                            </ul>\n                          </li>\n-->\n                          <li class=\"Sub\"   id=\"security_header\"><a href=\"#\"><span>Security</span></a></li>\n                          <li  class=\"subHeader\">\n                              <ul id=\"security_settings_header\" style=\"width:100%;height:100%\">\n\n                                  <!--<li class=\"SubMenu SubMenuWDS\"><a href=\"http://www.netgear.com/lpc\" id=\"PAR_menu2\" target=\"_blank\"><span style=\"border:0;\" class=\"subMenu_text\">Parental Controls</span></a></li>-->\n                                  \n                                  <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"access_control\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Access Control</span></a></li>\n\n                                  <li class=\"SubMenu SubMenuWDS\" id=\"blk_site\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Block Sites</span></a></li>\n                                    <li class=\"SubMenu SubMenuWDS\"id=\"blk_serv\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Block Services</span></a></li>\n<!--\n                                  <li class=\"SubMenu SubMenuWDS\"id=\"ParentalControls\"><a href=\"Parental_controls.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Parental Controls</span></a></li>\n-->\n                                  <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"sche\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Schedule</span></a></li>\n                                  <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"email\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">E-mail</span></a></li>\n                                <!--\n                                <li class=\"SubMenu SubMenuWDS\"id=\"arp\"><a href=\"ARP_binding.htm\" onClick=\"return false\"><span class=\"subMenu_text\">ARP Protection / IP MAC Binding</span></a></li>\n                                -->\n                              </ul>\n                          </li>\n                          <li class=\"Sub\" id=\"AdminId\"><a href=\"#\"><span>Administration</span></a></li>\n                          <li  class=\"subHeader\">\n                              <ul style=\"width:100%;height:100%\">\n                                <li class=\"SubMenu\" id=\"router_status\"><a href=\"RouterStatus.htm\" onClick=\"return false\"><span style=\"border:0;\" class=\"subMenu_text\" id=\"router_status_text\">Gateway Status</span></a></li>\n                                    <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"routerMode\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Router Mode</span></a></li>\n                                    <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"MtaStatus\" style=\"display: none;\"><a href=\"MtaStatusRetail.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Voice Status</span></a></li>\n                                    <li class=\"SubMenu SubMenuWDS SubMenuAP\" id=\"logs\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Logs</span></a></li>\n                                    <li class=\"SubMenu\" id=\"attach_dev\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Attached Devices</span></a></li>\n                                    <li class=\"SubMenu\" id=\"config_backup\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Backup Settings</span></a></li>\n                                    <li class=\"SubMenu\" id=\"password_recovery\"><a href=\"SetPassword.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Set Password</span></a></li>\n                                    <li class=\"SubMenu\" id=\"NTP_setting\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">NTP Settings</span></a></li>\n                                    <li class=\"SubMenu\" id=\"firmware_upgrade\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Router Update</span></a></li>\n                                    <li class=\"SubMenu\" id=\"event_log\"><a href=\"eventLog.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Event Log</span></a></li>\n                                    <li class=\"SubMenu\" id=\"MtaEventLogRetail\"><a href=\"MtaEventLogRetail.htm\" onClick=\"return false\"><span class=\"subMenu_text\">eMTA Event Log</span></a></li>\n                                    <li class=\"SubMenu\" id=\"MtaCallListRetail\"><a href=\"MtaCallListRetail.htm\" onClick=\"return false\"><span class=\"subMenu_text\">eMTA Call List</span></a></li>\n                                    <li class=\"SubMenu\" id=\"PortTrunking_setting\" style=\"display: none;\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Ethernet Port Aggregation</span></a></li>\n                                    <li class=\"SubMenu\" id=\"WebServiceManagement\"><a href=\"WebServiceManagement.htm\" onClick=\"return false\"><span class=\"subMenu_text\">Web Service Management</span></a></li>\n                                </ul>\n                            </li>\n                          <li class=\"Sub\" id=\"adv_header\"><a href=\"#\"><span>Advanced Setup</span></a></li>\n                          <li  class=\"subHeader\">\n                            <ul id=\"adv_settings_header\" style=\"width:100%;height:100%;display:block;\">\n                              <li class=\"SubMenu\" id=\"adv_wireless_set\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Wireless Settings</span></a></li>\n                              <li id=\"pf_head\"  class=\"SubMenuLarge SubMenu Large  SubMenuWDS\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Port Forwarding / Port Triggering</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"ddns\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Dynamic DNS</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"openvpn\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">VPN Service</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"remote\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Remote Management</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"upnp\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">UPnP</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"ipv6_setting\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">IPv6</span></a></li>\n                              <li class=\"SubMenu SubMenuWDS\" id=\"traffic_meter\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Traffic Meter</span></a></li>\n                              <!--\n                              <li class=\"SubMenu\"><a href=\"USB_settings.htm\" onClick=\"return false\"><span class=\"subMenu_text\">USB Settings</span></a></li>\n                              -->\n\n                              <li class=\"SubMenu\" id=\"LED_setting\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">LED Control Settings</span></a></li>\n\n                              <li class=\"SubMenu\" id=\"EthernetPortAggregation\"><a href=\"\" onClick=\"return false\"><span class=\"subMenu_text\">Ethernet Port Aggregation</span></a></li>\n\n                              <!--\n                              <li class=\"SubMenu\" id=\"device_mode\"><a href=\"Device_mode.htm\" onClick=\"return false\"><span class=\"subMenu_text\"></span></a></li>\n                              -->\n                            </ul>\n                          </li>\n                        </ul>\n                        </div>\n                      </td>\n                      <td style=\"background-color:#ffffff\">\n                        <div id=\"page_contain2\">\n                          <iframe id=\"page2\" name=\"page2\" style=\"width:600px;height:405px;margin-left:30px\"  frameborder=\"0\" border=\"0\" cellspacing=\"0\" scrolling=\"no\" onFocus=\"this.blur()\"></iframe>\n                        </div>\n                      </td>\n                    </tr>\n                  </table>\n                </div>\n              </td>\n            </tr>\n<!-- tab \"panes\" -->\n          </table>\n        </div> <!--  id=main_screen-->\n<!-- Trigger/Open The Modal -->\n<!-- The Modal -->\n        <!--<div id=\"circle-info-modal\" class=\"circle-modal\" style=\"border-width:1px;border-color:black\">-->\n          <!-- Modal content -->\n          <!--<div class=\"circle-info-content\">\n            <table style=\"align:center\">\n              <tr>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                <td style=\"text-align:center\">\n                  <p><span style=\"font-size:24px\"><b>Enable Circle with Disney</b></span></p>\n                </td>\n                <td style=\"text-align:center\">\n                  <span onclick=\"hide_circle_window();\" style=\"float:left;font-weight:bold;font-size:24px\">&times;</span>\n                </td>\n              </tr>\n              <tr>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                <td style=\"text-align:center\">\n                  <img src=\"img/circle_with_disney_blue.jpg\" border='0'\">\n                </td>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n              </tr>\n              <tr>\n              </tr>\n              <tr>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                  <td  style=\"text-align:center\">\n                    <span style=\"font-size:14px\"><b>With Circle, parents can filter content, limit screen time and set a bedtime for every device in the home.</b></span>\n                  </td>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n              </tr>\n              <tr style=\"height:50px\">\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                <td style=\"text-align:center\">\n                  <a onClick=\"window.open('http://www.netgear.com/circle', 'Help', 'scrollbars=yes')\" href=\"#\"><span style=\"font-size:12px;font-color:RGB(5,187,209)\"><b>Learn More</b></span></a>\n                </td>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n              </tr>\n              <tr>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                <td  align=center>\n                    <div  style=\"line-height:45px;width:320px;height:46px;cursor: pointer;cursor:hand;background: url(img/circle_enable_button_2.jpg) no-repeat left center\" onClick=\"enable_circle();\" >\n                        <span valign=middle style=\"font-size:16px;color:RGB(240,240,240)\">ENABLE<span>\n                   </div>\n                </td>\n                <td>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n              </tr>\n              <tr style=\"height:10px\">\n                <td colspan=\"3\">&nbsp;</td>\n              </tr>\n              <tr style=\"height:50px\">\n                <td >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n                <td class=\"centerTd\" style=\"text-align:center;font-size:12px\"><style=\"font-weight:normal;font-size:18px;\"><input type=\"checkbox\" name=\"never_remind_me\" value=\"1\"><b>Never remind me again.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</b><span onClick=\"skip_circle();\"><b><font color=RGB(149,198,462)>Skip</b></font></sapn></td>\n                <td style=\"text-align:center\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>\n              </tr>\n            </table>\n          </div>\n        </div>-->\n        </div>\n      </div>\n      </td>\n    </tr>\n  </table>\n    <input type=\"hidden\" name=\"time_zone\" value=\"0\">\n    <input type=\"hidden\" name=\"time_zone_configured\" value=\"0\">\n    <input type=\"hidden\" name=\"is_lan_access\" value=\"0\">\n\n</form>\n\n<div id=\"preloaded-images\">\n   <img src=\"img/basic-white-button.gif\" width=\"1\" height=\"1\" alt=\"\">  \n   <img src=\"img/firmware-hint-background.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/barrow.jpg\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/basic-white-button.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/firmware-hint-background.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/barrow.jpg\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/subMenuActive.png\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/subMenuActiveLarge.png\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/barrow_down.jpg\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/basic-purple-button.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/roundedcornr_637010.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/warrow.jpg\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"ajax-loader.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/main-page-bottom.gif\" width=\"1\" height=\"1\" alt=\"\">\n   <img src=\"img/gray-button.gif\" width=\"1\" height=\"1\" alt=\"\">\n    <input type=\"hidden\" name=\"repeater\" value=\"0\">\n    <input type=\"hidden\" name=\"repeater_an\" value=\"0\">\n    <input type=\"hidden\" name=\"no_remind\" value=\"\">\n    <input type=\"hidden\" name=\"enable_apmode\" value=\"0\">   \n    <input type=\"hidden\" name=\"enable_stamode\" value=\"0\">   \n    <input type=\"hidden\" name=\"have_usb_attached\" value=\"0\">\n</div>\n<!-- This JavaScript sn: ***REDACTED*** activates those tabs -->\n<script>\n\n// perform JavaScript after the document is scriptable.\n$(function() {\n    // setup ul.tabs to work as tabs for each div  directly under div.panes\n    $(\"ul.tabs\").tabs(\"> .pane\");\n        var pnpx = 0\n            if(pnpx == 1){\n            $(\"#AdvanceTab\").click();\n            $(\"#basic-pane\").css(\"display\",\"none\");\n            $(\"#adv-pane\").css(\"display\",\"block\");\n            pnpx = 0;\n        }\n});\n</script>\n\n<script>\n    //$(\".current\").css(\"background\",\"url(../img/tab-active.gif) no-repeat 0\");\n    //$(\"#AdvanceTab\").css(\"background\",\"url(../img/tab-nonactive.gif) no-repeat 0\");\n    $(\".noSub\").first().addClass(\"noSubActive\");\n    $('.basic-menu-div').first().addClass('menuActive'); \n\n</script>\n<div id=\"diablePage\" style=\"display:none;z-index:1;position: absolute;\"></div>\n</body>\n</html>\n"
