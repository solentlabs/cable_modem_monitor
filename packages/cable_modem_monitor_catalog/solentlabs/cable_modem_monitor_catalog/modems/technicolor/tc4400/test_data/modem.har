            "text": "<html>\n\n<head>\n      <meta HTTP-EQUIV='Pragma' CONTENT='no-cache'>\n      <link rel=\"stylesheet\" href='stylemain.css' type='text/css'>\n      <link rel=\"stylesheet\" href='colors.css' type='text/css'>\n      <title>Residential Getway Configuration: Status - Software</title>\n</head>\n\n<body>\n<blockquote>\n    <h1>Status</h1>\n    <h3>Software</h3>\n    <p>This page displays information on the current system software.</p>\n    <p>\n    <table border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n<tr><th colspan=2><b>Information</b></th></tr>\n<tr><td class='hd'><b>Standard Specification Compliant</b></td><td>Docsis 3.1</td></tr>\n<tr><td class='hd'><b>Hardware Version</b></td><td>TC4400 Rev:2.0.0</td></tr>\n<tr><td class='hd'><b>Software Version</b></td><td>70.13.41-180903</td></tr>\n<tr><td class='hd'><b>Cable Modem MAC Address</b></td><td>XX:XX:XX:XX:XX:XX</td></tr>\n<tr><td class='hd'><b>Cable Modem Serial Number: ***REDACTED***</td></tr>\n<tr><td class='hd'><b>CM certificate</b></td><td>Installed</td></tr>\n</table>\n</p>\n<p>\n<table border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n<tr><th colspan=2><b>Status</b></th></tr>\n<tr><td class='hd'><b>System Up Time</b></td><td>4 days 00h:16m:45s</td></tr>\n<tr><td class='hd'><b>Network Access</b></td><td>Allowed</td></tr>\n<tr><td class='hd'><b>Cable Modem IPv4 Address</b></td><td>IPv4=0.0.0.0</td></tr>\n<tr><td class='hd'><b>Cable Modem IPv6 Address</b></td><td>IPv6=***IPv6***</td></tr>\n<tr><td class='hd'><b>Board Temperature</b></td><td>-99.0 degrees Celsius</td></tr>\n</table>\n</p>\n</blockquote>\n</body>\n\n</html>\n"
