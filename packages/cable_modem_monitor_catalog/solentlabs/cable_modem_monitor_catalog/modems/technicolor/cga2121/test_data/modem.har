            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n <head>\n  <meta charset=\"utf-8\"/>\n  <meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n  <title>Technicolor CGA2121</title>\n  <link href=\"bootstrap.min.css\" rel=\"stylesheet\"/>\n  <script src=\"jquery.min.js\"></script>\n  <!--[if IE]>\n   <script src=\"html5shiv.min.js\"></script>\n   <script src=\"respond.min.js\"></script>\n  <![endif]-->\n  <script>\n   var mask_basicWireless = \"1\";\n   var mask_basicHomeNetwork = \"0\";    \n   var mask_basicStatus = \"1\";\n   var mask_basicTroubleshooting = \"1\";\n   $(document).ready(function ()\n   {\n    if(mask_basicWireless==0 && mask_basicHomeNetwork==0 && mask_basicStatus==0 && mask_basicTroubleshooting==0)\n    {\n     location.replace('wi_radio_settings.html');\n    }\n    if(mask_basicWireless == 0)\n    {\n  //      document.getElementById(\"basic_wireless\").style.display = \"none\";\n     $('#basic_wireless').hide();\n    }\n    if(mask_basicHomeNetwork == 0)\n    {\n//        document.getElementById(\"basic_homenetwork\").style.display = \"none\";\n     $('#basic_homenetwork').hide();\n    }\n    if(mask_basicStatus == 0)\n    {\n//        document.getElementById(\"basic_status\").style.display = \"none\";    \n     $('#basic_status').hide();\n    }\n    if(mask_basicTroubleshooting == 0)\n    {\n//        document.getElementById(\"basic_troubleshooting\").style.display = \"none\";    \n     $('#basic_troubleshooting').hide();\n    }    \n   });\n  </script>\n </head>\n  \n <body>\n  <script>tch_addLoadEvent2(tch_idle_logout,600000);</script>\n  <div class=\"navbar navbar-default\" id=\"main_navbar\" role=\"navigation\"><div class=\"container-fluid\"><div class=\"\"><a href=\"http://www.technicolor.com\" title=\"Technicolor Company Website\"><img src=\"logo.png\" alt=\"Company logo\"></a><span class=\"hidden-xs\"><strong>&nbsp;<span data-i18n=\"model\"></span>&nbsp;</strong></span><span class=\"hidden-xs hidden-sm\" da