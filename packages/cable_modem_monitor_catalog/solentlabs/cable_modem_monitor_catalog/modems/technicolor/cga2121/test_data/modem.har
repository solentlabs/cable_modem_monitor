n=\"CGA2121_RSvxH9Q\"></span>\n      <span class=\"tile-content\" id=\"wireless_info2\" data-ro-o18n=\"ba_w_info2\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"0\"></span>\n      <span class=\"tile-content\" id=\"wireless_info3\" data-ro-o18n=\"ba_w_info3\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"0\"></span>\n      <span class=\"tile-content\" id=\"wireless_info4\" data-ro-w-o18n=\"ba_w_info4\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"<br/>\" data-ro-p3-i18n=\"radio_interference_label\" data-ro-p4-i18n=\"<br/>\" data-ro-p5-i18n=\"radio_channel_width\" data-ro-p6-i18n=\": 20MHz\" ></span>\n      <span class=\"tile-content currentWireless\" id=\"wireless_info5\" data-ro-w-o18n=\"ba_w_info5\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"<br/>\" data-ro-p3-i18n=\"radio_interference_label\" data-ro-p4-i18n=\"<br/>\" data-ro-p5-i18n=\"radio_channel_width\" data-ro-p6-i18n=\": 20MHz\"></span>\n     </a>\n     <p class=\"tilecaption\" data-i18n=\"wireless_tilecaption\"></p>\n    </div>\n    <div class=\"col-sm-6\" id=\"basic_homenetwork\">\n     <a class=\"thumbnail tile tile-orange\" href=\"ba_homenetwork.html\">\n      <span class=\"tile-label\" id=\"homenetworkLabel\" data-i18n=\"tile_label_homenetwork\"></span>\n      <span class=\"tile-img glyphicon glyphicon-home\"></span>\n      <span class=\"tile-content\" id=\"homenetwork_info1\" data-ro-o18n=\"ba_h_info1\" data-ro-p-i18n=\"bridge\" data-ro-p2-i18n=\"\"></span>\n      <span class=\"tile-content\" id=\"homenetwork_info2\" data-ro-o18n=\"ba_h_info2\" data-ro-p-i18n=\"disable\" data-ro-p2-i18n=\"\"></span>\n      <span class=\"tile-content currentHomeNetwork\" id=\"homenetwork_info3\" data-ro-o18n=\"ba_h_info3\" data-ro-p-i18n=\"off\" data-ro-p2-i18n=\"\"></span>\n<!--  <span class=\"tile-content\" id=\"homenetwork_info4\" data-i18n=\"homenetwork_info4\"></span>-->\n<!--  <span class=\"tile-content\" id=\"homenetwork_info5\" data-i18n=\"homenetwork_info5\"></span>-->\n     </a>\n     <p class=\"tilecaption\" data-i18n=\"homenetwork_tilecaption\"></p>\n    </div>\n   </div>\n    \n   <div class=\"row-fluid\">\n    <div class=\"col-sm-6\" id=\"basic_status\">\n     <a class=\"thumbnail tile tile-green\" href=\"ba_status.html\">\n      <span class=\"tile-label\" id=\"statusLabel\" data-i18n=\"tile_label_status\"></span>\n      <span class=\"tile-img glyphicon glyphicon-dashboard\"></span>\n\n      <span class=\"tile-content\" id=\"status_info1\" data-ro-o18n=\"ba_s_info1\" data-ro-p-i18n=\"Operational\" data-ro-p2-i18n=\"\"></span>\n      <span class=\"tile-content\" id=\"status_info2\" data-i18n=\"ba_s_info2\" ></span>\n      <span class=\"tile-content\" id=\"status_info3\" data-ro-o18n=\"ba_s_info3\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"0.0.0.0\"></span>\n      <span class=\"tile-content currentStatus\" id=\"status_info4\" data-ro-o18n=\"ba_s_info4\" data-ro-p-i18n=\"null\" data-ro-p2-i18n=\"N/A\"></span>\n<!--  <span class=\"tile-content\" id=\"status_info5\" data-i18n=\"status_info5\"></span>-->\n     </a>\n    <p class=\"tilecaption\" data-i18n=\"status_tilecaption\"></p>\n   </div>\n\n   <div class=\"col-sm-6\" id=\"basic_troubleshooting\">\n    <a class=\"thumbnail tile tile-danger\" href=\"ba_troubleshooting.html\">\n     <span class=\"tile-label\" id=\"troubleshootingLabel\" data-i18n=\"tile_label_troubleshooting\"></span>\n     <span class=\"tile-img glyphicon glyphicon-wrench\"></span>\n     <span class=\"tile-content\" id=\"troubleshooting_info1\" data-i18n=\"ba_m_notest\"></span>\n     <span class=\"tile-content currentTroubleshooting\" id=\"troubleshooting_info2\" data-i18n=\"ba_m_notest\"></span>\n<!--\n     <span class=\"tile-content\" id=\"troubleshooting_info1\">Last Speed Test<br/>Downstream: 300 Mbps</span>\n     <span class=\"tile-content currentTroubleshooting\" id=\"troubleshooting_info2\">Last Speed Test<br/>Upstream: 300 Mbps</span>\n     <span class=\"tile-content\" id=\"troubleshooting_info3\" data-i18n=\"troubleshooting_info3\"></span>\n     <span class=\"tile-content\" id=\"troubleshooting_info4\" data-i18n=\"troubleshooting_info4\"></span>\n     <span class=\"tile-content\" id=\"troubleshooting_info5\" data-i18n=\"troubleshooting_info5\"></span>\n-->\n    </a>\n    <p class=\"tilecaption\" data-i18n=\"troubleshooting_tilecaption\"></p>\n   </div>\n  </div>\n </div>\n  \n <script type=\"text/javascript\">\n  $(document).ready(function()\n  {\n   var labelDelayTimer = 4000;\n   var labelAnimateTimer = 1000;\n   var rotateTileContentsTimer = 8000;\n   $(\"#wirelessLabel\")\n    .delay(labelDelayTimer)\n    .animate({marginTop: \"10px\"}, labelAnimateTimer, function () {\n     rotateTileContents(\".tile-content.currentWireless\", \"#wireless_info1\", \"currentWireless\");\n     setInterval(function () {\n      rotateTileContents(\".tile-content.currentWireless\", \"#wireless_info1\", \"currentWireless\")\n     }, rotateTileContentsTimer);\n    });\n    $(\"#homenetworkLabel\")\n     .delay(labelDelayTimer)\n     .animate({marginTop: \"10px\"}, labelAnimateTimer, function () {\n      rotateTileContents(\".tile-content.currentHomeNetwork\", \"#homenetwork_info1\", \"currentHomeNetwork\");\n      setInterval(function () {\n       rotateTileContents(\".tile-content.currentHomeNetwork\", \"#homenetwork_info1\", \"currentHomeNetwork\")\n      }, rotateTileContentsTimer);\n     });\n    $(\"#statusLabel\")\n     .delay(labelDelayTimer)\n     .animate({marginTop: \"10px\"}, labelAnimateTimer, function () {\n      rotateTileContents(\".tile-content.currentStatus\", \"#status_info1\", \"currentStatus\");\n      setInterval(function () {\n       rotateTileContents(\".tile-content.currentStatus\", \"#status_info1\", \"currentStatus\")\n      }, rotateTileContentsTimer);\n     });\n    $(\"#troubleshootingLabel\")\n     .delay(labelDelayTimer)\n     .animate({marginTop: \"10px\"}, labelAnimateTimer, function () {\n      rotateTileContents(\".tile-content.currentTroubleshooting\", \"#troubleshooting_info1\", \"currentTroubleshooting\");\n      setInterval(function () {\n       rotateTileContents(\".tile-content.currentTroubleshooting\", \"#troubleshooting_info1\", \"currentTroubleshooting\")\n      }, rotateTileContentsTimer);\n     });\n  });\n    \n  function rotateTileContents (id, first, tag, timer) {\n   // Function assumes that $(\"id\") selects something, and that something\n   // has the tag class which indicates the item currently displayed, or \n   // (on the first run) the last item in the rotate set.\n   if (timer === undefined) timer = 250;\n   var curContents = $(id);\n   var nxtContents = curContents.next();\n   if (nxtContents.length == 0) {\n    nxtContents = $(first);\n   }\n   curContents.animate({opacity: 0.0}, timer, function () {\n    curContents.removeClass(tag);\n    nxtContents.addClass(tag);\n    nxtContents.animate({opacity: 1.0}, timer);\n   });\n  };\n </script>\n  <script type=\"text/javascript\" >foot();</script>\n\n  <script>\n   var adminAccess = \"1\";\n   if(adminAccess == \"7\")\n   {\n    document.getElementById(\"i_nav_wiz_link\").style.visibility = \"hidden\";\n    document.getElementById(\"i_nav_adv_link\").style.visibility = \"hidden\";\n    document.getElementById(\"i_conf_setting\").style.visibility = \"hidden\";\n   }\n   else if(adminAccess == \"0\")\n   {\n    document.getElementById(\"i_nav_adv_link\").style.visibility = \"hidden\";\n   }\n  </script>\n </body>\n</html>\n"
