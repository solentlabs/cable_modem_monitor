            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\"/>\n  <meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n  <title data-i18n=\"adv_st_gateway_internet\"></title>\n  <link href=\"bootstrap.min.css\" rel=\"stylesheet\"/>\n\n  <script src=\"jquery.min.js\"></script>\n\n<script language=\"javascript\">\nvar wifi_enable = \"\";\nvar mask_statusGwInternetCon = \"1\";\n<!-- hide me\nfunction RenewWanLease()\n{\n\tvar F = document.getElementById(\"wan_leaseaction\");\n\tF.WanLeaseAction.value = 1;\n\tF.submit();\n\n\t//window.document.SmtaSetup.WanLeaseAction.value = 1;\n}\n\nfunction ReleaseWanLease()\n{\n\tvar F = document.getElementById(\"wan_leaseaction\");\n\tF.WanLeaseAction.value = 2;\n\tF.submit();\n\n        //window.document.SmtaSetup.WanLeaseAction.value = 2;\n}\n$(document).ready(function () {\nif((mask_statusGwInternetCon == 0))\n\t{\n\t\t$('#st_gateway').hide();\n        $('#wan_leaseaction').hide();\n        \n\t}\n        \n      });\n// show me -->\n</script>\n\n    <!--[if IE]>\n      <script src=\"html5shiv.min.js\"></script>\n      <script src=\"respond.min.js\"></script>\n      <![endif]-->\n    </head>\n    <body>\n <script>tch_addLoadEvent2(tch_idle_logout,600000);</script>\n <div class=\"navbar navbar-default\" id=\"main_navbar\" role=\"navigation\"><div class=\"container-fluid\"><div class=\"\"><a href=\"http://www.technicolor.com\" title=\"Technicolor Company Website\"><img src=\"logo.png\" alt=\"Company logo\"></a><span class=\"hidden-xs\"><strong>&nbsp;<span data-i18n=\"model\"></span>&nbsp;</strong></span><span class=\"hidden-xs hidden-sm\" data-i18n=\"modeldesc\"></span><div class=\"btn-group navbar-right\" aria-label=\"Choose Basic or Advanced configuration mode.\" role=\"group\"><a class=\"btn btn-link \" type=\"button\" id=\"i_nav_wiz_link\" href=\"setup_wizard.html\"><span class=\"glyphicon glyphicon-flash\"> </span><span class=\"hidden-xs\" data-i18n=\"nav_setup\"></span></a><a class=\"btn btn-link\" type=\"button\" href=\"basicUX.html\"><span class=\"glyphicon glyphicon-th-large\"> </span><span class=\"hidden-xs\" data-i18n=\"nav_basic\"></span></a><a class=\"btn btn-link\" type=\"button\" href=\"ad_wan_settings.html\" id=\"i_nav_adv_link\"><span class=\"glyphicon glyphicon-list\"> </span><span class=\"hidden-xs\" data-i18n=\"nav_advanced\"></span></a><a class=\"btn btn-link\" id=\"btn_logout\" type=\"button\" href=\"logout.html\"><span class=\"glyphicon glyphicon-log-out\"></span><span class=\"hidden-xs\" data-i18n=\"nav_logout\"></span></a></div></div></div></div>\n      <div class=\"container-fluid\">\n        <div class=\"row-fluid\">\n          <div class=\"col-xs-12 col-sm-3\" id=\"adv_navbar_container\">\n            <script src=\"adv_navbar.js\"></script>\n          </div>\n\n          <div class=\"col-xs-12 col-sm-9\" id=\"st_gateway\">\n            <h1 class=\"page-header\" data-i18n=\"adv_st_gateway_internet\"></h1>\n            <!--Startup Procedure-->\n            <div class=\"panel panel-default\">\n              <div class=\"panel-heading\" role=\"tab\">\n                <h2 class=\"h4\">\n                  <a data-toggle=\"collapse\" aria-expanded=\"false\" aria-controls=\"\">\n                  <span data-i18n=\"atg_header\"></span>\n                  </a>\n                </h2>\n              </div>\n              <table class=\"table table-bordered\">\n                <caption class=\"text-muted text-right\" data-i18n=\"atg_about\"></caption>\n                <tbody>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_model\"></th>\n                    <td class=\"col-xs-8\" scope=\"row\">CGA2121</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_hardware_version\"></th>\n                    <td class=\"col-xs-8\">1.01</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_serial_number\"></th>\n                    <td class=\"col-xs-8\">XXXXXXXXXXXXXXXXXXXX</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_firmware_version\"></th>\n                    <td class=\"col-xs-8\">CGA2121E-5_65_0-ES-13-E113C5-c7410r5714-241120</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_cm_mac_address\"></th>\n                    <td class=\"col-xs-8\">XX:XX:XX:XX:XX:XX</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"atg_system_uptime\" ></th>\n                    <td class=\"col-xs-8\">18 days 00h:09m:46s</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n\n            <div class=\"panel panel-default\">\n              <div class=\"panel-heading\" role=\"tab\">\n                <h2 class=\"h4\">\n                  <a data-toggle=\"collapse\" aria-expanded=\"false\" aria-controls=\"\">\n                  <span data-i18n=\"is_header\"></span>\n                  </a>\n                </h2>\n              </div>\n              <table class=\"table table-bordered\">\n                <caption class=\"text-muted text-right\" data-i18n=\"is_about\"></caption>\n                <tbody>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"is_wan_ip_address\"></th>\n                    <td class=\"col-xs-8\" scope=\"row\">0.0.0.0</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"is_rg_wan_mac\"></th>\n                    <td class=\"col-xs-8\">XX:XX:XX:XX:XX:XX</td>\n                  </tr>\n                  <tr>\n                    <th class=\"col-xs-4\" scope=\"row\" data-i18n=\"is_dns_servers\"></th>\n          