      }
    },
    "channel_width": {
      "tier": 2,
      "type": "integer",
      "headers": ["bandwidth"],
      "json_keys": ["channelwidth", "channel_width"]
    },
    "active_subcarriers": {
      "tier": 2,
      "type": "integer",
      "headers": ["active subcarriers"],
      "json_keys": []
    },
    "fft_size": {
      "tier": 2,
      "type": "integer",
      "headers": ["fft size"],
      "json_keys": []
    },
    "profile_id": {
      "tier": 2,
      "type": "string",
      "headers": ["profile id"],
      "json_keys": []
    },
    "ranging_status": {
      "tier": 2,
      "type": "string",
      "headers": ["ranging status"],
      "json_keys": []
    }
  }
}
