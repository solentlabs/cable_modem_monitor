{
  "fields": {
    "channel_id": {
      "tier": 1,
      "type": "integer",
      "headers": ["channel id", "channel", "ch", "dcid", "ucid", "ds channel id", "us channel id", "ds_link_ds_ch_id", "ds_link_us_ch_id"],
      "json_keys": ["channelid", "channel_id"]
    },
    "channel_number": {
      "tier": 1,
      "type": "integer",
      "headers": ["channel number", "channel index", "ch num", "channel no"],
      "json_keys": ["channel_number", "channelnumber"]
    },
    "frequency": {
      "tier": 1,
      "type": "frequency",
      "headers": ["frequency", "freq", "center frequency", "ds center freq"],
      "json_keys": ["frequency", "freq"],
      "header_units": {
        "freq. (mhz)": "MHz"
      }
    },
    "width": {
      "tier": 1,
      "type": "frequency",
      "headers": ["channel width", "width"],
      "json_keys": []
    },
    "power": {
      "tier": 1,
      "type": "float",
      "headers": ["power", "power level", "pwr", "tx power", "received level", "transmit level", "rx level", "tx level", "ds power level", "us power level", "ds_link_ds_pw_lv", "ds_link_us_pw_lv"],
      "json_keys": ["power", "powerlevel", "power_level", "signalstrength", "signal_strength"],
      "header_units": {
        "pwr (dbmv)": "dBmV",
        "tx power(dbmv)": "dBmV"
      }
    },
    "snr": {
      "tier": 1,
      "type": "float",
      "headers": ["snr", "snr/mer", "snr / mer", "mer", "snr/mer threshold value", "snr mer threshold value", "signal to noise", "signal to noise ratio", "ds_link_ds_snr"],
      "json_keys": ["snr", "rxmer", "rx_mer", "snrlevel"],
      "header_units": {
        "snr (db)": "dB"
      }
    },
    "lock_status": {
      "tier": 1,
      "type": "lock_status",
      "headers": ["lock status", "status"],
      "json_keys": ["lockstatus", "lock_status"]
    },
    "modulation": {
      "tier": 1,
      "type": "modulation",
      "headers": ["modulation", "mod", "modulation/profile id", "modulation profile id", "ds_link_ds_modu", "ds_link_us_modu"],
      "json_keys": ["modulation"]
    },
    "channel_type": {
      "tier": 1,
      "type": "string",
      "headers": ["channel type", "us channel type", "ds channel type"],
      "json_keys": ["channeltype", "channel_type"]
    },
    "corrected": {
      "tier": 1,
      "type": "integer",
      "headers": ["corrected", "correctable", "corrected codewords", "correctable codewords", "total correctable codewords", "correcteds"],
      "json_keys": ["corrected", "correctederrors", "corrected_errors", "correcteds"]
    },
    "uncorrected": {
      "tier": 1,
      "type": "integer",
      "headers": ["uncorrected", "uncorrectable", "uncorrectable codewords", "total uncorrectable codewords", "uncorrectables"],
      "json_keys": ["uncorrected", "uncorrectederrors", "uncorrected_errors", "uncorrect"]
    },
    "symbol_rate": {
      "tier": 1,
      "type": "integer",
      "headers": ["symbol rate", "symb. rate"],
      "json_keys": ["symbolrate", "symbol_rate"],
      "header_units": {
